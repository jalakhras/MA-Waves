{
  "meta": {
    "name": "M-Waves — أطلس حالة لوحة الاستنتاجات الكاملة",
    "name_en": "M-Waves Full Conclusions-Panel State Atlas",
    "version": "2.0.0",
    "source_lessons": [
      "04",
      "08",
      "09",
      "10",
      "11",
      "03",
      "04_شروط_الانعكاس"
    ],
    "principle": "نموذج حالة كامل للوحة: حقول مجمّعة (مشتقّة) + حالة لكل درجة (اتجاه+قوّة+مرحلة+خط سيولة+مستوى اتجاه). التعداد بآلة حالة + اشتقاق، لا ضرب توافيقيّ.",
    "panel_ref": "لوحة الاستنتاجات (الصورة المرفقة): اتجاه الموجة التاريخية · اتجاه السيولة · قوّة السيولة · الدخول المتاح · الصغيرة/المتوسطة/الكبيرة (اتجاه-قوّة-مرحلة)"
  },
  "panel_aggregate_fields": [
    {
      "key": "historical_wave_direction",
      "ar": "اتجاه الموجة التاريخية",
      "values": [
        "up",
        "down"
      ],
      "derived_from": "الموجة التاريخية (د04) / الدرجة الكبيرة",
      "color_rule": "down=أحمر▼ · up=أخضر▲"
    },
    {
      "key": "liquidity_direction",
      "ar": "اتجاه السيولة",
      "values": [
        "up",
        "down",
        "range"
      ],
      "derived_from": "f(medium.dir, large.dir): كلاهما up⇒up · كلاهما down⇒down · متعاكسان⇒range"
    },
    {
      "key": "liquidity_strength",
      "ar": "قوّة السيولة",
      "values": [
        "strong",
        "weak"
      ],
      "derived_from": "f(تباعد القمم/القيعان): قاع دخل نطاق القمة السابقة ⇒ weak"
    },
    {
      "key": "available_entry",
      "ar": "الدخول المتاح",
      "values": [
        "buy_only",
        "sell_only",
        "both",
        "none"
      ],
      "derived_from": "f(liquidity_direction, in_zone): up⇒buy · down⇒sell · range⇒both · خارج منطقة⇒none"
    }
  ],
