//@version=6
// ════════════════════════════════════════════════════════════════════════════
// J-Waves — M1 (الموجة التاريخية)
// إعادة بناء نظيف طبقةً طبقةً — فرع rebuild-from-scratch
// المرجع الحاكم: docs/build/ (الدستور · المعمارية · خطة البناء · الجرد)
// الإصدار الداخليّ: v0.5.0 — ط0 الأساس: صندوقا الموجة التاريخية وتاريخ التاريخ (بلا محرّك leg)
// ════════════════════════════════════════════════════════════════════════════
indicator("J-Waves M1", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 300, max_bars_back = 5000)

// ════════════════════════════════════════════════════════════════════════════
// المعمارية الفراكتالية (الاتجاه: كل سهم للأعلى — لا طبقة تقرأ من فوقها)
//   ط0 الأساس: الموجة التاريخية + تاريخ التاريخ     [دروس 03-04]  ← الأسفل
//   ط1 القمم والقيعان (صغيرة→متوسطة→كبيرة)            [دروس 05-07]
//   ط2 الخطوط والتجدّد                                [دروس 08-09]
//   ط3 الاستنتاجات والمراحل                           [دروس 10-11]
//   ط4 المناطق والفرص                                 [دروس 01-03]  ← الأعلى
// مؤجَّل لـط1: محرّك الـleg/الدرجة الكبيرة (حدود الموجات، الدوائر الزرقاء، مدخلاتها).
//   تاريخ التاريخ هنا = «بطول الموجة قبلها» (نصّ الدرس 04) — يُحسّن لاحقًا بالـleg إن لزم.
// ════════════════════════════════════════════════════════════════════════════


// ════════════════════════════════════════════════════════════════════════════
// ط0 — الأساس: الموجة التاريخية + تاريخ التاريخ   [درس 03-04]
// ════════════════════════════════════════════════════════════════════════════

// ─── المدخلات (أسماء/إعدادات/مجموعة الكود السابق) ───
string grpHist = "🌊 Historical Wave / الموجة التاريخية"
bool   showHist = input.bool(true, "Show historical wave bounds / حدود الموجة التاريخية", group = grpHist)
bool   useHistN = input.bool(false, "Set wave by candle count / تحديد الموجة بعدد الشموع", group = grpHist, tooltip = "On: bounds over the last N candles. Off: auto default length.\nمفعّل: آخر N شمعة. مطفأ: طول افتراضيّ تلقائيّ.")
int    histBars = input.int(100, "Historical wave candles / عدد شموع الموجة", minval = 1, group = grpHist)
color  cHist    = input.color(color.new(#607D8B, 82), "Historical wave color / لون الموجة التاريخية", group = grpHist)
bool   showHoh  = input.bool(true, "Show prior-history bounds / حدود تاريخ التاريخ", group = grpHist)
bool   useHohN  = input.bool(false, "Set prior-history by candle count / تحديد تاريخ التاريخ بعدد الشموع", group = grpHist, tooltip = "On: take N candles. Off: same length as the historical wave before it.\nمفعّل: N شمعة. مطفأ: بطول الموجة التاريخية قبله.")
int    hohBars  = input.int(100, "Prior-history candles / عدد شموع تاريخ التاريخ", minval = 1, group = grpHist)
color  cHoh     = input.color(color.new(#808080, 88), "Prior-history color / لون تاريخ التاريخ", group = grpHist)

// الطول الافتراضيّ للموجة عند الوضع التلقائيّ (نظير autoLen السابق). المحلّل يختار الموجة يدويًّا
//   (درس 03) عبر useHistN/histBars؛ هذا بداية عرض، لا عتبة استراتيجية.
int AUTO_WAVE_LEN = 150

// ─── النوع: سياق الموجة التاريخية (نافذة + حدود) — مصدر واحد للحقيقة، يُحسب كل شمعة ───
type WaveCtx
    int   win    // طول النافذة (wlen)
    int   left   // بداية الموجة (histLeft)
    float hi     // أعلى الموجة
    float lo     // أدنى الموجة

// ─── الدوال (مسؤولية واحدة لكلّ دالّة) ───
// طول الموجة (يدويّ بعدد الشموع أو افتراضيّ) مقيَّدًا ضمن المدى الصالح.
f_waveLen(bool useN, int nBars) =>
    int raw = useN ? nBars : AUTO_WAVE_LEN
    math.min(math.max(raw, 1), bar_index + 1)

// سياق الموجة التاريخية (يُحسب كل شمعة — ta.* تتطلّب تقييمًا مستمرًّا).
f_waveContext(bool useN, int nBars) =>
    int win  = f_waveLen(useN, nBars)
    WaveCtx.new(win, bar_index - win + 1, ta.highest(high, win), ta.lowest(low, win))

// أعلى/أدنى سعر ضمن نطاق بارات [leftB..rightB] (يُستدعى عند islast فقط — قليل التكلفة).
f_rangeHiLo(int leftB, int rightB) =>
    float hi = na
    float lo = na
    if not na(leftB) and not na(rightB) and rightB >= leftB
        for j = leftB to rightB
            int off = bar_index - j
            if off >= 0
                hi := na(hi) or high[off] > hi ? high[off] : hi
                lo := na(lo) or low[off] < lo ? low[off] : lo
    [hi, lo]

// ─── الحساب (لكلّ شمعة) ───
WaveCtx ctx = f_waveContext(useHistN, histBars)

// ─── الرسم (islast فقط — منفصل عن الحساب) ───
var box waveBox = na
var box hohBox  = na
if barstate.islast
    // صندوق الموجة التاريخية
    if not na(waveBox)
        box.delete(waveBox)
        waveBox := na
    if showHist
        waveBox := box.new(ctx.left, ctx.hi, bar_index, ctx.lo, xloc = xloc.bar_index, border_color = cHist, bgcolor = cHist)
    // صندوق تاريخ التاريخ = نافذة بطول الموجة (أو يدويّ) قبل بداية الموجة مباشرةً
    if not na(hohBox)
        box.delete(hohBox)
        hohBox := na
    if showHoh
        int hohLen = useHohN ? hohBars : ctx.win
        int hohL   = math.max(ctx.left - hohLen, 0)
        int hohR   = ctx.left
        [hohHi, hohLo] = f_rangeHiLo(hohL, hohR)
        if not na(hohHi) and not na(hohLo)
            hohBox := box.new(hohL, hohHi, hohR, hohLo, xloc = xloc.bar_index, border_color = cHoh, bgcolor = cHoh)


// ─────────────────────────────────────────────────────────────────────────────
// ط1 — القمم والقيعان (+ محرّك الـleg/الكبيرة)   [دروس 05-07]   (لاحقًا)
// ─────────────────────────────────────────────────────────────────────────────


