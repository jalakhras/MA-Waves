//@version=6
// ════════════════════════════════════════════════════════════════════════════
// J-Waves — M1 (الموجة التاريخية)
// إعادة بناء نظيف طبقةً طبقةً — فرع rebuild-from-scratch
// المرجع الحاكم: docs/build/ (الدستور · المعمارية · خطة البناء · الجرد)
// الإصدار الداخليّ: v0.9.13 — خطوات صريحة: (1) اتجاه (2) كل المرشّحات في ARRAY (3+4) تصفية تتابُع+فعاليّة
//   الزوج المخالف يُمسح + تشخيص النقاط المستثناة وسببها (showDiag) · يُبنى من الصفر كل islast
// ════════════════════════════════════════════════════════════════════════════
indicator("J-Waves M1", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 300, max_polylines_count = 100, max_bars_back = 5000)

// ════════════════════════════════════════════════════════════════════════════
// المعمارية الفراكتالية (الاتجاه: كل سهم للأعلى — لا طبقة تقرأ من فوقها)
//   ط0 الأساس: الموجة التاريخية + تاريخ التاريخ     [دروس 03-04]  ← الأسفل
//   ط1 القمم والقيعان (صغيرة→متوسطة→كبيرة)            [دروس 05-07]
//   ط2..ط4 (لاحقًا)
// الاختيار التلقائيّ من السعر الخام (لا دائرة، لا ارتكاز على ط1). عدّ الدرجات/موجات الدفعة
//   /ملاءمة الفريم في اللوحة يكتمل بـط1 (يحتاج الدرجات الثلاث).
// ════════════════════════════════════════════════════════════════════════════


// ════════════════════════════════════════════════════════════════════════════
// ط0 — الأساس: الموجة التاريخية + تاريخ التاريخ   [درس 03-04]
// ════════════════════════════════════════════════════════════════════════════

// ─── المدخلات: الموجة التاريخية ───
string grpHist = "🌊 Historical Wave / الموجة التاريخية"
bool   showHist = input.bool(true, "Show historical wave bounds / حدود الموجة التاريخية", group = grpHist)
bool   useHistN = input.bool(false, "Set wave by candle count / تحديد الموجة بعدد الشموع", group = grpHist, tooltip = "On: bounds over the last N candles. Off: auto — current move from its origin to now.\nمفعّل: آخر N شمعة. مطفأ: تلقائيّ — الحركة الحاليّة من أصلها إلى الآن.")
int    histBars = input.int(100, "Historical wave candles / عدد شموع الموجة", minval = 1, group = grpHist)
color  cHist    = input.color(color.new(#607D8B, 82), "Historical wave color / لون الموجة التاريخية", group = grpHist)
bool   showHoh  = input.bool(true, "Show prior-history bounds / حدود تاريخ التاريخ", group = grpHist)
bool   useHohN  = input.bool(false, "Set prior-history by candle count / تحديد تاريخ التاريخ بعدد الشموع", group = grpHist, tooltip = "On: N candles. Off: same length as the historical wave before it.\nمفعّل: N شمعة. مطفأ: بطول الموجة التاريخية قبله.")
int    hohBars  = input.int(100, "Prior-history candles / عدد شموع تاريخ التاريخ", minval = 1, group = grpHist)
color  cHoh     = input.color(color.new(#808080, 88), "Prior-history color / لون تاريخ التاريخ", group = grpHist)

// ─── المدخلات: لوحة اختبار الموجة (تصميم الكود السابق) ───
string grpFH = "🧪 Wave Test / لوحة اختبار الموجة"
bool   showFrameHelper = input.bool(true, "Wave-test panel (wave time ⇒ trading type) / لوحة اختبار الموجة", group = grpFH)
string fhPos        = input.string("Top L", "Panel position / موضع اللوحة", options = ["Top L", "Top C", "Top R", "Mid L", "Center", "Mid R", "Bot L", "Bot C", "Bot R"], group = grpFH)
float  swingMinDays = input.float(2.0, "Swing lower bound (days/wave) — below = Scalp / حدّ السوينغ الأدنى", minval = 0.1, step = 0.5, group = grpFH, tooltip = "زمن الموجة أقلّ من هذا ⇒ مضاربة ⇒ اصعد فريمًا.")
float  swingMaxDays = input.float(10.0, "Swing upper bound (days/wave) — above = Invest / حدّ السوينغ الأعلى", minval = 0.5, step = 0.5, group = grpFH, tooltip = "زمن الموجة أكثر من هذا ⇒ استثمار ⇒ انزل فريمًا.")
color  fhBg         = input.color(#1E222D, "Panel background / خلفية اللوحة", group = grpFH)

// ─── المدخلات: الدرجة 0 (الصغيرة) ───
string grpSmall = "🔴 Small Degree / الصغيرة (درجة 0)"
bool   showSmall = input.bool(true, "Show small pivots / إظهار القمم والقيعان الصغيرة", group = grpSmall)
string waveDirMode = input.string("Auto", "Wave direction / اتجاه الموجة", options = ["Auto", "Up", "Down"], group = grpSmall, tooltip = "يقود قوانين الصعود/الهبوط (درس 03: المحلّل يختار اتجاه الموجة). Auto = من نافذة السعر (مؤقّت). يُستبدَل باتجاه الكبيرة لاحقًا.")
int    minCorr   = input.int(2, "Correction candles to confirm / شموع التصحيح للتأكيد", minval = 1, maxval = 5, group = grpSmall, tooltip = "[درس 05] شمعتان صحيحتان في اتجاه التصحيح.")
bool   useValid  = input.bool(true, "Require valid candle (body ≥ each wick) / اشتراط الشمعة الصحيحة", group = grpSmall, tooltip = "[درس 05] النويز = ذيل أطول من الجسم ⇒ يُستبعَد.")
color  cTop      = input.color(#F23645, "Small top / قمّة صغيرة", group = grpSmall)
color  cBot      = input.color(#089981, "Small bottom / قاع صغير", group = grpSmall)
float  arrLen    = input.float(0.4, "Arrow length / طول السهم", minval = 0.1, step = 0.1, group = grpSmall, tooltip = "نسبة من نطاق سعريّ أصيل (لا ATR) — حجم رسم فقط.")
int    arrWidth  = input.int(2, "Arrow width (candles) / عرض السهم", minval = 1, maxval = 10, group = grpSmall)
bool   linkSmall = input.bool(true, "Link small pivots / وصل القمم والقيعان بخطوط", group = grpSmall)
color  cLineS    = input.color(color.new(color.gray, 55), "Link line / لون خطّ الوصل", group = grpSmall)
bool   showDiag  = input.bool(false, "Diagnose excluded pivots / تشخيص النقاط المستثناة", group = grpSmall, tooltip = "يُظهر القمم/القيعان المرشّحة التي مسحها قانونا التتابُع/الفعاليّة مع السبب.")

// نافذة البحث عن أصل الحركة (نظير autoLen السابق). المحلّل يضبط الموجة يدويًّا عبر useHistN/histBars.
int AUTO_WAVE_LEN = 150
int SMALL_KEEP = 300   // سقف القمم/القيعان الصغيرة المحفوظة (أداء)

// ─── الدوال (مسؤولية واحدة لكلّ دالّة) ───
// موضع اللوحة من اختيار نصّيّ.
f_pos(string s) =>
    s == "Top L" ? position.top_left : s == "Top C" ? position.top_center : s == "Top R" ? position.top_right : s == "Mid L" ? position.middle_left : s == "Center" ? position.middle_center : s == "Mid R" ? position.middle_right : s == "Bot L" ? position.bottom_left : s == "Bot C" ? position.bottom_center : position.bottom_right

// لون أغمق (للحدّ) من لون التعبئة مع حفظ الشفافية.
f_dark(color c) =>
    color.new(color.rgb(color.r(c) * 0.6, color.g(c) * 0.6, color.b(c) * 0.6), color.t(c))

// طول الموجة اليدويّ مقيَّدًا ضمن المدى الصالح.
f_waveLen(int nBars) =>
    math.min(math.max(nBars, 1), bar_index + 1)

// أعلى/أدنى سعر ضمن نطاق بارات [leftB..rightB] (يُستدعى عند islast فقط — قليل التكلفة).
f_rangeHiLo(int leftB, int rightB) =>
    float hi = na
    float lo = na
    if not na(leftB) and not na(rightB) and rightB >= leftB
        for j = leftB to rightB
            int off = bar_index - j
            if off >= 0
                hi := na(hi) or high[off] > hi ? high[off] : hi
                lo := na(lo) or low[off] < lo ? low[off] : lo
    [hi, lo]

// زمن نطاق بارات [leftB..rightB] بالأيام.
f_rangeDays(int leftB, int rightB) =>
    (time[bar_index - rightB] - time[bar_index - leftB]) / 86400000.0

// ─── الحساب (لكلّ شمعة — ta.* تتطلّب تقييمًا مستمرًّا) ───
// أصل الحركة الحاليّة: أبعد تطرّف (قمّة/قاع) في نافذة البحث. إن كانت القمّة أحدث ⇒ حركة صاعدة
//   فالأصل = القاع، والعكس. (السعر الخام، لا دائرة — هذه ط0)
int hiOff = ta.highestbars(high, AUTO_WAVE_LEN)
int loOff = ta.lowestbars(low, AUTO_WAVE_LEN)

// اتجاه الموجة: يدويّ (Up/Down — درس 03) يتجاوز التلقائيّ. التلقائيّ من نافذة السعر (القمّة أحدث ⇒ صعود).
//   🔴 التلقائيّ قد يتقلّب على الارتدادات الكبيرة (يُحَلّ نهائيًّا باتجاه الكبيرة، الدورة 3). اليدويّ مستقرّ.
int waveAutoDir    = hiOff > loOff ? 1 : -1
int waveGeneralDir = waveDirMode == "Up" ? 1 : waveDirMode == "Down" ? -1 : waveAutoDir

// يسار الموجة التاريخية: يدويّ (نافذة آخر N) أو تلقائيّ (أصل الحركة). يُحسب رخيصًا (بلا حلقة).
f_waveLeft() =>
    useHistN ? math.max(bar_index - f_waveLen(histBars) + 1, 0) : bar_index + (hiOff > loOff ? loOff : hiOff)

// ─── الرسم (islast فقط — منفصل عن الحساب) ───
var box   waveBox = na
var box   hohBox  = na
var label waveLbl = na
var label hohLbl  = na
if barstate.islast
    // ===== الموجة التاريخية: من الأصل (أو نافذة يدويّة) إلى الآن =====
    if not na(waveBox)
        box.delete(waveBox)
        waveBox := na
    if not na(waveLbl)
        label.delete(waveLbl)
        waveLbl := na
    int wL = f_waveLeft()
    int wR = bar_index
    [wHi, wLo] = f_rangeHiLo(wL, wR)
    if showHist and not na(wHi) and not na(wLo)
        color hBd = f_dark(cHist)
        waveBox := box.new(wL, wHi, wR, wLo, xloc = xloc.bar_index, border_color = hBd, border_width = 1, bgcolor = cHist)
        string hTxt = useHistN ? "الموجة التاريخية (يدوي)" : "الموجة التاريخية (تلقائي)"
        waveLbl := label.new(wL, wHi, hTxt, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_lower_right, color = hBd, textcolor = color.white, size = size.tiny)
    // ===== تاريخ التاريخ: خلف الموجة مباشرةً (ينتهي عند بدايتها wL) =====
    if not na(hohBox)
        box.delete(hohBox)
        hohBox := na
    if not na(hohLbl)
        label.delete(hohLbl)
        hohLbl := na
    int hR = wL
    int hL = useHohN ? math.max(wL - hohBars, 0) : math.max(wL - math.max(wR - wL, 1), 0)
    if showHoh and hR > hL
        [hHi, hLo] = f_rangeHiLo(hL, hR)
        if not na(hHi) and not na(hLo)
            color hohBd = color.new(color.gray, 0)
            hohBox := box.new(hL, hHi, hR, hLo, xloc = xloc.bar_index, border_color = hohBd, border_width = 1, bgcolor = cHoh)
            string hohTxt = useHohN ? "تاريخ التاريخ (يدوي)" : "تاريخ التاريخ (تلقائي)"
            hohLbl := label.new(hL, hLo, hohTxt, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_upper_right, color = hohBd, textcolor = color.white, size = size.tiny)

// ─── لوحة اختبار الموجة (تصميم الكود السابق) ───
// الدرس 03 خ6: زمن الموجة ⇒ نوع التداول. موجات الدفعة/عدّ الدرجات/ملاءمة الفريم يكتمل بـط1.
var table fht = table.new(f_pos(fhPos), 2, 7, bgcolor = fhBg, border_width = 1, border_color = #2A2E39, frame_width = 1, frame_color = #2A2E39)
f_drawWavePanel() =>
    table.set_position(fht, f_pos(fhPos))
    int   wL = f_waveLeft()
    float days = f_rangeDays(wL, bar_index)
    string timeTxt = na(days) or days <= 0 ? "—" : days >= 1 ? str.tostring(days, "#.0") + " يوم" : days >= 0.0417 ? str.tostring(days * 24, "#.0") + " ساعة" : str.tostring(days * 1440, "#.0") + " دق"
    string waveType = na(days) or days <= 0 ? "—" : days < swingMinDays ? "مضاربة" : days <= swingMaxDays ? "سوينغ" : "استثمار"
    color  wtBg = na(days) or days <= 0 ? color.new(#787B86, 0) : days < swingMinDays ? color.new(#FF9800, 0) : days <= swingMaxDays ? color.new(#089981, 0) : color.new(#2962FF, 0)
    string tradeNature = na(days) or days <= 0 ? "بيانات غير كافية" : days < swingMinDays ? "صفقات دقائق–يوم" : days <= swingMaxDays ? "صفقات يومين–10 أيام" : "صفقات أسابيع–شهور"
    color tvBg   = fhBg
    color tvHdr  = color.new(color.rgb(color.r(fhBg) * 0.72, color.g(fhBg) * 0.72, color.b(fhBg) * 0.72), color.t(fhBg))
    color tvMain = #D1D4DC
    color tvMute = #787B86
    table.cell(fht, 0, 0, "لوحة اختبار الموجة", text_color = tvMain, bgcolor = tvHdr, text_size = size.normal, text_halign = text.align_right)
    table.cell(fht, 1, 0, "", bgcolor = tvHdr)
    table.cell(fht, 0, 1, "درجات ظاهرة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 1, "— / 3 (ط1)", text_color = tvMute, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 2, "موجات دافعة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 2, "— (ط1)", text_color = tvMute, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 3, "زمن الموجة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 3, timeTxt, text_color = tvMain, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 4, "نوع التداول", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 4, waveType, text_color = color.white, bgcolor = wtBg, text_size = size.small)
    table.cell(fht, 0, 5, "نمط الصفقة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 5, tradeNature, text_color = tvMain, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 6, "الفريم مناسب؟", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 6, "ينتظر الدرجات (ط1)", text_color = tvMute, bgcolor = tvBg, text_size = size.small)

if showFrameHelper and barstate.islast
    f_drawWavePanel()


// ═════════════════════════════════════════════════════════════════════════════
// ط1 — القمم والقيعان   [دروس 05-07]
// ═════════════════════════════════════════════════════════════════════════════

// ═════════════════════════════════════════════════════════════════════════════
// المحرّك المعمّم — خطوات صريحة (طلب المستخدم): (1) اتجاه الموجة · (2) كل القمم/القيعان
//   بقاعدة الشمعتين في ARRAY خام · (3+4) تصفية بالتتابُع + الفعاليّة على islast، والزوج المخالف يُمسح.
//   لا حالة متراكمة (تُبنى الفعّالة من الصفر) ⇒ بنية نظيفة. مع تشخيص: النقاط المستثناة وسببها.
// ═════════════════════════════════════════════════════════════════════════════
type Degree
    array<int>    rawBars     = na   // (2) كل المرشّحات الخام من الشمعتين
    array<float>  rawPrices   = na
    array<bool>   rawIsTop    = na
    array<int>    effBars     = na   // (3+4) الفعّالة بعد التصفية
    array<float>  effPrices   = na
    array<bool>   effIsTop    = na
    array<int>    exclBars    = na   // التشخيص: المستثناة + السبب
    array<float>  exclPrices  = na
    array<bool>   exclIsTop   = na
    array<string> exclReason  = na

newDegree() =>
    Degree.new(rawBars = array.new<int>(), rawPrices = array.new<float>(), rawIsTop = array.new<bool>(), effBars = array.new<int>(), effPrices = array.new<float>(), effIsTop = array.new<bool>(), exclBars = array.new<int>(), exclPrices = array.new<float>(), exclIsTop = array.new<bool>(), exclReason = array.new<string>())

// (2) إضافة مرشّح خام (قمّة/قاع من الشمعتين) + قصّ السقف.
method addRaw(Degree self, bool isTop, float price, int bar, int keep) =>
    array.push(self.rawBars, bar)
    array.push(self.rawPrices, price)
    array.push(self.rawIsTop, isTop)
    while array.size(self.rawBars) > keep
        array.shift(self.rawBars)
        array.shift(self.rawPrices)
        array.shift(self.rawIsTop)

method pushEff(Degree self, int bar, float price, bool isTop) =>
    array.push(self.effBars, bar)
    array.push(self.effPrices, price)
    array.push(self.effIsTop, isTop)

method pushExcl(Degree self, int bar, float price, bool isTop, string reason) =>
    array.push(self.exclBars, bar)
    array.push(self.exclPrices, price)
    array.push(self.exclIsTop, isTop)
    array.push(self.exclReason, reason)

// (3+4) التصفية حسب الاتجاه: التتابُع + الفعاليّة. الزوج المخالف يُمسح ويُسجَّل سببه.
//   صعود: القمم تتصاعد؛ القاع المؤثّر = أدنى سعر قبل قمّة أعلى. هبوط: القيعان تتنازل؛ القمّة = أعلى سعر قبل قاع أدنى.
method buildEffective(Degree self, int dir) =>
    array.clear(self.effBars)
    array.clear(self.effPrices)
    array.clear(self.effIsTop)
    array.clear(self.exclBars)
    array.clear(self.exclPrices)
    array.clear(self.exclIsTop)
    array.clear(self.exclReason)
    int n = array.size(self.rawBars)
    if n > 0
        if dir == 1
            float lastPeak = na   // آخر قمّة فعّالة (للتتابُع)
            float rvPrice  = na   // أدنى قاع جارٍ منذ آخر قمّة فعّالة (الفعّال)
            int   rvBar    = na
            for i = 0 to n - 1
                bool  isTop = array.get(self.rawIsTop, i)
                float price = array.get(self.rawPrices, i)
                int   bar   = array.get(self.rawBars, i)
                if isTop
                    if na(lastPeak) or price > lastPeak                  // قمّة أعلى ⇒ صحيحة (ق4) + تؤكّد القاع (ق6)
                        if not na(rvPrice)
                            self.pushEff(rvBar, rvPrice, false)
                        self.pushEff(bar, price, true)
                        lastPeak := price
                        rvPrice  := na
                    else
                        self.pushExcl(bar, price, true, "قمّة ليست أعلى (تتابُع)")
                else
                    if na(rvPrice) or price < rvPrice                    // أدنى قاع ⇒ هو المؤثّر
                        if not na(rvPrice)
                            self.pushExcl(rvBar, rvPrice, false, "قاع ليس الأدنى (تغطية)")
                        rvPrice := price
                        rvBar   := bar
                    else
                        self.pushExcl(bar, price, false, "قاع ليس الأدنى (تغطية)")
        else
            float lastValley = na
            float rpPrice    = na   // أعلى قمّة جارية منذ آخر قاع فعّال
            int   rpBar      = na
            for i = 0 to n - 1
                bool  isTop = array.get(self.rawIsTop, i)
                float price = array.get(self.rawPrices, i)
                int   bar   = array.get(self.rawBars, i)
                if not isTop
                    if na(lastValley) or price < lastValley              // قاع أدنى ⇒ صحيح (ق5) + يؤكّد القمّة (ق7)
                        if not na(rpPrice)
                            self.pushEff(rpBar, rpPrice, true)
                        self.pushEff(bar, price, false)
                        lastValley := price
                        rpPrice    := na
                    else
                        self.pushExcl(bar, price, false, "قاع ليس أدنى (تتابُع)")
                else
                    if na(rpPrice) or price > rpPrice                    // أعلى قمّة ⇒ هي المؤثّرة
                        if not na(rpPrice)
                            self.pushExcl(rpBar, rpPrice, true, "قمّة ليست الأعلى (تغطية)")
                        rpPrice := price
                        rpBar   := bar
                    else
                        self.pushExcl(bar, price, true, "قمّة ليست الأعلى (تغطية)")

// ─── الدرجة 0 (الصغيرة): كشف كل المرشّحات بقاعدة الشمعتين [درس 05] ⇒ ARRAY خام (التصفية على islast) ───
//   مرشّح الضجيج الأصيل (لا ATR): شمعتان صحيحتان (الجسم ≥ كل ذيل) في اتجاه التصحيح.
//   القمّة = أعلى سعر قبل التصحيح · القاع = أدنى سعر قبله. كلّها تُخزَّن خامًا ثمّ تُصفّى.
var Degree     smallDegree    = newDegree()
var int        scanDir        = 0    // اتجاه المسح: 1 يترقّب قمّة · -1 يترقّب قاعًا · 0 غير مهيّأ
var float      runningHighPrice = na // أعلى سعر جارٍ (مرشّح القمّة)
var int        runningHighBar = na
var float      runningLowPrice = na  // أدنى سعر جارٍ (مرشّح القاع)
var int        runningLowBar  = na
var int        correctionCount = 0   // عدّاد شموع التصحيح الصحيحة المتدرّجة
var float      correctionLevel = na  // مرجع تدرّج التصحيح («تحت/فوق بعض»)

if barstate.isconfirmed
    float bodySize      = math.abs(close - open)
    float upperWick     = high - math.max(close, open)
    float lowerWick     = math.min(close, open) - low
    bool  isValidCandle = (not useValid) or (bodySize > 0 and bodySize >= upperWick and bodySize >= lowerWick)
    bool  isBearCandle  = close < open
    bool  isBullCandle  = close > open
    if scanDir == 0
        scanDir          := 1
        runningHighPrice := high
        runningHighBar   := bar_index
        runningLowPrice  := low
        runningLowBar    := bar_index
    else if scanDir == 1
        // يترقّب قمّة: القمّة = أعلى سعر قبل تصحيح بشمعتين صحيحتين هابطتين «تحت بعض»
        if high > runningHighPrice
            runningHighPrice := high
            runningHighBar   := bar_index
            correctionCount  := 0
            correctionLevel  := na
        else if isValidCandle and isBearCandle
            if correctionCount == 0
                correctionCount := 1
                correctionLevel := low
            else if low < correctionLevel
                correctionCount := correctionCount + 1
                correctionLevel := low
            if correctionCount >= minCorr
                smallDegree.addRaw(true, runningHighPrice, runningHighBar, SMALL_KEEP)
                scanDir          := -1
                runningLowPrice  := low
                runningLowBar    := bar_index
                correctionCount  := 0
                correctionLevel  := na
    else
        // يترقّب قاعًا: القاع = أدنى سعر قبل تصحيح بشمعتين صحيحتين صاعدتين «فوق بعض»
        if low < runningLowPrice
            runningLowPrice := low
            runningLowBar   := bar_index
            correctionCount := 0
            correctionLevel := na
        else if isValidCandle and isBullCandle
            if correctionCount == 0
                correctionCount := 1
                correctionLevel := high
            else if high > correctionLevel
                correctionCount := correctionCount + 1
                correctionLevel := high
            if correctionCount >= minCorr
                smallDegree.addRaw(false, runningLowPrice, runningLowBar, SMALL_KEEP)
                scanDir          := 1
                runningHighPrice := high
                runningHighBar   := bar_index
                correctionCount  := 0
                correctionLevel  := na

// ─── شكل السهم المملوء — منقول من الكود المثبَت (M-Waves_M1: drawSArrow) سهمًا 7 نقاط ───
//   انحراف أمين: الارتفاع = نسبة من **نطاق سعريّ أصيل** (آخر 50 شمعة) بدل ATR — حجم رسم لا قاعدة.
float arrScale = ta.highest(high, 50) - ta.lowest(low, 50)
f_drawArrow(bool isTop, float price, int bar, color col) =>
    float shaftLen  = arrLen * 0.25 * arrScale
    float headLen   = shaftLen * 0.45                              // ارتفاع رأس السهم (متناسق)
    int   headHalf  = math.max(1, arrWidth)                        // نصف عرض الرأس (شموع)
    int   shaftHalf = math.max(1, int(math.round(headHalf * 0.45)))// نصف عرض الساق ≈ نصف الرأس
    shaftHalf := math.min(shaftHalf, math.max(1, headHalf - 1))    // الرأس أعرض من الساق دائمًا
    float yShaft  = isTop ? price + shaftLen : price - shaftLen
    float yHead   = isTop ? price + headLen  : price - headLen
    pts = array.new<chart.point>()
    array.push(pts, chart.point.from_index(bar,             price))  // طرف السهم على النقطة
    array.push(pts, chart.point.from_index(bar - headHalf,  yHead))
    array.push(pts, chart.point.from_index(bar - shaftHalf, yHead))
    array.push(pts, chart.point.from_index(bar - shaftHalf, yShaft))
    array.push(pts, chart.point.from_index(bar + shaftHalf, yShaft))
    array.push(pts, chart.point.from_index(bar + shaftHalf, yHead))
    array.push(pts, chart.point.from_index(bar + headHalf,  yHead))
    polyline.new(pts, closed = true, xloc = xloc.bar_index, line_color = col, fill_color = col, line_width = 1)

// ─── رسم الدرجة الصغيرة (islast): التصفية ثمّ السهم على النقاط الفعّالة + الوصل + تشخيص المستثناة ───
var array<polyline> smallArrows = array.new<polyline>()
var array<line>     smallLinks  = array.new<line>()
var array<label>    smallDiag   = array.new<label>()
if barstate.islast
    for a in smallArrows
        polyline.delete(a)
    array.clear(smallArrows)
    for ln in smallLinks
        line.delete(ln)
    array.clear(smallLinks)
    for d in smallDiag
        label.delete(d)
    array.clear(smallDiag)
    smallDegree.buildEffective(waveGeneralDir)               // (1) اتجاه · (3+4) صفّ الفعّالة من الخام
    int effectiveCount = array.size(smallDegree.effBars)
    if effectiveCount > 0
        int firstDrawn = math.max(0, effectiveCount - 90)   // سقف polyline=100 ⇒ ارسم الأحدث
        for i = firstDrawn to effectiveCount - 1
            bool  isTop  = array.get(smallDegree.effIsTop, i)
            float price  = array.get(smallDegree.effPrices, i)
            int   bar    = array.get(smallDegree.effBars, i)
            if showSmall
                array.push(smallArrows, f_drawArrow(isTop, price, bar, isTop ? cTop : cBot))
            if linkSmall and i > firstDrawn
                float prevPrice = array.get(smallDegree.effPrices, i - 1)
                int   prevBar   = array.get(smallDegree.effBars, i - 1)
                array.push(smallLinks, line.new(prevBar, prevPrice, bar, price, xloc = xloc.bar_index, color = cLineS, width = 1))
    // التشخيص: النقاط المرشّحة المستثناة + سبب الاستثناء (× رماديّ + نصّ)
    if showDiag
        int ne = array.size(smallDegree.exclBars)
        if ne > 0
            int firstExcl = math.max(0, ne - 40)            // الأحدث فقط (تفادي الازدحام)
            for i = firstExcl to ne - 1
                bool   xTop = array.get(smallDegree.exclIsTop, i)
                float  xP   = array.get(smallDegree.exclPrices, i)
                int    xB   = array.get(smallDegree.exclBars, i)
                string xR   = array.get(smallDegree.exclReason, i)
                array.push(smallDiag, label.new(xB, xP, "✕ " + xR, xloc = xloc.bar_index, yloc = yloc.price, style = xTop ? label.style_label_down : label.style_label_up, color = color.new(color.gray, 30), textcolor = color.white, size = size.tiny))


