//@version=6
// ════════════════════════════════════════════════════════════════════════════
// J-Waves — M1 (الموجة التاريخية)
// إعادة بناء نظيف طبقةً طبقةً — فرع rebuild-from-scratch
// المرجع الحاكم: docs/build/ (الدستور · المعمارية · خطة البناء · الجرد)
// الإصدار الداخليّ: v0.2.0 — ط0 الأساس (محرّك leg + سياق الموجة + الصندوق)
// ════════════════════════════════════════════════════════════════════════════
indicator("J-Waves M1", overlay = true, max_lines_count = 500, max_labels_count = 500, max_boxes_count = 500)

// ════════════════════════════════════════════════════════════════════════════
// المعمارية الفراكتالية (الاتجاه: كل سهم للأعلى — لا طبقة تقرأ من فوقها)
//   ط0 الأساس: حدود الموجات + الموجة التاريخية      [دروس 03-04]  ← الأسفل
//   ط1 القمم والقيعان (صغيرة→متوسطة→كبيرة)            [دروس 05-07]
//   ط2 الخطوط والتجدّد                                [دروس 08-09]
//   ط3 الاستنتاجات والمراحل                           [دروس 10-11]
//   ط4 المناطق والفرص                                 [دروس 01-03]  ← الأعلى
// ════════════════════════════════════════════════════════════════════════════


// ─────────────────────────────────────────────────────────────────────────────
// ط0 — الأساس: حدود الموجات + الموجة التاريخية + اتجاهها   [درس 03-04]
// ─────────────────────────────────────────────────────────────────────────────

// ─── المدخلات: القاعدة (معايرة، لا تشغيل/إطفاء قاعدة جوهرية) ───
string grpL0 = "ط0 — الأساس / Foundation"
int   waveLen      = input.int(150, "طول الموجة التاريخية (شموع) / Historical wave length", minval = 10, maxval = 4500, group = grpL0, tooltip = "[درس 03] المحلّل يختار الموجة التاريخية يدويًّا — اضبط الطول حتى يطابق موجتك المختارة. نافذة حساب السعة والاتجاه.")
float legMinRatio  = input.float(0.3, "عتبة الـleg (× سعة الموجة) / Leg threshold (× wave amplitude)", minval = 0.0, maxval = 1.0, step = 0.05, group = grpL0, tooltip = "[درس 04] عتبة محرّك حدود الموجات = نسبة من سعة الموجة التاريخية (ampHist) — بديل أصيل لـATR. تضبط دقّة الـleg.")
int   legMinSwings = input.int(2, "أدنى شموع لساق / Min candles per leg", minval = 1, maxval = 20, group = grpL0, tooltip = "كبح السيقان الصغيرة: لا يُؤكَّد طرف قبل مرور هذا العدد من الشموع.")
int   legCandidates = input.int(7, "عدد حدود الموجات المحفوظة / Kept wave boundaries", minval = 2, maxval = 15, group = grpL0, tooltip = "سقف الأداء: يُحفظ آخر (العدد × 2 + 2) من أطراف الـleg.")

// ─── المدخلات: العرض (لون/إظهار فقط) ───
string grpL0v = "ط0 — العرض / Foundation Display"
bool   showWaveBox  = input.bool(true, "صندوق الموجة التاريخية / Historical wave box", group = grpL0v)
bool   showLegMarks = input.bool(true, "حدود الموجات (leg) / Wave boundaries", group = grpL0v)
bool   linkLeg      = input.bool(true, "وصل الحدود بخطّ / Link boundaries", group = grpL0v)
color  cWaveBox     = input.color(color.new(color.blue, 92), "لون صندوق الموجة / Wave box color", group = grpL0v)
color  cLeg         = input.color(color.blue, "لون حدود الموجات / Boundary color", group = grpL0v)
string legMarkSize  = input.string("Small", "حجم العلامة / Mark size", options = ["Tiny", "Small", "Normal", "Large"], group = grpL0v)

// ─── الأنواع (بيانات متماسكة — مصدر واحد للحقيقة) ───
// سياق الموجة التاريخية: نافذة + حدود + سعة + اتجاه. يُحسب مرّة كل شمعة.
type WaveCtx
    int   win        // طول النافذة (wlen)
    int   left       // بداية الموجة (histLeft)
    float hi         // أعلى الموجة (hwHiE)
    float lo         // أدنى الموجة (hwLoE)
    float amp        // السعة (ampHist)
    int   dir        // اتجاه الموجة (bigDir)

// محرّك الـleg: حالة متراكمة لاستخراج حدود الموجات من السعر الخام.
type LegEngine
    int          dir        // اتجاه الساق الجارية (legDir0): 1 صعود · -1 هبوط · 0 غير مهيّأ
    int          swC        // عدّاد شموع الساق الجارية
    float        extHi      // أعلى تطرّف جارٍ
    int          extHiBar
    float        extLo      // أدنى تطرّف جارٍ
    int          extLoBar
    array<int>   bars       // بارات حدود الموجات (أطراف الـleg المؤكَّدة)
    array<float> ps         // أسعارها
    array<bool>  tops       // الطرف قمّة؟

// ─── الدوال (مسؤولية واحدة لكلّ دالّة) ───
// طول الموجة مقيَّدًا ضمن المدى الصالح (يحرس الحدود وعدد الشموع المتاح).
f_clampWaveLen(int userLen) =>
    math.min(math.max(userLen, 1), bar_index + 1)

// اتجاه الموجة من خطّ ترندها (أحدث تطرّف) مع ثبات يمنع التذبذب قرب التوازن:
//   لا ينقلب إلا إذا فاق فارق موضعَي القمّة/القاع 10% من النافذة. (لا اشتقاق بالكسر — هذه ط0)
f_bigDir(int win) =>
    int hb  = ta.highestbars(high, win)
    int lb  = ta.lowestbars(low, win)
    int raw = hb > lb ? 1 : -1
    var int dir = 0
    if dir == 0
        dir := raw
    else if raw != dir and math.abs(hb - lb) > win * 0.1
        dir := raw
    dir

// سياق الموجة التاريخية كاملًا (النافذة/الحدود/السعة/الاتجاه) — يُجمّع مصدر الحقيقة في كائن واحد.
f_waveContext(int userLen) =>
    int   win  = f_clampWaveLen(userLen)
    int   left = bar_index - win + 1
    float hi   = ta.highest(high, win)
    float lo   = ta.lowest(low, win)
    WaveCtx.new(win, left, hi, lo, hi - lo, f_bigDir(win))

// مُنشئ محرّك leg بمصفوفات فارغة.
f_newLeg() =>
    LegEngine.new(0, 0, na, na, na, na, array.new<int>(), array.new<float>(), array.new<bool>())

// حجم العلامة من اختيار نصّيّ.
f_markSize(string s) =>
    s == "Tiny" ? size.tiny : s == "Small" ? size.small : s == "Normal" ? size.normal : size.large

// ─── الـmethods على محرّك الـleg (تغليف منطق الحالة) ───
// خطوة لكل شمعة: تهيئة عند توفّر الاتجاه، تتبّع التطرّف الجاري، وتأكيد الطرف عند ارتداد ≥ th
//   وعدد شموع ≥ minSw. التناوب قمّة↔قاع مضمون بنيويًّا (الاتجاه ينقلب عند كل تأكيد فقط).
method f_step(LegEngine e, int seedDir, float th, int minSw) =>
    if e.dir == 0 and seedDir != 0
        e.dir := seedDir
        e.extHi := high
        e.extHiBar := bar_index
        e.extLo := low
        e.extLoBar := bar_index
        e.swC := 0
    if e.dir == 1
        e.swC := e.swC + 1
        if na(e.extHi) or high > e.extHi
            e.extHi := high
            e.extHiBar := bar_index
        if not na(th) and th > 0 and not na(e.extHi) and low < e.extHi - th and e.swC >= minSw
            array.push(e.bars, e.extHiBar)
            array.push(e.ps, e.extHi)
            array.push(e.tops, true)
            e.dir := -1
            e.extLo := low
            e.extLoBar := bar_index
            e.swC := 0
    else if e.dir == -1
        e.swC := e.swC + 1
        if na(e.extLo) or low < e.extLo
            e.extLo := low
            e.extLoBar := bar_index
        if not na(th) and th > 0 and not na(e.extLo) and high > e.extLo + th and e.swC >= minSw
            array.push(e.bars, e.extLoBar)
            array.push(e.ps, e.extLo)
            array.push(e.tops, false)
            e.dir := 1
            e.extHi := high
            e.extHiBar := bar_index
            e.swC := 0

// قصّ المصفوفات لإبقاء آخر `keep` أطراف فقط (حدّ الأداء).
method f_trim(LegEngine e, int keep) =>
    while array.size(e.bars) > keep
        array.shift(e.bars)
        array.shift(e.ps)
        array.shift(e.tops)

// ─── الحساب (لكلّ شمعة — مصدر واحد للحقيقة، لا قراءة من ط1+) ───
WaveCtx ctx = f_waveContext(waveLen)
float   legTh = legMinRatio * ctx.amp
var LegEngine leg = f_newLeg()
leg.f_step(ctx.dir, legTh, legMinSwings)
leg.f_trim(legCandidates * 2 + 2)

// ─── الرسم (islast فقط — منفصل عن الحساب) ───
var box          waveBox  = na
var array<label> legMarks = array.new<label>()
var array<line>  legLines = array.new<line>()
if barstate.islast
    // صندوق الموجة التاريخية
    if not na(waveBox)
        box.delete(waveBox)
        waveBox := na
    if showWaveBox
        waveBox := box.new(ctx.left, ctx.hi, bar_index, ctx.lo, xloc = xloc.bar_index, border_color = cLeg, bgcolor = cWaveBox)
    // مسح علامات/خطوط الحدود قبل إعادة الرسم
    for lm in legMarks
        label.delete(lm)
    array.clear(legMarks)
    for ll in legLines
        line.delete(ll)
    array.clear(legLines)
    // علامات حدود الموجات + خطّ الوصل (التناوب مضمون من المحرّك)
    if showLegMarks
        int   n       = array.size(leg.bars)
        int   prevBar = na
        float prevP   = na
        if n > 0
            for i = 0 to n - 1
                int   b = array.get(leg.bars, i)
                float p = array.get(leg.ps, i)
                array.push(legMarks, label.new(b, p, "", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_circle, color = cLeg, size = f_markSize(legMarkSize)))
                if linkLeg and not na(prevBar)
                    array.push(legLines, line.new(prevBar, prevP, b, p, xloc = xloc.bar_index, color = cLeg, width = 2))
                prevBar := b
                prevP := p


// ─────────────────────────────────────────────────────────────────────────────
// ط1 — القمم والقيعان   [دروس 05-07]   (لاحقًا)
// ─────────────────────────────────────────────────────────────────────────────


