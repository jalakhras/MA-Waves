//@version=6
// ════════════════════════════════════════════════════════════════════════════
// J-Waves — M1 (الموجة التاريخية)
// إعادة بناء نظيف طبقةً طبقةً — فرع rebuild-from-scratch
// المرجع الحاكم: docs/build/ (الدستور · المعمارية · خطة البناء · الجرد)
// الإصدار الداخليّ: v0.8.1 — شكل السهم من القديم (polyline سهم مملوء) بدل label.arrow
//   (صندوق الموجة/اللوحة مؤقّتان حتى يُعاد ربطهما بالدرجة الكبيرة في الدورة 3)
// ════════════════════════════════════════════════════════════════════════════
indicator("J-Waves M1", overlay = true, max_labels_count = 500, max_lines_count = 500, max_boxes_count = 300, max_polylines_count = 100, max_bars_back = 5000)

// ════════════════════════════════════════════════════════════════════════════
// المعمارية الفراكتالية (الاتجاه: كل سهم للأعلى — لا طبقة تقرأ من فوقها)
//   ط0 الأساس: الموجة التاريخية + تاريخ التاريخ     [دروس 03-04]  ← الأسفل
//   ط1 القمم والقيعان (صغيرة→متوسطة→كبيرة)            [دروس 05-07]
//   ط2..ط4 (لاحقًا)
// الاختيار التلقائيّ من السعر الخام (لا دائرة، لا ارتكاز على ط1). عدّ الدرجات/موجات الدفعة
//   /ملاءمة الفريم في اللوحة يكتمل بـط1 (يحتاج الدرجات الثلاث).
// ════════════════════════════════════════════════════════════════════════════


// ════════════════════════════════════════════════════════════════════════════
// ط0 — الأساس: الموجة التاريخية + تاريخ التاريخ   [درس 03-04]
// ════════════════════════════════════════════════════════════════════════════

// ─── المدخلات: الموجة التاريخية ───
string grpHist = "🌊 Historical Wave / الموجة التاريخية"
bool   showHist = input.bool(true, "Show historical wave bounds / حدود الموجة التاريخية", group = grpHist)
bool   useHistN = input.bool(false, "Set wave by candle count / تحديد الموجة بعدد الشموع", group = grpHist, tooltip = "On: bounds over the last N candles. Off: auto — current move from its origin to now.\nمفعّل: آخر N شمعة. مطفأ: تلقائيّ — الحركة الحاليّة من أصلها إلى الآن.")
int    histBars = input.int(100, "Historical wave candles / عدد شموع الموجة", minval = 1, group = grpHist)
color  cHist    = input.color(color.new(#607D8B, 82), "Historical wave color / لون الموجة التاريخية", group = grpHist)
bool   showHoh  = input.bool(true, "Show prior-history bounds / حدود تاريخ التاريخ", group = grpHist)
bool   useHohN  = input.bool(false, "Set prior-history by candle count / تحديد تاريخ التاريخ بعدد الشموع", group = grpHist, tooltip = "On: N candles. Off: same length as the historical wave before it.\nمفعّل: N شمعة. مطفأ: بطول الموجة التاريخية قبله.")
int    hohBars  = input.int(100, "Prior-history candles / عدد شموع تاريخ التاريخ", minval = 1, group = grpHist)
color  cHoh     = input.color(color.new(#808080, 88), "Prior-history color / لون تاريخ التاريخ", group = grpHist)

// ─── المدخلات: لوحة اختبار الموجة (تصميم الكود السابق) ───
string grpFH = "🧪 Wave Test / لوحة اختبار الموجة"
bool   showFrameHelper = input.bool(true, "Wave-test panel (wave time ⇒ trading type) / لوحة اختبار الموجة", group = grpFH)
string fhPos        = input.string("Top L", "Panel position / موضع اللوحة", options = ["Top L", "Top C", "Top R", "Mid L", "Center", "Mid R", "Bot L", "Bot C", "Bot R"], group = grpFH)
float  swingMinDays = input.float(2.0, "Swing lower bound (days/wave) — below = Scalp / حدّ السوينغ الأدنى", minval = 0.1, step = 0.5, group = grpFH, tooltip = "زمن الموجة أقلّ من هذا ⇒ مضاربة ⇒ اصعد فريمًا.")
float  swingMaxDays = input.float(10.0, "Swing upper bound (days/wave) — above = Invest / حدّ السوينغ الأعلى", minval = 0.5, step = 0.5, group = grpFH, tooltip = "زمن الموجة أكثر من هذا ⇒ استثمار ⇒ انزل فريمًا.")
color  fhBg         = input.color(#1E222D, "Panel background / خلفية اللوحة", group = grpFH)

// ─── المدخلات: الدرجة 0 (الصغيرة) ───
string grpSmall = "🔴 Small Degree / الصغيرة (درجة 0)"
bool   showSmall = input.bool(true, "Show small pivots / إظهار القمم والقيعان الصغيرة", group = grpSmall)
int    minCorr   = input.int(2, "Correction candles to confirm / شموع التصحيح للتأكيد", minval = 1, maxval = 5, group = grpSmall, tooltip = "[درس 05] شمعتان صحيحتان في اتجاه التصحيح.")
bool   useValid  = input.bool(true, "Require valid candle (body ≥ each wick) / اشتراط الشمعة الصحيحة", group = grpSmall, tooltip = "[درس 05] النويز = ذيل أطول من الجسم ⇒ يُستبعَد.")
color  cTop      = input.color(#F23645, "Small top / قمّة صغيرة", group = grpSmall)
color  cBot      = input.color(#089981, "Small bottom / قاع صغير", group = grpSmall)
float  arrLen    = input.float(0.4, "Arrow length / طول السهم", minval = 0.1, step = 0.1, group = grpSmall, tooltip = "نسبة من نطاق سعريّ أصيل (لا ATR) — حجم رسم فقط.")
int    arrWidth  = input.int(2, "Arrow width (candles) / عرض السهم", minval = 1, maxval = 10, group = grpSmall)

// نافذة البحث عن أصل الحركة (نظير autoLen السابق). المحلّل يضبط الموجة يدويًّا عبر useHistN/histBars.
int AUTO_WAVE_LEN = 150
int SMALL_KEEP = 300   // سقف القمم/القيعان الصغيرة المحفوظة (أداء)

// ─── الدوال (مسؤولية واحدة لكلّ دالّة) ───
// موضع اللوحة من اختيار نصّيّ.
f_pos(string s) =>
    s == "Top L" ? position.top_left : s == "Top C" ? position.top_center : s == "Top R" ? position.top_right : s == "Mid L" ? position.middle_left : s == "Center" ? position.middle_center : s == "Mid R" ? position.middle_right : s == "Bot L" ? position.bottom_left : s == "Bot C" ? position.bottom_center : position.bottom_right

// لون أغمق (للحدّ) من لون التعبئة مع حفظ الشفافية.
f_dark(color c) =>
    color.new(color.rgb(color.r(c) * 0.6, color.g(c) * 0.6, color.b(c) * 0.6), color.t(c))

// طول الموجة اليدويّ مقيَّدًا ضمن المدى الصالح.
f_waveLen(int nBars) =>
    math.min(math.max(nBars, 1), bar_index + 1)

// أعلى/أدنى سعر ضمن نطاق بارات [leftB..rightB] (يُستدعى عند islast فقط — قليل التكلفة).
f_rangeHiLo(int leftB, int rightB) =>
    float hi = na
    float lo = na
    if not na(leftB) and not na(rightB) and rightB >= leftB
        for j = leftB to rightB
            int off = bar_index - j
            if off >= 0
                hi := na(hi) or high[off] > hi ? high[off] : hi
                lo := na(lo) or low[off] < lo ? low[off] : lo
    [hi, lo]

// زمن نطاق بارات [leftB..rightB] بالأيام.
f_rangeDays(int leftB, int rightB) =>
    (time[bar_index - rightB] - time[bar_index - leftB]) / 86400000.0

// ─── الحساب (لكلّ شمعة — ta.* تتطلّب تقييمًا مستمرًّا) ───
// أصل الحركة الحاليّة: أبعد تطرّف (قمّة/قاع) في نافذة البحث. إن كانت القمّة أحدث ⇒ حركة صاعدة
//   فالأصل = القاع، والعكس. (السعر الخام، لا دائرة — هذه ط0)
int hiOff = ta.highestbars(high, AUTO_WAVE_LEN)
int loOff = ta.lowestbars(low, AUTO_WAVE_LEN)

// يسار الموجة التاريخية: يدويّ (نافذة آخر N) أو تلقائيّ (أصل الحركة). يُحسب رخيصًا (بلا حلقة).
f_waveLeft() =>
    useHistN ? math.max(bar_index - f_waveLen(histBars) + 1, 0) : bar_index + (hiOff > loOff ? loOff : hiOff)

// ─── الرسم (islast فقط — منفصل عن الحساب) ───
var box   waveBox = na
var box   hohBox  = na
var label waveLbl = na
var label hohLbl  = na
if barstate.islast
    // ===== الموجة التاريخية: من الأصل (أو نافذة يدويّة) إلى الآن =====
    if not na(waveBox)
        box.delete(waveBox)
        waveBox := na
    if not na(waveLbl)
        label.delete(waveLbl)
        waveLbl := na
    int wL = f_waveLeft()
    int wR = bar_index
    [wHi, wLo] = f_rangeHiLo(wL, wR)
    if showHist and not na(wHi) and not na(wLo)
        color hBd = f_dark(cHist)
        waveBox := box.new(wL, wHi, wR, wLo, xloc = xloc.bar_index, border_color = hBd, border_width = 1, bgcolor = cHist)
        string hTxt = useHistN ? "الموجة التاريخية (يدوي)" : "الموجة التاريخية (تلقائي)"
        waveLbl := label.new(wL, wHi, hTxt, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_lower_right, color = hBd, textcolor = color.white, size = size.tiny)
    // ===== تاريخ التاريخ: خلف الموجة مباشرةً (ينتهي عند بدايتها wL) =====
    if not na(hohBox)
        box.delete(hohBox)
        hohBox := na
    if not na(hohLbl)
        label.delete(hohLbl)
        hohLbl := na
    int hR = wL
    int hL = useHohN ? math.max(wL - hohBars, 0) : math.max(wL - math.max(wR - wL, 1), 0)
    if showHoh and hR > hL
        [hHi, hLo] = f_rangeHiLo(hL, hR)
        if not na(hHi) and not na(hLo)
            color hohBd = color.new(color.gray, 0)
            hohBox := box.new(hL, hHi, hR, hLo, xloc = xloc.bar_index, border_color = hohBd, border_width = 1, bgcolor = cHoh)
            string hohTxt = useHohN ? "تاريخ التاريخ (يدوي)" : "تاريخ التاريخ (تلقائي)"
            hohLbl := label.new(hL, hLo, hohTxt, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_upper_right, color = hohBd, textcolor = color.white, size = size.tiny)

// ─── لوحة اختبار الموجة (تصميم الكود السابق) ───
// الدرس 03 خ6: زمن الموجة ⇒ نوع التداول. موجات الدفعة/عدّ الدرجات/ملاءمة الفريم يكتمل بـط1.
var table fht = table.new(f_pos(fhPos), 2, 7, bgcolor = fhBg, border_width = 1, border_color = #2A2E39, frame_width = 1, frame_color = #2A2E39)
f_drawWavePanel() =>
    table.set_position(fht, f_pos(fhPos))
    int   wL = f_waveLeft()
    float days = f_rangeDays(wL, bar_index)
    string timeTxt = na(days) or days <= 0 ? "—" : days >= 1 ? str.tostring(days, "#.0") + " يوم" : days >= 0.0417 ? str.tostring(days * 24, "#.0") + " ساعة" : str.tostring(days * 1440, "#.0") + " دق"
    string waveType = na(days) or days <= 0 ? "—" : days < swingMinDays ? "مضاربة" : days <= swingMaxDays ? "سوينغ" : "استثمار"
    color  wtBg = na(days) or days <= 0 ? color.new(#787B86, 0) : days < swingMinDays ? color.new(#FF9800, 0) : days <= swingMaxDays ? color.new(#089981, 0) : color.new(#2962FF, 0)
    string tradeNature = na(days) or days <= 0 ? "بيانات غير كافية" : days < swingMinDays ? "صفقات دقائق–يوم" : days <= swingMaxDays ? "صفقات يومين–10 أيام" : "صفقات أسابيع–شهور"
    color tvBg   = fhBg
    color tvHdr  = color.new(color.rgb(color.r(fhBg) * 0.72, color.g(fhBg) * 0.72, color.b(fhBg) * 0.72), color.t(fhBg))
    color tvMain = #D1D4DC
    color tvMute = #787B86
    table.cell(fht, 0, 0, "لوحة اختبار الموجة", text_color = tvMain, bgcolor = tvHdr, text_size = size.normal, text_halign = text.align_right)
    table.cell(fht, 1, 0, "", bgcolor = tvHdr)
    table.cell(fht, 0, 1, "درجات ظاهرة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 1, "— / 3 (ط1)", text_color = tvMute, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 2, "موجات دافعة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 2, "— (ط1)", text_color = tvMute, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 3, "زمن الموجة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 3, timeTxt, text_color = tvMain, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 4, "نوع التداول", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 4, waveType, text_color = color.white, bgcolor = wtBg, text_size = size.small)
    table.cell(fht, 0, 5, "نمط الصفقة", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 5, tradeNature, text_color = tvMain, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 6, "الفريم مناسب؟", text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 6, "ينتظر الدرجات (ط1)", text_color = tvMute, bgcolor = tvBg, text_size = size.small)

if showFrameHelper and barstate.islast
    f_drawWavePanel()


// ═════════════════════════════════════════════════════════════════════════════
// ط1 — القمم والقيعان   [دروس 05-07]
// ═════════════════════════════════════════════════════════════════════════════

// ─── الدرجة 0 (الصغيرة): كشف القمم/القيعان بقاعدة الشمعتين [درس 05] ───
//   مرشّح الضجيج الأصيل (لا ATR): شمعتان صحيحتان (الجسم ≥ كل ذيل) في اتجاه التصحيح.
//   القمّة = أعلى سعر قبل التصحيح · القاع = أدنى سعر قبله. أساسٌ تُشتقّ منه بقيّة الدرجات بالكسر.
//   منقول من المحرّك المثبَت (M-Waves_M1) منظّفًا. [الدورة 1: كشف خام؛ الفعالية/التتابُع لاحقًا]
var int   sdir    = 0       // اتجاه الموجة الصغيرة: 1 صعود · -1 هبوط · 0 غير مهيّأ
var float curHi   = na      // أعلى سعر جارٍ (مرشّح القمّة)
var int   curHiBar = na
var float curLo   = na      // أدنى سعر جارٍ (مرشّح القاع)
var int   curLoBar = na
var int   corr    = 0       // عدّاد شموع التصحيح الصحيحة
var float corrRef = na      // مرجع تدرّج التصحيح (تحت بعض)
var array<int>   sBars = array.new<int>()
var array<float> sPs   = array.new<float>()
var array<bool>  sTops = array.new<bool>()

if barstate.isconfirmed
    float body = math.abs(close - open)
    float uw   = high - math.max(close, open)
    float lw   = math.min(close, open) - low
    bool  valid = (not useValid) or (body > 0 and body >= uw and body >= lw)
    bool  bear  = close < open
    bool  bull  = close > open
    if sdir == 0
        sdir := 1
        curHi := high
        curHiBar := bar_index
        curLo := low
        curLoBar := bar_index
    else if sdir == 1
        // موجة صاعدة: القمّة = أعلى سعر قبل تصحيح بشمعتين صحيحتين «تحت بعض»
        if high > curHi
            curHi := high
            curHiBar := bar_index
            corr := 0
            corrRef := na
        else if valid and bear
            if corr == 0
                corr := 1
                corrRef := low
            else if low < corrRef
                corr := corr + 1
                corrRef := low
            if corr >= minCorr
                array.push(sBars, curHiBar)
                array.push(sPs, curHi)
                array.push(sTops, true)
                sdir := -1
                curLo := low
                curLoBar := bar_index
                corr := 0
                corrRef := na
    else
        // موجة هابطة: القاع = أدنى سعر قبل تصحيح بشمعتين صحيحتين «فوق بعض»
        if low < curLo
            curLo := low
            curLoBar := bar_index
            corr := 0
            corrRef := na
        else if valid and bull
            if corr == 0
                corr := 1
                corrRef := high
            else if high > corrRef
                corr := corr + 1
                corrRef := high
            if corr >= minCorr
                array.push(sBars, curLoBar)
                array.push(sPs, curLo)
                array.push(sTops, false)
                sdir := 1
                curHi := high
                curHiBar := bar_index
                corr := 0
                corrRef := na
    // قصّ للأحدث فقط (أداء)
    while array.size(sBars) > SMALL_KEEP
        array.shift(sBars)
        array.shift(sPs)
        array.shift(sTops)

// شكل السهم — منقول من الكود المثبَت (M-Waves_M1: drawSArrow) بشكله المعتمد (سهم 7 نقاط مملوء).
//   انحراف أمين: المقياس العموديّ = نسبة من **نطاق سعريّ أصيل** (آخر 50 شمعة) بدل ATR — حجم رسم فقط، لا قاعدة.
float arrScale = ta.highest(high, 50) - ta.lowest(low, 50)
f_drawSArrow(bool isTop, float px, int bar, color colA) =>
    float slen    = arrLen * 0.25 * arrScale
    float headH   = slen * 0.45                                  // ارتفاع رأس السهم (متناسق)
    int   headWb  = math.max(1, arrWidth)                        // نصف عرض الرأس (شموع)
    int   shaftWb = math.max(1, int(math.round(headWb * 0.45)))  // نصف عرض الساق ≈ نصف الرأس
    shaftWb := math.min(shaftWb, math.max(1, headWb - 1))        // الرأس أعرض من الساق دائمًا
    float yShaft  = isTop ? px + slen  : px - slen
    float yHead   = isTop ? px + headH : px - headH
    pts = array.new<chart.point>()
    array.push(pts, chart.point.from_index(bar,           px))   // طرف السهم على النقطة
    array.push(pts, chart.point.from_index(bar - headWb,  yHead))
    array.push(pts, chart.point.from_index(bar - shaftWb, yHead))
    array.push(pts, chart.point.from_index(bar - shaftWb, yShaft))
    array.push(pts, chart.point.from_index(bar + shaftWb, yShaft))
    array.push(pts, chart.point.from_index(bar + shaftWb, yHead))
    array.push(pts, chart.point.from_index(bar + headWb,  yHead))
    polyline.new(pts, closed = true, xloc = xloc.bar_index, line_color = colA, fill_color = colA, line_width = 1)

// رسم القمم/القيعان الصغيرة (islast فقط)
var array<polyline> sMarks = array.new<polyline>()
if barstate.islast
    for m in sMarks
        polyline.delete(m)
    array.clear(sMarks)
    if showSmall
        int ns = array.size(sBars)
        if ns > 0
            int from = math.max(0, ns - 90)   // سقف polyline = 100 ⇒ ارسم الأحدث فقط (التخزين يبقى كاملًا لتغذية الدرجات)
            for i = from to ns - 1
                bool t = array.get(sTops, i)
                array.push(sMarks, f_drawSArrow(t, array.get(sPs, i), array.get(sBars, i), t ? cTop : cBot))


// ─────────────────────────────────────────────────────────────────────────────
// ط1 — المتوسطة/الكبيرة (بالكسر)   [دروس 06-07]   (لاحقًا)
// ─────────────────────────────────────────────────────────────────────────────


// ─────────────────────────────────────────────────────────────────────────────
// ط2 — الخطوط والتجدّد   [دروس 08-09]   (لاحقًا)
// ─────────────────────────────────────────────────────────────────────────────


// ─────────────────────────────────────────────────────────────────────────────
// ط3 — الاستنتاجات والمراحل   [دروس 10-11]   (لاحقًا)
// ─────────────────────────────────────────────────────────────────────────────


// ─────────────────────────────────────────────────────────────────────────────
// ط4 — المناطق والفرص   [دروس 01-03]   (لاحقًا)
// ─────────────────────────────────────────────────────────────────────────────
