//@version=6
// ============================================================================
//  استراتيجية M-Waves — نواة المحرّك (المرحلة أ — الإصدار 0.1)
//  Engine nucleus: القمم والقيعان للدرجات الثلاث + قاعدة الشمعتين + الكسر
// ----------------------------------------------------------------------------
//  المنهج:
//   • الدرجة الصغيرة (أحمر/أخضر): تُكتشف بقاعدة «الشمعتين الصحيحتين» في التصحيح،
//     مع قانونَي التتابُع والفعالية (لا تُرسم النقطة إلا بعد تأكّدها).
//   • الدرجة المتوسطة (برتقالي): تُشتق من الصغيرة «بالكسر» (قاعدة الاستراتيجية).
//   • الدرجة الكبيرة (أزرق): اتجاهها فقط = اتجاه ترند الموجة التاريخية (bigDir)؛
//     أُزيل اشتقاقها بالكسر. بناء قمم/قيعان الكبيرة (آخر 7 موجات، §07) لاحقاً.
//
//  هذا إصدار أوّلي للتحقّق مقابل تحليلك اليدوي. الأجزاء التقديرية المتبقّية (اختيار
//  الموجة التاريخية، والفريم) تُقارَب بمعاملات قابلة للضبط — لا تُطابَق 100%.
//
//  خريطة التوسعة:
//   [✓] خطوط السيولة            [✓] مستويات تحديد الاتجاه
//   [✓] الاستنتاجات وحالة السوق  [✓] المناطق (المستوى الثاني)
//   [ ] إشارات الصفقات (دخول/وقف/هدف)
// ============================================================================
indicator("M-Waves Engine v0.43", overlay = true, max_labels_count = 500, max_lines_count = 500, max_polylines_count = 100, max_boxes_count = 300, max_bars_back = 5000)

// ============================ الإعدادات ====================================
grpEng  = "محرّك الدرجات"
minCorr = input.int(2, "عدد شموع التصحيح لتأكيد القمة/القاع", minval = 1, maxval = 5, group = grpEng,
     tooltip = "قاعدة الاستراتيجية = شمعتان صحيحتان في اتجاه التصحيح")
useValid = input.bool(true, "اشتراط الشمعة الصحيحة (جسم ≥ كل ذيل)", group = grpEng,
     tooltip = "استبعاد النويز كاندل: أي ذيل أطول من الجسم")

grpShow   = "الإظهار"
showSmall = input.bool(true,  "الدرجة الصغيرة (أحمر/أخضر)", group = grpShow)
showMed   = input.bool(true,  "الدرجة المتوسطة (برتقالي)",  group = grpShow)
showBig   = input.bool(true,  "الدرجة الكبيرة (أزرق)",      group = grpShow)
linkSmall = input.bool(true,  "وصل قمم/قيعان الصغيرة بخطوط", group = grpShow)
linkMed   = input.bool(true,  "وصل قمم/قيعان المتوسطة بخطوط", group = grpShow)
// ===== شكل السهم (مصمت يشبه shape.arrowup مع تحكّم بالطول والعرض) =====
grpArr    = "شكل السهم"
arrLenAtr = input.float(1.5, "طول السهم (× ATR)", minval = 0.2, step = 0.1, group = grpArr)
arrWidth  = input.float(3.0, "عرض السهم (شموع)", minval = 0.5, maxval = 15, step = 0.5, group = grpArr)

// ===== الألوان (كلٌّ في سطر) =====
grpCol = "الألوان"
cTop   = input.color(#C00000, "لون سهم القمة (صغيرة)",  group = grpCol)
cBot   = input.color(#2E7D32, "لون سهم القاع (صغيرة)",  group = grpCol)
cMed   = input.color(#C55A11, "لون دائرة المتوسطة",     group = grpCol)
cBig   = input.color(#1F3A5F, "لون دائرة الكبيرة",       group = grpCol)
cLineS = input.color(color.new(color.gray, 55), "لون خط الصغيرة",  group = grpCol)
cLineM = input.color(color.new(#C55A11, 35),    "لون خط المتوسطة", group = grpCol)
cLiqS = input.color(#C00000, "سيولة الصغيرة",  group = grpCol)
cLvlS = input.color(color.new(#C00000, 30), "مستوى الصغيرة", group = grpCol)
cLiqM = input.color(#C55A11, "سيولة المتوسطة", group = grpCol)
cLvlM = input.color(color.new(#C55A11, 30), "مستوى المتوسطة", group = grpCol)
cLiqB = input.color(#1F3A5F, "سيولة الكبيرة",  group = grpCol)
cLvlB = input.color(color.new(#1F3A5F, 30), "مستوى الكبيرة", group = grpCol)
cMedDead = input.color(#C00000, "المتوسطة غير الفعّالة", group = grpCol)

// ===== الموجة التاريخية =====
grpHist   = "الموجة التاريخية"
showHist  = input.bool(true,  "إظهار حدود الموجة التاريخية", group = grpHist)
useHistN  = input.bool(false, "تحديد الموجة بعدد الشموع (بدل التلقائي)", group = grpHist,
     tooltip = "مفعّل: تُرسم الحدود على آخر «عدد الشموع». مطفأ: تُحدَّد تلقائياً من الدرجة الكبيرة.")
histBars  = input.int(100, "عدد شموع الموجة التاريخية", minval = 1, group = grpHist)
cHist     = input.color(color.new(#B8860B, 80), "لون الموجة التاريخية", group = grpHist)
showHoh   = input.bool(true,  "إظهار حدود تاريخ التاريخ", group = grpHist)
useHohN   = input.bool(false, "تحديد تاريخ التاريخ بعدد الشموع (بدل التلقائي)", group = grpHist,
     tooltip = "مفعّل: يأخذ «عدد شموع تاريخ التاريخ». مطفأ: بطول مساوٍ للموجة التاريخية قبلها مباشرةً.")
hohBars   = input.int(100, "عدد شموع تاريخ التاريخ", minval = 1, group = grpHist)
cHoh      = input.color(color.new(#808080, 88), "لون تاريخ التاريخ", group = grpHist)

// ===== خطوط السيولة ومستويات الاتجاه =====
grpLiq  = "السيولة والمستويات"
showLiq = input.bool(true, "خطوط السيولة (على الذيول)",      group = grpLiq)
showLvl = input.bool(true, "مستويات الاتجاه (على الأجسام)", group = grpLiq)

// ===== الاستنتاجات وحالة السوق =====
grpConc   = "الاستنتاجات والحالة"
showPanel = input.bool(true, "لوحة الاستنتاجات والحالة", group = grpConc)

// ===== المناطق (المستوى الثاني) =====
grpZone    = "المناطق (المستوى الثاني)"
showZones  = input.bool(true, "إظهار المناطق", group = grpZone)
zoneTol    = input.float(0.5, "تقارب المنطقة (× ATR)", minval = 0.1, step = 0.1, group = grpZone,
     tooltip = "خطّان من الدرجة المتوسطة يُعتبران منطقةً إذا كان الفرق بينهما ضمن هذا الحد")
zoneExt    = input.int(0, "امتداد إضافي بعد السعر الحالي (شموع)", minval = 0, group = grpZone,
     tooltip = "افتراضياً تمتدّ المنطقة حتى السعر الحالي (0). زِد القيمة لتمديدها أكثر يميناً.")
zoneFill   = input.color(color.new(#2E75B6, 85), "تعبئة المنطقة", group = grpZone)
zoneBorder = input.color(color.new(#2E75B6, 35), "حدّ المنطقة",   group = grpZone)

// ===== وحدات قادمة (Placeholders) — غير مُفعّلة بعد =====
grpNext  = "وحدات قادمة (قريباً)"
phSignal = input.bool(false, "إشارات الصفقات", group = grpNext)

// ====================== أداة: معالج الدرجة الأعلى ===========================
// يستقبل قمم/قيعان درجةٍ ما، ويُخرج قمم/قيعان الدرجة الأعلى عبر «كسر الهيكل»:
//   • في موجة صاعدة: كسر قاعٍ للأسفل ⇒ أعلى قمة قبله = قمة أعلى درجة.
//   • في موجة هابطة: كسر قمةٍ للأعلى ⇒ أدنى قاع قبله = قاع أعلى درجة.
type Proc
    int   dir        = 0
    float maxTopBHi  = na   // أعلى جسم القمة = max(open,close)
    float maxTopBLo  = na   // أسفل جسم القمة = min(open,close)
    int   maxTopBar  = na
    int   maxTopTime = na
    float maxTopP    = na   // ذيل القمة (high)
    float minBotBHi  = na   // أعلى جسم القاع
    float minBotBLo  = na   // أسفل جسم القاع
    int   minBotBar  = na
    int   minBotTime = na
    float minBotP    = na   // ذيل القاع (low)
    float prevTopP   = na
    float prevBotP   = na

// يُغذّى بنقطة (ذيل p، أعلى الجسم bHi، أسفل الجسم bLo، وقت t، شمعة b، isTop)
// يُعيد: [أُخرجت؟، الذيل، أعلى الجسم، أسفل الجسم، الوقت، الشمعة، أهي قمة؟]
feed(Proc s, float p, float bHi, float bLo, int t, int b, bool isTop) =>
    bool  emitted = false
    float eP      = na
    float eBHi    = na
    float eBLo    = na
    int   eTime   = na
    int   eB      = na
    bool  eTop    = false
    if isTop
        if s.dir == 0
            s.dir := 1
            s.maxTopP := p
            s.maxTopBHi := bHi
            s.maxTopBLo := bLo
            s.maxTopBar := b
            s.maxTopTime := t
        else if s.dir == 1
            if na(s.maxTopP) or p > s.maxTopP
                s.maxTopP := p
                s.maxTopBHi := bHi
                s.maxTopBLo := bLo
                s.maxTopBar := b
                s.maxTopTime := t
        else
            // موجة هابطة: قمة أعلى من سابقتها = كسر للأعلى ⇒ تأكيد قاع أعلى درجة
            if not na(s.prevTopP) and p > s.prevTopP
                emitted := true
                eP := s.minBotP
                eBHi := s.minBotBHi
                eBLo := s.minBotBLo
                eTime := s.minBotTime
                eB := s.minBotBar
                eTop := false
                s.dir := 1
                s.maxTopP := p
                s.maxTopBHi := bHi
                s.maxTopBLo := bLo
                s.maxTopBar := b
                s.maxTopTime := t
        s.prevTopP := p
    else
        if s.dir == 0
            s.dir := -1
            s.minBotP := p
            s.minBotBHi := bHi
            s.minBotBLo := bLo
            s.minBotBar := b
            s.minBotTime := t
        else if s.dir == -1
            if na(s.minBotP) or p < s.minBotP
                s.minBotP := p
                s.minBotBHi := bHi
                s.minBotBLo := bLo
                s.minBotBar := b
                s.minBotTime := t
        else
            // موجة صاعدة: قاع أدنى من سابقه = كسر للأسفل ⇒ تأكيد قمة أعلى درجة
            if not na(s.prevBotP) and p < s.prevBotP
                emitted := true
                eP := s.maxTopP
                eBHi := s.maxTopBHi
                eBLo := s.maxTopBLo
                eTime := s.maxTopTime
                eB := s.maxTopBar
                eTop := true
                s.dir := -1
                s.minBotP := p
                s.minBotBHi := bHi
                s.minBotBLo := bLo
                s.minBotBar := b
                s.minBotTime := t
        s.prevBotP := p
    [emitted, eP, eBHi, eBLo, eTime, eB, eTop]

// ============== ذاكرة الدرجة + رسم السيولة والمستويات ===================
// لكل درجة: نحفظ آخر قمتين/قاعين (ذيل + جسم + شمعة)، ثم:
//   • خط السيولة: يصل آخر قاعين (صعود) أو آخر قمتين (هبوط) على الذيول.
//   • مستوى الاتجاه: خط أفقي عند آخر قاع/قمة على الجسم.
type DegMem
    float ltP    = na
    float ltBody = na
    int   ltBar  = na
    float ptP    = na
    int   ptBar  = na
    float lbP    = na
    float lbBody = na
    int   lbBar  = na
    float pbP    = na
    int   pbBar  = na
    line  liq    = na
    line  lvl    = na

updateDeg(DegMem m, bool isTop, float wick, float body, int bar, int dir, color liqCol, color lvlCol, bool sLiq, bool sLvl) =>
    if isTop
        m.ptP := m.ltP
        m.ptBar := m.ltBar
        m.ltP := wick
        m.ltBody := body
        m.ltBar := bar
    else
        m.pbP := m.lbP
        m.pbBar := m.lbBar
        m.lbP := wick
        m.lbBody := body
        m.lbBar := bar
    if not na(m.liq)
        line.delete(m.liq)
        m.liq := na
    if not na(m.lvl)
        line.delete(m.lvl)
        m.lvl := na
    if sLiq
        if dir == 1 and not na(m.lbP) and not na(m.pbP)
            m.liq := line.new(m.pbBar, m.pbP, m.lbBar, m.lbP, xloc = xloc.bar_index, color = liqCol, width = 2, extend = extend.right)
        if dir == -1 and not na(m.ltP) and not na(m.ptP)
            m.liq := line.new(m.ptBar, m.ptP, m.ltBar, m.ltP, xloc = xloc.bar_index, color = liqCol, width = 2, extend = extend.right)
    if sLvl
        if dir == 1 and not na(m.lbBody)
            m.lvl := line.new(m.lbBar, m.lbBody, bar_index, m.lbBody, xloc = xloc.bar_index, color = lvlCol, width = 1, style = line.style_solid, extend = extend.right)
        if dir == -1 and not na(m.ltBody)
            m.lvl := line.new(m.ltBar, m.ltBody, bar_index, m.ltBody, xloc = xloc.bar_index, color = lvlCol, width = 1, style = line.style_solid, extend = extend.right)

// ===================== الدرجة الصغيرة: محرّك الشمعتين ========================
var int   sdir      = 0      // 1=نبحث عن قمة (موجة صاعدة)، -1=نبحث عن قاع
var float curHi     = na
var float curHiBHi  = na     // أعلى جسم شمعة القمة
var float curHiBLo  = na     // أسفل جسم شمعة القمة
var int   curHiBar  = na
var int   curHiTime = na
var float curLo     = na
var float curLoBHi  = na     // أعلى جسم شمعة القاع
var float curLoBLo  = na     // أسفل جسم شمعة القاع
var int   curLoBar  = na
var int   curLoTime = na
var int   corr      = 0      // عدّاد شموع التصحيح الصحيحة
var float corrRef   = na     // مرجع تدرّج التصحيح (أدنى/أعلى آخر شمعة مُحتسبة)
var float corrPrevBHi = na   // أعلى جسم آخر شمعة تصحيح مُحتسبة (لفحص الابتلاع)
var float corrPrevBLo = na   // أسفل جسمها

var Proc pmed = Proc.new()  // معالج المتوسطة (يُغذّى بالصغيرة)

var DegMem memS = DegMem.new()  // ذاكرة الصغيرة
var DegMem memM = DegMem.new()  // ذاكرة المتوسطة

var array<box>   dispBoxes = array.new<box>()   // الصناديق المعروضة حالياً (٦ كحدّ أقصى)

// لربط النقاط بخطوط
var float lastSmallP   = na
var int   lastSmallBar = na
var float lastMedP     = na
var int   lastMedBar   = na
var array<int> medBars = array.new<int>()   // شمع آخر النقاط المتوسطة (لطول الموجة التلقائي)
// مخزن دوائر المتوسطة (للفعالية: برتقالية فعّالة ← حمراء عند تغطيتها)
var array<float> mcP   = array.new<float>()   // سعر النقطة (الذيل)
var array<float> mcLvl = array.new<float>()   // قيمة المستوى (الجسم) للمناطق
var array<float> mcHi  = array.new<float>()   // أعلى الجسم
var array<float> mcLo  = array.new<float>()   // أسفل الجسم
var array<int>   mcBar = array.new<int>()
var array<int>   mcTm  = array.new<int>()
var array<bool>  mcTop = array.new<bool>()
var array<bool>  mcEff = array.new<bool>()    // فعّالة؟
var array<label> mcLbl = array.new<label>()


atrv = ta.atr(14)   // لقياس طول السهم بمعزل عن سعر الأداة

// دالّة رسم سهم صغير مصمت (الطرف على الذيل) وتُعيد الكائن لإمكان حذفه/إعادة تلوينه
drawSArrow(bool isTop, float px, int bar, color colA) =>
    float slen    = arrLenAtr * atrv
    float headH   = slen * 0.4
    int   headWb  = math.max(1, int(math.round(arrWidth)))
    int   shaftWb = math.max(1, int(math.round(arrWidth * 0.4)))
    float yShaft  = isTop ? px + slen  : px - slen
    float yHead   = isTop ? px + headH : px - headH
    pts = array.new<chart.point>()
    array.push(pts, chart.point.from_index(bar,           px))
    array.push(pts, chart.point.from_index(bar - headWb,  yHead))
    array.push(pts, chart.point.from_index(bar - shaftWb, yHead))
    array.push(pts, chart.point.from_index(bar - shaftWb, yShaft))
    array.push(pts, chart.point.from_index(bar + shaftWb, yShaft))
    array.push(pts, chart.point.from_index(bar + shaftWb, yHead))
    array.push(pts, chart.point.from_index(bar + headWb,  yHead))
    polyline.new(pts, closed = true, xloc = xloc.bar_index, line_color = colA, fill_color = colA, line_width = 1)

// حالة الدرجة الصغيرة: لا تُرسم القمة/القاع إلا بعد تأكّدها (تتابُع + فعالية)
var float ldTopP   = na   // آخر قمة مرسومة (مؤكّدة)
var int   ldTopBar = na
var float ldBotP   = na   // آخر قاع مرسوم (مؤكّد)
var int   ldBotBar = na
var float candBotP = na   // أدنى قاع مرشّح منذ آخر قمة مرسومة (للصعود)
var int   candBotBar = na
var float candTopP = na   // أعلى قمة مرشّحة منذ آخر قاع مرسوم (للهبوط)
var int   candTopBar = na
var float ldAnyP   = na   // آخر نقطة مرسومة (لربط الخطوط)
var int   ldAnyBar = na
var int   ldType   = 0    // نوع آخر نقطة مرسومة: 1=قمة، -1=قاع، 0=لا شيء

// مخزن الأسهم الصغيرة المرسومة (لحذف ما يقع داخل التصحيح المتوسط)
var array<polyline> sArr  = array.new<polyline>()
var array<int>      sArrB = array.new<int>()

// يرسم سهماً صغيراً ويخزّنه — مع فرض التناوب (لا نقطتان من نفس النوع متتاليتين)
// يأخذ نوع آخر نقطة ويُعيد النوع الجديد (تفادياً لتعديل متغيّر عام داخل دالّة)
storeSArrow(bool isTop, float px, int bar, color colA, int lastType) =>
    if (isTop and lastType == 1) or ((not isTop) and lastType == -1)
        // نفس نوع آخر نقطة: استبدل السابق بالأبعد (احذفه)
        if array.size(sArr) > 0
            polyline.delete(array.last(sArr))
            array.pop(sArr)
            array.pop(sArrB)
    array.push(sArr, drawSArrow(isTop, px, bar, colA))
    array.push(sArrB, bar)
    isTop ? 1 : -1

// حدّ الموجة التاريخية المؤثّرة في السعر (يدوي/تلقائي) — يُحسب مبكراً ليُستخدم موحّداً
// طول الموجة التلقائي = من النقطة المتوسطة السابعة الأخيرة حتى الآن (الموجة ≈ آخر 7 تأرجحات متوسطة)
int autoLen = 150
if array.size(medBars) > 0
    int idxA = math.max(0, array.size(medBars) - 7)
    autoLen := bar_index - array.get(medBars, idxA) + 1
int wlen    = useHistN ? histBars : autoLen
wlen := math.min(math.min(math.max(wlen, 1), bar_index + 1), 4500)
int histLeft = bar_index - wlen + 1   // بداية الموجة الحالية
// تاريخ التاريخ: يدوي بعدد الشموع، أو تلقائياً بطول مساوٍ للموجة التاريخية قبلها مباشرةً
int hohLen  = useHohN ? hohBars : wlen
hohLen := math.min(math.min(math.max(hohLen, 1), math.max(histLeft, 1)), math.max(4900 - wlen, 1))
int hohLeft = math.max(histLeft - hohLen, 0)   // بداية تاريخ التاريخ

// اتجاه الدرجة الكبيرة = اتجاه خط ترند كامل الموجة التاريخية:
//   إن كانت قمّة الموجة أحدث من قاعها ⇒ صاعدة، والعكس ⇒ هابطة. (لا اشتقاق بالكسر)
//   ثبات (hysteresis): لا ينقلب إلا إذا اتّضح الفارق، تفادياً للتذبذب قرب التوازن.
int hbW = ta.highestbars(high, wlen)
int lbW = ta.lowestbars(low, wlen)
int rawBigDir = hbW > lbW ? 1 : -1
var int bigDir = 0
if bigDir == 0
    bigDir := rawBigDir
else if rawBigDir != bigDir and math.abs(hbW - lbW) > wlen * 0.1
    bigDir := rawBigDir

emitSmallTop = false
emitSmallBot = false
float sPx   = na
float sBHi  = na
float sBLo  = na
int   sBar  = na
int   sTime = na

if barstate.isconfirmed
    body = math.abs(close - open)
    uw   = high - math.max(close, open)
    lw   = math.min(close, open) - low
    isValid = (not useValid) or (body > 0 and body > uw and body > lw)
    bear = close < open
    bull = close > open

    if sdir == 0
        sdir := 1
        curHi := high
        curHiBHi := math.max(open, close)
        curHiBLo := math.min(open, close)
        curHiBar := bar_index
        curHiTime := time
        curLo := low
        curLoBHi := math.max(open, close)
        curLoBLo := math.min(open, close)
        curLoBar := bar_index
        curLoTime := time
    else if sdir == 1
        // موجة صاعدة: القمة = أعلى سعر قبل التصحيح. التصحيح = شمعتان صحيحتان
        // كل واحدة قاعها أدنى من سابقتها (لا يُشترط تتابُعهما زمنياً؛ تُسمح فجوات).
        if high > curHi
            curHi := high
            curHiBHi := math.max(open, close)
            curHiBLo := math.min(open, close)
            curHiBar := bar_index
            curHiTime := time
            corr := 0
            corrRef := na
            corrPrevBHi := na
            corrPrevBLo := na
        else if isValid and bear
            float bHiC = math.max(open, close)
            float bLoC = math.min(open, close)
            if corr == 0
                corr := 1
                corrRef := low
                corrPrevBHi := bHiC
                corrPrevBLo := bLoC
            else if low < corrRef
                // فحص الابتلاع: لا تُحتسب إن ابتلع جسمها جسم السابقة أو العكس
                bool engulf = (bHiC >= corrPrevBHi and bLoC <= corrPrevBLo) or (corrPrevBHi >= bHiC and corrPrevBLo <= bLoC)
                if not engulf
                    corr := corr + 1
                    corrRef := low
                    corrPrevBHi := bHiC
                    corrPrevBLo := bLoC
            if corr >= minCorr
                emitSmallTop := true
                sPx := curHi
                sBHi := curHiBHi
                sBLo := curHiBLo
                sBar := curHiBar
                sTime := curHiTime
                sdir := -1
                curLo := low
                curLoBHi := math.max(open, close)
                curLoBLo := math.min(open, close)
                curLoBar := bar_index
                curLoTime := time
                corr := 0
                corrRef := na
                corrPrevBHi := na
                corrPrevBLo := na
    else
        // موجة هابطة: القاع = أدنى سعر قبل التصحيح. التصحيح = شمعتان صحيحتان
        // كل واحدة قمّتها أعلى من سابقتها (لا يُشترط تتابُعهما زمنياً).
        if low < curLo
            curLo := low
            curLoBHi := math.max(open, close)
            curLoBLo := math.min(open, close)
            curLoBar := bar_index
            curLoTime := time
            corr := 0
            corrRef := na
            corrPrevBHi := na
            corrPrevBLo := na
        else if isValid and bull
            float bHiC = math.max(open, close)
            float bLoC = math.min(open, close)
            if corr == 0
                corr := 1
                corrRef := high
                corrPrevBHi := bHiC
                corrPrevBLo := bLoC
            else if high > corrRef
                bool engulf = (bHiC >= corrPrevBHi and bLoC <= corrPrevBLo) or (corrPrevBHi >= bHiC and corrPrevBLo <= bLoC)
                if not engulf
                    corr := corr + 1
                    corrRef := high
                    corrPrevBHi := bHiC
                    corrPrevBLo := bLoC
            if corr >= minCorr
                emitSmallBot := true
                sPx := curLo
                sBHi := curLoBHi
                sBLo := curLoBLo
                sBar := curLoBar
                sTime := curLoTime
                sdir := 1
                curHi := high
                curHiBHi := math.max(open, close)
                curHiBLo := math.min(open, close)
                curHiBar := bar_index
                curHiTime := time
                corr := 0
                corrRef := na
                corrPrevBHi := na
                corrPrevBLo := na

    // عند تأكيد قمة/قاع صغيرة: لا تُرسم إلا بعد تأكّدها (تتابُع + فعالية) حسب اتجاه الموجة الكبيرة
    if emitSmallTop or emitSmallBot
        bool isTop = emitSmallTop
        bool up = bigDir == 1
        if showSmall
            if up
                // موجة صاعدة: القاع يتأكّد (ويُرسم) عند صناعة قمة أعلى؛ والقمة تُرسم معه
                if isTop
                    if na(ldTopP) or sPx > ldTopP
                        if not na(candBotP)
                            ldType := storeSArrow(false, candBotP, candBotBar, cBot, ldType)
                            if linkSmall and not na(ldAnyBar)
                                line.new(ldAnyBar, ldAnyP, candBotBar, candBotP, xloc = xloc.bar_index, color = cLineS, width = 1)
                            ldAnyP := candBotP
                            ldAnyBar := candBotBar
                            ldBotP := candBotP
                            ldBotBar := candBotBar
                        ldType := storeSArrow(true, sPx, sBar, cTop, ldType)
                        if linkSmall and not na(ldAnyBar)
                            line.new(ldAnyBar, ldAnyP, sBar, sPx, xloc = xloc.bar_index, color = cLineS, width = 1)
                        ldAnyP := sPx
                        ldAnyBar := sBar
                        ldTopP := sPx
                        ldTopBar := sBar
                        candBotP := na
                        candBotBar := na
                else
                    if na(candBotP) or sPx < candBotP
                        candBotP := sPx
                        candBotBar := sBar
            else
                // موجة هابطة: القمة تتأكّد (وتُرسم) عند صناعة قاع أدنى؛ والقاع يُرسم معها
                if not isTop
                    if na(ldBotP) or sPx < ldBotP
                        if not na(candTopP)
                            ldType := storeSArrow(true, candTopP, candTopBar, cTop, ldType)
                            if linkSmall and not na(ldAnyBar)
                                line.new(ldAnyBar, ldAnyP, candTopBar, candTopP, xloc = xloc.bar_index, color = cLineS, width = 1)
                            ldAnyP := candTopP
                            ldAnyBar := candTopBar
                            ldTopP := candTopP
                            ldTopBar := candTopBar
                        ldType := storeSArrow(false, sPx, sBar, cBot, ldType)
                        if linkSmall and not na(ldAnyBar)
                            line.new(ldAnyBar, ldAnyP, sBar, sPx, xloc = xloc.bar_index, color = cLineS, width = 1)
                        ldAnyP := sPx
                        ldAnyBar := sBar
                        ldBotP := sPx
                        ldBotBar := sBar
                        candTopP := na
                        candTopBar := na
                else
                    if na(candTopP) or sPx > candTopP
                        candTopP := sPx
                        candTopBar := sBar
        lastSmallP := sPx
        lastSmallBar := sBar
        // سيولة ومستوى الدرجة الصغيرة (قيمة المستوى = حافة الجسم المواجهة)
        float sLevel = isTop ? sBHi : sBLo
        updateDeg(memS, isTop, sPx, sLevel, sBar, bigDir, cLiqS, cLvlS, showLiq, showLvl)

        // --- الدرجة المتوسطة ---
        [emM, ePM, eBHiM, eBLoM, eTimeM, eBM, eTopM] = feed(pmed, sPx, sBHi, sBLo, sTime, sBar, isTop)
        if emM
            float levelM = eTopM ? eBHiM : eBLoM   // خط المستوى (قمة=أعلى الجسم، قاع=أسفل الجسم)
            label mlbl = na
            if showMed
                mlbl := label.new(eBM, ePM, "", xloc = xloc.bar_index, yloc = yloc.price,
                     style = label.style_circle, color = cMed, size = size.small)
            // خزّن النقطة المتوسطة (فعّالة مبدئياً)
            array.push(mcP, ePM)
            array.push(mcLvl, levelM)
            array.push(mcHi, eBHiM)
            array.push(mcLo, eBLoM)
            array.push(mcBar, eBM)
            array.push(mcTm, eTimeM)
            array.push(mcTop, eTopM)
            array.push(mcEff, true)
            array.push(mcLbl, mlbl)
            // (الفعالية تُحسب في نهاية الشارت حسب الفاصل histLeft: داخل الموجة التاريخية
            //  كل النقاط فعّالة برتقالية؛ وفي تاريخ التاريخ يُلوَّن المُغطّى أحمر.)
            // حدّ المخزن
            if array.size(mcP) > 80
                array.shift(mcP)
                array.shift(mcLvl)
                array.shift(mcHi)
                array.shift(mcLo)
                array.shift(mcBar)
                array.shift(mcTm)
                array.shift(mcTop)
                array.shift(mcEff)
                array.shift(mcLbl)
            if linkMed and not na(lastMedBar)
                line.new(lastMedBar, lastMedP, eBM, ePM, xloc = xloc.bar_index,
                     color = cLineM, width = 2)
            // نهاية تصحيح متوسط: أعد تأسيس مراجع الصغيرة من النقطة المتوسطة (موجة صغيرة جديدة).
            // (لا مسح يدوي بالنطاق — القوانين تمنع رسم ما يجب أن يُمسح أصلاً.)
            bool upW    = bigDir == 1
            bool corrEnd = (upW and not eTopM) or ((not upW) and eTopM)
            if corrEnd
                if upW
                    ldBotP := ePM
                    ldBotBar := eBM
                    ldTopP := na
                else
                    ldTopP := ePM
                    ldTopBar := eBM
                    ldBotP := na
                candBotP := na
                candBotBar := na
                candTopP := na
                candTopBar := na
                ldAnyP := ePM
                ldAnyBar := eBM
                ldType := 0
            lastMedP := ePM
            lastMedBar := eBM
            array.push(medBars, eBM)
            if array.size(medBars) > 20
                array.shift(medBars)
            // سيولة ومستوى الدرجة المتوسطة
            updateDeg(memM, eTopM, ePM, levelM, eBM, bigDir, cLiqM, cLvlM, showLiq, showLvl)

            // (المناطق تُبنى في نهاية الشارت من النقاط المتوسطة الفعّالة فقط — أسفل)


            // ملاحظة: الدرجة الكبيرة (الاتجاه) تُؤخذ من bigDir (ترند الموجة).
            //         بناء قمم/قيعان الكبيرة الصحيح (آخر 7 موجات، §07) يأتي لاحقاً —
            //         أُزيل اشتقاقها بالكسر لإنهاء التناقض المنهجي.

// ===================== حدود الموجة التاريخية ==============================
// • إذا أدخل المستخدم عدد شموع > 0: تُرسم الحدود على آخر هذا العدد من الشموع.
// • إذا تركه 0: تُحدَّد تلقائياً من الدرجة الكبيرة (من آخر موجة كبيرة حتى الآن).
var box   hbox = na
var label hlbl = na
float hwHi = ta.highest(high, wlen)
float hwLo = ta.lowest(low, wlen)
if showHist and barstate.islast
    if not na(hbox)
        box.delete(hbox)
    if not na(hlbl)
        label.delete(hlbl)
    int   hLeft   = histLeft
    color hBorder = color.new(color.rgb(184, 134, 11), 0)
    string hTxt   = useHistN ? "الموجة التاريخية (يدوي)" : "الموجة التاريخية (تلقائي)"
    hbox := box.new(hLeft, hwHi, bar_index, hwLo, border_color = hBorder, border_width = 2,
         bgcolor = cHist)
    hlbl := label.new(hLeft, hwHi, hTxt, xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_lower_right, color = hBorder, textcolor = color.white,
         size = size.small)

// حدود تاريخ التاريخ (الموجة الكبيرة السابقة مباشرةً)
var box   hohBox = na
var label hohLb  = na
if showHoh and barstate.islast and hohLeft < histLeft
    if not na(hohBox)
        box.delete(hohBox)
    if not na(hohLb)
        label.delete(hohLb)
    int   hohRight = math.max(histLeft - 1, hohLeft)
    float hohHi    = na
    float hohLo    = na
    for k = (bar_index - hohRight) to (bar_index - hohLeft)
        float hk = high[k]
        float lk = low[k]
        hohHi := na(hohHi) ? hk : math.max(hohHi, hk)
        hohLo := na(hohLo) ? lk : math.min(hohLo, lk)
    color hohBd    = color.new(color.gray, 0)
    string hohTxt  = useHohN ? "تاريخ التاريخ (يدوي)" : "تاريخ التاريخ (تلقائي)"
    if not na(hohHi)
        hohBox := box.new(hohLeft, hohHi, hohRight, hohLo, border_color = hohBd, border_width = 1,
             bgcolor = cHoh)
        hohLb := label.new(hohLeft, hohLo, hohTxt, xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_upper_right, color = hohBd, textcolor = color.white,
             size = size.small)

// ============== فعالية الدرجة المتوسطة (تُحسب نهايةً حسب الفاصل) ==============
// • داخل الموجة التاريخية (bar >= histLeft): كل النقاط فعّالة (برتقالية).
// • في تاريخ التاريخ (bar < histLeft): النقطة المُغطّاة بنقطة لاحقة تتجاوزها (قمة أعلى/قاع أدنى) ⇒ حمراء.
//   نطاق تاريخ التاريخ = موجة بطول مساوٍ للموجة التاريخية قبلها مباشرةً: [histLeft - wlen , histLeft - 1].
if barstate.islast
    int mm = array.size(mcP)
    if mm > 0
        for i = 0 to mm - 1
            int   bi = array.get(mcBar, i)
            bool  effI = true
            if bi < histLeft
                // نقطة تاريخ التاريخ: مُغطّاة؟ (نقطة لاحقة من نفس النوع تتجاوزها)
                bool tp = array.get(mcTop, i)
                float pv = array.get(mcP, i)
                bool covered = false
                for j = 0 to mm - 1
                    if array.get(mcBar, j) > bi and array.get(mcTop, j) == tp
                        if tp ? (array.get(mcP, j) > pv) : (array.get(mcP, j) < pv)
                            covered := true
                            break
                effI := bi >= hohLeft and not covered
            array.set(mcEff, i, effI)
            label li = array.get(mcLbl, i)
            if not na(li)
                label.set_color(li, effI ? cMed : cMedDead)


    if array.size(dispBoxes) > 0
        for i = 0 to array.size(dispBoxes) - 1
            box.delete(array.get(dispBoxes, i))
        array.clear(dispBoxes)
    float tol  = zoneTol * atrv
    int   rEdge = time + zoneExt * (1000 * timeframe.in_seconds(timeframe.period))
    int   m    = array.size(mcP)
    // ابنِ المناطق من النقاط المتوسطة الفعّالة فقط (برتقالية)، من جسم لجسم،
    // عدا «قمة مع قاعها» المتتالي، وأولوية الموجة الحالية (الشمعة ≥ histLeft).
    array<float> zT = array.new<float>()
    array<float> zB = array.new<float>()
    array<int>   zL = array.new<int>()
    if m > 0
        for i = 0 to m - 1
            if array.get(mcEff, i) and array.get(mcBar, i) >= histLeft
                float lvlI = array.get(mcLvl, i)
                int   barI = array.get(mcBar, i)
                int   bestJ = -1
                float bestD = tol
                for j = 0 to m - 1
                    if j != i and array.get(mcEff, j) and math.abs(j - i) > 1 and array.get(mcBar, j) >= histLeft
                        float d = math.abs(lvlI - array.get(mcLvl, j))
                        if d <= bestD
                            bestD := d
                            bestJ := j
                // كوّن المنطقة مرّة واحدة: عندما تكون i هي الطرف الأيسر
                if bestJ >= 0 and barI < array.get(mcBar, bestJ)
                    array.push(zT, math.max(array.get(mcHi, i), array.get(mcHi, bestJ)))
                    array.push(zB, math.min(array.get(mcLo, i), array.get(mcLo, bestJ)))
                    array.push(zL, math.min(array.get(mcTm, i), array.get(mcTm, bestJ)))
    int n = array.size(zT)
    if n > 0
        for side = 0 to 1
            array<int> used = array.new<int>()
            int picked = 0
            while picked < 3
                float bestDist = 1e18
                int   bestI    = -1
                for i = 0 to n - 1
                    float mid     = (array.get(zT, i) + array.get(zB, i)) / 2.0
                    bool  isAbove = mid >= close
                    bool  sideOk  = side == 0 ? isAbove : not isAbove
                    if sideOk and not array.includes(used, i)
                        float dist = math.abs(mid - close)
                        if dist < bestDist
                            bestDist := dist
                            bestI := i
                if bestI == -1
                    break
                array.push(used, bestI)
                box b = box.new(array.get(zL, bestI), array.get(zT, bestI), rEdge, array.get(zB, bestI),
                     xloc = xloc.bar_time, border_color = zoneBorder, bgcolor = zoneFill, border_width = 1)
                array.push(dispBoxes, b)
                picked := picked + 1

// ===================== الاستنتاجات وحالة السوق (لوحة) =====================
// تُقرأ من اتجاهات الدرجات وذاكرة السيولة:
//   • اتجاه السيولة = توافق الكبيرة + المتوسطة (تعارض ⇒ Range).
//   • الدخول المتاح = صديق الترند (صاعد⇒شراء فقط / هابط⇒بيع فقط / تعارض⇒الاثنان).
//   • قوة السيولة = هل دخل آخر قاع منطقة القمة السابقة (متوسطة) ⇒ ضعيفة.
//   • الحالة لكل درجة = صاعدة (مشاركة عامة) / هابطة (تصريف/هبوط).
f_dir(int d) => d == 1 ? "صاعد ▲" : d == -1 ? "هابط ▼" : "—"
f_state(int d) => d == 1 ? "مشاركة صاعدة" : d == -1 ? "تصريف/هبوط" : "—"

var table tbl = table.new(position.top_right, 2, 8, border_width = 1,
     border_color = color.new(color.gray, 60), frame_width = 1, frame_color = color.new(color.gray, 40))

if showPanel and barstate.islast
    bool bigUp = bigDir == 1
    bool medUp = pmed.dir == 1
    bool bigDn = bigDir == -1
    bool medDn = pmed.dir == -1
    // اتجاه الموجة التاريخية = اتجاه الدرجة الكبيرة
    string histDir = bigUp ? "صاعدة ▲" : bigDn ? "هابطة ▼" : "—"
    color  histCol = bigUp ? color.new(#2E7D32, 0) : bigDn ? color.new(#C00000, 0) : color.new(#595959, 0)
    string liqDir = (bigUp and medUp) ? "صاعد" : (bigDn and medDn) ? "هابط" : "Range"
    color  liqCol = (bigUp and medUp) ? color.new(#2E7D32, 0) : (bigDn and medDn) ? color.new(#C00000, 0) : color.new(#C55A11, 0)
    string entry  = (bigUp and medUp) ? "شراء فقط" : (bigDn and medDn) ? "بيع فقط" : "شراء وبيع"
    bool strong = true
    if pmed.dir == 1 and not na(memM.lbP) and not na(memM.ptP)
        strong := memM.lbP > memM.ptP
    if pmed.dir == -1 and not na(memM.ltP) and not na(memM.pbP)
        strong := memM.ltP < memM.pbP
    string strTxt = strong ? "قوية" : "ضعيفة"
    color  hd  = color.new(#1F3A5F, 0)
    color  lt  = color.new(#EAF1F8, 0)
    table.cell(tbl, 0, 0, "اتجاه الموجة التاريخية", text_color = color.white, bgcolor = color.new(#B8860B, 0), text_size = size.small)
    table.cell(tbl, 1, 0, histDir,       text_color = color.white, bgcolor = histCol, text_size = size.small)
    table.cell(tbl, 0, 1, "اتجاه السيولة", text_color = color.white, bgcolor = hd, text_size = size.small)
    table.cell(tbl, 1, 1, liqDir,        text_color = color.white, bgcolor = liqCol, text_size = size.small)
    table.cell(tbl, 0, 2, "قوة السيولة",  text_color = color.white, bgcolor = hd, text_size = size.small)
    table.cell(tbl, 1, 2, strTxt,        text_color = color.white, bgcolor = strong ? color.new(#2E7D32, 0) : color.new(#C00000, 0), text_size = size.small)
    table.cell(tbl, 0, 3, "الدخول المتاح", text_color = color.white, bgcolor = hd, text_size = size.small)
    table.cell(tbl, 1, 3, entry,         text_color = #1F3A5F, bgcolor = lt, text_size = size.small)
    table.cell(tbl, 0, 4, "الدرجة",  text_color = color.white, bgcolor = hd, text_size = size.small)
    table.cell(tbl, 1, 4, "الاتجاه / الحالة", text_color = color.white, bgcolor = hd, text_size = size.small)
    table.cell(tbl, 0, 5, "الصغيرة",  text_color = #1F3A5F, bgcolor = lt, text_size = size.small)
    table.cell(tbl, 1, 5, f_dir(sdir) + " | " + f_state(sdir), text_color = #1F3A5F, bgcolor = lt, text_size = size.small)
    table.cell(tbl, 0, 6, "المتوسطة", text_color = #1F3A5F, bgcolor = lt, text_size = size.small)
    table.cell(tbl, 1, 6, f_dir(pmed.dir) + " | " + f_state(pmed.dir), text_color = #1F3A5F, bgcolor = lt, text_size = size.small)
    table.cell(tbl, 0, 7, "الكبيرة",  text_color = #1F3A5F, bgcolor = lt, text_size = size.small)
    table.cell(tbl, 1, 7, f_dir(bigDir) + " | " + f_state(bigDir), text_color = #1F3A5F, bgcolor = lt, text_size = size.small)

// ============================================================================
//  القسم الأخير القادم:
//
//  (هـ) إشارات الصفقات: عند تطابق منطقة + مرحلة (تجميع/تصريف) + تأكيد كسر آخر قمة/قاع
//                      بدرجة أصغر ⇒ إشارة دخول + وقف خلف القاع/القمة + هدف عند المنطقة
//                      التالية + تنبيه alert().
// ============================================================================
