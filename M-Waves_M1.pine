//@version=6
// ============================================================================
//  استراتيجية M-Waves — نواة المحرّك (المرحلة أ — الإصدار 0.1)
//  Engine nucleus: القمم والقيعان للدرجات الثلاث + قاعدة الشمعتين + الكسر
// ----------------------------------------------------------------------------
//  المنهج:
//   • الدرجة الصغيرة (أحمر/أخضر): تُكتشف بقاعدة «الشمعتين الصحيحتين» في التصحيح،
//     مع قانونَي التتابُع والفعالية (لا تُرسم النقطة إلا بعد تأكّدها).
//   • الدرجة المتوسطة (برتقالي): تُشتق من الصغيرة «بالكسر» (قاعدة الاستراتيجية).
//   • الدرجة الكبيرة (أزرق): قمم/قيعان تُشتقّ بالكسر من المتوسطة الفعّالة (الافتراضي)، وتخضع
//     لقانونَي الفعالية (التغطية + التتابُع) كالمتوسطة. الاتجاه من بنية الزرقاء.
//
//  هذا إصدار أوّلي للتحقّق مقابل تحليلك اليدوي. الأجزاء التقديرية المتبقّية (اختيار
//  الموجة التاريخية، والفريم) تُقارَب بمعاملات قابلة للضبط — لا تُطابَق 100%.
//
//  خريطة التوسعة:
//   [✓] خطوط السيولة            [✓] مستويات تحديد الاتجاه
//   [✓] الاستنتاجات وحالة السوق  [✓] المناطق (المستوى الثاني)
//   [ ] إشارات الصفقات (دخول/وقف/هدف)
// ============================================================================
indicator("M-Waves Engine v3.88.41", overlay = true, max_labels_count = 500, max_lines_count = 500, max_polylines_count = 100, max_boxes_count = 300, max_bars_back = 5000)

// ============================ Settings / الإعدادات ====================================
// ----- 🌐 Language -----
grpLang   = "🌐 Language / اللغة"
lang      = input.string("عربي", "Language / اللغة", options = ["عربي", "English"], group = grpLang)
f_t(string ar, string en) => lang == "English" ? en : ar   // chart text follows the language; input labels are static in Pine

// ----- ⚙️ Engine -----
grpEng  = "⚙️ Engine / المحرّك"
minCorr = input.int(2, "Correction candles to confirm pivot / شموع التصحيح للتأكيد", minval = 1, maxval = 5, group = grpEng,
     tooltip = "Strategy rule = two valid candles in the correction direction.\nقاعدة الاستراتيجية: شمعتان صحيحتان في اتجاه التصحيح.")
useValid = input.bool(true, "Require valid candle (body ≥ each wick) / اشتراط الشمعة الصحيحة", group = grpEng,
     tooltip = "Excludes noise candles (any wick longer than the body).\nيستبعد شمعة النويز: أيّ ذيل أطول من الجسم.")

// ----- 👁️ Display & Layers -----
grpShow   = "👁️ Display & Layers / الإظهار والطبقات"
showSmall = input.bool(true,  "Small pivots (red/green) / الصغيرة (أحمر/أخضر)", group = grpShow)
showMed   = input.bool(true,  "Medium degree (orange) / المتوسطة (برتقالي)",  group = grpShow)
showBig   = input.bool(true,  "Big degree (blue) / الكبيرة (أزرق)",      group = grpShow)
showPending = input.bool(true, "Pending circles (grey) / الدوائر المعلّقة (رماديّة)", group = grpShow)
showArrows = input.bool(true, "All small arrows / كل الأسهم الصغيرة", group = grpShow,
     tooltip = "Show/hide every small pivot arrow (connector lines keep their own toggle).\nإظهار/إخفاء كل الأسهم الصغيرة (الخطوط الواصلة بمفتاحها).")
linkSmall = input.bool(true,  "Link small pivots / وصل الصغيرة بخطوط", group = grpShow)
linkMed   = input.bool(true,  "Link medium pivots / وصل المتوسطة بخطوط", group = grpShow)
linkBig   = input.bool(true,  "Link big pivots / وصل الكبيرة بخطوط",  group = grpShow)
showOpp    = input.bool(true, "Opportunity & entry signals / إشارات الفرص والدخول", group = grpShow)
showOppWaiting = input.bool(true, "Unconfirmed signals (waiting/high-risk/small) / الفرص غير المؤكّدة", group = grpShow)
drawWaves = input.int(3, "Drawn waves (performance) / عدد الموجات المرسومة", minval = 1, maxval = 20, group = grpShow,
     tooltip = "Small/medium pivots and signals draw on the last N waves only; older still feed state. (Blue stays 7.)\nترسم آخر N موجة فقط؛ الأقدم يُحسب دون رسم. (الكبيرة تبقى 7.)")

// ----- 📐 Sizes & Shapes -----
grpArr    = "📐 Sizes & Shapes / الأحجام والأشكال"
medCircleSize = input.string("Small", "Medium circle size / حجم دائرة المتوسطة", options = ["Fine","Small","Normal","Large","Huge"], group = grpArr,
     tooltip = "Native TradingView circle size (5 fixed steps).\nحجم الدائرة الأصلية (5 مستويات ثابتة).")
bigCircleSize = input.string("Normal", "Big circle size / حجم دائرة الكبيرة",  options = ["Fine","Small","Normal","Large","Huge"], group = grpArr)
arrLenAtr = input.float(0.4, "Arrow length (× ATR) / طول السهم", minval = 0.1, step = 0.1, group = grpArr,
     tooltip = "Close to TradingView's standard arrow size; raise/lower to fit your symbol.\nمقارب لحجم سهم TradingView القياسي.")
arrWidth  = input.int(2, "Arrow width (candles) / عرض السهم", minval = 1, maxval = 10, group = grpArr,
     tooltip = "Arrow-head width in candles (1 = one candle).\nعرض رأس السهم بالشموع (1 = شمعة).")

// ----- 🎨 Colors (grouped by degree: small · medium · big · pending) -----
grpCol = "🎨 Colors / الألوان"
cTop   = input.color(#F23645, "Small top arrow / سهم القمة (صغيرة)",  group = grpCol)
cBot   = input.color(#089981, "Small bottom arrow / سهم القاع (صغيرة)",  group = grpCol)
cLineS = input.color(color.new(color.gray, 55), "Small line / خط الصغيرة",  group = grpCol)
cLiqS = input.color(#C00000, "Small liquidity / سيولة الصغيرة",  group = grpCol)
cLvlS = input.color(#C00000, "Small level / مستوى الصغيرة", group = grpCol)
cMed   = input.color(color.new(#C55A11, 45), "Medium fill (active) / تعبئة المتوسطة (فعّالة)",     group = grpCol)
cMedBorder = input.color(color.new(#5A2D08, 0), "Medium border / حدّ المتوسطة", group = grpCol)
cMedDead = input.color(color.new(#C00000, 45), "Medium inactive fill / المتوسطة غير الفعّالة", group = grpCol)
cLineM = input.color(color.new(#C55A11, 35),    "Medium line / خط المتوسطة", group = grpCol)
cLiqM = input.color(#C55A11, "Medium liquidity / سيولة المتوسطة", group = grpCol)
cLvlM = input.color(#C55A11, "Medium level / مستوى المتوسطة", group = grpCol)
cBig   = input.color(color.new(#1F3A5F, 45), "Big fill (active) / تعبئة الكبيرة (فعّالة)", group = grpCol)
cBigBorder = input.color(color.new(#0E1B2E, 0), "Big border / حدّ الكبيرة", group = grpCol)
cBigDead = input.color(color.new(#C00000, 45), "Big inactive fill / الكبيرة غير الفعّالة", group = grpCol)
cLiqB = input.color(#1F3A5F, "Big liquidity / سيولة الكبيرة",  group = grpCol)
cLvlB = input.color(#1F3A5F, "Big level / مستوى الكبيرة", group = grpCol)
cPend    = input.color(color.new(#B2B5BE, 25), "Pending fill (grey) / تعبئة المعلّقة", group = grpCol)
cPendBordMed = input.color(#FFD700, "Pending medium border (yellow) / حدّ المعلّقة المتوسطة", group = grpCol)
cPendBordBig = input.color(#2962FF, "Pending big border (blue) / حدّ المعلّقة الكبيرة",  group = grpCol)

// ----- 🌊 Historical Wave -----
grpHist   = "🌊 Historical Wave / الموجة التاريخية"
showHist  = input.bool(true,  "Show historical wave bounds / حدود الموجة التاريخية", group = grpHist)
histAnchorBig = input.bool(false, "Widen working analysis to big wave / توسيع التحليل للموجة الكبيرة", group = grpHist,
     tooltip = "The drawn historical wave is ALWAYS the big wave now (lesson 03). This toggle also widens the WORKING analysis (effectiveness/zones/signals) to it. Off (default): working stays on the medium wave (lesson 09 renewal).\nالموجة المرسومة صارت دائمًا الكبيرة (الدرس 03). هذا المفتاح يوسّع أيضًا التحليل العامل (الفعالية/المناطق/الإشارات) إليها. مطفأ: التحليل يبقى على الموجة المتوسطة (تجدّد الدرس 09).")
useHistN  = input.bool(false, "Set wave by candle count / تحديد الموجة بعدد الشموع", group = grpHist,
     tooltip = "On: draw bounds over the last N candles. Off: auto from the big degree.\nمفعّل: آخر N شمعة. مطفأ: تلقائي من الكبيرة.")
histBars  = input.int(100, "Historical wave candles / عدد شموع الموجة", minval = 1, group = grpHist)
cHist     = input.color(color.new(#607D8B, 82), "Historical wave color / لون الموجة التاريخية", group = grpHist)
showHoh   = input.bool(true,  "Show prior-history bounds / حدود تاريخ التاريخ", group = grpHist)
useHohN   = input.bool(false, "Set prior-history by candle count / تحديد تاريخ التاريخ بعدد الشموع", group = grpHist,
     tooltip = "On: take N candles. Off: same length as the historical wave before it.\nمفعّل: N شمعة. مطفأ: بطول الموجة التاريخية قبله.")
hohBars   = input.int(100, "Prior-history candles / عدد شموع تاريخ التاريخ", minval = 1, group = grpHist)
hohMinRatio = input.float(0.618, "Prior-history size threshold (× wave amplitude) / حدّ حجم تاريخ التاريخ", minval = 0.1, maxval = 1.0, step = 0.05, group = grpHist,
     tooltip = "Prior-history = newest earlier big leg with amplitude ≥ this ratio of the historical wave. Default 0.618 (Fibonacci).\nتاريخ التاريخ = أحدث ساق كبيرة سابقة سعتها ≥ هذه النسبة.")
cHoh      = input.color(color.new(#808080, 88), "Prior-history color / لون تاريخ التاريخ", group = grpHist)

// ----- 💧 Liquidity & Levels -----
grpLiq  = "💧 Liquidity & Levels / السيولة والمستويات"
showLiq = input.bool(true, "Liquidity lines (on wicks) / خطوط السيولة (على الذيول)",      group = grpLiq)
showLvl = input.bool(true, "Trend levels (on bodies) / مستويات الاتجاه (على الأجسام)", group = grpLiq)
wSmall = input.int(2, "Small line width / عرض خطوط الصغيرة",  minval = 1, maxval = 8, group = grpLiq)
wMed   = input.int(2, "Medium line width / عرض خطوط المتوسطة", minval = 1, maxval = 8, group = grpLiq)
wBig   = input.int(3, "Big line width / عرض خطوط الكبيرة",  minval = 1, maxval = 8, group = grpLiq)
liqExtBars = input.int(24, "Liquidity extension past price (candles) / امتداد السيولة بعد السعر", minval = 0, group = grpLiq,
     tooltip = "Liquidity line reaches the current candle then extends N more (sloped). 0 = up to price only.\nيمتدّ N شمعة إضافية بالميل. 0 = حتى السعر.")
lvlExtBars = input.int(24, "Level extension past price (candles) / امتداد المستوى بعد السعر", minval = 0, group = grpLiq,
     tooltip = "Level line reaches the current candle then extends N more (horizontal). 0 = up to price only.\nيمتدّ N شمعة أفقياً. 0 = حتى السعر.")
keepBrokenLiq = input.bool(false, "Keep broken liquidity lines / الاحتفاظ بالسيولة المكسورة", group = grpLiq,
     tooltip = "On a liquidity break (half body) a frozen copy stays at the break point instead of being deleted.\nعند الكسر يُجمَّد نسخة بدل الحذف.")
keepBrokenLvl = input.bool(false, "Keep broken trend levels / الاحتفاظ بالمستويات المكسورة", group = grpLiq,
     tooltip = "On a medium direction flip (2-candle level break) the old level is frozen instead of deleted.\nعند الانقلاب يُجمَّد المستوى القديم.")
brokenCol   = input.color(#787B86, "Broken line color / لون الخطوط المكسورة", group = grpLiq)
brokenWidth = input.int(1, "Broken line width / عرض الخطوط المكسورة", minval = 1, maxval = 5, group = grpLiq)

// ----- 🟦 Zones -----
grpZone    = "🟦 Zones / المناطق"
showZones  = input.bool(true, "Show zones module / إظهار وحدة المناطق", group = grpZone)
showZoneLevels = input.bool(true, "Show M.A level lines / خطوط مستويات M.A", group = grpZone)
applySeqAct    = input.bool(true, "Apply sequence/effectiveness laws / تطبيق التتابُع والفعالية", group = grpZone, tooltip = "ON = strict per lesson 06/07 (cleaner, fewer zones & signals). OFF = coverage + positional only (more zones & signals). / مفعّل = صارم بالدرس 06/07 (مناطق وإشارات أنقى وأقلّ)؛ مطفأ = تغطية + موضعيّة فقط (مناطق وإشارات أكثر).")
zoneAutoBox = input.bool(true, "Show zone boxes / مستطيلات المناطق", group = grpZone,
     tooltip = "Draws a zone between each pair of nearby levels (nearest + consume + no-containment).\nمستطيل بين كل زوج مستويين متقاربين.")
zoneExt    = input.int(0, "Extension past price (candles) / امتداد بعد السعر", minval = 0, group = grpZone,
     tooltip = "Levels/zones extend to the current price by default (0).\nتمتدّ حتى السعر افتراضياً (0).")
zoneLvlCol = input.color(color.new(#D1D4DC, 0), "M.A level line color / لون خطوط م.A", group = grpZone)
zoneFill   = input.color(color.new(#2E75B6, 72), "Zone box fill / تعبئة المستطيل", group = grpZone)
zoneBorder = input.color(color.new(#2E75B6, 35), "Zone box border / حدّ المستطيل",   group = grpZone)

// ----- 🔄 Structural Renewal -----
grpRenew   = "🔄 Structural Renewal / التجدّد البنيوي"
useRenewal = input.bool(true, "Liquidity renewal (clear on 2-candle break, wait two points) / تجدّد السيولة", group = grpRenew)

// ----- 🧭 Conclusions Panel -----
grpConc   = "🧭 Conclusions Panel / لوحة الاستنتاجات"
showPanel = input.bool(true, "Conclusions & status panel / لوحة الاستنتاجات والحالة", group = grpConc)
panelPos  = input.string("Top R", "Panel position / موضع اللوحة", group = grpConc,
     options = ["Top L","Top C","Top R","Mid L","Center","Mid R","Bot L","Bot C","Bot R"],
     tooltip = "Pick the panel position (Pine has no mouse drag).\nاختر الموضع (Pine لا يدعم السحب).")
panelBg   = input.color(#1E222D, "Panel background (transparency from picker) / خلفية اللوحة", group = grpConc)
liqTol    = input.float(0.0, "Liquidity-strength penetration tolerance / سماحيّة اختراق قوّة السيولة", minval = 0.0, step = 0.05, group = grpConc,
     tooltip = "How far the correction may pierce the prior peak/trough and still count as a 'touch' (Strong). 0 = boundary exactly at the level (any close beyond ⇒ Weak).\nكم يُغتفر للتصحيح أن يخترق القمّة/القاع السابق ويبقى «ملامسة» (قويّة). 0 = الحدّ عند المستوى تمامًا (أيّ تجاوز ⇒ ضعيفة).")

// ----- 🎯 Trade Management -----
grpManage    = "🎯 Trade Management / إدارة الصفقات"
enableManage = input.bool(true, "Enable management (trailing stop + trade row) / تفعيل الإدارة", group = grpManage)
mgStopPts    = input.float(0.0, "Stop buffer behind last pivot (price, 0=auto) / هامش الوقف", minval = 0.0, step = 0.1, group = grpManage,
     tooltip = "If > 0: stop = last low − value (buy) / last high + value (sell). If 0: auto buffer from the degree.\nإن>0: الوقف بهذا الهامش. إن=0: هامش تلقائي.")
mgTgtPts     = input.float(0.0, "Target offset before zone (price, 0=zone edge) / تقريب الهدف", minval = 0.0, step = 0.1, group = grpManage,
     tooltip = "Take profit this far before the next zone edge to ensure fill. 0 = exact zone edge.\nجني الربح قبل الحافّة بهذه المسافة. 0 = الحافّة تماماً.")
bufMult    = input.float(0.5, "Stop/invalidation buffer (× small amplitude) / هامش الوقف/الإبطال", minval = 0.1, maxval = 2.0, step = 0.1, group = grpManage,
     tooltip = "Stop = zone edge ∓ buffer; invalidation = clear support/resistance break (not a mere touch). Buffer = ratio × last small swing.\nالهامش = هذه النسبة × آخر تأرجح صغير.")
colBasicBuy  = input.color(#089981,                 "Basic Buy color (green) / لون شراء أساسي",                group = grpManage)
colHRBuy     = input.color(color.new(#089981, 60),  "High-risk Buy color / لون شراء عالي المخاطرة", group = grpManage)
colBasicSell = input.color(#F23645,                 "Basic Sell color (red) / لون بيع أساسي",                 group = grpManage)
colHRSell    = input.color(color.new(#F23645, 60),  "High-risk Sell color / لون بيع عالي المخاطرة",  group = grpManage)

// ----- 📈 Big Degree (advanced) -----
grpBig    = "📈 Big Degree (advanced) / الدرجة الكبيرة (متقدّم)"
useBigBreak  = input.bool(true, "Extract big by break (from active medium) / استخراج الكبيرة بالكسر", group = grpBig,
     tooltip = "Blue pivots derived by the break mechanism from active medium points; direction from blue structure.\nتُشتقّ الزرقاء بالكسر من المتوسطة الفعّالة.")
bigMinSwings = input.int(2, "Min medium points in big wave / أدنى نقاط متوسطة", minval = 1, maxval = 10, group = grpBig,
     tooltip = "Helper filter (auto): fewest medium points to count a move as a big wave.\nفلتر مساعد: أقل عدد نقاط متوسطة.")
bigMinATR    = input.float(3.0, "Min big-wave size (× ATR) / أدنى حجم", minval = 0.0, step = 0.5, group = grpBig,
     tooltip = "Helper filter: 0 = disabled.\nفلتر مساعد: 0 = تعطيل.")
bigMinBars   = input.int(30, "Min big-wave time (candles) / أدنى زمن", minval = 0, group = grpBig,
     tooltip = "Helper filter: 0 = disabled.\nفلتر مساعد: 0 = تعطيل.")
bigLegs      = input.int(7, "Candidate big waves / عدد الموجات الكبيرة المرشّحة", minval = 2, maxval = 15, group = grpBig)

// ----- 🧪 Wave Test panel -----
grpFH      = "🧪 Wave Test / لوحة اختبار الموجة"
showFrameHelper = input.bool(true, "Wave-test panel (wave time ⇒ trading type) / لوحة اختبار الموجة", group = grpFH)
fhPos      = input.string("Top L", "Wave-test panel position / موضع اللوحة", group = grpFH,
     options = ["Top L","Top C","Top R","Mid L","Center","Mid R","Bot L","Bot C","Bot R"],
     tooltip = "Pick the panel position (Pine has no mouse drag).\nاختر الموضع (Pine لا يدعم السحب).")
swingMinDays = input.float(2.0, "Swing lower bound (days/impulse) — below = Scalp / حدّ السوينغ الأدنى", minval = 0.1, step = 0.5, group = grpFH,
     tooltip = "Median impulse-wave time below this ⇒ short wave (scalp) ⇒ move up a timeframe.\nأقلّ من هذا ⇒ مضاربة ⇒ اصعد فريماً.")
swingMaxDays = input.float(10.0, "Swing upper bound (days/impulse) — above = Invest / حدّ السوينغ الأعلى", minval = 0.5, step = 0.5, group = grpFH,
     tooltip = "Median impulse-wave time above this ⇒ invest ⇒ drop a timeframe for swing.\nأكثر من هذا ⇒ استثمار ⇒ انزل فريماً.")
fhBg       = input.color(#1E222D, "Panel background / خلفية اللوحة", group = grpFH)

// ----- 🔬 Fourth Degree (confirmation) -----
grpD4      = "🔬 Fourth Degree / الدرجة الرابعة"
enableD4   = input.bool(true, "Enable fourth-degree confirmation (smaller TF) / تفعيل الدرجة الرابعة", group = grpD4,
     tooltip = "Confirms small trades only via a last-pivot break on a smaller timeframe. No liquidity/zones/phases.\nيؤكّد الصغيرة فقط عبر كسر على فريم أصغر.")
d4Auto     = input.bool(true, "Auto 4th-degree TF (from chart ≈ ÷12) / فريم الرابعة تلقائيّ", group = grpD4, tooltip = "ON: auto-pick the smaller TF from the chart TF (≈ chart÷12 ⇒ ~5m for 1H), no manual input. OFF: use the manual TF below.\nمفعّل: يختار الفريم الأصغر تلقائيًّا من فريم الشارت (≈ الشارت÷12 ⇒ ~5د للساعة) بلا تدخّل. مطفأ: استعمل الفريم اليدويّ أدناه.")
d4tf       = input.timeframe("5", "Manual 4th-degree TF (when Auto off) / فريم الرابعة اليدويّ", group = grpD4)

// ===== 🌊 إليوت/فيبو (طبقة وصفيّة مستقلّة عن M-Waves) — ثلاث مجموعات فرعيّة =====
grpWave    = "🌊 إليوت/فيبو · ① الترقيم"
showWaveCount      = input.bool(false, "Wave-count labels (Elliott/Dow) / ترقيم الموجات", group = grpWave, tooltip = "Descriptive overlay derived from existing effective pivots + phase. Does NOT affect signals/strategy.\nطبقة وصفيّة مشتقّة من نقاطك الفعّالة + المرحلة. لا تمسّ الإشارات/الاستراتيجية.")
showWaveCountSmall = input.bool(false, "  • Small / الصغيرة", group = grpWave)
showWaveCountMed   = input.bool(false, "  • Medium / المتوسطة", group = grpWave)
showWaveCountBig   = input.bool(true,  "  • Big / الكبيرة (نبدأ بها)", group = grpWave)
waveLblColMed      = input.color(#C55A11, "Label color: Medium / لون المتوسطة", group = grpWave)
waveLblColSmall    = input.color(#F23645, "Label color: Small / لون الصغيرة", group = grpWave)
waveLblColBig      = input.color(#1F3A5F, "Label color: Big / لون الكبيرة", group = grpWave)
waveLblSize        = input.string("Normal", "Label size / حجم الوسم", options = ["Tiny","Small","Normal"], group = grpWave)
waveUpBig    = input.float(1.6, "Big: raise above peak (×ATR) / الكبيرة: رفع فوق القمّة",  minval = 0.0, step = 0.1, group = grpWave)
waveDnBig    = input.float(2.2, "Big: lower below trough (×ATR) / الكبيرة: خفض تحت القاع", minval = 0.0, step = 0.1, group = grpWave)
waveUpMed    = input.float(1.5, "Medium: raise / المتوسطة: رفع",  minval = 0.0, step = 0.1, group = grpWave)
waveDnMed    = input.float(1.6, "Medium: lower / المتوسطة: خفض",  minval = 0.0, step = 0.1, group = grpWave)
waveUpSmall  = input.float(1.0, "Small: raise / الصغيرة: رفع",    minval = 0.0, step = 0.1, group = grpWave)
waveDnSmall  = input.float(1.3, "Small: lower / الصغيرة: خفض",    minval = 0.0, step = 0.1, group = grpWave)
maxWaveSets  = input.int(2, "Max wave-sets per degree (0=all) / أقصى دفعات لكلّ درجة (0=الكلّ)", minval = 0, group = grpWave, tooltip = "Show only the latest N impulse+abc sets per degree (reduces clutter, esp. small).\nيعرض آخر N دفعة فقط لكلّ درجة (يقلّل الزحام، خاصّةً الصغيرة).")
wcMaxPivots  = input.int(60, "Scan only last N pivots (perf) / امسح آخر N نقطة فقط (أداء)", minval = 12, maxval = 500, group = grpWave, tooltip = "Wave-count & Fibonacci scan only the most recent N pivots per degree instead of all history — fixes CPU-time errors. Lower = faster.\nالترقيم والفيبو يمسحان آخر N نقطة فقط لكلّ درجة بدل كلّ التاريخ — يحلّ خطأ CPU. الأقلّ = أسرع.")
useWaveValidation  = input.bool(false, "Elliott validation rules (! + tooltip) / قواعد التحقّق إليوت", group = grpWave, tooltip = "Wave 2/3/4 rules ⇒ ! mark + reason in tooltip.\nقواعد الموجة 2/3/4 ⇒ علامة ! + السبب في Tooltip.")

// ----- الفيبو (رسم) + الإشارات ✦ -----
grpFib       = "🌊 إليوت/فيبو · ② الفيبو (رسم)"
grpFibSig    = "🌊 إليوت/فيبو · ③ الإشارات ✦"
showFib        = input.bool(false, "Fibonacci levels (on last impulse) / فيبوناتشي (على آخر دفعة)", group = grpFib, tooltip = "Retracement of wave 1 ⇒ wave-2 entry zone (0.5/0.618). Drawn on the last detected impulse.\nارتداد الموجة 1 ⇒ منطقة دخول الموجة 2. على آخر دفعة مكتشَفة.")
// تحكّم مستقلّ لكلّ (درجة × نوع): الارتداد (منقّط) والامتداد (متقطّع) لكلّ درجة على حدة
fibRetrBig   = input.bool(false, "Retracement • Big / ارتداد • الكبيرة",     group = grpFib)
fibRetrMed   = input.bool(true,  "Retracement • Medium / ارتداد • المتوسطة", group = grpFib)
fibRetrSmall = input.bool(false, "Retracement • Small / ارتداد • الصغيرة",   group = grpFib)
fibExtBig    = input.bool(false, "Extension • Big / امتداد • الكبيرة",       group = grpFib)
fibExtMed    = input.bool(false, "Extension • Medium / امتداد • المتوسطة",   group = grpFib)
fibExtSmall  = input.bool(false, "Extension • Small / امتداد • الصغيرة",     group = grpFib)
fibColBig      = input.color(#2962FF, "Fib color: Big / لون الكبيرة", group = grpFib)
fibColMed      = input.color(#C55A11, "Fib color: Medium / لون المتوسطة", group = grpFib)
fibColSmall    = input.color(#F23645, "Fib color: Small / لون الصغيرة", group = grpFib)
showFibConfluence = input.bool(true, "Confluence ☆ with next zone / تقاطُع ☆ مع المنطقة", group = grpFib, tooltip = "Marks a fib level that coincides (within tolerance) with an effective M-Waves zone level ⇒ ☆ + brighter/thicker line. Strengthens the existing M-Waves signal (no new trade).\nيميّز مستوى فيبو يتطابق (ضمن هامش) مع مستوى منطقة M-Waves فعّال ⇒ ☆ + خطّ أوضح/أسمك. يقوّي إشارة M-Waves القائمة (لا صفقة جديدة).")
fibConflTol    = input.float(0.30, "Confluence tolerance (×ATR) / هامش التقاطُع", minval = 0.05, maxval = 2.0, step = 0.05, group = grpFib)
fibStandaloneSignals = input.bool(false, "Standalone fib signals ✦ (isolated) / إشارات فيبو مستقلّة ✦", group = grpFibSig, tooltip = "Independent fib-based entry signals (✦), separate from M-Waves trades. Off by default.\nإشارات دخول مستقلّة مبنيّة على الفيبو (✦)، منفصلة عن صفقات M-Waves. مطفأ افتراضيًّا.")
fibSigBig      = input.bool(false, "  ✦ signals • Big / إشارات • الكبيرة",     group = grpFibSig)
fibSigMed      = input.bool(true,  "  ✦ signals • Medium / إشارات • المتوسطة", group = grpFibSig)
fibSigSmall    = input.bool(false, "  ✦ signals • Small / إشارات • الصغيرة",   group = grpFibSig)
fibSigConfluentOnly = input.bool(false, "Confluence-only ☆ (in M-Waves zone) / التقاطُع فقط ☆ (داخل منطقة)", group = grpFibSig, tooltip = "On ⇒ fire a ✦ signal only when its entry is inside an M-Waves zone (fib + zone agree = strongest). Off by default.\nمفعّل ⇒ لا يُطلِق إشارة إلّا إن كان دخولها داخل منطقة M-Waves (فيبو + منطقة يتّفقان = أقوى). مطفأ افتراضيًّا.")
fibSigMinWave  = input.float(1.0, "Min wave-1 size (×ATR) / أدنى حجم الموجة 1", minval = 0.0, step = 0.1, group = grpFibSig, tooltip = "Ignore signals whose wave-1 is smaller than this (×ATR) — cuts tiny-wave noise.\nيتجاهل الإشارات التي موجتها 1 أصغر من هذا (×ATR) — يحذف ضجيج الموجات الصغيرة.")
fibSigMinRR    = input.float(1.0, "Min R:R for ✦ signals / أدنى R:R للإشارة", minval = 0.0, step = 0.1, group = grpFibSig, tooltip = "Hide signals whose reward:risk is below this (cuts choppy/range noise). 1.0 = reward ≥ risk.\nيُخفي الإشارات التي عائدها/مخاطرتها أقلّ من هذا. 1.0 = العائد ≥ المخاطرة.")
fibSigKeepOld  = input.bool(false, "Keep old ✦ signals / الاحتفاظ بالإشارات القديمة", group = grpFibSig, tooltip = "Off ⇒ keep only the latest 6 signals. On ⇒ keep all.\nمطفأ ⇒ آخر 6 فقط. مفعّل ⇒ الكلّ.")
fibSigColBuy   = input.color(#7E57C2, "Fib signal Buy color / لون شراء فيبو", group = grpFibSig)
fibSigColSell  = input.color(#AB47BC, "Fib signal Sell color / لون بيع فيبو", group = grpFibSig)

// ----- 🛠️ Diagnostics (temporary) -----
grpDiag    = "🛠️ Diagnostics / تشخيص (مؤقّت)"
showEffTable = input.bool(false, "Effectiveness table (why active/inactive + M.A) / جدول الفعالية", group = grpDiag)
showDerivTable = input.bool(false, "Derivation table (small→medium→big) / جدول الاشتقاق", group = grpDiag)
diagBigWaves = input.int(3, "Big waves in diagnostic tables / عدد الموجات في الجداول", minval = 1, maxval = 10, group = grpDiag,
     tooltip = "1 = current wave only; 3 = last 3 big waves (hides small points in the derivation table).\n1 = الحالية فقط؛ 3 = آخر 3 موجات.")

// ----- helper functions (size/color/position mapping) -----
f_dark(color c) => color.rgb(color.r(c) * 0.5, color.g(c) * 0.5, color.b(c) * 0.5)   // darker solid border from a degree color
f_lblSize(string s)   => s == "Fine" ? size.tiny : s == "Small" ? size.small : s == "Large" ? size.large : s == "Huge" ? size.huge : size.normal
f_lblSizeIn(string s) => s == "Huge" ? size.large : s == "Large" ? size.normal : s == "Normal" ? size.small : size.tiny


// ====================== أداة: معالج الدرجة الأعلى ===========================
// يستقبل قمم/قيعان درجةٍ ما، ويُخرج قمم/قيعان الدرجة الأعلى عبر «كسر الهيكل»:
//   • في موجة صاعدة: كسر قاعٍ للأسفل ⇒ أعلى قمة قبله = قمة أعلى درجة.
//   • في موجة هابطة: كسر قمةٍ للأعلى ⇒ أدنى قاع قبله = قاع أعلى درجة.
type Proc
    int   dir        = 0
    float maxTopBHi  = na   // أعلى جسم القمة = max(open,close)
    float maxTopBLo  = na   // أسفل جسم القمة = min(open,close)
    int   maxTopBar  = na
    int   maxTopTime = na
    float maxTopP    = na   // ذيل القمة (high)
    float minBotBHi  = na   // أعلى جسم القاع
    float minBotBLo  = na   // أسفل جسم القاع
    int   minBotBar  = na
    int   minBotTime = na
    float minBotP    = na   // ذيل القاع (low)
    float prevTopP   = na
    float prevBotP   = na

// يُغذّى بنقطة (ذيل p، أعلى الجسم bHi، أسفل الجسم bLo، وقت t، شمعة b، isTop)
// يُعيد: [أُخرجت؟، الذيل، أعلى الجسم، أسفل الجسم، الوقت، الشمعة، أهي قمة؟]
feed(Proc s, float p, float bHi, float bLo, int t, int b, bool isTop) =>
    bool  emitted = false
    float eP      = na
    float eBHi    = na
    float eBLo    = na
    int   eTime   = na
    int   eB      = na
    bool  eTop    = false
    if isTop
        if s.dir == 0
            s.dir := 1
            s.maxTopP := p
            s.maxTopBHi := bHi
            s.maxTopBLo := bLo
            s.maxTopBar := b
            s.maxTopTime := t
        else if s.dir == 1
            if na(s.maxTopP) or p > s.maxTopP
                s.maxTopP := p
                s.maxTopBHi := bHi
                s.maxTopBLo := bLo
                s.maxTopBar := b
                s.maxTopTime := t
        else
            // موجة هابطة: قمة أعلى من سابقتها = كسر للأعلى ⇒ تأكيد قاع أعلى درجة
            if not na(s.prevTopP) and p > s.prevTopP
                emitted := true
                eP := s.minBotP
                eBHi := s.minBotBHi
                eBLo := s.minBotBLo
                eTime := s.minBotTime
                eB := s.minBotBar
                eTop := false
                s.dir := 1
                s.maxTopP := p
                s.maxTopBHi := bHi
                s.maxTopBLo := bLo
                s.maxTopBar := b
                s.maxTopTime := t
        s.prevTopP := p
    else
        if s.dir == 0
            s.dir := -1
            s.minBotP := p
            s.minBotBHi := bHi
            s.minBotBLo := bLo
            s.minBotBar := b
            s.minBotTime := t
        else if s.dir == -1
            if na(s.minBotP) or p < s.minBotP
                s.minBotP := p
                s.minBotBHi := bHi
                s.minBotBLo := bLo
                s.minBotBar := b
                s.minBotTime := t
        else
            // موجة صاعدة: قاع أدنى من سابقه = كسر للأسفل ⇒ تأكيد قمة أعلى درجة
            if not na(s.prevBotP) and p < s.prevBotP
                emitted := true
                eP := s.maxTopP
                eBHi := s.maxTopBHi
                eBLo := s.maxTopBLo
                eTime := s.maxTopTime
                eB := s.maxTopBar
                eTop := true
                s.dir := -1
                s.minBotP := p
                s.minBotBHi := bHi
                s.minBotBLo := bLo
                s.minBotBar := b
                s.minBotTime := t
        s.prevBotP := p
    [emitted, eP, eBHi, eBLo, eTime, eB, eTop]

// ============== ذاكرة الدرجة + رسم السيولة والمستويات ===================
// لكل درجة: نحفظ آخر قمتين/قاعين (ذيل + جسم + شمعة)، ثم:
//   • خط السيولة: يصل آخر قاعين (صعود) أو آخر قمتين (هبوط) على الذيول.
//   • مستوى الاتجاه: خط أفقي عند آخر قاع/قمة على الجسم.
type DegMem
    float ltP    = na
    float ltBody = na
    int   ltBar  = na
    float ptP    = na
    int   ptBar  = na
    float lbP    = na
    float lbBody = na
    int   lbBar  = na
    float pbP    = na
    int   pbBar  = na
    line  liq    = na
    line  lvl    = na

updateDeg(DegMem m, bool isTop, float wick, float body, int bar, int dir, color liqCol, color lvlCol, bool sLiq, bool sLvl, int waveStart, int liqExt, int lvlExt, float bandHi, float bandLo, int liqW, int lvlW) =>
    if isTop
        m.ptP := m.ltP
        m.ptBar := m.ltBar
        m.ltP := wick
        m.ltBody := body
        m.ltBar := bar
    else
        m.pbP := m.lbP
        m.pbBar := m.lbBar
        m.lbP := wick
        m.lbBody := body
        m.lbBar := bar
    if sLiq and not na(m.liq)        // [V3.6] لا تحذف إن كان الرسم مُدار خارجياً (المتوسطة: sLiq=false ⇒ تُدار في كتلة zoneEff)
        line.delete(m.liq)
        m.liq := na
    if sLvl and not na(m.lvl)
        line.delete(m.lvl)
        m.lvl := na
    // تجدّد: لا تُرسم السيولة إلا إذا كانت نقطتاها ضمن الموجة النشطة الحالية (bar >= waveStart).
    //   صعوداً: آخر قاعين؛ هبوطاً: آخر قمتين. وإلا تبقى ممسوحة حتى تتكوّن نقطتان جديدتان.
    if sLiq
        if dir == 1 and not na(m.lbP) and not na(m.pbP) and (na(waveStart) or (m.lbBar >= waveStart and m.pbBar >= waveStart))   // [v3.87.14] الدرس 08 حرفيًّا: «وصّل آخر قاعين» بلا شرط تصاعد (أُزيل m.lbP>m.pbP)
            float slU = m.lbBar != m.pbBar ? (m.lbP - m.pbP) / (m.lbBar - m.pbBar) : 0.0
            int   rbU = last_bar_index + liqExt
            // الامتداد يتبع liqExt فقط (لا قصّ بالنطاق) — مطابق للدرس؛ التكدّس يُحَلّ بـ Scale price chart only
            m.liq := line.new(m.pbBar, m.pbP, rbU, m.lbP + slU * (rbU - m.lbBar), xloc = xloc.bar_index, color = liqCol, width = liqW)
        if dir == -1 and not na(m.ltP) and not na(m.ptP) and (na(waveStart) or (m.ltBar >= waveStart and m.ptBar >= waveStart))   // [v3.87.14] الدرس 08 حرفيًّا: «وصّل آخر قمّتين» بلا شرط تنازل
            float slD = m.ltBar != m.ptBar ? (m.ltP - m.ptP) / (m.ltBar - m.ptBar) : 0.0
            int   rbD = last_bar_index + liqExt
            m.liq := line.new(m.ptBar, m.ptP, rbD, m.ltP + slD * (rbD - m.ltBar), xloc = xloc.bar_index, color = liqCol, width = liqW)
    if sLvl
        // مستوى الاتجاه = جسم آخر تطرّف في الاتجاه النشط (نقطة واحدة) — يظهر دائماً للاتجاه الحالي
        //   يمتدّ من نقطته حتى آخر شمعة بالشارت + lvlExt (لا شمعة الانبثاق) حتى يصل السعر الحالي.
        if dir == 1 and not na(m.lbBody)
            m.lvl := line.new(m.lbBar, m.lbBody, last_bar_index + lvlExt, m.lbBody, xloc = xloc.bar_index, color = lvlCol, width = lvlW, style = line.style_solid)
        if dir == -1 and not na(m.ltBody)
            m.lvl := line.new(m.ltBar, m.ltBody, last_bar_index + lvlExt, m.ltBody, xloc = xloc.bar_index, color = lvlCol, width = lvlW, style = line.style_solid)

// الاحتفاظ بالخطوط المكسورة: جمّد نسخة من الخط عند نقطة الكسر (بلا امتداد يمين)، بلون/نمط مميّز.
//   مشترك لكل الدرجات (السيولة/الاتجاه). سقف ضمن max_lines_count — حذف الأقدم عند التجاوز.
var array<line> brokenLines = array.new<line>()
var int medLiqBrkBar = na   // [V4.61] بار كسر خط السيولة المتوسط (نصف الجسم) ⇒ تجميد امتداد الخط عنده حتى يتجدّد ببنية جديدة
f_retainBroken(line src, int breakBar) =>
    if not na(src)
        line c = line.copy(src)
        line.set_xy2(c, breakBar, line.get_price(src, breakBar))
        line.set_color(c, brokenCol)
        line.set_width(c, brokenWidth)
        line.set_style(c, line.style_dotted)
        array.push(brokenLines, c)
        if array.size(brokenLines) > 100
            line.delete(array.shift(brokenLines))

// ===================== آلة المراحل العامة (لكل درجة على سيولتها) ==============
// منفصلة تماماً عن آلة الاتجاه. تُبنى على كسر خط سيولة نفس الدرجة (نصف الجسم للقراءة)،
// ثم تسلسل: مشاركة عامة ⇒ ذعر ⇒ (أول قاع/قمة) يأس ⇒ (كسر آخر امتداد) مشاركة جديدة.
type Phase
    int   code       = 0    // 0 مشاركة، 1 ذعر، 2 يأس، 3 تجميع، 4 تصريف
    int   brkDir     = 0    // -1 سياق صاعد كُسر هبوطاً، 1 سياق هابط كُسر صعوداً
    int   brkBar     = na
    float despairExt = na   // آخر نقطة retracement في اليأس/التجميع (كسرها = مشاركة جديدة)
    int   trendDir   = 0    // اتجاه الترند الحالي (لكشف التصريف داخل المشاركة)
    float partExt    = na   // ذروة المشاركة (أعلى قمة صعوداً / أدنى قاع هبوطاً)
    float despDeep   = na   // عمق اليأس (أدنى قاع صعوداً / أعلى قمة هبوطاً) — لبداية التجميع
    float brkLvl     = na   // [v3.84] مستوى السيولة **المجمَّد لحظة الكسر** — الاستئناف يُقاس عليه لا على الخطّ الحيّ المتحرّك (يقفز مع إعادة الإرساء) ⇒ لا استئناف مبكّر ولا ذعر عالق
    bool  passedDespair = false   // [V3.81] هل مرّ التصحيح الحاليّ باليأس(2)؟ ⇒ شرط الشراء/البيع الأساسيّ (الدورة كاملة: الذعر واليأس ثمّ التجميع)

// تحديث المرحلة لكل بار: كسر السيولة (نصف الجسم) ⇒ ذعر؛ كسر امتداد اليأس/التجميع ⇒ مشاركة جديدة
phaseOnBar(Phase p, int dir, float liqLvl, float c, float o) =>
    // [V3.80] الفجوة 3 (تماسك المرحلة ↔ الاتجاه): **انقلاب اتجاه الدرجة** ⇒ بداية مشاركة عامّة جديدة ⇒ أعِد المرحلة لـ0 (markup صعودًا / markdown هبوطًا)، لئلّا تبقى مرحلة تصحيح قديمة معاكسة للاتجاه («هابط | يأس» أو «صاعد | تجميع»). الدرس 11: بعد قلب الموجة تبدأ المشاركة الجديدة. يطبَّق على الدرجات الثلاث (نفس الدالّة).
    if dir != 0 and p.trendDir != 0 and dir != p.trendDir
        p.code := 0
        p.brkDir := 0
        p.despairExt := na
        p.partExt := na
        p.despDeep := na
        p.brkLvl := na   // [v3.84] قلب الاتجاه ⇒ كسر جديد سيضبط مستوًى جديدًا
    p.trendDir := dir
    float body = math.abs(c - o)
    if not na(liqLvl) and body > 0
        if dir == 1 and c < liqLvl and (liqLvl - c) > 0.5 * body and p.brkDir != -1
            p.brkDir := -1
            p.brkBar := bar_index
            p.code := 1
            p.despairExt := na
            p.partExt := na
            p.despDeep := na
            p.brkLvl := liqLvl   // [v3.84] جمّد مستوى الكسر (سياق صاعد كُسر هبوطاً)
        if dir == -1 and c > liqLvl and (c - liqLvl) > 0.5 * body and p.brkDir != 1
            p.brkDir := 1
            p.brkBar := bar_index
            p.code := 1
            p.despairExt := na
            p.partExt := na
            p.despDeep := na
            p.brkLvl := liqLvl   // [v3.84] جمّد مستوى الكسر (سياق هابط كُسر صعوداً)
    // [V3.79] اليأس per-bar (الدرس 11: «الذعر عند كسر السيولة وبعده اليأس»): بعد الذعر، تجاوز قاع/قمّة الذعر (despDeep) بنصف جسم ⇒ يأس فورًا (لا ننتظر النقطة المتأخّرة). يعمل في الموجتين: brkDir=-1 قيعان صعودًا · brkDir=1 قمم هبوطًا.
    if p.code == 1 and not na(p.despDeep) and body > 0
        if p.brkDir == -1 and c < p.despDeep and (p.despDeep - c) > 0.5 * body
            p.code := 2
            p.despDeep := c
        if p.brkDir == 1 and c > p.despDeep and (c - p.despDeep) > 0.5 * body
            p.code := 2
            p.despDeep := c
    // [V3.79] التصريف(قمة، صعود)/التجميع(قاع، هبوط) قبيل كسر السيولة per-bar (الدرس 11: «تجمّع علويّ/سفليّ قبيل كسر السيولة»): أثناء المشاركة، تراجع السعر من ذروة المشاركة (partExt) إلى النصف الأقرب للسيولة قبل كسرها ⇒ يظهر **قبل** الذعر (كان يُحجَب لأنّ القمّة المتأخّرة تُعالَج بعد ضبط الذعر code=1). يَرجع للمشاركة عند قمّة/قاع جديد (phaseOnPivot س435/438)، وللذعر عند الكسر (أعلاه).
    if p.code == 0 and not na(liqLvl) and not na(p.partExt)
        if dir == 1 and p.partExt > liqLvl and c > liqLvl and c < (liqLvl + p.partExt) * 0.5
            p.code := 4
        if dir == -1 and p.partExt < liqLvl and c < liqLvl and c > (liqLvl + p.partExt) * 0.5
            p.code := 3
    // [V3.82] استئناف المشاركة **من الذعر مباشرةً**: إن عاد السعر عبر خطّ السيولة لجهة الاتجاه (الارتداد التصحيحيّ فشل **بلا يأس**) ⇒ تستأنف المشاركة، لئلّا يبقى «ذعر» عالقًا بينما السعر عاد تحت/فوق السيولة. (الاستئناف أدناه يتطلّب despairExt المضبوط في اليأس فقط ⇒ الذعر بلا يأس كان يَعلَق.)
    if p.code == 1 and not na(p.brkLvl) and body > 0   // [v3.84] يُقاس على **مستوى الكسر المجمَّد** (p.brkLvl) لا الخطّ الحيّ liqLvl — فلا يقفز مع إعادة إرساء السيولة (يصلح الاستئناف المبكّر عند هبوط الخطّ والذعر العالق عند صعوده)
        if p.brkDir == -1 and c > p.brkLvl and (c - p.brkLvl) > 0.5 * body
            p.code := 0
            p.brkDir := 0
        if p.brkDir == 1 and c < p.brkLvl and (p.brkLvl - c) > 0.5 * body
            p.code := 0
            p.brkDir := 0
    // [V4.28] استئناف المشاركة = كسر آخر قمّة/قاع تصحيح **بنصف الجسم** (الدرس 11: «يقفل شمعة أكثر من نص جسمها فوق/تحت»)
    if (p.code == 2 or p.code == 3 or p.code == 4) and not na(p.despairExt)
        if p.brkDir == -1 and c > p.despairExt and (c - p.despairExt) > 0.5 * body
            p.code := 0
            p.brkDir := 0
            p.despairExt := na
            p.despDeep := na
            p.partExt := na
        if p.brkDir == 1 and c < p.despairExt and (p.despairExt - c) > 0.5 * body
            p.code := 0
            p.brkDir := 0
            p.despairExt := na
            p.despDeep := na
            p.partExt := na
    // [V3.81] تتبّع «مرّ التصحيح الحاليّ باليأس» (شرط الأساسيّ — الدرس: «الذعر واليأس ثمّ التجميع»). يُضبط بعد كلّ تحديثات المرحلة هذا البار (phaseOnBar يُنادى **بعد** phaseOnPivot ⇒ يرى code النهائيّ؛ انعكاس V يمرّ 1→2→3 في نداء phaseOnPivot واحد فيبقى code=3 ⇒ لا يُضبط).
    if p.code == 2
        p.passedDespair := true
    if p.code == 0 or p.code == 1
        p.passedDespair := false

// تحديث المرحلة عند انبثاق نقطة من نفس الدرجة
phaseOnPivot(Phase p, bool isTop, float pivP, int pivBar) =>
    // --- المشاركة(0): توقّف التقدّم ⇒ تصريف(قمة) صعوداً / تجميع(قاع) هبوطاً ---
    // القاعدة موضعية: قمة⇒تصريف، قاع⇒تجميع (لا تتبع اتجاه الموجة).
    if p.code == 0
        if p.trendDir == 1 and isTop
            if na(p.partExt) or pivP > p.partExt
                p.partExt := pivP            // قمة أعلى ⇒ ما زال مشاركة صاعدة
            else
                p.code := 4                  // قمة أدنى (إخفاق) ⇒ تصريف (قمة)
        if p.trendDir == -1 and not isTop
            if na(p.partExt) or pivP < p.partExt
                p.partExt := pivP            // قاع أدنى ⇒ ما زال مشاركة هابطة
            else
                p.code := 3                  // قاع أعلى (إخفاق) ⇒ تجميع (قاع)
    else if p.code == 4 and p.trendDir == 1 and isTop and not na(p.partExt) and pivP > p.partExt
        p.partExt := pivP
        p.code := 0                          // استئناف صنع قمة أعلى ⇒ عودة للمشاركة الصاعدة
    else if p.code == 3 and p.trendDir == -1 and not isTop and not na(p.partExt) and pivP < p.partExt
        p.partExt := pivP
        p.code := 0                          // استئناف صنع قاع أدنى ⇒ عودة للمشاركة الهابطة
    // --- الذعر(1): أول نقطة معاكسة = «قاع/قمة الزعر» تبقى ذعرًا؛ النقطة المعاكسة الثانية (الهبوط/الصعود
    //   الثاني بعد الارتداد الفاشل) ⇒ تدخل اليأس/الحلّ (الدرس 11). [V4.28] كان الكود يقفز لليأس عند الأولى.
    bool justYas = false
    if p.code == 1 and not na(p.brkBar) and pivBar > p.brkBar
        if (p.brkDir == -1 and not isTop) or (p.brkDir == 1 and isTop)
            if na(p.despDeep)
                p.despDeep := pivP        // قاع/قمة الزعر — يبقى ذعرًا (code 1) حتى الارتداد الفاشل
                justYas := true
            else
                p.code := 2               // نقطة معاكسة ثانية ⇒ مرّر البوّابة؛ الكتلة التالية تصنّف يأس/تجميع/تصريف
    // --- اليأس(2) ⇄ القاعدة/القمة: تجميع(قاع) سياق صاعد / تصريف(قمة) سياق هابط ---
    if (p.code == 2 or p.code == 3 or p.code == 4) and not justYas
        // النهاية: آخر نقطة retracement (كسرها = مشاركة جديدة) — تُتتبّع في كل الحالات
        if p.brkDir == -1 and isTop
            p.despairExt := pivP
        if p.brkDir == 1 and not isTop
            p.despairExt := pivP
        // العمق + الكشف الموضعي
        if p.brkDir == -1 and not isTop          // سياق صاعد مكسور: قيعان ⇒ تجميع
            if na(p.despDeep) or pivP < p.despDeep
                p.despDeep := pivP
                p.code := 2                      // قاع أدنى ⇒ يأس مستمرّ/انتكاس
            else
                p.code := 3                      // قاع أعلى ⇒ تجميع (قاع)
        if p.brkDir == 1 and isTop                // سياق هابط مكسور: قمم ⇒ تصريف
            if na(p.despDeep) or pivP > p.despDeep
                p.despDeep := pivP
                p.code := 2                      // قمة أعلى ⇒ يأس مستمرّ/انتكاس
            else
                p.code := 4                      // قمة أدنى ⇒ تصريف (قمة)

phaseText(Phase p, int dir) =>
    p.code == 1 ? f_t("ذعر","Panic") : p.code == 2 ? f_t("يأس","Despair") : p.code == 3 ? f_t("تجميع","Accumulation") : p.code == 4 ? f_t("تصريف","Distribution") : (dir == 1 ? f_t("مشاركة عامة صاعدة","Markup") : dir == -1 ? f_t("مشاركة عامة هابطة","Markdown") : "—")

// ===================== كسر السيولة البنيوي (شمعتان) — للتجدّد ==================
// منفصل تماماً عن المراحل (نصف الجسم). الكسر البنيوي = شمعتان متتاليتان مغلقتان خلف الخط:
//   صعوداً (سيولة على القيعان): شمعتان حمراوان (إغلاق<فتح) تحت الخط.
//   هبوطاً (سيولة على القمم):   شمعتان خضراوان (إغلاق>فتح) فوق الخط.
// عند تأكّده ⇒ يُسجَّل brkBar؛ ولا يُعاد رسم الخط إلا بنقطتين جديدتين بعده (gate في updateDeg).
type LiqBreak
    int cnt     = 0
    int brkBar  = na

// الكسر البنيويّ = شمعتان متتاليتان مغلقتان خلف الخط (الدرس 09 حرفيًّا: «شمعتان حمر تحت بعض» صعوداً —
//   مرآةً خضراوان فوقه هبوطاً). لا شرط جسم/ذيل للكسر (الدرس لا ينصّ عليه — قرار المستخدم: الالتزام الحرفيّ).
structuralBreak(LiqBreak lb, int dir, float liqLvl, float c, float o) =>
    bool justBroke = false
    if not na(liqLvl)
        if dir == 1
            lb.cnt := (c < o and c < liqLvl) ? lb.cnt + 1 : 0
            if lb.cnt >= 2
                lb.brkBar := bar_index
                lb.cnt := 0
                justBroke := true
        if dir == -1
            lb.cnt := (c > o and c > liqLvl) ? lb.cnt + 1 : 0
            if lb.cnt >= 2
                lb.brkBar := bar_index
                lb.cnt := 0
                justBroke := true
    justBroke

// ===================== الدرجة الرابعة (تأكيد الصفقات الصغيرة فقط) =============
// تُقرأ من فريم أصغر بـ«نفس منطق القمم/القيعان الصغيرة» (لا Fractal جارَين):
//   دفعة ⇒ تصحيح بشمعتين صحيحتين (جسم ≥ كل ذيل) مع تجاهل الابتلاع ⇒ تأكيد قمة/قاع.
//   تأكيد شراء صغير = كسر آخر قمة صحيحة في الهبوط. تأكيد بيع صغير = كسر آخر قاع صحيح في الصعود.
// لا سيولة/مناطق/مراحل لهذه الدرجة — تأكيد فقط. تُعيد: [كسر صاعد، كسر هابط، قاع الهبوط، قمة الصعود].
f_degree4() =>
    var int   dd    = 0
    var float dHi   = na
    var float dLo   = na
    var int   dcorr = 0
    var float dref  = na
    var float dpHi  = na
    var float dpLo  = na
    var float lastPH = na   // آخر قمة صحيحة (مؤكّدة) — تُكسر للأعلى ⇒ تأكيد شراء
    var float lastPL = na   // آخر قاع صحيح (مؤكّد) — يُكسر للأسفل ⇒ تأكيد بيع
    var int   lastPHt = na  // [V3.66] زمن تأكيد آخر قمّة (للحصر الزمنيّ ب — تأكيد الرابعة داخل الموجة الصغيرة فقط)
    var int   lastPLt = na  // [V3.66] زمن تأكيد آخر قاع
    float bdy = math.abs(close - open)
    float uw  = high - math.max(close, open)
    float lw  = math.min(close, open) - low
    bool  vld = bdy > 0 and bdy > uw and bdy > lw
    bool  br  = close < open
    bool  bl  = close > open
    if dd == 0
        dd := 1
        dHi := high
        dLo := low
    else if dd == 1
        if high > dHi
            dHi := high
            dcorr := 0
            dref := na
        else if vld and br
            float bHi = math.max(open, close)
            float bLo = math.min(open, close)
            if dcorr == 0
                dcorr := 1
                dref := low
                dpHi := bHi
                dpLo := bLo
            else if low < dref
                bool eng = (bHi >= dpHi and bLo <= dpLo) or (dpHi >= bHi and dpLo <= bLo)
                if not eng
                    dcorr := dcorr + 1
                    dref := low
                    dpHi := bHi
                    dpLo := bLo
            if dcorr >= 2
                lastPH := dHi              // قمة صحيحة مؤكّدة (بداية الهبوط)
                lastPHt := time            // [V3.66] زمن تأكيد القمّة
                dd := -1
                dLo := low
                dcorr := 0
                dref := na
    else
        if low < dLo
            dLo := low
            dcorr := 0
            dref := na
        else if vld and bl
            float bHi = math.max(open, close)
            float bLo = math.min(open, close)
            if dcorr == 0
                dcorr := 1
                dref := high
                dpHi := bHi
                dpLo := bLo
            else if high > dref
                bool eng = (bHi >= dpHi and bLo <= dpLo) or (dpHi >= bHi and dpLo <= bLo)
                if not eng
                    dcorr := dcorr + 1
                    dref := high
                    dpHi := bHi
                    dpLo := bLo
            if dcorr >= 2
                lastPL := dLo              // قاع صحيح مؤكّد (بداية الصعود)
                lastPLt := time            // [V3.66] زمن تأكيد القاع
                dd := 1
                dHi := high
                dcorr := 0
                dref := na
    bool brokeUp = not na(lastPH) and close > lastPH and close[1] <= lastPH   // كسر آخر قمة صحيحة
    bool brokeDn = not na(lastPL) and close < lastPL and close[1] >= lastPL   // كسر آخر قاع صحيح
    int brokenT = brokeUp ? lastPHt : brokeDn ? lastPLt : na   // [V3.66] زمن القمّة/القاع المكسور (للحصر الزمنيّ ب على الفريم الأصليّ)
    [brokeUp, brokeDn, brokenT]

// ===================== الدرجة الصغيرة: محرّك الشمعتين ========================
var int   sdir      = 0      // 1=نبحث عن قمة (موجة صاعدة)، -1=نبحث عن قاع
var float curHi     = na
var float curHiBHi  = na     // أعلى جسم شمعة القمة
var float curHiBLo  = na     // أسفل جسم شمعة القمة
var int   curHiBar  = na
var int   curHiTime = na
var float curLo     = na
var float curLoBHi  = na     // أعلى جسم شمعة القاع
var float curLoBLo  = na     // أسفل جسم شمعة القاع
var int   curLoBar  = na
var int   curLoTime = na
var int   corr      = 0      // عدّاد شموع التصحيح الصحيحة
var float corrRef   = na     // مرجع تدرّج التصحيح (أدنى/أعلى آخر شمعة مُحتسبة)
var float corrPrevBHi = na   // أعلى جسم آخر شمعة تصحيح مُحتسبة (لفحص الابتلاع)
var float corrPrevBLo = na   // أسفل جسمها

var Proc pmed = Proc.new()  // معالج المتوسطة (يُغذّى بالصغيرة)

var DegMem memS = DegMem.new()  // ذاكرة الصغيرة
var DegMem memM = DegMem.new()  // ذاكرة المتوسطة
var Proc   pbigPh = Proc.new()    // معالج مرحلة الكبيرة (يُغذّى بالمتوسطة بالكسر — للمرحلة فقط، مستقلّ عن useBigBreak)
var DegMem memBph = DegMem.new()  // ذاكرة نقاط الكبيرة للمرحلة (لا تُرسم ⇒ لا تكدّس)

var array<box>   dispBoxes = array.new<box>()   // الصناديق المعروضة حالياً (٦ كحدّ أقصى)
var array<line>  zoneLvls  = array.new<line>()   // خطوط مستويات المناطق (على الأجسام)

// لربط النقاط بخطوط
var float lastSmallP   = na
var int   lastSmallBar = na
var float lastMedP     = na
var int   lastMedBar   = na
var array<int> medBars = array.new<int>()   // شمع آخر النقاط المتوسطة (لطول الموجة التلقائي)
// مخزن دوائر المتوسطة (للفعالية: برتقالية فعّالة ← حمراء عند تغطيتها)
var array<float> mcP   = array.new<float>()   // سعر النقطة (الذيل)
var array<float> mcLvl = array.new<float>()   // قيمة المستوى (الجسم) للمناطق
var array<float> mcHi  = array.new<float>()   // أعلى الجسم
var array<float> mcLo  = array.new<float>()   // أسفل الجسم
var array<int>   mcBar = array.new<int>()
var array<int>   mcTm  = array.new<int>()
var array<bool>  mcTop = array.new<bool>()
var array<bool>  mcEff = array.new<bool>()    // فعّالة؟
var array<label> mcLbl = array.new<label>()
var array<label> mcLblO = array.new<label>()   // الحلقة الخارجية (الحدّ) للمتوسطة
// ===== طبقة وصول المناطق (Zone Access Layer) — واجهة الإشارات القادمة =====
//   كل منطقة لها حدود دقيقة (بداية/نهاية) تُستهلَك في الإشارات (inZone / f_nextZoneEdge):
//   • zTop/zBot = حافتا السعر (نهاية/بداية النطاق = الجسمان الفعّالان). المنفردة: zTop==zBot (خط m.A، لا عرض).
//   • zAnchor   = بار التأسيس = أحدث المصدرين (بداية صلاحية المنطقة زمنياً — اكتمال الزوج).
//   • zLeftTm   = زمن الحافة اليسرى للرسم. zSrcA/zSrcB = فهرسا المصدرين (mc). zIsHist = استعارة تاريخية؟
var array<float> zTop    = array.new<float>()
var array<float> zBot    = array.new<float>()
var array<int>   zAnchor = array.new<int>()
var array<int>   zSrcA   = array.new<int>()   //فهرس المستوى المصدر الأوّل لكل منطقة (mc index)
var array<int>   zSrcB   = array.new<int>()   //فهرس المستوى المصدر الثاني (== الأوّل للمنفردة)
var array<bool>  zIsHist = array.new<bool>()  //هل المنطقة من استعارة تاريخية (المرحلة 2)؟ (العبور مسموح فيها)
var array<int>   zLeftTm = array.new<int>()   // زمن الحافة اليسرى (لرسم المستطيل بـ bar_time)
var array<bool>  zoneEff = array.new<bool>()  // [V3] فعالية المتوسطة للمناطق — تُحسب طازجةً مُقيّدةً بالموجة كل تمريرة (تقود الرسم والتزويج)
// تشخيص الفعالية (1:1 مع mcP): نتيجة كل قانون على حدة — لجدول التحقّق
var array<bool>  dgCov = array.new<bool>()    // مُغطّى؟ (f_coveredIn)
var array<bool>  dgSeq = array.new<bool>()    // تتابُع؟ (f_seqEff)
var array<bool>  dgAct = array.new<bool>()    // فعالية؟ (f_activated)
var array<bool>  dgPend = array.new<bool>()   // معلّقة؟ (غير محدَّدة — لون مميّز، لا م.A)
var array<string> dgReason = array.new<string>()   // سبب الحُكم + المرجع (لجدول التشخيص)
// تخزين نقاط الصغيرة (للتشخيص الاشتقاقيّ: ترتيب صغيرة→متوسطة→كبيرة) — لا تُرسم، بيانات فقط
var array<float> dsP   = array.new<float>()
var array<int>   dsBar = array.new<int>()
var array<bool>  dsTop = array.new<bool>()
var array<int>   bluePivotBars = array.new<int>()   // بارات النقاط الزرقاء (الكبيرة) — تُستعمل خارج المناطق فقط (لا تخصيص للزرقاء في المناطق)
var array<float> bluePivotP    = array.new<float>() // [v3.88.7] أسعار النقاط الزرقاء — لتحديد اتجاه كلّ ساق كبيرة (دافعة/تصحيحيّة) في ترقيم الموجات
var array<bool>  bluePivotT    = array.new<bool>()  // [v3.88.9] أنواع النقاط الزرقاء (قمّة/قاع) — لترقيم الكبيرة البنيويّ
// ===== طبقة الوصول للقمم/القيعان (Pivot Access Layer) — لاعتماد الدروس القادمة بسهولة =====
//   • المتوسطة: mcP/mcLvl/mcBar/mcTm/mcTop + mcEff (فعّالة؟) — global، تُملأ تزايُدياً per-bar.
//   • الكبيرة:  bigP/bigLvl/bigBar/bigTop + bigEff — global، تُملأ في كتلة الكبيرة (islast).
//   • الصغيرة:  خام (آلية النقطة المعلّقة)؛ آخر قمة/قاع في memS. الفعالية تُحسب على المتوسطة/الكبيرة.
//   الفعالية في الدرجتين = (ليست مُغطّاة f_coveredIn) و(تتابُع f_seqEff) — قوانين موحّدة لكل الدرجات.
var array<float> bigP   = array.new<float>()   // سعر النقطة الزرقاء (الذيل)
var array<float> bigLvl = array.new<float>()   // مستوى الجسم (للمناطق/الخطوط)
var array<int>   bigBar = array.new<int>()
var array<bool>  bigTop = array.new<bool>()
var array<bool>  bigEff = array.new<bool>()    // فعّالة؟ (تُحسب مرّة في كتلة الكبيرة)
var array<bool>  bigPend = array.new<bool>()   // معلّقة؟ (غير محدَّدة الفعالية — رماديّ، مرآة dgPend)
var array<float> zHistP  = array.new<float>()   // مستوى نقطة التاريخ التي دخلت زوجاً (لرسم خط m.A عليها)
var array<int>   zHistTm = array.new<int>()      // زمنها
var array<int>   zHistIdx = array.new<int>()     // [V4.32] فهرس شريك التاريخ في mc* (للتشخيص: حالته الفعليّة)
// هل بار النقطة = نقطة زرقاء (كبيرة فعّالة في kP)؟ — لمنع تزاوج زرقاء-زرقاء في المناطق
f_isBlue(int br) =>
    bool r = false
    if array.size(bluePivotBars) > 0
        for k = 0 to array.size(bluePivotBars) - 1
            if array.get(bluePivotBars, k) == br
                r := true
                break
    r
// التغطية [M4]: هل النقطة i مُغطّاة؟ = وُجد بعدها (زمنياً) نقطة من نوعها أكثر تطرّفاً
//   (قاع أدنى يُغطّي القاع الأعلى / قمة أعلى تُغطّي القمة الأدنى) — قانون الدرس 3.
f_coveredPrice(int i) =>
    bool cov = false
    float pi = array.get(mcP, i)
    bool  ti = array.get(mcTop, i)
    int   bi = array.get(mcBar, i)
    int   n  = array.size(mcP)
    if n > 0
        for k = 0 to n - 1
            if k != i and array.get(mcTop, k) == ti and array.get(mcBar, k) > bi
                if ti ? (array.get(mcP, k) > pi) : (array.get(mcP, k) < pi)
                    cov := true
    cov
// [E1] تغطية بالـ(سعر/بار/نوع) فوق نقاط المتوسطة — لتلوين أيّ درجة (الزرقاء) بنفس القانون.
f_coveredAt(float p, int b, bool t) =>
    bool cov = false
    int  n = array.size(mcP)
    if n > 0
        for k = 0 to n - 1
            if array.get(mcTop, k) == t and array.get(mcBar, k) > b
                if t ? (array.get(mcP, k) > p) : (array.get(mcP, k) < p)
                    cov := true
    cov
// [E1] التغطية العامّة — نفس قانون المتوسطة، يُطبَّق على مصفوفات أيّ درجة (مرّر مصفوفات الدرجة).
//   النقطة مُغطّاة إن وُجد بعدها (في نفس الدرجة) نقطة من نوعها أكثر تطرّفاً. تمييز الدرجة = أيّ مصفوفات تمرّر.
f_coveredIn(array<float> pArr, array<int> barArr, array<bool> topArr, int i) =>
    bool  cov = false
    float pi  = array.get(pArr, i)
    bool  ti  = array.get(topArr, i)
    int   bi  = array.get(barArr, i)
    int   n   = array.size(pArr)
    if n > 0
        for k = 0 to n - 1
            if k != i and array.get(topArr, k) == ti and array.get(barArr, k) > bi
                if ti ? (array.get(pArr, k) > pi) : (array.get(pArr, k) < pi)
                    cov := true
    cov
// تتابُع الدرجة (مشترك، أي درجة): القمة/القاع الدافع داخل الموجة النشطة يجب أن يتجاوز أطرف نقطة سابقة من نوعه.
//   صاعدة(dir=1) ⇒ القمم تتصاعد؛ هابطة(dir=-1) ⇒ القيعان تتناقص. النقطة غير الدافعة لا تخضع.
f_seqEff(array<float> pArr, array<int> barArr, array<bool> topArr, int i, int dir) =>
    bool ok = true
    if dir != 0 and array.get(topArr, i) == (dir == 1)
        float pi = array.get(pArr, i)
        int   bi = array.get(barArr, i)
        float ref = na
        for k = 0 to array.size(pArr) - 1
            if k != i and array.get(topArr, k) == (dir == 1) and array.get(barArr, k) < bi
                float pk = array.get(pArr, k)
                ref := na(ref) ? pk : (dir == 1 ? math.max(ref, pk) : math.min(ref, pk))
        if not na(ref) and (dir == 1 ? pi <= ref : pi >= ref)
            ok := false
    ok
// فعالية النقطة (مشترك، أي درجة) — الدرس 05: النقطة **غير الدافعة** (قاع صعوداً / قمة هبوطاً) تُفعَّل فقط
//   إذا صنع السعر بعدها تطرّفاً جديداً يتجاوز النقطة الدافعة **السابقة** (قمة أعلى صعوداً / قاع أدنى هبوطاً).
//   «عمل سعر أعلى من آخر قمة قبله». لا تُفعَّل بمجرّد وجودها، ولا علاقة للتغطية. النقطة الدافعة لا تخضع (true).
//   النقاط تتناوب قمة/قاع، فالنقطة الدافعة التالية = أوّل نقطة من النوع المعاكس بعدها.
f_activated(array<float> pArr, array<int> barArr, array<bool> topArr, int i, int dir) =>
    bool ok = true
    if dir != 0 and array.get(topArr, i) != (dir == 1)        // نقطة غير دافعة
        int   bi = array.get(barArr, i)
        float prevOpp = na
        int   prevB = na
        float nextOpp = na
        int   nextB = na
        int n = array.size(pArr)
        for k = 0 to n - 1
            if array.get(topArr, k) == (dir == 1)             // النقطة الدافعة (قمة صعوداً / قاع هبوطاً)
                int bk = array.get(barArr, k)
                if bk < bi and (na(prevB) or bk > prevB)
                    prevB := bk
                    prevOpp := array.get(pArr, k)
                if bk > bi and (na(nextB) or bk < nextB)
                    nextB := bk
                    nextOpp := array.get(pArr, k)
        ok := na(nextOpp) ? false : na(prevOpp) ? true : (dir == 1 ? nextOpp > prevOpp : nextOpp < prevOpp)
    ok
// [تشخيص] سبب حُكم الفعالية + القيمة المرجعية: أيّ قانون أسقط النقطة وبأيّ مرجع — لجدول التحقّق.
//   oi = الفهرس في mc*؛ subTop/subBar = مصفوفة الموجة الفرعية؛ dir = اتجاهها؛ covd/sq/ac = نتائج القوانين.
f_effReason(int oi, int mmz, array<float> subP, array<bool> subTop, array<int> subBar, int dir, bool covd, bool sq, bool ac) =>
    string rsn = "فعّال (غير مُختبَر) ✓"
    bool  ti  = array.get(mcTop, oi)
    int   bio = array.get(mcBar, oi)
    if covd
        float pio = array.get(mcP, oi)
        float cvp = na
        for k = 0 to mmz - 1
            if k != oi and array.get(mcTop, k) == ti and array.get(mcBar, k) > bio
                float pk = array.get(mcP, k)
                if (ti ? pk > pio : pk < pio) and (na(cvp) or (ti ? pk > cvp : pk < cvp))
                    cvp := pk
        rsn := "مُغطّى بـ " + str.tostring(cvp, format.mintick) + " (مُختبَر)"   // [V4.1] التغطية = مُختبَر ⇒ ليس منطقة طازجة
    else if dir != 0 and ti != (dir == 1)
        // [V4.27] غير مُغطّى ونقطة غير دافعة ⇒ معلّق حتى تتجاوز نقطةٌ دافعة تالية السابقةَ (سعر جديد، الدرس 05/09).
        float prevOpp = na
        int   prevB = na
        float nextOpp = na
        int   nextB = na
        int  ns = array.size(subTop)
        for k = 0 to ns - 1
            if array.get(subTop, k) == (dir == 1)
                int bk = array.get(subBar, k)
                if bk < bio and (na(prevB) or bk > prevB)
                    prevB := bk
                    prevOpp := array.get(subP, k)
                if bk > bio and (na(nextB) or bk < nextB)
                    nextB := bk
                    nextOpp := array.get(subP, k)
        bool pendR = na(nextOpp) ? true : na(prevOpp) ? false : (dir == 1 ? not (nextOpp > prevOpp) : not (nextOpp < prevOpp))
        if pendR
            rsn := "معلّقة (انتظار التأكيد)"
    rsn
// [V3] هل النقطة «معلّقة»؟ نقطة غير دافعة (قاع صعوداً / قمة هبوطاً) لم تتكوّن بعدها نقطة دافعة تؤكّدها بتطرّف
//   جديد ⇒ غير محدَّدة (ليست فعّالة ولا غير فعّالة) — لون مميّز ولا تُرسم عليها م.A حتى تتأكّد (الدرس: قاعدة الانتظار).
f_pending(array<float> subP, array<bool> subTop, array<int> subBar, int bi, bool ti, int dir) =>
    bool pend = false
    if dir != 0 and ti != (dir == 1)
        // [V4.27] الدرس 05/09: المعلّق (قاع صعوداً / قمّة هبوطاً) لا يُفعَّل بمجرّد ظهور نقطة دافعة تالية،
        //   بل فقط حين **تتجاوز** النقطة الدافعة التالية السابقةَ (قمّة أعلى من آخر قمّة قبله / قاع أدنى) = «سعر جديد».
        float prevOpp = na
        int   prevB = na
        float nextOpp = na
        int   nextB = na
        int n = array.size(subTop)
        for k = 0 to n - 1
            if array.get(subTop, k) == (dir == 1)             // النقطة الدافعة (قمة صعوداً / قاع هبوطاً)
                int bk = array.get(subBar, k)
                if bk < bi and (na(prevB) or bk > prevB)
                    prevB := bk
                    prevOpp := array.get(subP, k)
                if bk > bi and (na(nextB) or bk < nextB)
                    nextB := bk
                    nextOpp := array.get(subP, k)
        pend := na(nextOpp) ? true : na(prevOpp) ? false : (dir == 1 ? not (nextOpp > prevOpp) : not (nextOpp < prevOpp))
    pend
// [تشخيص] فهرس نقطة في مصفوفة بارات حسب رقم الشمعة (لربط الصغيرة بالمتوسطة/الكبيرة) — -1 إن لم تُوجد.
f_idxByBar(array<int> barArr, int b) =>
    int idx = -1
    int n = array.size(barArr)
    if n > 0
        for k = 0 to n - 1
            if array.get(barArr, k) == b
                idx := k
                break
    idx
// تلوين نقطة درجة (مشترك): يعيد [لون الحدّ، لون التعبئة] حسب الفعالية؛ ألوان الدرجة تميّز مَن استدعاها.
f_pivotCols(bool eff, color baseCol, color deadCol) =>
    [eff ? f_dark(baseCol) : baseCol, eff ? baseCol : deadCol]
// فعالية النقطة لأغراض المناطق = zoneEff[i] (تُحسب طازجةً مُقيّدةً بالموجة في كتلة البناء أدناه).
//   قاعدة المستخدم: النقطة الزرقاء تُعامَل كنقطة متوسطة («صفراء ضمنياً») — لا تخصيص للزرقاء.
//   نحدّد الفعّالة داخل الموجة التاريخية (غير مُغطّاة + تتابُع) ثم نرسم/نزاوج عليها فقط.
//   حارس الحدود يُرجع mcEff كاحتياطيّ قبل أوّل تعبئة لـ zoneEff (لا out-of-bounds).
f_effForZone(int i, int hist) =>
    array.size(zoneEff) > i ? array.get(zoneEff, i) : array.get(mcEff, i)
// [V2] قاعدة المجاورة (الدرس 02): المنطقة بين مستويين «متجاورين سعرياً» = لا مستوى م.A فعّال ثالث بينهما.
//   يمنع المستطيل العريض الذي يبتلع مستويات (طرفَي سوينغ بمستويين مختلفين). بلا رقم عرض مخترع.
f_levelBetween(float cB, float cT, int iA, int iB, int hist) =>
    bool hit = false
    int n = array.size(mcP)
    if n > 0
        for k = 0 to n - 1
            if k != iA and k != iB and array.get(mcBar, k) >= hist and f_effForZone(k, hist)
                float lk = array.get(mcLvl, k)
                if lk > cB and lk < cT
                    hit := true
                    break
    hit
// [V1] قاعدة الدرس: لا تُزاوِج عبر تصحيح. يعبر تصحيحاً إن وُجدت نقطة متوسطة فعّالة بين المصدرين (زمنياً)
//   وسعرها خارج نطاق [cB,cT] بهامش الدرجة (tol) ⇒ بينهما تأرجح/موجة تصحيحية ⇒ يُرفض الزوج.
f_crossesCorrection(int iA, int iB, float cB, float cT, float tol, int hist) =>
    bool cr = false
    float lo = math.min(array.get(mcBar, iA), array.get(mcBar, iB))
    float hi = math.max(array.get(mcBar, iA), array.get(mcBar, iB))
    int nm = array.size(mcBar)
    if nm > 0
        for k = 0 to nm - 1
            if k != iA and k != iB and f_effForZone(k, hist)
                int bk = array.get(mcBar, k)
                if bk > lo and bk < hi
                    float lk = array.get(mcLvl, k)
                    if lk > cT + tol or lk < cB - tol
                        cr := true
    cr
// هل المنطقة المرشّحة [cB,cT] محتواة داخل منطقة موجودة أو تحتوي واحدة؟ (منع تداخل الاحتواء)
f_zoneContain(float cT, float cB) =>
    bool hit = false
    int zc = array.size(zTop)
    if zc > 0
        for k = 0 to zc - 1
            float zt = array.get(zTop, k)
            float zb = array.get(zBot, k)
            if (cT <= zt and cB >= zb) or (zt <= cT and zb >= cB)   // المرشّحة داخل موجودة أو العكس
                hit := true
                break
    hit
// فعالية البار المتوسط (covered؟) — لتلوين الزرقاء غير الفعّالة حمراء ببوردر أزرق
f_barMedEff(int br) =>
    bool e = true
    int nm = array.size(mcBar)
    if nm > 0
        for k = 0 to nm - 1
            if array.get(mcBar, k) == br
                e := array.get(mcEff, k)
                break
    e
// كائنات عرض الدرجة الكبيرة (تُمسح وتُعاد كل تحديث في نهاية الشارت)
var array<label> bigLbls  = array.new<label>()
var array<line>  bigLines = array.new<line>()
var line  bigLiqLine = na
var line  bigLvlLine = na
// [V4.18] الزوج الأزرق المثبَّت: نُبقي الخطّين على آخر زوج صالح، ولا ننقلهما إلا عند ظهور زوج جديد (الدرس 09/10)
var int   bigAncQa1  = na    // مرساة الزوج الأحدث (بار)
var float bigAncQv1  = na    // سعر الأحدث
var int   bigAncQa2  = na    // مرساة الأقدم في الزوج (بار)
var float bigAncQv2  = na    // سعر الأقدم
var float bigAncLvl  = na    // مستوى الاتجاه الأزرق (جسم الأحدث)
var int   bigAncDir  = 0     // اتجاه رسم الأزرق وقت التثبيت (= medActiveDir آنذاك) — تستعمله الاستنتاجات
// [V4.18] تشخيص بحث الزوج الأزرق (لِمَ لا يُرسم الخطّ): يُملأ في كتلة الكبيرة، يُعرض في لوحة حالة الموجة
var int   bigDbgBelow = 0    // عدد القيعان الزرقاء الفعّالة أسفل السعر (لازمها الصعود)
var int   bigDbgAbove = 0    // عدد القمم الزرقاء الفعّالة أعلى السعر (لازمها الهبوط)
var bool  bigDbgPair  = false // وُجد زوج صالح جديد هذا البار؟
var int   bigDbgNb    = 0    // إجمالي النقاط الزرقاء (kP)
var int   largeDir   = 0    // اتجاه الدرجة الكبيرة من النقاط الزرقاء المنظّفة
// اتجاه الموجة النشطة المستقرّ لكل درجة (لا ينقلب مع التصحيحات — قاعدة «نهاية الموجة»):
//   ينقلب صعوداً عند قمة أعلى من سابقتها، وهبوطاً عند قاع أدنى من سابقه.
var int   smallActiveDir = 0
var int   medActiveDir   = 0
var int   bigDirLvl      = 0    // [v3.86] اتجاه الكبيرة بقاعدة المستخدم (حالتان: كسر مستوى الكبيرة · انقلاب المتوسطة+بنية زرقاء) — آلة حالة per-bar تغذّي largeDir عند islast
var int   bigTLcnt       = 0    // [v3.86] عدّاد كسر مستوى الكبيرة بشمعتين (مرآة medTLcnt)
// [v3.87.4] أُزيل تشخيص مرحلة الصغيرة المؤقّت (dbgSmText/smDbgLbl) بعد حسم مرحلة الصغيرة (إصلاح 08).
var int   smallWaveStart = na   // شمعة بداية الموجة الصغيرة النشطة (عند آخر انقلاب)
var int   smallWaveStartTime = na   // [V3.66] زمن بداية الموجة (للحصر الزمنيّ ب — تأكيد الرابعة الصغيرة داخل الموجة فقط)
var int   medWaveStart   = na   // شمعة بداية الموجة المتوسطة النشطة (= مرساة الموجة التاريخية)
var int   medWavePrevStart = na // بداية الموجة المتوسطة السابقة (= مرساة تاريخ التاريخ عند الإرساء المتوسط)
// المرحلة 1 — حالة الفعالية المتوسطة التزايُدية (per-bar, non-repainting):
var float mcSeqRef   = na       // مرجع التتابُع [M3] الجاري (أعلى قمة/أدنى قاع مُبقى داخل الموجة النشطة)
var int   mcSeqWsBar = na       // بار بداية الموجة المستعملة للتتابُع (لكشف الانعكاس)
// كسر خط السيولة المتوسط (المراحل): الاتجاه والشمعة
var int    medBreakDir = 0   // (يبقى لكاشف كسر مستوى الاتجاه فقط)
var int    medPrevDir  = 0
var string medPhase    = "—"
var string smallPhase  = "—"
var string bigPhase    = "—"
var bool   bigCtxReview = false   // كسر مستوى الاتجاه الكبير ⇒ إعادة تقييم سياق (لا قلب/مسح/إنهاء)
// ===== الاستنتاجات (الدرس 10) — حالة global سهلة القراءة للإشارات، non-repainting =====
//   تُحدَّث في الحلقة الرئيسية: الاتجاه/الدخول per-bar (رخيص)، والقوّة عند انبعاث نقطة متوسطة فقط (أداء).
var int  concLiqDir = 0    // اتجاه السيولة: 1 صاعد / -1 هابط / 0 (Range أو غير محدّد — يُميَّز بـ concDefined/concRange)
var int  concEntry  = 0    // الدخول المتاح: 1 شراء فقط / -1 بيع فقط / 0 شراء وبيع (عرضيّ) أو لا توصية (غير محدّد)
var bool concDefined = false // كلا الدرجتين (سيولة المتوسطة + اتجاه الكبيرة) محدَّد ⇒ الاستنتاج موثوق (لا تلفيق)
var bool concRange   = false // محدَّد لكن متعارض (كبيرة ≠ متوسطة) ⇒ سوق عرضيّ (Range) ⇒ الاثنان متاحان
var bool entryDefined = false // [V4.17] الدخول: كلا مستويي الاتجاه (متوسط + كبير) متاحان
var bool entryRange   = false // [V4.17] مستويا الاتجاه متعارضان ⇒ شراء وبيع
var bool concStrong = true // قوة السيولة: قويّة (true) / ضعيفة (false) — تباعد القاع عن المقاومة المكسورة
var bool concStrongDef = false // [V3.59] هل حُسبت قوة السيولة للاتجاه الحاليّ هذا البار؟ (يمنع عرض قوة قديمة من اتجاه سابق بعد الانعكاس)
var bool concCorrectionLikely = false // الاستنتاج الرابع/الربط (الدرس 11): 3 درجات مشاركة + سيولة ضعيفة + سعر قرب الذروة ⇒ تصحيح متوسط متوقّع
// ===== طبقة الفرص (المرحلة 2) — حالة/تنبيه فقط، بلا دخول/أوامر =====
var string oppText   = "—"
var bool   diagInZone = false   // inZone وحده
var bool   diagPhase  = false   // inZone + مرحلة مناسبة (تجميع/تصريف)
var bool   diagConf   = false   // دخول مؤكّد فعلي
var int    cSm3      = 0   // smallPh==3
var int    cSm3Zone  = 0   // smallPh==3 و داخل منطقة
var int    cPendSm   = 0   // pendBuySmall مُسلَّح
var int    cD4Up     = 0   // d4Up (تحقّق d4Valid)
var int    cPendD4   = 0   // pendBuySmall و d4Up (= يجب دخول صغير)
var int    cMed3Zone = 0   // medPh==3 و داخل منطقة
var int    cPendMed  = 0   // pendBuyMed مُسلَّح
var int    cSmConf   = 0   // smConfBuy
var int    cPendSmCf = 0   // pendBuyMed و smConfBuy (= يجب دخول متوسط)
var bool   diagArmed  = false   // مُسلَّح (pending)
var bool   oppBasicBuy  = false
var bool   oppBasicSell = false
var bool   oppHRBuy     = false
var bool   oppHRSell    = false
// [V4.41] درجة الفرصة الأساسيّة: 3 = صغيرة (منطقة قريبة) · 2 = متوسطة (منطقة أعمق) · 0 = لا فرصة (الكتاب L2-03)
var int    oppBasicBuyDeg  = 0
var int    oppBasicSellDeg = 0
// [V4.42] هدف الفرصة = المنطقة/المستوى التالي نحو الاتجاه (الكتاب: «الهدف = المنطقة التالية»)؛ na إن لا يوجد
var float  oppTarget = na
// [V4.45] تأمين الصفقة (الكتاب L2-04): متعقّب صفقة مفتوحة + وقف متحرّك خلف آخر قاع/قمّة بعد كل مشاركة عامة جديدة
var int    tradeDir   = 0     // 1 شراء مفتوح · -1 بيع · 0 لا صفقة
var float  tradeStop  = na    // الوقف المتحرّك
var float  tradeEntry = na
var float  tradeTgt   = na
var int    tradeBar   = na    // بار الدخول (مرساة صناديق الصفقة)
var box    rewardBox  = na    // صندوق العائد (أخضر: دخول↔هدف)
var box    riskBox    = na    // صندوق المخاطرة (أحمر: دخول↔وقف)
var label  rrBadge    = na    // شارة RR ملوّنة
// ===== المرحلة 3 (شروط الانعكاس): تأكيد بالدرجة الأصغر + دخول/وقف/هدف =====
// درجة الفرصة = صغيرة أو متوسطة حسب التصحيح المكتمل داخل المنطقة؛ التأكيد دائماً بدرجة أصغر.
var bool   pendBuySmall  = false   // فرصة شراء أساسية على تصحيح صغير داخل منطقة (انتظار)
var bool   pendBuyMed    = false   // فرصة شراء أساسية على تصحيح متوسط داخل منطقة
var bool   pendSellSmall = false
var bool   pendSellMed   = false
var float  zbEntryB = na           // حافتا منطقة إعداد الشراء (دعم) — للوقف + الإبطال + الهدف
var float  ztEntryB = na
var float  zbEntryS = na           // حافتا منطقة إعداد البيع (مقاومة)
var float  ztEntryS = na
var float  buySetupLow  = na       // قاع إعداد الشراء = أعمق قاع يأس (despDeep) وقت التسليح؛ كسره = فشل حقيقيّ
var float  sellSetupHigh = na      // قمة إعداد البيع  = أعلى قمة يأس (despDeep) وقت التسليح؛ كسرها = فشل حقيقيّ
var bool   smConfBuy   = false     // تأكيد مشاركة صغيرة صاعدة جديدة هذا البار (المُطلِق)
var bool   smConfSell  = false
var bool   entryBuy    = false
var bool   entrySell   = false
// آلة المراحل المتوسطة (عامة، منفصلة عن الاتجاه)
var Phase  medPh       = Phase.new()
var Phase  smallPh     = Phase.new()
var Phase  bigPh       = Phase.new()
// كسر السيولة البنيوي (شمعتان) + بوّابة إعادة الرسم لكل درجة
var LiqBreak medLB     = LiqBreak.new()
var LiqBreak smLB      = LiqBreak.new()
var LiqBreak smLvlLB   = LiqBreak.new()   // [V4.70] عدّاد كسر المستوى الأحمر (الصغير) لحذفه عند الكسر
var LiqBreak bigLB     = LiqBreak.new()   // [V4.72] عدّاد كسر خطّ السيولة الأزرق (الكبير)
var LiqBreak bigLvlLB  = LiqBreak.new()   // [V4.76] عدّاد كسر مستوى الاتجاه الأزرق (شمعتان) ⇒ تنتهي موجة الأزرق
var int      bigLiqBrkBar = na            // [V4.72] بار كسر السيولة الأزرق ⇒ لا يُعاد رسمه إلّا بمحورين زرقاوين جديدين
var int      bigLvlBrkBar = na            // [V4.75] بار إعادة بناء الأزرق (كسر مستوى المتوسط) ⇒ المستوى الأزرق لا يُعاد إلّا بمحور أزرق جديد بعده
var int    medGate     = na   // أحدث حدث يفرض انتظار نقطتين جديدتين (كسر مستوى أو كسر سيولة بنيوي)
var int    smGate      = na
var int    medTLcnt    = 0    // عدّاد شمعتي كسر مستوى الاتجاه المتوسط (نهاية الموجة)


atrv = ta.atr(14)   // لقياس طول السهم بمعزل عن سعر الأداة

// طلب الدرجة الرابعة من الفريم الأصغر (متاح فقط إن كان الفريم أصغر فعلاً)
// [V3.67] فريم الرابعة المحسوب تلقائيًّا (≈ الشارت÷12 ⇒ ~5د للساعة، متكيّف) أو اليدويّ d4tf حين d4Auto مطفأ. طلب واحد ⇒ صفر كلفة أداء إضافيّة.
int    d4ChartSec = timeframe.in_seconds(timeframe.period)
string d4tfEff = d4Auto ? timeframe.from_seconds(math.max(60, int(d4ChartSec / 12))) : d4tf
bool d4Valid = enableD4 and timeframe.in_seconds(d4tfEff) > 0 and timeframe.in_seconds(d4tfEff) < d4ChartSec
[d4UpRaw, d4DnRaw, d4BrokenT] = request.security(syminfo.tickerid, d4tfEff, f_degree4(), lookahead = barmerge.lookahead_off)   // [V3.66/3.67] d4tfEff = فريم الرابعة (تلقائيّ÷12 أو يدويّ)؛ d4BrokenT = زمن المكسور (الحصر ب)
bool d4Up = d4Valid and d4UpRaw   // كسر آخر قمة على الفريم الأصغر ⇒ تأكيد شراء صغير
bool d4Dn = d4Valid and d4DnRaw   // كسر آخر قاع ⇒ تأكيد بيع صغير

// دالّة رسم سهم صغير مصمت (الطرف على الذيل) وتُعيد الكائن لإمكان حذفه/إعادة تلوينه
drawSArrow(bool isTop, float px, int bar, color colA) =>
    polyline result = na
    if showArrows
        float slen    = arrLenAtr * atrv
        float headH   = slen * 0.45                                  // ارتفاع رأس السهم (متناسق)
        int   headWb  = math.max(1, arrWidth)                        // نصف عرض الرأس (شموع) — يتبع المدخل مباشرةً
        int   shaftWb = math.max(1, int(math.round(headWb * 0.45)))  // نصف عرض الساق ≈ نصف الرأس
        shaftWb := math.min(shaftWb, math.max(1, headWb - 1))        // الرأس أعرض من الساق دائماً
        float yShaft  = isTop ? px + slen  : px - slen
        float yHead   = isTop ? px + headH : px - headH
        pts = array.new<chart.point>()
        array.push(pts, chart.point.from_index(bar,           px))   // طرف السهم على النقطة
        array.push(pts, chart.point.from_index(bar - headWb,  yHead))
        array.push(pts, chart.point.from_index(bar - shaftWb, yHead))
        array.push(pts, chart.point.from_index(bar - shaftWb, yShaft))
        array.push(pts, chart.point.from_index(bar + shaftWb, yShaft))
        array.push(pts, chart.point.from_index(bar + shaftWb, yHead))
        array.push(pts, chart.point.from_index(bar + headWb,  yHead))
        result := polyline.new(pts, closed = true, xloc = xloc.bar_index, line_color = colA, fill_color = colA, line_width = 1)
    result

// حالة الدرجة الصغيرة: لا تُرسم القمة/القاع إلا بعد تأكّدها (تتابُع + فعالية)
var float ldTopP   = na   // آخر قمة مرسومة (مؤكّدة)
var int   ldTopBar = na
var float ldBotP   = na   // آخر قاع مرسوم (مؤكّد)
var int   ldBotBar = na
var float ldAnyP   = na   // آخر نقطة مرسومة (لربط الخطوط)
var int   ldAnyBar = na
var int   ldType   = 0    // نوع آخر نقطة مرسومة: 1=قمة، -1=قاع، 0=لا شيء
// آلية النقطة المعلّقة الموحّدة: لا تُرسم نقطة إلا مع شريكها المعاكس (لا منفردة إلا الأخيرة)
var float pendP    = na   // سعر النقطة المعلّقة (لم تُرسم بعد)
var int   pendBar  = na   // شمعة النقطة المعلّقة
var int   pendType = 0    // نوع المعلّقة: 1=قمة، -1=قاع، 0=لا شيء

// مخزن الأسهم الصغيرة المرسومة (لحذف ما يقع داخل التصحيح المتوسط)
var array<polyline> sArr  = array.new<polyline>()
var array<int>      sArrB = array.new<int>()

// يرسم سهماً صغيراً ويخزّنه — مع فرض التناوب (لا نقطتان من نفس النوع متتاليتين)
// يأخذ نوع آخر نقطة ويُعيد النوع الجديد (تفادياً لتعديل متغيّر عام داخل دالّة)
storeSArrow(bool isTop, float px, int bar, color colA, int lastType) =>
    if (isTop and lastType == 1) or ((not isTop) and lastType == -1)
        // نفس نوع آخر نقطة: استبدل السابق بالأبعد (احذفه)
        if array.size(sArr) > 0
            polyline.delete(array.last(sArr))
            array.pop(sArr)
            array.pop(sArrB)
    array.push(sArr, drawSArrow(isTop, px, bar, colA))
    array.push(sArrB, bar)
    if array.size(sArr) > 400   // [V3.45] سقف ذاكرة: قصّ الأقدم (تفادي نموّ sArr/sArrB بلا حدّ عبر التاريخ + تخفيف حلقة المسح)
        polyline.delete(array.shift(sArr))
        array.shift(sArrB)
    isTop ? 1 : -1

// حدّ الموجة التاريخية المؤثّرة في السعر (يدوي/تلقائي) — يُحسب مبكراً ليُستخدم موحّداً
// طول الموجة التلقائي = من بداية آخر موجة كبيرة مؤثّرة (الدرس 03): الموجة الحقيقية مرساة على نقطة كبيرة.
//   آخر نقطة كبيرة زمنياً = أصل الساق الجارية ونوعها يحدّد الاتجاه:
//     قاع ⇒ ساق صاعدة (ابدأ من القاع) · قمة ⇒ ساق هابطة (ابدأ من القمة). (نقاط memBph التزايُدية non-repainting.)
//   احتياطيّ عند غياب نقاط كبيرة بعد: آخر 7 تأرجحات متوسطة.
int autoLen = 150
int bigAnchor = na
int bigDirA = medActiveDir != 0 ? medActiveDir : largeDir   // [V4.91] اتجاه تقريبيّ للإرساء الكبير (متوسط ثمّ كبير سابق)
// [V4.91] الدرس 03 (histAnchorBig): إرساء على آخر **تطرّف كبير** باتجاه الموجة (قاع صعوداً / قمّة هبوطاً) = أصل الموجة الكبيرة (أوسع).
//   الافتراضيّ (مطفأ): الدرس 09 — على medWaveStart (الموجة المتوسطة العاملة، أضيق). احتياطيّ قبل أوّل انقلاب = نقطة كبيرة.
if histAnchorBig and ((bigDirA == 1 and not na(memBph.lbBar)) or (bigDirA == -1 and not na(memBph.ltBar)))
    bigAnchor := bigDirA == 1 ? memBph.lbBar : memBph.ltBar
else if medActiveDir != 0 and not na(medWaveStart)
    bigAnchor := medWaveStart
else if not na(memBph.lbBar) and not na(memBph.ltBar)
    bigAnchor := memBph.lbBar > memBph.ltBar ? memBph.lbBar : memBph.ltBar   // الأحدث = أصل الساق الجارية
else if not na(memBph.lbBar)
    bigAnchor := memBph.lbBar
else if not na(memBph.ltBar)
    bigAnchor := memBph.ltBar
if not na(bigAnchor)
    autoLen := bar_index - bigAnchor + 1
else if array.size(medBars) > 0
    int idxA = math.max(0, array.size(medBars) - 7)
    autoLen := bar_index - array.get(medBars, idxA) + 1
int wlen    = useHistN ? histBars : autoLen
wlen := math.min(math.min(math.max(wlen, 1), bar_index + 1), 4500)
int histLeft = bar_index - wlen + 1   // بداية الموجة الحالية (نافذة العمل الضيّقة — الدرس 09)
// [V3.44] الدرس 03 — نافذة «السياق» الواسعة، منفصلة عن نافذة «العمل» الضيّقة (الدرس 09):
//   مرساة دائمًا على آخر تطرّف كبير باتجاه الموجة (أصل الموجة الكبيرة) ⇒ تقود الصندوق المرسوم + تاريخ التاريخ + لوحة الفريم فقط.
//   الفعالية/المناطق/الإشارات تبقى على histLeft الضيّق (قرار v2.14 سليم) ⇒ لا انحدار في طبقة التحليل.
int ctxAnchor = na
if (bigDirA == 1 and not na(memBph.lbBar)) or (bigDirA == -1 and not na(memBph.ltBar))
    ctxAnchor := bigDirA == 1 ? memBph.lbBar : memBph.ltBar
else if not na(memBph.lbBar) and not na(memBph.ltBar)
    ctxAnchor := memBph.lbBar > memBph.ltBar ? memBph.lbBar : memBph.ltBar
else if not na(memBph.lbBar)
    ctxAnchor := memBph.lbBar
else if not na(memBph.ltBar)
    ctxAnchor := memBph.ltBar
int ctxLen = (useHistN or na(ctxAnchor)) ? wlen : (bar_index - ctxAnchor + 1)   // [V3.47] احترم التحديد اليدويّ: useHistN ⇒ الصندوق يتبع histBars (= wlen) لا التطرّف الكبير (إصلاح impact v3.44)
ctxLen := math.min(math.min(math.max(ctxLen, 1), bar_index + 1), 4500)
int ctxLeft  = bar_index - ctxLen + 1
float ctxHiE = ta.highest(high, ctxLen)
float ctxLoE = ta.lowest(low, ctxLen)
int ctxHohRight = ctxLeft - 1                         // تاريخ التاريخ للسياق = نافذة بطول الموجة قبلها مباشرةً (احتياطيّ بسيط؛ مطابقة السعة لاحقًا)
int ctxHohLen   = useHohN ? hohBars : ctxLen
ctxHohLen := math.min(math.min(math.max(ctxHohLen, 1), math.max(ctxLeft, 1)), math.max(4900 - ctxLen, 1))
int ctxHohLeft  = math.max(0, ctxLeft - ctxHohLen)
// نطاق الموجة الحالية (يُحسب مبكراً) — يُستخدم لرسم الصندوق
float hwHiE = ta.highest(high, wlen)
float hwLoE = ta.lowest(low, wlen)
// حزام قصّ امتداد السيولة: يُحسب دائماً من الطول التلقائي (لا من الاختيار اليدوي)
//   حتى لا يتضخّم الحزام عند تحديد الموجة بعدد شموع كبير ⇒ لا إسقاط لسعر بعيد ⇒ لا تكدّس.
int   bandLen  = math.min(math.max(autoLen, 1), bar_index + 1)
float hwHiBand = ta.highest(high, bandLen)
float hwLoBand = ta.lowest(low, bandLen)
// تاريخ التاريخ = أحدث ساق كبيرة سابقة سعتها ≥ hohMinRatio من سعة الموجة التاريخية (موجة مقارِبة، لا تصحيح).
//   نفحص حتى ثلاث سيقان للخلف من نقاط memBph (قمتان/قاعان)، ونتخطّى التصحيحات الأصغر. الملاصقة مسموحة لا مشترطة.
//   كل ساق = (مرساة البداية، نهايتها، سعتها بين سعرَي طرفيها). يدويّ بعدد الشموع (useHohN)؛ واحتياطيّ بطول الموجة عند التعذّر.
float ampHist  = hwHiE - hwLoE
float hohThr   = hohMinRatio * ampHist
int   hohLeftV  = na
int   hohRightV = histLeft - 1
bool  medAnchored = medActiveDir != 0 and not na(medWaveStart)
if not useHohN and not histAnchorBig and medAnchored and not na(medWavePrevStart) and medWavePrevStart < histLeft
    // الإرساء المتوسط: تاريخ التاريخ = الموجة المتوسطة السابقة [medWavePrevStart → histLeft)
    hohLeftV := medWavePrevStart
    hohRightV := histLeft - 1
else if not useHohN and (not medAnchored or histAnchorBig) and ampHist > 0 and not na(memBph.lbBar) and not na(memBph.ltBar)
    bool upLeg = memBph.lbBar > memBph.ltBar   // الأحدث قاع ⇒ ساق صاعدة جارية
    if upLeg
        // المرشّحات (الأقرب للمرساة أولاً): A: ltBar→lbBar · B: pbBar→ltBar · C: ptBar→pbBar
        if math.abs(memBph.ltP - memBph.lbP) >= hohThr
            hohLeftV := memBph.ltBar
            hohRightV := histLeft - 1
        else if not na(memBph.pbBar) and math.abs(memBph.ltP - memBph.pbP) >= hohThr
            hohLeftV := memBph.pbBar
            hohRightV := memBph.ltBar
        else if not na(memBph.ptBar) and not na(memBph.pbBar) and math.abs(memBph.pbP - memBph.ptP) >= hohThr
            hohLeftV := memBph.ptBar
            hohRightV := memBph.pbBar
    else
        // ساق هابطة جارية (الأحدث قمة): A: lbBar→ltBar · B: ptBar→lbBar · C: pbBar→ptBar
        if math.abs(memBph.lbP - memBph.ltP) >= hohThr
            hohLeftV := memBph.lbBar
            hohRightV := histLeft - 1
        else if not na(memBph.ptBar) and math.abs(memBph.ptP - memBph.lbP) >= hohThr
            hohLeftV := memBph.ptBar
            hohRightV := memBph.lbBar
        else if not na(memBph.pbBar) and not na(memBph.ptBar) and math.abs(memBph.ptP - memBph.pbP) >= hohThr
            hohLeftV := memBph.pbBar
            hohRightV := memBph.ptBar
// طول/مرساة تاريخ التاريخ: المرشّح المقارِب إن وُجد، وإلا الاحتياطيّ (يدويّ أو طول الموجة الحالية).
int hohLen = useHohN ? hohBars : wlen
hohLen := math.min(math.min(math.max(hohLen, 1), math.max(histLeft, 1)), math.max(4900 - wlen, 1))
int hohLoFloor = math.max(0, histLeft - math.max(4900 - wlen, 1))
int hohLeft = na(hohLeftV) ? math.max(histLeft - hohLen, 0) : math.max(math.min(hohLeftV, histLeft - 1), hohLoFloor)
hohRightV := na(hohLeftV) ? histLeft - 1 : math.max(math.min(hohRightV, histLeft - 1), hohLeft)
// نافذة الرسم: آخر 3 موجات تاريخية (الموجة + تاريخ التاريخ + تاريخ تاريخ التاريخ).
//   الأقدم يُحسب للحالة لكن لا يُرسم (أداء أخفّ). ثابتة من نهاية الشارت عبر last_bar_index.
int drawLeft = math.max(0, last_bar_index - drawWaves * wlen)

// بداية المنطقة التالية في اتجاه الصفقة (الهدف):
//   شراء (up): الحافة السفلى (zb) لأقرب منطقة فوق السعر. بيع: الحافة العليا (zt) لأقرب منطقة تحته.
//   خط m.A المنفرد (zt==zb) = مستوى هدف صالح أيضاً (بلا عرض منطقة) — ملاحظة المستخدم.
f_nextZoneEdge(float px, bool up) =>
    float best = na
    int   zn   = array.size(zTop)
    if zn > 0
        for k = 0 to zn - 1
            float zt = array.get(zTop, k)
            float zb = array.get(zBot, k)
            if up
                if zb > px and (na(best) or zb < best)
                    best := zb
            else
                if zt < px and (na(best) or zt > best)
                    best := zt
    best
// [V4.59] هدف الصفقة بحسب الدرس L2-02/04: «المنطقة القادمة» = **مستطيل بين مستويين** (zt≠zb)، لا خطًّا منفردًا.
//   نُفضّل أوّل **منطقة مزدوجة** في الجهة؛ والمنفرد (zt==zb، كخطّ تصحيح متروك عند حدّ منطقة الدخول) احتياطيّ فقط
//   عند غياب أيّ منطقة مزدوجة — بلا أيّ مسافة رقميّة مخترعة (الدرس: «لا مسافة رقمية في الشرح»).
f_nextZonePaired(float px, bool up) =>
    float best  = na   // أقرب منطقة مزدوجة
    float bestS = na   // أقرب منفرد (احتياطيّ)
    int   zn    = array.size(zTop)
    if zn > 0
        for k = 0 to zn - 1
            float zt = array.get(zTop, k)
            float zb = array.get(zBot, k)
            bool  pair = zt != zb
            float edge = up ? zb : zt          // صعوداً يلامس السعر قاع المنطقة أولاً؛ هبوطاً قمّتها
            bool  ok   = up ? (edge > px) : (edge < px)
            if ok
                if pair
                    if na(best) or (up ? edge < best : edge > best)
                        best := edge
                else
                    if na(bestS) or (up ? edge < bestS : edge > bestS)
                        bestS := edge
    not na(best) ? best : bestS
// [V4.47] إشارة صفقة بلون مستقلّ لكلّ نوع (المستخدم يميّزها بالألوان) — وسم واحد، النصّ بلا «HR».
// [V4.52] + شارة RR ملوّنة على الجهة المقابلة (Pine لا يلوّن tooltip ⇒ نُظهر RR ملوّنًا بوسم): أخضر ≥2 · أصفر 1-2 · أحمر <1.
f_tradeSig(int x, float y, string txt, bool up, color col, float rr, string tip) =>
    label.new(x, y, txt, yloc = yloc.price, style = up ? label.style_label_up : label.style_label_down, color = col, textcolor = color.white, size = size.small, tooltip = tip)
    if not na(rr)
        color rc = rr >= 2 ? #089981 : rr >= 1 ? #FF9800 : #F23645
        label.new(x, y, "RR " + str.tostring(rr, "#.##"), yloc = yloc.price, style = up ? label.style_label_down : label.style_label_up, color = rc, textcolor = color.white, size = size.tiny, tooltip = tip)
// [v3.88.31 · B4] إشارة فيبو (إليوت) — دالّة **منفصلة تمامًا** عن f_tradeSig (M-Waves): لا تشارك شيئًا، وسم خاصّ ✦ + شارة RR
// [V4.48] نسبة المخاطرة/العائد RR = (المسافة للهدف) ÷ (المسافة للوقف). na إن الوقف عند الدخول. (المستخدم يحكم: ≥2 جيّدة)
f_rr(float entry, float stop, float tgt) =>
    float risk = math.abs(entry - stop)
    float rew  = math.abs(tgt - entry)
    (not na(risk) and not na(rew) and risk > 0) ? rew / risk : na
// ===== [v3.88.36 · B4] إشارات فيبو/إليوت معمّمة لكلّ درجة — حالة منع التكرار لكلّ درجة [0=كبيرة,1=متوسطة,2=صغيرة] =====
var array<int>   fibPeakArr   = array.from(-1, -1, -1)     // قمّة الارتداد المتتبَّعة
var array<bool>  fibArmArr    = array.from(false, false, false)
var array<bool>  fibFiredArr  = array.from(false, false, false)
var array<int>   fibTroughArr = array.from(-1, -1, -1)
var array<bool>  fibArmDArr   = array.from(false, false, false)
var array<bool>  fibFiredDArr = array.from(false, false, false)
var array<label> fibSigLbls   = array.new<label>()        // للاحتفاظ/الحذف
// رسم إشارة واحدة: وسم شراء/بيع + tooltip (الدرجة بالاسم، الترتيب حسب الجهة) + احتفاظ/حذف + تنبيه
f_emitFibSig(bool up, string degName, float entry, float stop, float tgt, bool confl) =>
    float rrF = f_rr(entry, stop, tgt)
    if (na(rrF) or rrF >= fibSigMinRR) and (not fibSigConfluentOnly or confl)   // فلتر RR + التقاطُع فقط (داخل منطقة)
        string e = str.tostring(entry, format.mintick)
        string s = str.tostring(stop, format.mintick)
        string t = str.tostring(tgt, format.mintick)
        string mk = confl ? "☆" : "✦"   // [v3.88.40] إشارة التقاطُع (داخل منطقة) = ☆ · الباقي = ✦
        string body = up ? (f_t("الهدف: ","Target: ") + t + f_t("\nالدخول: ","\nEntry: ") + e + f_t("\nالوقف: ","\nStop: ") + s) : (f_t("الوقف: ","Stop: ") + s + f_t("\nالدخول: ","\nEntry: ") + e + f_t("\nالهدف: ","\nTarget: ") + t)
        string tip = mk + " " + f_t("فيبو ","Fib ") + degName + (confl ? f_t(" · تقاطُع منطقة"," · zone confluence") : "") + "\n" + body + "\nR:R = " + (na(rrF) ? "—" : str.tostring(rrF, "#.##"))
        label lb = label.new(bar_index, entry, mk + (up ? f_t("شراء","Buy") : f_t("بيع","Sell")), yloc = yloc.price, style = up ? label.style_label_up : label.style_label_down, color = up ? fibSigColBuy : fibSigColSell, textcolor = color.white, size = size.small, tooltip = tip)
        array.push(fibSigLbls, lb)
        if not na(rrF)   // [v3.88.41] شارة RR على الجهة المقابلة (مثل M-Waves): أخضر ≥2 · أصفر 1-2 · أحمر <1
            color rc = rrF >= 2 ? #089981 : rrF >= 1 ? #FF9800 : #F23645
            label rb = label.new(bar_index, entry, "RR " + str.tostring(rrF, "#.##"), yloc = yloc.price, style = up ? label.style_label_down : label.style_label_up, color = rc, textcolor = color.white, size = size.tiny, tooltip = tip)
            array.push(fibSigLbls, rb)
        if not fibSigKeepOld
            while array.size(fibSigLbls) > 12   // 6 إشارات × (وسم + شارة RR)
                label.delete(array.shift(fibSigLbls))
        alert("M-Waves " + mk + "Fib " + degName + ": " + (up ? f_t("شراء @ ","Buy @ ") : f_t("بيع @ ","Sell @ ")) + e + f_t(" · هدف ","· tgt ") + t, alert.freq_once_per_bar)
// منطق الإشارة لدرجة واحدة (كسر + ارتداد، شراء + بيع). di فهرس حالة الدرجة؛ dir اتجاه الدرجة (للارتداد)
f_fibDegSig(DegMem m, int di, int dir, string degName, bool confl) =>
    float fbuf = mgStopPts > 0 ? mgStopPts : 0.25 * atrv
    float minW = fibSigMinWave * atrv   // أدنى حجم للموجة 1 (فلتر الموجات الصغيرة)
    // كسر صعودًا: درجة صاعدة + تصحيح الموجة 2 (قاع أحدث) ثمّ إغلاق يكسر قمّة1 (الاتجاه يطابق رسم الفيبو ⇒ الهدف على ext المرسوم)
    if dir == 1 and not na(m.ltP) and not na(m.lbP) and not na(m.pbP) and m.lbBar > m.ltBar and close > m.ltP and close[1] <= m.ltP
        float rng1   = m.ltP - m.pbP
        float fEntry = close
        float fStop  = math.max(m.lbP, m.ltP - 0.786 * rng1) - fbuf   // قاع2 مقصوصًا عند 0.786
        float fTgt   = m.pbP + 1.618 * rng1
        if fStop < fEntry and fTgt > fEntry and rng1 >= minW
            f_emitFibSig(true, degName, fEntry, fStop, fTgt, confl)
    // كسر هبوطًا: درجة هابطة
    if dir == -1 and not na(m.lbP) and not na(m.ltP) and not na(m.ptP) and m.ltBar > m.lbBar and close < m.lbP and close[1] >= m.lbP
        float rng1   = m.ptP - m.lbP
        float fEntry = close
        float fStop  = math.min(m.ltP, m.lbP + 0.786 * rng1) + fbuf   // قمّة2 مقصوصًا عند 0.786
        float fTgt   = m.ptP - 1.618 * rng1
        if fStop > fEntry and fTgt < fEntry and rng1 >= minW
            f_emitFibSig(false, degName, fEntry, fStop, fTgt, confl)
    // ارتداد صعودًا: لمس 0.618 يُسلّح ⇒ أوّل شمعة صاعدة تُطلِق
    if dir == 1 and not na(m.ltP)
        float w1s = m.ltBar > m.lbBar ? m.lbP : m.pbP
        if not na(w1s) and m.ltP > w1s
            float rng1 = m.ltP - w1s
            float f618 = m.ltP - 0.618 * rng1
            float f786 = m.ltP - 0.786 * rng1
            if m.ltBar != array.get(fibPeakArr, di)
                array.set(fibPeakArr, di, m.ltBar)
                array.set(fibArmArr, di, false)
                array.set(fibFiredArr, di, false)
            if close < m.ltP and low <= f618
                array.set(fibArmArr, di, true)
            if array.get(fibArmArr, di) and not array.get(fibFiredArr, di) and close > open and close > f786
                float fEntry = close
                float fStop  = f786 - fbuf
                float fTgt   = w1s + 1.618 * rng1
                if fStop < fEntry and fTgt > fEntry and rng1 >= minW
                    array.set(fibFiredArr, di, true)
                    f_emitFibSig(true, degName, fEntry, fStop, fTgt, confl)
    // ارتداد هبوطًا
    if dir == -1 and not na(m.lbP)
        float w1s = m.lbBar > m.ltBar ? m.ltP : m.ptP
        if not na(w1s) and w1s > m.lbP
            float rng1 = w1s - m.lbP
            float f618 = m.lbP + 0.618 * rng1
            float f786 = m.lbP + 0.786 * rng1
            if m.lbBar != array.get(fibTroughArr, di)
                array.set(fibTroughArr, di, m.lbBar)
                array.set(fibArmDArr, di, false)
                array.set(fibFiredDArr, di, false)
            if close > m.lbP and high >= f618
                array.set(fibArmDArr, di, true)
            if array.get(fibArmDArr, di) and not array.get(fibFiredDArr, di) and close < open and close < f786
                float fEntry = close
                float fStop  = f786 + fbuf
                float fTgt   = w1s - 1.618 * rng1
                if fStop > fEntry and fTgt < fEntry and rng1 >= minW
                    array.set(fibFiredDArr, di, true)
                    f_emitFibSig(false, degName, fEntry, fStop, fTgt, confl)

// اتجاه الدرجة الكبيرة = اتجاه خط ترند كامل الموجة التاريخية:
//   إن كانت قمّة الموجة أحدث من قاعها ⇒ صاعدة، والعكس ⇒ هابطة. (لا اشتقاق بالكسر)
//   ثبات (hysteresis): لا ينقلب إلا إذا اتّضح الفارق، تفادياً للتذبذب قرب التوازن.
int hbW = ta.highestbars(high, wlen)
int lbW = ta.lowestbars(low, wlen)
int rawBigDir = hbW > lbW ? 1 : -1
var int bigDir = 0
if bigDir == 0
    bigDir := rawBigDir
else if rawBigDir != bigDir and math.abs(hbW - lbW) > wlen * 0.1
    bigDir := rawBigDir

emitSmallTop = false
emitSmallBot = false
float sPx   = na
float sBHi  = na
float sBLo  = na
int   sBar  = na
int   sTime = na
bool  emittedMedBar = false   // عامّ: انبعثت نقطة متوسطة هذه الشمعة؟ (لإعادة بناء المناطق عند الحدث + الصيانة التزايُدية)

if barstate.isconfirmed
    body = math.abs(close - open)
    uw   = high - math.max(close, open)
    lw   = math.min(close, open) - low
    isValid = (not useValid) or (body > 0 and body >= uw and body >= lw)   // [فجوة05] «جسم ≥ كل ذيل» مطابقةً للمدخل والدرس (النويز = ذيل **أطول** من الجسم؛ الجسم=الذيل ليس نويزًا)
    bear = close < open
    bull = close > open

    if sdir == 0
        sdir := 1
        curHi := high
        curHiBHi := math.max(open, close)
        curHiBLo := math.min(open, close)
        curHiBar := bar_index
        curHiTime := time
        curLo := low
        curLoBHi := math.max(open, close)
        curLoBLo := math.min(open, close)
        curLoBar := bar_index
        curLoTime := time
    else if sdir == 1
        // موجة صاعدة: القمة = أعلى سعر قبل التصحيح. التصحيح = شمعتان صحيحتان
        // كل واحدة قاعها أدنى من سابقتها (لا يُشترط تتابُعهما زمنياً؛ تُسمح فجوات).
        if high > curHi
            curHi := high
            curHiBHi := math.max(open, close)
            curHiBLo := math.min(open, close)
            curHiBar := bar_index
            curHiTime := time
            corr := 0
            corrRef := na
            corrPrevBHi := na
            corrPrevBLo := na
        else if isValid and bear
            float bHiC = math.max(open, close)
            float bLoC = math.min(open, close)
            if corr == 0
                corr := 1
                corrRef := low
                corrPrevBHi := bHiC
                corrPrevBLo := bLoC
            else if low < corrRef
                // فحص الابتلاع: لا تُحتسب إن ابتلع جسمها جسم السابقة أو العكس
                bool engulf = (bHiC >= corrPrevBHi and bLoC <= corrPrevBLo) or (corrPrevBHi >= bHiC and corrPrevBLo <= bLoC)
                if not engulf
                    corr := corr + 1
                    corrRef := low
                    corrPrevBHi := bHiC
                    corrPrevBLo := bLoC
            if corr >= minCorr
                emitSmallTop := true
                sPx := curHi
                sBHi := curHiBHi
                sBLo := curHiBLo
                sBar := curHiBar
                sTime := curHiTime
                sdir := -1
                curLo := low
                curLoBHi := math.max(open, close)
                curLoBLo := math.min(open, close)
                curLoBar := bar_index
                curLoTime := time
                corr := 0
                corrRef := na
                corrPrevBHi := na
                corrPrevBLo := na
    else
        // موجة هابطة: القاع = أدنى سعر قبل التصحيح. التصحيح = شمعتان صحيحتان
        // كل واحدة قمّتها أعلى من سابقتها (لا يُشترط تتابُعهما زمنياً).
        if low < curLo
            curLo := low
            curLoBHi := math.max(open, close)
            curLoBLo := math.min(open, close)
            curLoBar := bar_index
            curLoTime := time
            corr := 0
            corrRef := na
            corrPrevBHi := na
            corrPrevBLo := na
        else if isValid and bull
            float bHiC = math.max(open, close)
            float bLoC = math.min(open, close)
            if corr == 0
                corr := 1
                corrRef := high
                corrPrevBHi := bHiC
                corrPrevBLo := bLoC
            else if high > corrRef
                bool engulf = (bHiC >= corrPrevBHi and bLoC <= corrPrevBLo) or (corrPrevBHi >= bHiC and corrPrevBLo <= bLoC)
                if not engulf
                    corr := corr + 1
                    corrRef := high
                    corrPrevBHi := bHiC
                    corrPrevBLo := bLoC
            if corr >= minCorr
                emitSmallBot := true
                sPx := curLo
                sBHi := curLoBHi
                sBLo := curLoBLo
                sBar := curLoBar
                sTime := curLoTime
                sdir := 1
                curHi := high
                curHiBHi := math.max(open, close)
                curHiBLo := math.min(open, close)
                curHiBar := bar_index
                curHiTime := time
                corr := 0
                corrRef := na
                corrPrevBHi := na
                corrPrevBLo := na

    // عند تأكيد قمة/قاع صغيرة: لا تُرسم إلا بعد تأكّدها (تتابُع + فعالية) حسب اتجاه موجتها الصغيرة النشطة
    if emitSmallTop or emitSmallBot
        bool isTop = emitSmallTop
        // اتجاه الموجة الصغيرة النشطة (يُحسب قبل الرسم): يبدأ = اتجاه الموجة التاريخية،
        //   ولا ينقلب إلا بكسر البنية: قمة أعلى من آخر قمة ⇒ صاعدة، قاع أدنى من آخر قاع ⇒ هابطة.
        //   (= قاعدة الدرس: كسر آخر قاع صعوداً / آخر قمة هبوطاً يبدأ موجة صغيرة جديدة.)
        if smallActiveDir == 0
            // [D] التمهيد من المصدر البنيوي للأكبر (largeDir) أولاً؛ نافذة bigDir احتياط أخير فقط
            int sBoot = largeDir != 0 ? largeDir : bigDir
            if sBoot != 0
                smallActiveDir := sBoot
        if isTop and not na(memS.ltP) and sPx > memS.ltP
            smallActiveDir := 1
        if (not isTop) and not na(memS.lbP) and sPx < memS.lbP
            smallActiveDir := -1
        if showSmall and sBar >= drawLeft
            // آلية موحّدة: النقطة لا تُرسم إلا عند تكوّن شريكها المعاكس.
            //   • لا معلّقة ⇒ اجعل الحالية معلّقة (لا ترسم بعد).
            //   • نفس نوع المعلّقة ⇒ استبدلها بالأنسب (الأعلى للقمة/الأدنى للقاع) = تتابُع.
            //   • نوع معاكس ⇒ ارسم المعلّقة (مع شريكها)، ثم اجعل الحالية معلّقة.
            int curType = isTop ? 1 : -1
            if pendType == 0
                pendP := sPx
                pendBar := sBar
                pendType := curType
            else if curType == pendType
                if (isTop and sPx > pendP) or ((not isTop) and sPx < pendP)
                    pendP := sPx
                    pendBar := sBar
            else
                // [ق3 الفعاليّة، v3.87.5 — الدرس 05] النقطة التصحيحيّة لا تُرسم إلّا إن أُكِّدت بتطرّف معاكس:
                //   صعودًا (smallActiveDir==1) القاع المعلّق فعّال إن صنعت القمّةُ التاليةُ (sPx) سعرًا أعلى من
                //   القمّة المرسومة السابقة (ldTopP)؛ هبوطًا القمّة المعلّقة فعّالة بقاعٍ تالٍ (sPx) أدنى من السابق (ldBotP).
                //   الدافعة (قمّة صعودًا/قاع هبوطًا) تُرسم دائمًا. الحالة تتقدّم سواء رُسمت أم لا (تصويريّ فقط، لا يمسّ تغذية المتوسطة).
                bool corrEffS = true
                if smallActiveDir == 1 and pendType == -1
                    corrEffS := na(ldTopP) or sPx > ldTopP
                else if smallActiveDir == -1 and pendType == 1
                    corrEffS := na(ldBotP) or sPx < ldBotP
                if corrEffS
                    color pc = pendType == 1 ? cTop : cBot
                    ldType := storeSArrow(pendType == 1, pendP, pendBar, pc, ldType)
                    if linkSmall and not na(ldAnyBar)
                        line.new(ldAnyBar, ldAnyP, pendBar, pendP, xloc = xloc.bar_index, color = cLineS, width = 1)
                    ldAnyP := pendP
                    ldAnyBar := pendBar
                    if pendType == 1
                        ldTopP := pendP
                        ldTopBar := pendBar
                    else
                        ldBotP := pendP
                        ldBotBar := pendBar
                pendP := sPx
                pendBar := sBar
                pendType := curType
        lastSmallP := sPx
        lastSmallBar := sBar
        // [تشخيص] خزّن نقطة الصغيرة بالترتيب (لجدول الاشتقاق صغيرة→متوسطة→كبيرة)
        array.push(dsP, sPx)
        array.push(dsBar, sBar)
        array.push(dsTop, isTop)
        if array.size(dsP) > 200
            array.shift(dsP)
            array.shift(dsBar)
            array.shift(dsTop)
        // (اتجاه الموجة الصغيرة النشطة smallActiveDir حُسب قبل كتلة الرسم أعلاه — قاعدة الدرس)
        int sActive = smallActiveDir != 0 ? smallActiveDir : (largeDir != 0 ? largeDir : bigDir)
        // سيولة ومستوى الدرجة الصغيرة (قيمة المستوى = حافة الجسم المواجهة)
        float sLevel = isTop ? sBHi : sBLo
        // [V4.22] الصغيرة هي الأساس الخام ⇒ نرفع قيد موجة التجدّد (waveStart=na) فيُرسم خطّ السيولة الأحمر
        //   على آخر قاعين/قمّتين دائمًا (memS تحفظ آخر+سابق فقط ⇒ لا خطّ شارد). كان smGate يحجبه عند تجدّد الصغيرة.
        updateDeg(memS, isTop, sPx, sLevel, sBar, sActive, cLiqS, cLvlS, showLiq, showLvl, na, liqExtBars, lvlExtBars, hwHiBand, hwLoBand, wSmall, wSmall)
        // آلة المراحل العامة عند انبثاق نقطة صغيرة
        phaseOnPivot(smallPh, isTop, sPx, sBar)

        // --- الدرجة المتوسطة ---
        [emM, ePM, eBHiM, eBLoM, eTimeM, eBM, eTopM] = feed(pmed, sPx, sBHi, sBLo, sTime, sBar, isTop)
        if emM
            float levelM = eTopM ? eBHiM : eBLoM   // خط المستوى (قمة=أعلى الجسم، قاع=أسفل الجسم)
            label mlbl = na
            label mlblO = na
            if showMed and eBM >= drawLeft
                // دائرة TradingView الأصلية: حلقة خارجية = بوردر ثابت (محجوز لاحقاً)، ثم تعبئة داخلية = الفعالية.
                mlblO := label.new(eBM, ePM, "", xloc = xloc.bar_index, yloc = yloc.price,
                     style = label.style_circle, color = cMedBorder, size = f_lblSize(medCircleSize))
                mlbl  := label.new(eBM, ePM, "", xloc = xloc.bar_index, yloc = yloc.price,
                     style = label.style_circle, color = cMed, size = f_lblSizeIn(medCircleSize))
            // خزّن النقطة المتوسطة (فعّالة مبدئياً)
            array.push(mcP, ePM)
            array.push(mcLvl, levelM)
            array.push(mcHi, eBHiM)
            array.push(mcLo, eBLoM)
            array.push(mcBar, eBM)
            array.push(mcTm, eTimeM)
            array.push(mcTop, eTopM)
            array.push(mcEff, true)
            array.push(mcLbl, mlbl)
            array.push(mcLblO, mlblO)
            emittedMedBar := true   // المرحلة 1: نقطة متوسطة جديدة ⇒ صيانة تزايُدية لاحقاً (بعد تثبيت الاتجاه)
            // (الفعالية تُحسب في نهاية الشارت حسب الفاصل histLeft: داخل الموجة التاريخية
            //  كل النقاط فعّالة برتقالية؛ وفي تاريخ التاريخ يُلوَّن المُغطّى أحمر.)
            // حدّ المخزن [فجوة06] رُفِع 80→150: على الشارتات الطويلة كان شريك المنطقة التاريخيّ الأعمق من 80 نقطة يُزاح ⇒ منطقة بلا شريك. 150 يضاعف الهامش؛ الأداء سليم (الفعالية/المناطق islast وn مسقوف؛ الحلقات بـsize).
            if array.size(mcP) > 150
                label oldLbl = array.get(mcLbl, 0)
                if not na(oldLbl)
                    label.delete(oldLbl)
                label oldLblO = array.get(mcLblO, 0)
                if not na(oldLblO)
                    label.delete(oldLblO)
                array.shift(mcP)
                array.shift(mcLvl)
                array.shift(mcHi)
                array.shift(mcLo)
                array.shift(mcBar)
                array.shift(mcTm)
                array.shift(mcTop)
                array.shift(mcEff)
                array.shift(mcLbl)
                array.shift(mcLblO)
            if linkMed and not na(lastMedBar) and eBM >= drawLeft
                line.new(lastMedBar, lastMedP, eBM, ePM, xloc = xloc.bar_index,
                     color = cLineM, width = 2)
            // نهاية تصحيح متوسط: أعد تأسيس مراجع الصغيرة من النقطة المتوسطة (موجة صغيرة جديدة).
            // (M5) يُمسح بصرياً ما رُسم من أسهم صغيرة داخل ساق التصحيح (أدناه) — الحالة الوظيفية تبقى.
            // نهاية تصحيح متوسط: الاتجاه الحاكم = اتجاه الموجة المتوسطة المنتِجة للتصحيح
            //   (fallback إلى bigDir فقط عند الصفر — تمهيد أوّلي مشروع، لا قاعدة دائمة).
            int  corrDir = medActiveDir != 0 ? medActiveDir : (largeDir != 0 ? largeDir : bigDir)
            bool upW     = corrDir == 1
            bool corrEnd = (upW and not eTopM) or ((not upW) and eTopM)
            if corrEnd
                // (M5) نظافة التصحيح المتوسط: امسح الأسهم الصغيرة المرسومة الواقعة داخل
                //   ساق التصحيح (lastMedBar → eBM) حصراً — مسح بصري لا يمسّ حالة الصغيرة.
                if not na(lastMedBar) and array.size(sArrB) > 0   // قاعدة الدرس (دائمة): التصحيح المتوسط يخلو من الأسهم الصغيرة
                    for k = array.size(sArrB) - 1 to 0
                        int ab = array.get(sArrB, k)
                        if ab > lastMedBar and ab < eBM
                            polyline.delete(array.get(sArr, k))
                            array.remove(sArr, k)
                            array.remove(sArrB, k)
                if upW
                    ldBotP := ePM
                    ldBotBar := eBM
                    ldTopP := na
                else
                    ldTopP := ePM
                    ldTopBar := eBM
                    ldBotP := na
                ldAnyP := ePM
                ldAnyBar := eBM
                ldType := 0
            lastMedP := ePM
            lastMedBar := eBM
            array.push(medBars, eBM)
            if array.size(medBars) > 20
                array.shift(medBars)
            // اتجاه الموجة المتوسطة النشطة المستقرّ — تمهيد أولي فقط (عند الصفر).
            //   بعد التهيئة، لا ينقلب إلا بكسر مستوى الاتجاه المتوسط بشمعتين (انتهاء الموجة).
            if medActiveDir == 0
                if eTopM and not na(memM.ltP) and ePM > memM.ltP
                    medActiveDir := 1
                    if na(medWaveStart)   // [V3.78] مرساة الموجة الأولى = آخر قاع (بداية الصعود)؛ كانت تُضبط عند الانقلاب فقط ⇒ v3.77 (الإرساء على التطرّف) معطَّل قبل أوّل انقلاب
                        medWaveStart := na(memM.lbBar) ? eBM : memM.lbBar
                if (not eTopM) and not na(memM.lbP) and ePM < memM.lbP
                    medActiveDir := -1
                    if na(medWaveStart)   // [V3.78] مرساة الموجة الأولى = آخر قمّة (بداية الهبوط)
                        medWaveStart := na(memM.ltBar) ? eBM : memM.ltBar
            int mActive = medActiveDir != 0 ? medActiveDir : (largeDir != 0 ? largeDir : bigDir)
            // سيولة ومستوى الدرجة المتوسطة
            updateDeg(memM, eTopM, ePM, levelM, eBM, mActive, cLiqM, cLvlM, false, false, medGate, liqExtBars, lvlExtBars, hwHiBand, hwLoBand, wMed, wMed)   // [V3.6] السيولة/المستوى المتوسط تُحسب فعّالةً عند islast/emittedMedBar (لا عند الانبعاث)

            // --- آلة المراحل العامة عند انبثاق نقطة متوسطة (ذعر⇒يأس + تتبّع الامتداد) ---
            phaseOnPivot(medPh, eTopM, ePM, eBM)

            // --- تغذية مرحلة الكبيرة بالكسر (مستقلّة عن useBigBreak ورسم الكبيرة) ---
            //   تُشتقّ نقاط الكبيرة منطقياً من المتوسطة بالكسر (نفس آلية اشتقاق المتوسطة من الصغيرة).
            //   memBph/bigPh للمرحلة فقط — لا رسم (أعلام updateDeg مطفأة) ⇒ لا تكدّس.
            [embp, ePbp, eHibp, eLobp, eTbp, eBbp, eTopbp] = feed(pbigPh, ePM, eBHiM, eBLoM, eTimeM, eBM, eTopM)
            if embp
                int bDirPiv = largeDir != 0 ? largeDir : bigDir
                updateDeg(memBph, eTopbp, ePbp, (eTopbp ? eHibp : eLobp), eBbp, bDirPiv, na, na, false, false, na, 0, 0, na, na, 2, 2)
                phaseOnPivot(bigPh, eTopbp, ePbp, eBbp)

            // (المناطق تُبنى في نهاية الشارت من النقاط المتوسطة الفعّالة فقط — أسفل)


            // ملاحظة [صُحّح v3.87.12]: اتجاه الكبيرة من bigDirLvl (حالتان، §07) يُقرأ islast.
            //         بناء قمم/قيعان الكبيرة (آخر ~7 موجات) يتمّ **لاحقاً** (§07، islast)
            //         بالاستخراج **بالكسر** من المتوسطة الفعّالة (المسار الافتراضيّ useBigBreak) — لا اشتقاق إنلاين هنا.

    // ===== كاشف كسر خط السيولة المتوسط (نصف الجسم) — أساس المراحل الخمس =====
    // الكسر = إغلاق شمعة خلف خط السيولة بأكثر من نصف جسمها.
    //   سيولة صاعدة (آخر قاعين) ⇒ كسر هابط يبدأ التصريف/الذعر.
    //   سيولة هابطة (آخر قمتين) ⇒ كسر صاعد.
    // (آلة المراحل تُعيد التهيئة ذاتياً عند بدء المشاركة العامة الجديدة — لا نصفّر بتغيّر الاتجاه)
    int mDir = medActiveDir != 0 ? medActiveDir : (largeDir != 0 ? largeDir : bigDir)
    // ===== كسر مستوى الاتجاه المتوسط (شمعتان) ⇒ نهاية الموجة وبدء موجة معاكسة =====
    // (كسر بنيوي مختلف عن كسر السيولة للمراحل): صاعدة ⇒ شمعتان حمراوان تحت آخر قاع؛
    //  هابطة ⇒ شمعتان خضراوان فوق آخر قمة. القمم/القيعان القديمة تبقى (تاريخ التاريخ).
    float medTL = mDir == 1 ? memM.lbBody : mDir == -1 ? memM.ltBody : na
    if not na(medTL) and medActiveDir != 0
        if mDir == 1
            medTLcnt := (close < open and close < medTL) ? medTLcnt + 1 : 0
            if medTLcnt >= 2
                medActiveDir := -1            // انتهت الصاعدة ⇒ نبدأ هابطة من البداية
                medWavePrevStart := medWaveStart                          // الموجة المنتهية ⇒ تاريخ التاريخ
                // [V3.77] الموجة الهابطة تبدأ من **أعلى قمّة** في الموجة الصاعدة قبل الكسر — لا آخر قمّة (قد تكون قمّة أدنى عند التباعُد). الدرس 03 «من البداية إلى أعلى نقطة» + الدرس 05 «بداية التصحيح = القمّة/أعلى نقطة».
                float hiPf   = memM.ltP
                int   hiBarf = memM.ltBar
                int   nmcF   = array.size(mcP)
                if nmcF > 0
                    for imf = 0 to nmcF - 1
                        if array.get(mcTop, imf) and array.get(mcBar, imf) >= medWaveStart and array.get(mcBar, imf) <= bar_index
                            float pimf = array.get(mcP, imf)
                            if na(hiPf) or pimf > hiPf
                                hiPf   := pimf
                                hiBarf := array.get(mcBar, imf)
                medWaveStart := na(hiBarf) ? bar_index : hiBarf  // قمة الانعكاس = **أعلى** قمّة في الموجة (لا آخر قمّة)
                smallActiveDir := medActiveDir   // الصغيرة تبدأ مع الموجة المعاكسة الجديدة (من البداية)
                smallWaveStart := medWaveStart
                smallWaveStartTime := time   // [V3.66] زمن بدء الموجة (للحصر الزمنيّ ب)
                // (آلية النقطة المعلّقة تَعبُر الانقلاب: آخر نقطة من الموجة السابقة تقترن بأول نقطة جديدة)
                medTLcnt := 0
                if not na(memM.liq)
                    line.delete(memM.liq)
                    memM.liq := na
                medLiqBrkBar := na   // [V4.61] انقلاب الاتجاه ⇒ بداية جديدة، صفّر تجميد الكسر
                if not na(memM.lvl)
                    if keepBrokenLvl
                        f_retainBroken(memM.lvl, bar_index)   // جمّد مستوى الاتجاه المكسور قبل حذفه
                    line.delete(memM.lvl)
                    memM.lvl := na
        if mDir == -1
            medTLcnt := (close > open and close > medTL) ? medTLcnt + 1 : 0
            if medTLcnt >= 2
                medActiveDir := 1             // انتهت الهابطة ⇒ نبدأ صاعدة من البداية
                medWavePrevStart := medWaveStart                          // الموجة المنتهية ⇒ تاريخ التاريخ
                // [V3.77] الموجة الصاعدة تبدأ من **أدنى قاع** في الموجة الهابطة قبل الكسر — لا آخر قاع (قد يكون قاعًا أعلى عند التباعُد). الدرس 03 + الدرس 05 (مرآةً).
                float loPf   = memM.lbP
                int   loBarf = memM.lbBar
                int   nmcG   = array.size(mcP)
                if nmcG > 0
                    for img = 0 to nmcG - 1
                        if (not array.get(mcTop, img)) and array.get(mcBar, img) >= medWaveStart and array.get(mcBar, img) <= bar_index
                            float pimg = array.get(mcP, img)
                            if na(loPf) or pimg < loPf
                                loPf   := pimg
                                loBarf := array.get(mcBar, img)
                medWaveStart := na(loBarf) ? bar_index : loBarf  // قاع الانعكاس = **أدنى** قاع في الموجة (لا آخر قاع)
                smallActiveDir := medActiveDir   // الصغيرة تبدأ مع الموجة المعاكسة الجديدة (من البداية)
                smallWaveStart := medWaveStart
                smallWaveStartTime := time   // [V3.66] زمن بدء الموجة (للحصر الزمنيّ ب)
                // (آلية النقطة المعلّقة تَعبُر الانقلاب: آخر نقطة من الموجة السابقة تقترن بأول نقطة جديدة)
                medTLcnt := 0
                // القديم يصبح تاريخ التاريخ: امسح الخط وانتظر قاعين جديدين (لا ترسم بالقديم)
                if not na(memM.liq)
                    line.delete(memM.liq)
                    memM.liq := na
                medLiqBrkBar := na   // [V4.61] انقلاب الاتجاه ⇒ بداية جديدة، صفّر تجميد الكسر
                if not na(memM.lvl)
                    if keepBrokenLvl
                        f_retainBroken(memM.lvl, bar_index)   // جمّد مستوى الاتجاه المكسور قبل حذفه
                    line.delete(memM.lvl)
                    memM.lvl := na
    mDir := medActiveDir != 0 ? medActiveDir : (largeDir != 0 ? largeDir : bigDir)
    // ===== [v3.86] اتجاه الكبيرة بقاعدة المستخدم (حالتان) — آلة حالة per-bar (مرآة المتوسطة) =====
    //   تغذّي largeDir عند islast (يبقى largeDir islast ⇒ صفر انحدار تاريخيّ؛ هنا نبني الحالة per-bar فقط).
    if bigDirLvl == 0
        bigDirLvl := medActiveDir != 0 ? medActiveDir : bigDir   // تمهيد أوّليّ
    // الحالة 2: انقلاب المتوسطة + بنية زرقاء صالحة (قاعان متصاعدان صعودًا / قمّتان متنازلتان هبوطًا — شرط رسم السيولة الزرقاء)
    if medActiveDir == 1 and not na(memBph.lbP) and not na(memBph.pbP) and memBph.lbP > memBph.pbP
        bigDirLvl := 1
    else if medActiveDir == -1 and not na(memBph.ltP) and not na(memBph.ptP) and memBph.ltP < memBph.ptP
        bigDirLvl := -1
    // الحالة 1: كسر مستوى الكبيرة نفسها بشمعتين (يطغى على الحالة 2) — المستوى = تطرّف آخر قاع/قمّة زرقاء (memBph)
    //   صعودًا: شمعتان حمراوان تُغلقان تحت قاع الكبيرة ⇒ هابط · هبوطًا: شمعتان خضراوان فوق قمّتها ⇒ صاعد (الدرس 09)
    float bigTLv = bigDirLvl == 1 ? memBph.lbBody : bigDirLvl == -1 ? memBph.ltBody : na
    if not na(bigTLv)
        if bigDirLvl == 1
            bigTLcnt := (close < open and close < bigTLv) ? bigTLcnt + 1 : 0
            if bigTLcnt >= 2
                bigDirLvl := -1
                bigTLcnt := 0
        else
            bigTLcnt := (close > open and close > bigTLv) ? bigTLcnt + 1 : 0
            if bigTLcnt >= 2
                bigDirLvl := 1
                bigTLcnt := 0
    // ===== المرحلة 1: صيانة فعالية المتوسطة تزايُدياً (per-bar, non-repainting) =====
    //   تُنفَّذ بعد تثبيت الاتجاه/بداية الموجة لهذه الشمعة، عند انبعاث نقطة متوسطة فقط.
    //   النقطة الجديدة = آخر عنصر في mc* (قد يكون بارها ماضياً، لذا نعتمد العَلَم لا bar_index).
    if emittedMedBar
        int   iNew = array.size(mcP) - 1
        if iNew >= 0
            float pNew = array.get(mcP, iNew)
            bool  tNew = array.get(mcTop, iNew)
            int   bNew = array.get(mcBar, iNew)
            // (ب) التغطية [M4]: النقطة الجديدة تُغطّي الأقدم من نوعها (مقارنة سعر، مستقلّة عن الاتجاه؛ رتيبة — false فقط)
            if iNew >= 1
                for j = 0 to iNew - 1
                    if array.get(mcTop, j) == tNew
                        if tNew ? (pNew > array.get(mcP, j)) : (pNew < array.get(mcP, j))
                            array.set(mcEff, j, false)
            // إعادة ضبط مرجع التتابُع عند انعكاس الموجة المتوسطة (تغيّر بدايتها)
            int wsM = na(medWaveStart) ? histLeft : medWaveStart
            if mcSeqWsBar != wsM
                mcSeqRef   := na
                mcSeqWsBar := wsM
            // (ج) فعالية النقطة الجديدة عبر التتابُع [M3]: نقطة دافعة داخل الموجة النشطة يجب أن تتجاوز المرجع
            bool seqIsTop = (medActiveDir == 1)
            bool effNew = true
            if medActiveDir != 0 and bNew >= wsM and tNew == seqIsTop and not na(mcSeqRef)
                if seqIsTop ? (pNew <= mcSeqRef) : (pNew >= mcSeqRef)
                    effNew := false
            array.set(mcEff, iNew, effNew)
            // (د) تقديم مرجع التتابُع على النقطة المُبقاة من نوع الدافعة داخل الموجة النشطة
            if medActiveDir != 0 and bNew >= wsM and tNew == seqIsTop and effNew
                if na(mcSeqRef) or (seqIsTop ? pNew > mcSeqRef : pNew < mcSeqRef)
                    mcSeqRef := pNew
    // [V3.71] إصلاح اختفاء الإشارات: v3.68 جعل المرحلة تقرأ memM.liq (مرسوم في islast فقط) ⇒ تاريخيًّا na ⇒ المرحلة المتوسطة (mc2 = مصدر شرط المرحلة الوحيد للإشارات؛ الصغيرة بلا phaseOnBar) لا تتقدّم ⇒ لا تصل تجميعًا(3) ⇒ لا إشارة.
    //   الحلّ: medLiqLvl **per-bar** (يتقدّم تاريخيًّا) + **شرط التصاعد** (memM.lbP>pbP صعودًا / ltP<ptP هبوطًا) يطابق رسم السيولة v3.69 فيقلّل الذعر الكاذب دون كسر الإشارات.
    float medLiqLvl = na
    if mDir == 1 and not na(memM.lbP) and not na(memM.pbP) and memM.lbBar != memM.pbBar and memM.lbP > memM.pbP
        float slope = (memM.lbP - memM.pbP) / (memM.lbBar - memM.pbBar)
        medLiqLvl := memM.lbP + slope * (bar_index - memM.lbBar)
    if mDir == -1 and not na(memM.ltP) and not na(memM.ptP) and memM.ltBar != memM.ptBar and memM.ltP < memM.ptP
        float slope = (memM.ltP - memM.ptP) / (memM.ltBar - memM.ptBar)
        medLiqLvl := memM.ltP + slope * (bar_index - memM.ltBar)
    phaseOnBar(medPh, mDir, medLiqLvl, close, open)
    medBreakDir := medPh.brkDir   // (متاح إن احتاجته أجزاء أخرى)
    // [V4.64] كسر خط السيولة المتوسط = **كسر بنيويّ بشمعتين** (الدرس 09 حرفيًّا: «شمعتان تحت بعض») — لا نصف جسم
    //   (ذاك للمرحلة) ولا عبور بشمعة واحدة. عند تأكّده: يُمسَح الخطّ + يُسجَّل medLiqBrkBar ⇒ لا يُعاد رسمه إلّا
    //   بظهور **قاعين/قمّتين جديدين** بعد بار الكسر (المرجع: الكسور الثلاثة، three-break-thresholds).
    //   يعمل فقط والخط مرسوم؛ أثناء الانتظار (ممسوح) يتوقّف حتى لا يتقدّم brkBar بلا نهاية.
    bool medStruct = false
    if useRenewal and not na(memM.liq)
        // [V4.67] الكسر البنيويّ يُقاس على **الخطّ المائل المرسوم نفسه** (memM.liq) لا على medLiqLvl المنطقيّ
        //   (الأخير من memM.lbP/pbP الخامّتين، والمرسوم من mb1/mb2 الفعّالتين ⇒ يختلفان ⇒ تأخّر المسح ساعات بعد
        //   الكسر البصريّ). شمعتان تغلقان خلف الخطّ المرسوم ⇒ مسح فوريّ مطابق لما يراه المستخدم.
        medStruct := structuralBreak(medLB, mDir, line.get_price(memM.liq, bar_index), close, open)
    else
        medLB.cnt := 0
    if medStruct and not na(memM.liq)
        if keepBrokenLiq
            f_retainBroken(memM.liq, bar_index)
        line.delete(memM.liq)
        memM.liq := na
        medLiqBrkBar := bar_index
    // البوّابة: عند التفعيل = أحدث حدث (كسر مستوى أو كسر بنيوي)؛ وإلا = كسر المستوى فقط (الموثوق)
    medGate := useRenewal ? (na(medWaveStart) ? medLB.brkBar : na(medLB.brkBar) ? medWaveStart : math.max(medWaveStart, medLB.brkBar)) : medWaveStart
    // نص المرحلة (مطابق للدرس): مشاركة عامة / ذعر / يأس
    medPhase := phaseText(medPh, mDir)

    // ===== مرحلة الكبيرة (نفس الآلة، على خط سيولة كبيرة منطقي — لا يُرسم، لا تكدّس) =====
    //   التزام الدروس: منطق المراحل الخمس للكبيرة = نفس آلة Phase المؤكّدة (الدرس 11 [P5]، بلا زيادة/نقصان).
    //   المرحلة تعكس البنية الحقيقية بالكسر دائماً (قانون [NEW-1] الزرقاء بالكسر) — الأصحّ بنيوياً —
    //   لا «الرسم بالنظر» الحرفي للدرس 7. عند إطفاء useBigBreak يستعمل الرسم تجميع legs للعرض فقط،
    //   وقد يختلف عن نقاط المرحلة (الكسر) — مقبول وموثّق: المرحلة هي المرجع البنيوي، والرسم عرضٌ فقط.
    //   (افتراضياً useBigBreak مفعّل ⇒ الجانبان متّسقان.)
    //   bigLiqLvl قيمة منطقية فقط من memBph (آخر قاعين صعوداً / قمتين هبوطاً) — لا line.new.
    int   bDirPh = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : (largeDir != 0 ? largeDir : bigDir)   // [V4.90] توحيد: مرحلة الكبيرة تتبع اتجاه المرساة (bigAncDir) كاللوحة/الإشارات
    float bigLiqLvl = na
    if bDirPh == 1 and not na(memBph.lbP) and not na(memBph.pbP) and memBph.lbBar != memBph.pbBar
        float slopeBp = (memBph.lbP - memBph.pbP) / (memBph.lbBar - memBph.pbBar)
        bigLiqLvl := memBph.lbP + slopeBp * (bar_index - memBph.lbBar)
    if bDirPh == -1 and not na(memBph.ltP) and not na(memBph.ptP) and memBph.ltBar != memBph.ptBar
        float slopeBp = (memBph.ltP - memBph.ptP) / (memBph.ltBar - memBph.ptBar)
        bigLiqLvl := memBph.ltP + slopeBp * (bar_index - memBph.ltBar)
    phaseOnBar(bigPh, bDirPh, bigLiqLvl, close, open)
    bigPhase := phaseText(bigPh, bDirPh)
    // [V4.72] كسر خطّ السيولة الأزرق البنيويّ (شمعتان على **الخطّ المرسوم** bigLiqLine) ⇒ مسح فوريّ +
    //   لا يُعاد رسمه إلّا بمحورين زرقاوين جديدين (كما المتوسط v4.64/v4.67). الكبيرة ثابتة لكنّ سيولتها تُمسَح عند كسرها.
    int bigLqDirB = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : largeDir   // [V4.89] اتجاه الخطّ المرسوم (المرساة) لا largeDir — اتّساقًا مع كسر المستوى (v4.77)
    if useRenewal and not na(bigLiqLine)
        if structuralBreak(bigLB, bigLqDirB, line.get_price(bigLiqLine, bar_index), close, open)
            line.delete(bigLiqLine)
            bigLiqLine := na
            bigLiqBrkBar := bar_index
    else
        bigLB.cnt := 0
    // [V4.76] **كسر مستوى الاتجاه الأزرق = شمعتان** على الخطّ المرسوم (الدرس، rule 3): تنتهي موجة الأزرق ⇒ امحُ خطّيه
    //   (سيولة+مستوى) وانتظر محاور زرقاء جديدة (القاعدة 2). المُطلِق الصحيح = كسر الأزرق فعليًّا (السعر تحت قاعه/فوق قمّته)
    //   — لا تصحيح متوسط فوق القاع الأزرق (السعر يبقى فوق الخطّ ⇒ لا كسر ⇒ يبقى الأزرق على قاعه الفعّال). بلا قلب largeDir.
    if useRenewal and not na(bigLvlLine)
        int bigLvlDirB = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : largeDir   // [V4.77] اتجاه الخطّ المرسوم (المرساة) لا largeDir — وإلّا كشف الكسر على الجهة الخطأ
        if structuralBreak(bigLvlLB, bigLvlDirB, line.get_price(bigLvlLine, bar_index), close, open)
            if not na(bigLiqLine)
                line.delete(bigLiqLine)
                bigLiqLine := na
            bigLiqBrkBar := bar_index
            line.delete(bigLvlLine)
            bigLvlLine := na
            bigLvlBrkBar := bar_index
    else
        bigLvlLB.cnt := 0

    // ===== مرحلة الصغيرة (نفس الآلة، على خط سيولة الصغيرة واتجاهها) =====
    int sDir = smallActiveDir != 0 ? smallActiveDir : (largeDir != 0 ? largeDir : bigDir)
    float smLiqLvl = na
    if sDir == 1 and not na(memS.lbP) and not na(memS.pbP) and memS.lbBar != memS.pbBar and memS.lbP > memS.pbP   // [فجوة08] شرط التصاعد (قاعان متصاعدان) مرآةً لـ medLiqLvl — فلا ذعر كاذب على زوج غير متّجه
        float slopeS = (memS.lbP - memS.pbP) / (memS.lbBar - memS.pbBar)
        smLiqLvl := memS.lbP + slopeS * (bar_index - memS.lbBar)
    if sDir == -1 and not na(memS.ltP) and not na(memS.ptP) and memS.ltBar != memS.ptBar and memS.ltP < memS.ptP   // [فجوة08] شرط التنازل (قمّتان متنازلتان) مرآةً لـ medLiqLvl
        float slopeS = (memS.ltP - memS.ptP) / (memS.ltBar - memS.ptBar)
        smLiqLvl := memS.ltP + slopeS * (bar_index - memS.ltBar)
    // (اتجاه الدرجة الصغيرة يُحدَّد من بنية قممها/قيعانها في المحرّك الأساسي — لا حاجة لكسر مستوى منفصل.)
    // التقاط تأكيد المشاركة الصغيرة الجديدة (المُطلِق لتأكيد الصفقة المتوسطة)
    int psBrk  = smallPh.brkDir
    int psCode = smallPh.code
    phaseOnBar(smallPh, sDir, smLiqLvl, close, open)
    smConfBuy  := (psCode == 2 or psCode == 3) and smallPh.code == 0 and psBrk == -1   // مشاركة صغيرة صاعدة جديدة (من يأس/تجميع)
    smConfSell := (psCode == 2 or psCode == 4) and smallPh.code == 0 and psBrk == 1    // مشاركة صغيرة هابطة جديدة (من يأس/تصريف)
    bool smStruct = false
    if useRenewal and not na(memS.liq)
        // [V4.71] الكسر على **الخطّ المرسوم نفسه** memS.liq (لا smLiqLvl المنطقيّ) — كما المتوسط v4.67.
        smStruct := structuralBreak(smLB, sDir, line.get_price(memS.liq, bar_index), close, open)
    else
        smLB.cnt := 0
    if smStruct and not na(memS.liq)
        line.delete(memS.liq)
        memS.liq := na
    // [V4.70] حذف المستوى الأحمر (الصغير) عند **كسره** (شمعتان على الخطّ المرسوم) — كان يبقى حتى الانبعاث التالي.
    //   الصغيرة لا تنقلب بكسر المستوى (اتجاهها من البنية)، لكن الخطّ المكسور يُحذف فورًا حتى لا يبقى مكسورًا.
    if useRenewal and not na(memS.lvl)
        if structuralBreak(smLvlLB, sDir, line.get_price(memS.lvl, bar_index), close, open)
            line.delete(memS.lvl)
            memS.lvl := na
    else
        smLvlLB.cnt := 0
    smGate := useRenewal ? (na(smallWaveStart) ? smLB.brkBar : na(smLB.brkBar) ? smallWaveStart : math.max(smallWaveStart, smLB.brkBar)) : smallWaveStart
    smallPhase := phaseText(smallPh, sDir)

    // ===== طبقة الفرص (المرحلة 2): داخل منطقة + AllowedSide + المرحلة المناسبة =====
    // داخل منطقة = عضوية في قائمة المناطق المُصانة (تُبنى عند الانبعاث بخوارزمية islast الكاملة:
    //   greedy الأقرب عالمياً + استهلاك + منع احتواء). فحص رخيص O(Z)، non-repainting.
    // [V4.88] النقطة 4: الإشارات تتبع **نفس اتجاه الاستنتاجات/اللوحة** = اتجاه السيولة الأزرق المرسوم (bigAncDir)
    //   لا largeDir البنيويّ — وإلّا قد تخالف الإشارةُ «الدخول المتاح» في اللوحة. احتياطيّ largeDir/bigDir عند غياب المرساة.
    //   [ملاحظة هامّة — لا تُسقط الاحتياطيّ] bigAncDir يُضبَط في islast فقط (=0 تاريخيًّا)، بينما المناطق per-bar ⇒ بلا احتياطيّ تختفي الإشارات التاريخيّة (انحدار). التباين النادر (لا مرساة) يُعالَج في اللوحة عند اللزوم.
    int   bEff = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : (largeDir != 0 ? largeDir : bigDir)
    int   mEff = medActiveDir != 0 ? medActiveDir : bEff
    bool  buyOK  = (bEff == 1 and mEff == 1) or (bEff != mEff)   // اتفاق صاعد ⇒ شراء؛ تعارض ⇒ الاثنان
    bool  sellOK = (bEff == -1 and mEff == -1) or (bEff != mEff)
    // ===== الاستنتاجات (الدرس 10) — تُحسب الآن **داخل f_drawConclusionsPanel** (v3.76) بعد رسم الخطوط لتعكس الحالة الفعليّة =====
    // [V3.78] حُذفت من هنا حسابات concDefined/concRange/concLiqDir/entryDefined/entryRange/concEntry (+ aliases medLiqDir/bigLiqDir/medLvlDir/bigLvlDir):
    //   صارت **كتابات ميتة** بعد لفّ اللوحة (لا قارئ خارج اللوحة، واللوحة تعيد حسابها محلّيًّا بعد الرسم) ⇒ تنظيف + توفير حساب per-bar + تقليص الجسم الرئيسيّ. (concStrong/concCorrectionLikely أدناه تبقى — تُقرأ في اللوحة.)
    // (4) ربط حالات السوق (الدرس 11): الدرجات الثلاث «مشاركة عامة» + سيولة ضعيفة + سعر قرب ذروة الموجة
    //   ⇒ تصحيح متوسط متوقّع (قد يصل لخط السيولة الأكبر). مراحل الدرجات per-bar (medPh/bigPh/smallPh).
    bool allMarkup = bigPh.code == 0 and medPh.code == 0 and smallPh.code == 0
    float histRng  = hwHiBand - hwLoBand
    bool priceExtreme = histRng > 0 and (bEff == 1 ? close > hwLoBand + 0.8 * histRng : bEff == -1 ? close < hwHiBand - 0.8 * histRng : false)
    concCorrectionLikely := allMarkup and (not concStrong) and priceExtreme
    concStrongDef := false   // [V3.59] يُعاد كل بار؛ يُضبط true فقط إن حُسبت القوة للاتجاه الحاليّ أدناه ⇒ العرض يُظهر «—» لا قيمة قديمة
    // (2) قوة السيولة العامّة: **نقاطُها من الصغيرة** (memS/dsP)، لكنّ **اتجاهَها = الترند الأكبر (المتوسطة medActiveDir)**
    //   [v3.87.10 — قرار المستخدم «عكس الصغيرة»]: تُقاس صحّة الترند بتصحيحات الصغيرة. حين توافق الصغيرةُ الترندَ ⇒ نفس قوّتها؛
    //   وحين تنقلب الصغيرة (تصحيح/انعكاس) ⇒ تلقائيًّا **عكسها** (تصحيح قويّ = ترند ضعيف). [رجوعٌ عن v3.87.8 التي جعلتها smallActiveDir
    //   فأظهرت «قويّة» من صغيرة منقلبة هابطة بجانب ترند صاعد ⇒ تناقُض ظاهريّ]. صفّ «الصغيرة» في اللوحة يبقى يعرض قوّتها الخام (smlEff).
    //   صعوداً: آخر قاع صغير عند/فوق المقاومة المكسورة (ثاني قمة صغيرة قبله) ⇒ قويّة. هبوطاً: المرآة.
    float liqTolV = liqTol * atrv
    int   nds = array.size(dsP)
    if medActiveDir == -1 and not na(memS.ltP)
        float prevBrokenLow = na
        int   refBar = na(memS.ltBar) ? bar_index : memS.ltBar
        int   cnt = 0
        if nds > 0
            for i = nds - 1 to 0
                if (not array.get(dsTop, i)) and array.get(dsBar, i) < refBar
                    cnt := cnt + 1
                    if cnt == 2
                        prevBrokenLow := array.get(dsP, i)
                        break
        if not na(prevBrokenLow)
            concStrong := (prevBrokenLow - memS.ltP) >= -liqTolV   // [v3.87.9] قويّة = القمّة التصحيحيّة عند/تحت القاع المرجع (ملامسة أو قبله)؛ ضعيفة = اخترقته فوقه بأكثر من السماحيّة
            concStrongDef := true
    if medActiveDir == 1 and not na(memS.lbP)
        float prevBrokenHigh = na
        int   refBarU = na(memS.lbBar) ? bar_index : memS.lbBar
        int   cntU = 0
        if nds > 0
            for i = nds - 1 to 0
                if array.get(dsTop, i) and array.get(dsBar, i) < refBarU
                    cntU := cntU + 1
                    if cntU == 2
                        prevBrokenHigh := array.get(dsP, i)
                        break
        if not na(prevBrokenHigh)
            concStrong := (memS.lbP - prevBrokenHigh) >= -liqTolV   // [v3.87.9] قويّة = قاع التصحيح عند/فوق القمّة المرجع (ملامسة أو قبله)؛ ضعيفة = اخترقها تحتها بأكثر من السماحيّة
            concStrongDef := true
    bool  inZone = false
    float zbCur  = na
    float ztCur  = na
    int znc = array.size(zTop)
    if znc > 0
        for k = 0 to znc - 1
            float zt = array.get(zTop, k)
            float zb = array.get(zBot, k)
            if zt > zb and close <= zt and close >= zb   // zt>zb يستبعد خطوط m.A المنفردة (بلا عرض)
                inZone := true
                zbCur  := zb
                ztCur  := zt
                break
    diagInZone := inZone
    // [V3.55] تصنيف المنطقة دعم/مقاومة بموضع السعر (قاعدة المستخدم + L2-03 «منطقة دعم/مقاومة»):
    //   دخل السعر المنطقةَ من فوق ⇒ دعم(+1)؛ من تحت ⇒ مقاومة(-1)؛ غموض (تكوّنت حول السعر) ⇒ 0 ⇒ يرجع للاتجاه (قرار المستخدم: الاحتياطيّ بالاتجاه).
    var bool inZonePrev = false
    var int  zoneSide   = 0
    if inZone   // [V3.78] إعادة تقييم **كلّ بار** (لا عند الدخول فقط): بعد إعادة بناء المنطقة (emittedMedBar) يتحدّث التصنيف من موضع close[1] مقابل حدّ المنطقة الحاليّ ⇒ لا يبقى «دعم/+1» على منطقة صارت مقاومة ⇒ يمنع شراء عند مقاومة
        zoneSide := close[1] > ztCur ? 1 : close[1] < zbCur ? -1 : zoneSide
    if not inZone
        zoneSide := 0
    inZonePrev := inZone
    // هامش الوقف/الإبطال = bufMult × سعة آخر تأرجح صغير (مقياس الدرجة الأدنى — أصيل، لا ATR).
    float smallSwing = (not na(memS.ltP) and not na(memS.lbP)) ? math.abs(memS.ltP - memS.lbP) : na
    float buf = na(smallSwing) ? 0.0 : bufMult * smallSwing
    // [V4.41] الكتاب L2-03: المرحلة 1=ذعر 2=يأس 3=تجميع 4=تصريف 0=مشاركة. الأساسيّة تكتمل دورتها في
    //   **الصغيرة (منطقة قريبة) أو المتوسطة (أعمق)**؛ العالية المخاطر = تصحيح بعد الذعر (ذعر/يأس قبل اكتمال التجميع).
    int   sc2 = smallPh.code
    int   mc2 = medPh.code
    // أساسيّة: تجميع (دعم) للشراء / تصريف (مقاومة) للبيع — مكتملًا في الصغيرة أو المتوسطة داخل المنطقة.
    bool  basBuyS  = sc2 == 3 and smallPh.passedDespair   // [V3.81] الدورة كاملة: تجميع **بعد يأس** (الدرس س128: «الذعر واليأس ثمّ التجميع») ⇒ يمنع الأساسيّ في انعكاس V بلا يأس (تبقى HR للسريع)
    bool  basBuyM  = mc2 == 3 and medPh.passedDespair
    bool  basSellS = sc2 == 4 and smallPh.passedDespair
    bool  basSellM = mc2 == 4 and medPh.passedDespair
    // [V3.72] الفجوة 1 + الدخول المتاح: «فوق المستويين (الكبير+المتوسط)=شراء · تحتهما=بيع · بينهما=عرضيّ» (bEff/mEff).
    //   في **العرضيّ** (بينهما) ⇒ جهة المنطقة **صارمة** (شراء عند دعم صريح فقط، بيع عند مقاومة صريحة)؛ في الاتجاه الواضح ⇒ احتياطيّ الاتجاه (الغموض يمرّ). يمنع شراءً عرضيًّا عند مقاومة (إشارتك الكاذبة).
    bool  buyZoneOK  = (zoneSide ==  1) or (zoneSide == 0 and bEff ==  1 and mEff ==  1)
    bool  sellZoneOK = (zoneSide == -1) or (zoneSide == 0 and bEff == -1 and mEff == -1)
    // [V3.73] الفجوة 2: لا شراء والمتوسط في **مشاركة هابطة نشطة** (mc2==0 وهابط = هبوط فاعل لا تصحيح)؛ يجب أن يكون صاعدًا أو في تصحيح(ذعر/يأس)/تجميع. مرآته للبيع. (التصحيح mc2==1/2 يمرّ — هو غرض المخاطرة.)
    bool  medActiveDown = mc2 == 0 and medActiveDir == -1
    bool  medActiveUp   = mc2 == 0 and medActiveDir ==  1
    oppBasicBuy  := inZone and buyOK  and (basBuyS or basBuyM)  and buyZoneOK  and not medActiveDown   // [V3.72/3.73]
    oppBasicSell := inZone and sellOK and (basSellS or basSellM) and sellZoneOK and not medActiveUp     // [V3.72/3.73]
    oppBasicBuyDeg  := oppBasicBuy  ? (basBuyS  ? 3 : 2) : 0   // الصغيرة أولًا (القريبة) وإلا المتوسطة
    oppBasicSellDeg := oppBasicSell ? (basSellS ? 3 : 2) : 0
    // عالية المخاطر: تصحيح بعد الذعر (ذعر/يأس) في الصغيرة أو المتوسطة مع الاتجاه — قبل اكتمال التجميع/التصريف.
    oppHRBuy  := inZone and bEff == 1  and (sc2 == 1 or sc2 == 2 or mc2 == 1 or mc2 == 2) and not oppBasicBuy  and buyZoneOK  and not medActiveDown   // [V3.72/3.73]
    oppHRSell := inZone and bEff == -1 and (sc2 == 1 or sc2 == 2 or mc2 == 1 or mc2 == 2) and not oppBasicSell and sellZoneOK and not medActiveUp
    oppText := f_t("لا فرصة","No opportunity")
    if inZone
        oppText := f_t("داخل منطقة — لا مرحلة مناسبة","In zone — no suitable phase")
    if oppHRBuy
        oppText := f_t("شراء عالي المخاطر (داخل منطقة)","High-risk Buy (in zone)")
    if oppHRSell
        oppText := f_t("بيع عالي المخاطر (داخل منطقة)","High-risk Sell (in zone)")
    if oppBasicBuy
        oppText := f_t("شراء أساسي (","Basic Buy (") + (oppBasicBuyDeg == 3 ? f_t("صغيرة","Small") : f_t("متوسطة","Medium")) + f_t("): انتظار تأكيد تجميع","): awaiting accumulation")
    if oppBasicSell
        oppText := f_t("بيع أساسي (","Basic Sell (") + (oppBasicSellDeg == 3 ? f_t("صغيرة","Small") : f_t("متوسطة","Medium")) + f_t("): انتظار تأكيد تصريف","): awaiting distribution")
    // [v3.87.13 — قرار المستخدم] الهدف (معاينةً ومؤكّدًا) = أقرب **حافّة** تالية عبر `f_nextZoneEdge` — **المنفرد (m.A، zt==zb) يُحتسَب هدفًا** (لا منطقة دخول).
    //   شراء ⇒ أقرب حافّة سفلى (zb) فوق السعر؛ بيع ⇒ أقرب حافّة عليا (zt) تحت السعر. الدخول يبقى في منطقة **مزدوجة** فقط (inZone: zt>zb).
    oppTarget := na
    if oppBasicBuy or oppHRBuy
        oppTarget := f_nextZoneEdge(close, true)
    if oppBasicSell or oppHRSell
        oppTarget := f_nextZoneEdge(close, false)
    if not na(oppTarget) and (oppBasicBuy or oppBasicSell or oppHRBuy or oppHRSell)
        oppText := oppText + f_t("  → هدف ","  → Target ") + str.tostring(oppTarget, format.mintick)
    // ===== المرحلة 3: انتظار (درجة الفرصة) ⇒ تأكيد بدرجة أصغر ⇒ دخول/وقف/هدف =====
    // الصفقة المتوسطة: التأكيد بالصغيرة (مشاركة صغيرة جديدة) ⇒ دخول مؤكّد.
    // الصفقة الصغيرة: التأكيد يحتاج درجة أصغر (غير متوفّرة) ⇒ تبقى انتظاراً (لا دخول آلي).
    // pending يتبع نفس المرحلة المصنِّفة: شراء عند تجميع (دعم)، بيع عند تصريف (مقاومة).
    if inZone and buyOK and medPh.code == 3
        pendBuyMed := true
        zbEntryB := zbCur
        ztEntryB := ztCur
        if not na(medPh.despDeep)
            buySetupLow := na(buySetupLow) ? medPh.despDeep : math.min(buySetupLow, medPh.despDeep)
    if inZone and buyOK and smallPh.code == 3
        pendBuySmall := true
        zbEntryB := zbCur
        ztEntryB := ztCur
        if not na(smallPh.despDeep)
            buySetupLow := na(buySetupLow) ? smallPh.despDeep : math.min(buySetupLow, smallPh.despDeep)
    if inZone and sellOK and medPh.code == 4
        pendSellMed := true
        zbEntryS := zbCur
        ztEntryS := ztCur
        if not na(medPh.despDeep)
            sellSetupHigh := na(sellSetupHigh) ? medPh.despDeep : math.max(sellSetupHigh, medPh.despDeep)
    if inZone and sellOK and smallPh.code == 4
        pendSellSmall := true
        zbEntryS := zbCur
        ztEntryS := ztCur
        if not na(smallPh.despDeep)
            sellSetupHigh := na(sellSetupHigh) ? smallPh.despDeep : math.max(sellSetupHigh, smallPh.despDeep)
    entryBuy  := false
    entrySell := false
    float entryP = na
    float stopP  = na
    float tgtP   = na
    bool  entrySmall = false   // الصفقة المؤكّدة صغيرة؟ (للوقف من الدرجة الرابعة)
    // الصفقة المتوسطة: تأكيد بالصغيرة (مشاركة صغيرة جديدة).
    // الصفقة الصغيرة: تأكيد بالدرجة الرابعة فقط (كسر آخر قمة/قاع على فريم أصغر). لا بديل.
    // هامش الجري = ارتفاع منطقة الإعداد + buf — يُستعمل لإبطال الانتظار حين يبتعد السعر كثيرًا (أسفل، لا للدخول).
    float buyRun  = (not na(ztEntryB) and not na(zbEntryB)) ? (ztEntryB - zbEntryB) + buf : (na(smallSwing) ? na : smallSwing)
    float sellRun = (not na(ztEntryS) and not na(zbEntryS)) ? (ztEntryS - zbEntryS) + buf : (na(smallSwing) ? na : smallSwing)
    // [V4.57] بوّابة «داخل المنطقة» — قاعدة الاستراتيجيّة (04.شروط الانعكاس): «دخل **داخل المنطقة** وكسر آخر قمة».
    //   التأكيد يجب أن يقع والسعر **بين حدّي M.A لمنطقة الدخول** (zb ≤ close ≤ zt)، لا قريبًا/خارجها.
    //   غياب حدّي المنطقة (na) ⇒ لا منطقة ⇒ لا دخول. يستبدل بوّابتَي «القرب» السابقتين (كانتا تسمحان بالخارج).
    bool buyNearZone  = (not na(zbEntryB)) and (not na(ztEntryB)) and close >= zbEntryB and close <= ztEntryB
    bool sellNearZone = (not na(zbEntryS)) and (not na(ztEntryS)) and close >= zbEntryS and close <= ztEntryS
    bool buyMedConf = smConfBuy and pendBuyMed and buyNearZone
    bool buySmConf  = d4Up and (na(smallWaveStartTime) or d4BrokenT >= smallWaveStartTime) and pendBuySmall and not pendBuyMed and buyNearZone   // [V3.66] الحصر ب: كسر الرابعة لقمّة **داخل الموجة الصغيرة** فقط (زمن المكسور ≥ بدء الموجة)
    bool sellMedConf = smConfSell and pendSellMed and sellNearZone
    bool sellSmConf  = d4Dn and (na(smallWaveStartTime) or d4BrokenT >= smallWaveStartTime) and pendSellSmall and not pendSellMed and sellNearZone   // [V3.66] الحصر ب: كسر الرابعة لقاع داخل الموجة الصغيرة فقط
    bool pendArmed = pendBuyMed or pendBuySmall or pendSellMed or pendSellSmall
    diagArmed := pendArmed                                                          // مُسلَّح (pending)
    diagPhase := smConfBuy or smConfSell or d4Up or d4Dn                            // مُطلِق تأكيد يحدث (كسر بدرجة أصغر)
    diagConf  := buyMedConf or buySmConf or sellMedConf or sellSmConf               // التأكيد (مُسلَّح + مُطلِق)
    // [v3.87.11] منع التكديس (L2-04 ن7): لا دخول جديد وصفقة مفتوحة (tradeDir != 0) — يُترَك الانعكاس/الإضافة للدرجة الأصغر.
    //   تُستثنى حالةُ إطفاء الإدارة (enableManage=false) فتُعرَض كلّ الإشارات (ماسح إشارات بلا تتبّع صفقة).
    if (buyMedConf or buySmConf) and (tradeDir == 0 or not enableManage)
        bool sm = buySmConf and not buyMedConf
        float eP = close
        // الوقف = تحت قاع التجميع (أعمق قاع يأس) بهامش — مطابقة الدرس 04 «وقف الخسارة تحت القاع».
        //   احتياطيّ: حافة المنطقة ثمّ قاع الدرجة الرابعة/الصغيرة عند غياب قاع التجميع.
        // [V4.44] إن حُدّدت نقاط يدويّة: الوقف = آخر قاع بدرجة التأكيد (صغيرة/رابعة) − النقاط؛ وإلّا الافتراضيّ (despDeep − buf)
        // [V4.58] الوقف = **حدّ منطقة الدخول السفليّ مباشرةً** (zbEntryB من التسليح) − نقاطك فقط (عند الحافّة).
        //   بوّابة v4.57 تضمن الدخول داخل المنطقة ⇒ zbEntryB تحته دائمًا. لا f_nearestEdge (كان يفحص zTop/zBot
        //   القديمة — تُبنى عند islast/انبعاث متوسط فقط، س2522 — فيسقط على قمّة تاريخيّة memS). احتياطيّ: آخر قاع ثمّ despDeep.
        float sP = (not na(zbEntryB)) ? zbEntryB - mgStopPts : ((not na(memS.lbP)) ? memS.lbP - buf : (not na(buySetupLow)) ? buySetupLow - buf : na)
        // [V4.59] الهدف = أوّل **منطقة مزدوجة** فوق حدّ منطقة الدخول (الدرس: «المنطقة القادمة»)؛ المنفرد المتروك
        //   عند الحدّ يُتجاوز بنيويًّا (لا بمسافة رقميّة). المرجع = ztEntryB (حدّ المنطقة العلويّ، يستبعد المنطقة نفسها).
        float tgRefB = na(ztEntryB) ? eP : ztEntryB
        float tg0 = f_nextZoneEdge(tgRefB, true)    // [v3.87.13] المنفرد يُحتسَب هدفًا (أقرب حافّة، مزدوجة أو منفردة)
        float tg  = (mgTgtPts > 0 and not na(tg0)) ? tg0 - mgTgtPts : tg0   // [V4.44] جني قبل المنطقة بالنقاط
        if not na(sP) and not na(tg) and sP < eP and tg > eP   // شبكة أمان: الوقف تحت الدخول والهدف فوقه
            entryBuy := true
            entrySmall := sm
            entryP := eP
            stopP  := sP
            tgtP   := tg
        pendBuyMed := false
        pendBuySmall := false
    if (sellMedConf or sellSmConf) and (tradeDir == 0 or not enableManage)   // [v3.87.11] منع التكديس (L2-04 ن7): لا دخول وصفقة مفتوحة
        bool sm = sellSmConf and not sellMedConf
        float eP = close
        // الوقف = خلف قمة التصريف (أعلى قمة يأس) بهامش — مطابقة الدرس 04 «وقف الخسارة خلف القمة».
        //   احتياطيّ: حافة المنطقة ثمّ قمة الدرجة الرابعة/الصغيرة عند غياب قمة التصريف.
        // [V4.44] إن حُدّدت نقاط يدويّة: الوقف = آخر قمّة بدرجة التأكيد + النقاط؛ وإلّا الافتراضيّ (despDeep + buf)
        // [V4.58] الوقف = **حدّ منطقة الدخول العلويّ مباشرةً** (ztEntryS من التسليح) + نقاطك فقط (عند الحافّة).
        //   بوّابة v4.57 تضمن الدخول داخل المنطقة ⇒ ztEntryS فوقه دائمًا. لا f_nearestEdge (كان يسقط على قمّة تاريخيّة).
        //   احتياطيّ: آخر قمّة ثمّ despDeep.
        float sP = (not na(ztEntryS)) ? ztEntryS + mgStopPts : ((not na(memS.ltP)) ? memS.ltP + buf : (not na(sellSetupHigh)) ? sellSetupHigh + buf : na)
        // [V4.59] الهدف = أوّل **منطقة مزدوجة** تحت حدّ منطقة الدخول (الدرس: «المنطقة القادمة»)؛ المنفرد المتروك
        //   عند الحدّ يُتجاوز بنيويًّا. المرجع = zbEntryS (حدّ المنطقة السفليّ، يستبعد المنطقة نفسها).
        float tgRefS = na(zbEntryS) ? eP : zbEntryS
        float tg0 = f_nextZoneEdge(tgRefS, false)   // [v3.87.13] المنفرد يُحتسَب هدفًا (أقرب حافّة، مزدوجة أو منفردة)
        float tg  = (mgTgtPts > 0 and not na(tg0)) ? tg0 + mgTgtPts : tg0   // [V4.44] جني قبل المنطقة بالنقاط
        if not na(sP) and not na(tg) and sP > eP and tg < eP   // شبكة أمان: الوقف فوق الدخول والهدف تحته
            entrySell := true
            entrySmall := sm
            entryP := eP
            stopP  := sP
            tgtP   := tg
        pendSellMed := false
        pendSellSmall := false
    // ===== إبطال الانتظار الأصدق (v1.64) =====
    // إبطال الانتظار (بعد فحص الدخول): الفشل الحقيقيّ = كسر قاع/قمة الإعداد (أعمق يأس) بهامش،
    //   لا الغوص الطبيعيّ ولا مجرّد فقد الاتجاه. الغوص الطبيعيّ يبقى فوق despDeep ⇒ pending يصمد حتى الكسر المؤكِّد.
    //   شراء: close يكسر buySetupLow − buf (هبوط جديد استأنف) أو فقد الاتجاه ⇒ إبطال.
    //   بيع:  close يكسر sellSetupHigh + buf (صعود جديد استأنف) أو فقد الاتجاه ⇒ إبطال.
    if not buyOK or (not na(buySetupLow) and close < buySetupLow - buf)
        pendBuyMed   := false
        pendBuySmall := false
    if not sellOK or (not na(sellSetupHigh) and close > sellSetupHigh + buf)
        pendSellMed   := false
        pendSellSmall := false
    // إبطال «الجري بعيداً»: السعر ابتعد فوق منطقة الإعداد (شراء) أو تحتها (بيع) بأكثر من هامش الجري ⇒
    //   الكسر المؤكِّد لم يحدث قرب الإعداد ⇒ الإعداد فات (يمنع التقاط كسر بعيد بانتظار قديم).
    if not na(ztEntryB) and not na(buyRun) and close > ztEntryB + buyRun
        pendBuyMed   := false
        pendBuySmall := false
    if not na(zbEntryS) and not na(sellRun) and close < zbEntryS - sellRun
        pendSellMed   := false
        pendSellSmall := false
    // تفريغ قاع/قمة الإعداد عند خلوّ الجهة من أيّ انتظار (بعد الدخول أو الإبطال)
    if not (pendBuyMed or pendBuySmall)
        buySetupLow := na
    if not (pendSellMed or pendSellSmall)
        sellSetupHigh := na
    // ===== [V4.45] تأمين الصفقة (الكتاب L2-04 س530/534 + التفريغ س41-47) =====
    //   افتح الصفقة عند التأكيد؛ ومع كلّ **مشاركة عامة جديدة** انقل الوقف خلف آخر قاع (شراء)/قمّة (بيع) — لا يُضيَّق
    //   عكسيًّا (لا يُبالَغ في التضييق). أُغلِق عند ضرب الوقف أو بلوغ الهدف. الهامش = نفس منطق الدخول (نقاط/مشتقّ).
    float trailBuf = mgStopPts > 0 ? mgStopPts : buf
    if entryBuy
        tradeDir := 1
        tradeEntry := entryP
        tradeStop := stopP
        tradeTgt := tgtP
        tradeBar := bar_index
    if entrySell
        tradeDir := -1
        tradeEntry := entryP
        tradeStop := stopP
        tradeTgt := tgtP
        tradeBar := bar_index
    if tradeDir == 1 and not entryBuy
        if smConfBuy and not na(memS.lbP)
            // [V4.85] تأمين بمرحلتين (الدرس L2-04 ن6): أوّلًا **≥ نقطة الدخول** (تعادُل) ثمّ خلف القاع الجديد.
            float ns = na(tradeEntry) ? memS.lbP - trailBuf : math.max(memS.lbP - trailBuf, tradeEntry)
            if na(tradeStop) or ns > tradeStop   // يرتفع فقط (لا تضييق عكسيّ)
                tradeStop := ns
        bool buyHitS = not na(tradeStop) and low <= tradeStop
        bool buyHitT = not na(tradeTgt) and high >= tradeTgt
        if buyHitS or buyHitT                          // [v3.87.12] إشعار إغلاق الصفقة (وقف/هدف)
            alert("M-Waves: " + (buyHitS ? f_t("وقف الشراء مضروب @ ","Buy stop hit @ ") : f_t("هدف الشراء محقّق @ ","Buy target reached @ ")) + str.tostring(buyHitS ? tradeStop : tradeTgt, format.mintick), alert.freq_once_per_bar)
            tradeDir := 0                              // أُغلِقت (وقف أو هدف)
    if tradeDir == -1 and not entrySell
        if smConfSell and not na(memS.ltP)
            // [V4.85] تأمين بمرحلتين: أوّلًا **≤ نقطة الدخول** (تعادُل) ثمّ خلف القمّة الجديدة.
            float ns = na(tradeEntry) ? memS.ltP + trailBuf : math.min(memS.ltP + trailBuf, tradeEntry)
            if na(tradeStop) or ns < tradeStop   // ينخفض فقط (لا تضييق عكسيّ)
                tradeStop := ns
        bool sellHitS = not na(tradeStop) and high >= tradeStop
        bool sellHitT = not na(tradeTgt) and low <= tradeTgt
        if sellHitS or sellHitT                        // [v3.87.12] إشعار إغلاق الصفقة (وقف/هدف)
            alert("M-Waves: " + (sellHitS ? f_t("وقف البيع مضروب @ ","Sell stop hit @ ") : f_t("هدف البيع محقّق @ ","Sell target reached @ ")) + str.tostring(sellHitS ? tradeStop : tradeTgt, format.mintick), alert.freq_once_per_bar)
            tradeDir := 0
    // [v3.87.12] التنبيهات: alert() واحد يغطّي **كلّ** الإشارات (فرصة أساسيّة + عالية مخاطرة + دخول مؤكّد + إغلاق بوقف/هدف).
    //   في TradingView: أنشئ تنبيهًا على «Any alert() function call» وفعّل الصوت (Notifications → Play sound) ⇒ صوت تلقائيّ عند كلّ إشارة.
    //   (بديل: alertcondition باسمها أدناه = تنبيه/صوت منفصل لكلّ نوع. Pine لا يضبط الصوت برمجيًّا — يُختار في نافذة التنبيه.)
    if entryBuy
        alert("M-Waves: " + f_t("دخول شراء مؤكّد @ ","Confirmed Buy entry @ ") + str.tostring(entryP, format.mintick) + f_t("  ·  وقف ","  ·  Stop ") + (na(stopP) ? "—" : str.tostring(stopP, format.mintick)) + f_t("  ·  هدف ","  ·  Target ") + (na(tgtP) ? "—" : str.tostring(tgtP, format.mintick)), alert.freq_once_per_bar)
    if entrySell
        alert("M-Waves: " + f_t("دخول بيع مؤكّد @ ","Confirmed Sell entry @ ") + str.tostring(entryP, format.mintick) + f_t("  ·  وقف ","  ·  Stop ") + (na(stopP) ? "—" : str.tostring(stopP, format.mintick)) + f_t("  ·  هدف ","  ·  Target ") + (na(tgtP) ? "—" : str.tostring(tgtP, format.mintick)), alert.freq_once_per_bar)
    if oppHRBuy and not oppHRBuy[1]   // [V4.92] تنبيه فرصة عالية المخاطر (تظهر أكثر من المؤكّدة)
        alert("M-Waves: " + f_t("فرصة شراء عالية المخاطر داخل منطقة (تصحيح بعد الذعر)","High-risk Buy opportunity inside a zone (correction after panic)"), alert.freq_once_per_bar)
    if oppHRSell and not oppHRSell[1]
        alert("M-Waves: " + f_t("فرصة بيع عالية المخاطر داخل منطقة (تصحيح بعد الذعر)","High-risk Sell opportunity inside a zone (correction after panic)"), alert.freq_once_per_bar)
    if oppBasicBuy and not oppBasicBuy[1]     // [v3.87.12] إشعار الفرصة الأساسيّة (كان alertcondition فقط، لا alert ديناميكيّ)
        alert("M-Waves: " + f_t("فرصة شراء أساسيّة داخل منطقة دعم — انتظار تأكيد التجميع","Basic Buy opportunity in a support zone — awaiting accumulation"), alert.freq_once_per_bar)
    if oppBasicSell and not oppBasicSell[1]
        alert("M-Waves: " + f_t("فرصة بيع أساسيّة داخل منطقة مقاومة — انتظار تأكيد التصريف","Basic Sell opportunity in a resistance zone — awaiting distribution"), alert.freq_once_per_bar)
    // [V4.50] صناديق الصفقة (مودرن، مكافئ TradingView): أخضر عائد (دخول↔هدف) + أحمر مخاطرة (دخول↔وقف) + شارة RR
    if showOpp and barstate.islast
        if not na(rewardBox)
            box.delete(rewardBox)
            rewardBox := na
        if not na(riskBox)
            box.delete(riskBox)
            riskBox := na
        if not na(rrBadge)
            label.delete(rrBadge)
            rrBadge := na
        if enableManage and tradeDir != 0 and not na(tradeEntry) and not na(tradeStop) and not na(tradeTgt)
            int   le = na(tradeBar) ? bar_index - 30 : tradeBar
            int   re = bar_index + 8
            rewardBox := box.new(le, math.max(tradeEntry, tradeTgt), re, math.min(tradeEntry, tradeTgt), xloc = xloc.bar_index, border_color = color.new(#089981, 30), border_width = 1, bgcolor = color.new(#089981, 88))
            // [V4.87] صندوق المخاطرة يصير **أخضر** حين يُؤمَّن الوقف (≥ تعادُل) = ربح مُقفَل لا مخاطرة.
            bool secured = (tradeDir == 1 and tradeStop >= tradeEntry) or (tradeDir == -1 and tradeStop <= tradeEntry)
            color riskCol = secured ? #089981 : #F23645
            riskBox   := box.new(le, math.max(tradeEntry, tradeStop), re, math.min(tradeEntry, tradeStop), xloc = xloc.bar_index, border_color = color.new(riskCol, 30), border_width = 1, bgcolor = color.new(riskCol, 88))
            float rrV = f_rr(tradeEntry, tradeStop, tradeTgt)
            color rrCol = na(rrV) ? color.gray : rrV >= 2 ? #089981 : rrV >= 1 ? #FF9800 : #F23645
            string rrTx = "RR " + (na(rrV) ? "—" : str.tostring(rrV, "#.##"))
            rrBadge := label.new(re, tradeEntry, rrTx, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_label_left, color = rrCol, textcolor = color.white, size = size.small)
    // إشارات الشارت — قرب سعر الدخول (yloc.price)، الاسم على الإشارة، اللون يميّز الجهة، Tooltip: دخول/وقف/هدف
    if showOpp and bar_index >= drawLeft
        string diagTip = ""
        if entryBuy
            float rrB = f_rr(entryP, stopP, tgtP)
            string tipB = f_t("دخول: ","Entry: ") + str.tostring(entryP, format.mintick) + f_t("\nوقف: ","\nStop: ") + (na(stopP) ? "—" : str.tostring(stopP, format.mintick)) + f_t("\nهدف: ","\nTarget: ") + (na(tgtP) ? f_t("لا منطقة هدف","No target zone") : str.tostring(tgtP, format.mintick)) + "\nR:R = " + (na(rrB) ? "—" : str.tostring(rrB, "#.##")) + diagTip
            f_tradeSig(bar_index, entryP, f_t("شراء","Buy"), true, colBasicBuy, rrB, tipB)    // أساسي شراء
        if entrySell
            float rrS = f_rr(entryP, stopP, tgtP)
            string tipS = f_t("دخول: ","Entry: ") + str.tostring(entryP, format.mintick) + f_t("\nوقف: ","\nStop: ") + (na(stopP) ? "—" : str.tostring(stopP, format.mintick)) + f_t("\nهدف: ","\nTarget: ") + (na(tgtP) ? f_t("لا منطقة هدف","No target zone") : str.tostring(tgtP, format.mintick)) + "\nR:R = " + (na(rrS) ? "—" : str.tostring(rrS, "#.##")) + diagTip
            f_tradeSig(bar_index, entryP, f_t("بيع","Sell"), false, colBasicSell, rrS, tipS)   // أساسي بيع
        // ثانوية عالية المخاطر (تصحيح بعد الزعر) = لون كهرمانيّ مميّز ووسم HR؛ صغيرة بانتظار الرابعة = «؟» أفتح.
        if showOppWaiting
            bool hrBuy    = oppHRBuy  and not oppHRBuy[1]  and not entryBuy
            bool hrSell   = oppHRSell and not oppHRSell[1] and not entrySell
            bool waitBuy  = smConfBuy and pendBuySmall and not pendBuyMed and not d4Up and not entryBuy
            bool waitSell = smConfSell and pendSellSmall and not pendSellMed and not d4Dn and not entrySell
            if hrBuy or waitBuy
                // [V4.60] توحيد منطق HR/الانتظار مع الدرس: الوقف = حدّ المنطقة الحاليّة (بلا هامش)، الهدف = أوّل منطقة مزدوجة قادمة.
                float ub = f_nextZoneEdge(inZone ? ztCur : close, true)    // [v3.87.13] المنفرد هدف
                float sPwB = inZone ? zbCur - mgStopPts : ((not na(zbEntryB)) ? zbEntryB - mgStopPts : memS.lbP)
                if not na(sPwB) and not na(ub) and sPwB < close and ub > close
                    float rrUB = f_rr(close, sPwB, ub)
                    string tipUB = f_t("دخول: ","Entry: ") + str.tostring(close, format.mintick) + f_t("\nوقف: ","\nStop: ") + str.tostring(sPwB, format.mintick) + f_t("\nهدف: ","\nTarget: ") + str.tostring(ub, format.mintick) + "\nR:R = " + (na(rrUB) ? "—" : str.tostring(rrUB, "#.##")) + diagTip
                    if hrBuy
                        f_tradeSig(bar_index, close, f_t("شراء","Buy"), true, colHRBuy, rrUB, tipUB)   // عالي المخاطرة شراء (لون مستقلّ)
                    else
                        label.new(bar_index, close, f_t("شراء؟","Buy?"), yloc = yloc.price, style = label.style_label_up, color = color.new(#1B5E20, 50), textcolor = color.white, size = size.tiny, tooltip = tipUB)
            if hrSell or waitSell
                // [V4.60] توحيد منطق HR/الانتظار مع الدرس: الوقف = حدّ المنطقة الحاليّة (بلا هامش)، الهدف = أوّل منطقة مزدوجة قادمة.
                float us = f_nextZoneEdge(inZone ? zbCur : close, false)   // [v3.87.13] المنفرد هدف
                float sPwS = inZone ? ztCur + mgStopPts : ((not na(ztEntryS)) ? ztEntryS + mgStopPts : memS.ltP)
                if not na(sPwS) and not na(us) and sPwS > close and us < close
                    float rrUS = f_rr(close, sPwS, us)
                    string tipUS = f_t("دخول: ","Entry: ") + str.tostring(close, format.mintick) + f_t("\nوقف: ","\nStop: ") + str.tostring(sPwS, format.mintick) + f_t("\nهدف: ","\nTarget: ") + str.tostring(us, format.mintick) + "\nR:R = " + (na(rrUS) ? "—" : str.tostring(rrUS, "#.##")) + diagTip
                    if hrSell
                        f_tradeSig(bar_index, close, f_t("بيع","Sell"), false, colHRSell, rrUS, tipUS)   // عالي المخاطرة بيع (لون مستقلّ)
                    else
                        label.new(bar_index, close, f_t("بيع؟","Sell?"), yloc = yloc.price, style = label.style_label_down, color = color.new(#C00000, 50), textcolor = color.white, size = size.tiny, tooltip = tipUS)

// ===== [v3.88.36 · B4] إشارات فيبو/إليوت لكلّ درجة (دالّة معمّمة) — منفصلة تمامًا عن M-Waves =====
//   كلّ درجة بذاكرتها (كبيرة memBph · متوسطة memM · صغيرة memS) واتجاهها؛ الوسم شراء/بيع، الدرجة بالاسم في tooltip.
//   مستقلّة عن نافذة drawWaves، خارج tradeDir/التأمين/منع التكديس. (barstate.isconfirmed ⇒ غير مُعيد للرسم)
if fibStandaloneSignals and barstate.isconfirmed
    if fibSigBig
        f_fibDegSig(memBph, 0, largeDir,       f_t("كبيرة","Big"),   diagInZone)
    if fibSigMed
        f_fibDegSig(memM,   1, medActiveDir,   f_t("متوسطة","Med"),  diagInZone)
    if fibSigSmall
        f_fibDegSig(memS,   2, smallActiveDir, f_t("صغيرة","Small"), diagInZone)

// ===================== حدود الموجة التاريخية ==============================
// • إذا أدخل المستخدم عدد شموع > 0: تُرسم الحدود على آخر هذا العدد من الشموع.
// • إذا تركه 0: تُحدَّد تلقائياً من الدرجة الكبيرة (من آخر موجة كبيرة حتى الآن).
var box   hbox = na
var label hlbl = na
float hwHi = ctxHiE   // [V3.44] الصندوق المرسوم = نافذة السياق الواسعة (الدرس 03)
float hwLo = ctxLoE
if showHist and barstate.islast
    if not na(hbox)
        box.delete(hbox)
    if not na(hlbl)
        label.delete(hlbl)
    // [V3.75] أُرجِع تجريب v3.74 (الصندوق من التطرّفات المؤكَّدة): كان يُخرج السعرَ خارج الصندوق عند تكوّن قمّة جديدة أعلى من آخر تطرّف. الصندوق = نافذة السياق الخام (hwHi/Lo = ctxHiE/LoE = ta.highest/lowest) ⇒ يحتوي السعر دائمًا (الدرس 03: «من البداية إلى أعلى نقطة وصلها» = حدّ الموجة الحيّ).
    int   hLeft   = ctxLeft
    color hBorder = f_dark(cHist)   // [V4.94] بوردر من لون التعبئة (درجة أغمق) بدل الأصفر؛ عرضه = عرض بورد تاريخ التاريخ (1)
    string hTxt   = useHistN ? f_t("الموجة التاريخية (يدوي)","Historical Wave (manual)") : f_t("الموجة التاريخية (تلقائي)","Historical Wave (auto)")
    hbox := box.new(hLeft, hwHi, bar_index, hwLo, border_color = hBorder, border_width = 1,
         bgcolor = cHist)
    hlbl := label.new(hLeft, hwHi, hTxt, xloc = xloc.bar_index, yloc = yloc.price,
         style = label.style_label_lower_right, color = hBorder, textcolor = color.white,
         size = size.tiny)

// حدود تاريخ التاريخ (الموجة الكبيرة السابقة مباشرةً)
var box   hohBox = na
var label hohLb  = na
if showHoh and barstate.islast and ctxHohLeft < ctxLeft
    if not na(hohBox)
        box.delete(hohBox)
    if not na(hohLb)
        label.delete(hohLb)
    int   hohRight = math.max(math.min(ctxHohRight, ctxLeft - 1), ctxHohLeft)
    float hohHi    = na
    float hohLo    = na
    for k = (bar_index - hohRight) to (bar_index - ctxHohLeft)
        float hk = high[k]
        float lk = low[k]
        hohHi := na(hohHi) ? hk : math.max(hohHi, hk)
        hohLo := na(hohLo) ? lk : math.min(hohLo, lk)
    color hohBd    = color.new(color.gray, 0)
    string hohTxt  = useHohN ? f_t("تاريخ التاريخ (يدوي)","History-of-History (manual)") : f_t("تاريخ التاريخ (تلقائي)","History-of-History (auto)")
    if not na(hohHi)
        hohBox := box.new(ctxHohLeft, hohHi, hohRight, hohLo, border_color = hohBd, border_width = 1,
             bgcolor = cHoh)
        hohLb := label.new(ctxHohLeft, hohLo, hohTxt, xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_label_upper_right, color = hohBd, textcolor = color.white,
             size = size.tiny)

// ============== تلوين دوائر الدرجة المتوسطة (القوانين الثلاثة) ==============
// القوانين الثلاثة (الشرح + قائمة التحقق): تتابُع + فعالية + تغطية. الدائرة برتقالية إن كانت النقطة فعّالة
//   (zoneEff داخل [hohLeft,now]) وإلا حمراء — متّسق تماماً مع خطوط م.A (كلاهما zoneEff في النطاق).
//   ملاحظة: mcEff (تغطية+تتابُع، بلا فعالية) يبقى لمستهلكيه الآخرين (إشارات/سيولة) — لا يُلوِّن الدوائر بعد الآن.
if barstate.islast
    int mm = array.size(mcP)
    if mm > 0
        // [V4.5] التلوين يقرأ zoneEff لكل دائرة مرسومة [drawLeft,now] (تطبّق «خارج النطاق ⇒ فعّال»).
        //   كان يقرأها فقط ضمن hohLeft ويرجع لـ mcEff القديم للأقدم ⇒ نقاط خارج النطاق أقدم من hohLeft تبقى حمراء خطأً.
        for i = 0 to mm - 1
            label li = array.get(mcLbl, i)
            label liO = array.get(mcLblO, i)
            float pci = array.get(mcP, i)
            bool outsideC = pci > hwHiE or pci < hwLoE   // [V4.6] «خارج النطاق ⇒ فعّال» يُحسب هنا بالنطاق الحاليّ (hwHiE/hwLoE) — يتجاوز تأخّر zoneEff (كتلته بعد التلوين)
            bool inWin = array.size(zoneEff) > i and array.get(mcBar, i) >= drawLeft
            bool effC = outsideC or (inWin ? array.get(zoneEff, i) : array.get(mcEff, i))
            bool pndC = (not outsideC) and inWin and array.size(dgPend) > i ? array.get(dgPend, i) : false
            if not na(li)
                label.set_color(li, effC ? cMed : pndC ? (showPending ? cPend : color.new(color.gray, 100)) : cMedDead)   // [V4.8] إخفاء المعلّق ⇒ شفاف
            if not na(liO)
                label.set_color(liO, pndC ? (showPending ? cPendBordMed : color.new(color.gray, 100)) : cMedBorder)

    // (بناء المناطق نُقل إلى ما بعد كتلة الكبيرة لتطبيق override الزرقاء — انظر أدناه)
// ============== الدرجة الكبيرة (الدرس 07) — مساران ==============
//   • المسار 1 (useBigBreak=true، افتراضيّ): استخراج بالكسر من كل النقاط المتوسطة — يطابق قواعد المتوسطة تماماً.
//   • المسار 2 (useBigBreak=false): تجميع legs تلقائيّ بفلاتر (swings/ATR/زمن) — مساعد، لا يُعدَّل (تحقّق فقط).
//   كلاهما يُنتج نقاطاً زرقاء candidate تُنظَّف بالقوانين الثلاثة (تغطية f_coveredIn + تتابُع f_seqEff + فعالية f_activated) — نفس قوانين الدرجات الأدنى.
if (showBig or showWaveCountBig or (showFib and (fibRetrBig or fibExtBig))) and barstate.islast   // [v3.88.24] يعمل أيضًا للترقيم/فيبو الكبيرة وحدهما (تُملأ النقاط الزرقاء)؛ رسم الدوائر يبقى على showBig أدناه
    // امسح كائنات الكبيرة السابقة
    if array.size(bigLbls) > 0
        for i = 0 to array.size(bigLbls) - 1
            label.delete(array.get(bigLbls, i))
        array.clear(bigLbls)
    if array.size(bigLines) > 0
        for i = 0 to array.size(bigLines) - 1
            line.delete(array.get(bigLines, i))
        array.clear(bigLines)
    // اجمع نقاط الكبيرة المرشّحة
    array<float> bcP   = array.new<float>()
    array<float> bcLvl = array.new<float>()
    array<int>   bcBar = array.new<int>()
    array<bool>  bcTop = array.new<bool>()
    float minAmp = bigMinATR * atrv
    int   mcn    = array.size(mcP)
    int   bdir   = 0
    float extP   = na
    float extLvl = na
    int   extB   = na
    int   legSw  = 0
    int   bigBreakDir = 0   // اتجاه بنية الزرقاء بالكسر (يغذّي largeDir عند التفعيل)
    int   bigPendBar  = na  // [V4.0] بار المرشّح الزرقاء المعلّق (لا يُحتسب في اتجاه الكبيرة — قاعدة الانتظار)
    // ===== المسار 1: استخراج الكبيرة بالكسر (الدرس 07) =====
    //   نفس آلية Proc/feed التي تشتقّ المتوسطة من الصغيرة، مُغذّاة بـ«كل» النقاط المتوسطة (لا الفعّالة فقط —
    //   كما تُشتقّ المتوسطة من كل الصغيرة)؛ محرّك الكسر يستخرج البنية ثم تُصفّى بالتتابُع/الفعالية لاحقاً.
    //   صعوداً: كسر قاع متوسط ⇒ قمة زرقاء (أعلى قبله) + قاع أزرق (أدنى بعده)؛ والعكس هبوطاً.
    //   العمق: داخل الموجة/تاريخ التاريخ بلا حدّ؛ يكفي 7 نقاط زرقاء قبل تاريخ التاريخ (hohLeft).
    if useBigBreak
        Proc pb = Proc.new()
        for i = 0 to mcn - 1
            // غذِّ كل النقاط المتوسطة المتناوبة (كما تُشتقّ المتوسطة من كل الصغيرة):
            //   محرّك الكسر نفسه يستخرج البنية الحقيقية ويتجاهل المكسور (فلتر الفعالية للكبيرة).
            [emb, ePb, eBHib, eBLob, eTmb, eBb, eTpb] = feed(pb, array.get(mcP, i), array.get(mcLvl, i), array.get(mcLvl, i), array.get(mcBar, i), array.get(mcBar, i), array.get(mcTop, i))
            if emb
                array.push(bcP, ePb)
                array.push(bcLvl, eBHib)
                array.push(bcBar, eBb)
                array.push(bcTop, eTpb)
        // النقطة المعلّقة الأخيرة (التطرّف الجاري) = أحدث نقطة زرقاء مرشّحة
        if pb.dir == 1 and not na(pb.maxTopP)
            array.push(bcP, pb.maxTopP)
            array.push(bcLvl, pb.maxTopBHi)
            array.push(bcBar, pb.maxTopBar)
            array.push(bcTop, true)
            bigPendBar := pb.maxTopBar   // [V4.0] هذه معلّقة ⇒ تُستثنى من حساب الاتجاه
        else if pb.dir == -1 and not na(pb.minBotP)
            array.push(bcP, pb.minBotP)
            array.push(bcLvl, pb.minBotBHi)
            array.push(bcBar, pb.minBotBar)
            bigPendBar := pb.minBotBar   // [V4.0] هذه معلّقة ⇒ تُستثنى من حساب الاتجاه
            array.push(bcTop, false)
        bigBreakDir := pb.dir
        // حدّ العمق: أبقِ كل النقاط >= hohLeft + آخر 7 نقاط قبل hohLeft فقط
        int beforeN = 0
        if array.size(bcBar) > 0
            for i = 0 to array.size(bcBar) - 1
                if array.get(bcBar, i) < hohLeft
                    beforeN += 1
        while beforeN > 7 and array.size(bcBar) > 0
            array.shift(bcP)
            array.shift(bcLvl)
            array.shift(bcBar)
            array.shift(bcTop)
            beforeN -= 1
    // Layer 3 يستعمل كل النقاط المتوسطة المؤكّدة بنيوياً (مستخرجة بالكسر) حيث bar <= histLeft،
    // بصرف النظر عن «الفعالية الحالية» (التي تخصّ المناطق فقط). التنظيف بقوانين الكبيرة لاحقاً.
    for i = 0 to mcn - 1
        if (not useBigBreak) and array.get(mcBar, i) <= histLeft
            float p = array.get(mcP, i)
            float lv = array.get(mcLvl, i)
            int   b = array.get(mcBar, i)
            if bdir == 0
                if na(extP)
                    extP := p
                    extLvl := lv
                    extB := b
                else
                    bdir := p > extP ? 1 : -1
                    legSw := 1
                    if (bdir == 1 and p > extP) or (bdir == -1 and p < extP)
                        extP := p
                        extLvl := lv
                        extB := b
            else
                legSw := legSw + 1
                if bdir == 1
                    if p > extP
                        extP := p
                        extLvl := lv
                        extB := b
                    else
                        bool okAmp  = bigMinATR <= 0 or (extP - p) >= minAmp
                        bool okBars = bigMinBars <= 0 or (b - extB) >= bigMinBars
                        bool okSw   = legSw >= bigMinSwings
                        if okAmp and okBars and okSw
                            array.push(bcP, extP)
                            array.push(bcLvl, extLvl)
                            array.push(bcBar, extB)
                            array.push(bcTop, true)
                            bdir := -1
                            extP := p
                            extLvl := lv
                            extB := b
                            legSw := 1
                else
                    if p < extP
                        extP := p
                        extLvl := lv
                        extB := b
                    else
                        bool okAmp  = bigMinATR <= 0 or (p - extP) >= minAmp
                        bool okBars = bigMinBars <= 0 or (b - extB) >= bigMinBars
                        bool okSw   = legSw >= bigMinSwings
                        if okAmp and okBars and okSw
                            array.push(bcP, extP)
                            array.push(bcLvl, extLvl)
                            array.push(bcBar, extB)
                            array.push(bcTop, false)
                            bdir := 1
                            extP := p
                            extLvl := lv
                            extB := b
                            legSw := 1
    // الامتداد الأخير المعلّق = نقطة زرقاء candidate أخيرة
    if (not useBigBreak) and not na(extP) and bdir != 0
        array.push(bcP, extP)
        array.push(bcLvl, extLvl)
        array.push(bcBar, extB)
        array.push(bcTop, bdir == 1)
    // أبقِ مرشّحات كافية (آخر ~2×عدد الموجات) — التقليم النهائي بعد التنظيف
    int keep = 2 * bigLegs + 2
    while (not useBigBreak) and array.size(bcP) > keep
        array.shift(bcP)
        array.shift(bcLvl)
        array.shift(bcBar)
        array.shift(bcTop)
    // اتجاه الكبيرة (bootstrap من ميل المرشّحات): آخر نقطة مقابل أولاها
    int nb0 = array.size(bcP)
    // اتجاه الموجة التاريخية = نوع أقرب نقطة متوسطة إلى histLeft (من الجهتين):
    //   قاع ⇒ صاعدة (1)، قمة ⇒ هابطة (-1). (بدايتها قد تقع بعد histLeft بقليل)
    int histDir = 0
    int bdist = 1000000000
    float pinBP = na
    float pinBL = na
    int   pinBB = na
    if mcn > 0
        for i = 0 to mcn - 1
            int dHL = math.abs(array.get(mcBar, i) - histLeft)
            if dHL < bdist
                bdist := dHL
                histDir := array.get(mcTop, i) ? -1 : 1
                pinBP := array.get(mcP, i)
                pinBL := array.get(mcLvl, i)
                pinBB := array.get(mcBar, i)
    if useBigBreak and bigBreakDir != 0
        histDir := bigBreakDir   // [D] الاتجاه من بنية الزرقاء المُشتقّة بالكسر
    else if histDir == 0
        histDir := bigDir
    largeDir := histDir
    // تنظيف الزرقاء حسب اتجاه الموجة التاريخية (لا اتجاه كل leg):
    //   صاعدة: التتابُع على القمم فقط (كل قمة أعلى)؛ القيعان بالفعالية (تُعتمد إذا صنع بعدها قمة أعلى).
    //   هابطة: التتابُع على القيعان فقط؛ القمم بالفعالية (إذا صنع بعدها قاع أدنى).
    array<float> kP   = array.new<float>()
    array<float> kLvl = array.new<float>()
    array<int>   kB   = array.new<int>()
    array<bool>  kT   = array.new<bool>()
    float lastSeq  = na   // آخر امتداد متتالٍ مُبقى (قمة صعوداً / قاع هبوطاً)
    float pendEffP = na   // نقطة الفعالية المعلّقة (قاع صعوداً / قمة هبوطاً)
    float pendEffL = na
    int   pendEffB = na
    // ===== مسار الكسر [NEW-2]: إبقاء متناوب (النقاط الزرقاء بالكسر نظيفة ومتناوبة أصلاً) =====
    //   أبقِ: كل نقاط الموجة التاريخية (bar >= histLeft) + 7 نقاط زرقاء قبل histLeft (للاتجاه)
    //         + نافذة الرسم (bar >= drawLeft = آخر drawWaves موجات). الأقدم يُمسح.
    //   لا حاجة لحلقة تتابُع/فعالية: الكسر طبّق القوانين ضمنياً، والاتجاه من ميل كل قطعة.
    if useBigBreak
        int cntB = array.size(bcBar)
        int sevenBar = -1
        int beforeC  = 0
        if cntB > 0
            for i = cntB - 1 to 0
                if array.get(bcBar, i) < histLeft
                    beforeC += 1
                    if beforeC >= 7
                        sevenBar := array.get(bcBar, i)
                        break
        int cutoffB = sevenBar < 0 ? 0 : math.min(drawLeft, sevenBar)
        if cntB > 0
            for i = 0 to cntB - 1
                if array.get(bcBar, i) >= cutoffB
                    array.push(kP,   array.get(bcP, i))
                    array.push(kLvl, array.get(bcLvl, i))
                    array.push(kB,   array.get(bcBar, i))
                    array.push(kT,   array.get(bcTop, i))
    if (not useBigBreak) and nb0 > 0
        for i = 0 to nb0 - 1
            float p  = array.get(bcP, i)
            float lv = array.get(bcLvl, i)
            int   b  = array.get(bcBar, i)
            bool  tp = array.get(bcTop, i)
            bool isSeq = (histDir == 1 and tp) or (histDir == -1 and not tp)
            if isSeq
                bool better = na(lastSeq) or (histDir == 1 ? p > lastSeq : p < lastSeq)
                if better
                    // امتداد متتالٍ صحيح ⇒ يُفعّل نقطة الفعالية المعلّقة قبله
                    if not na(pendEffP)
                        array.push(kP, pendEffP)
                        array.push(kLvl, pendEffL)
                        array.push(kB, pendEffB)
                        array.push(kT, histDir != 1)   // عكس نوع التتابُع
                        pendEffP := na
                    array.push(kP, p)
                    array.push(kLvl, lv)
                    array.push(kB, b)
                    array.push(kT, tp)
                    lastSeq := p
            else
                // مرشّح فعالية: أبقِ الأكثر تطرّفاً (أدنى قاع صعوداً / أعلى قمة هبوطاً)
                bool moreExt = na(pendEffP) or (histDir == 1 ? p < pendEffP : p > pendEffP)
                if moreExt
                    pendEffP := p
                    pendEffL := lv
                    pendEffB := b
    // ادفع آخر نقطة فعالية معلّقة (تصحيح حديث نحتاجه للسيولة) إن لم تُدفع
    if (not useBigBreak) and not na(pendEffP)
        array.push(kP, pendEffP)
        array.push(kLvl, pendEffL)
        array.push(kB, pendEffB)
        array.push(kT, histDir != 1)
        pendEffP := na
    // النقطة الزرقاء الحدودية المثبّتة عند histLeft (بداية الـleg الكبير النشط) — تُرسم دائماً.
    //   صاعدة ⇒ قاع أزرق حدودي؛ هابطة ⇒ قمة زرقاء حدودية. لا تخضع لحذف الفعالية.
    if (not useBigBreak) and not na(pinBP)
        bool dup = array.size(kB) > 0 and array.get(kB, array.size(kB) - 1) == pinBB
        if not dup
            array.push(kP, pinBP)
            array.push(kLvl, pinBL)
            array.push(kB, pinBB)
            array.push(kT, histDir == -1)
    // خزّن بارات الزرقاء النهائية لاستعمالها في override فعالية المناطق (الزرقاء = قمة/قاع متوسط صالح)
    array.clear(bluePivotBars)
    array.clear(bluePivotP)
    array.clear(bluePivotT)
    if array.size(kB) > 0
        for i = 0 to array.size(kB) - 1
            array.push(bluePivotBars, array.get(kB, i))
            array.push(bluePivotP,    array.get(kP, i))
            array.push(bluePivotT,    array.get(kT, i))
    // اتجاه الكبيرة من بنية الزرقاء النهائية (قاعدة الدرس): آخر قمة زرقاء أحدث من آخر قاع ⇒ صاعدة، والعكس
    int kTopBar = na
    int kBotBar = na
    // [V4.65] آخر قمّتين/قاعين زرقاوين (بالسعر) لقرار الاتجاه الكبير **بنيويًّا** (داو) — استثناء المرشّح المعلّق.
    float lastTopP = na
    float prevTopP = na
    float lastBotP = na
    float prevBotP = na
    if array.size(kP) > 0
        for i = array.size(kP) - 1 to 0   // من الأحدث للأقدم
            if na(bigPendBar) or array.get(kB, i) != bigPendBar   // [V4.0] استثنِ المرشّح المعلّق (قاعدة الانتظار)
                if array.get(kT, i)
                    if na(kTopBar)
                        kTopBar  := array.get(kB, i)
                        lastTopP := array.get(kP, i)
                    else if na(prevTopP)
                        prevTopP := array.get(kP, i)
                else
                    if na(kBotBar)
                        kBotBar  := array.get(kB, i)
                        lastBotP := array.get(kP, i)
                    else if na(prevBotP)
                        prevBotP := array.get(kP, i)
    if not na(kTopBar) and not na(kBotBar)
        // [V4.65] الاتجاه الكبير **ثابت بنيويًّا** (المرجع: «الكبيرة ثابتة نسبيًّا»): لا يقلب بمجرّد أنّ آخر نقطة
        //   زرقاء قاع/قمّة (ارتداد)، بل فقط بكسر بنيويّ — صاعدٌ ⇒ هابطٌ بقاع أزرق **أدنى** من سابقه (كُسر قاع الترند)؛
        //   وهابطٌ ⇒ صاعدٌ بقمّة أزرق **أعلى** من سابقتها. الأوّليّة (largeDir==0): نوع آخر نقطة حتى تتوفّر نقطتان.
        if largeDir == 0
            largeDir := kTopBar > kBotBar ? 1 : -1
        // [v3.85] **قلب داو أُلغي** (lowerLow/higherHigh على نقاط خام): كان يُطلق قلبًا كاذبًا على قاعٍ غير فعّال،
        //   ويحجب التعافي لأنّ قمّةً أدنى (يجب أن تُمسح بالتتابُع، الدرس 07 بند 3) كانت تُحتسَب فتمنع higherHigh.
        //   يُستبدَل بقاعدة المستخدم (الحالة 2) أدناه. (يبقى kTopBar/kBotBar للتمهيد الأوّليّ فقط.)
    // [v3.86] اتجاه الكبيرة = آلة الحالة per-bar (bigDirLvl) المبنيّة بقاعدة المستخدم (الحالتان 1+2، أعلى الكود قرب
    //   انقلاب المتوسطة). largeDir يبقى islast (يقرأ القيمة النهائيّة) ⇒ يُصلح العرض/الإشارات بلا انحدار تاريخيّ.
    if bigDirLvl != 0
        largeDir := bigDirLvl
    // ===== فعالية الكبيرة (تُحسب مرّة) + تصدير global (طبقة الوصول) =====
    //   كانت تُحسب مرّتين (رسم + سيولة) ⇒ O(n²)×2؛ الآن مرّة، ويقرأها الرسم/السيولة من bigEff (أداء + وصول).
    array.clear(bigP)
    array.clear(bigLvl)
    array.clear(bigBar)
    array.clear(bigTop)
    array.clear(bigEff)
    array.clear(bigPend)
    int nkp = array.size(kP)
    if nkp > 0
        // [V3.5] قصر فعالية الكبيرة على الموجة (مرآة zoneEff): التتابُع/الفعالية على مصفوفة فرعية باتجاه الموجة،
        //   والتغطية عالميّة على kP. داخل الموجة (kB>=histLeft) باتجاه largeDir؛ التاريخ (kB<histLeft) بالمعاكس —
        //   يمنع تلوّث نقاط الموجة الحالية بقمم/قيعان الموجة السابقة (كانت تُسقط القمة الزرقاء الحدودية خطأً).
        array<float> inKP = array.new<float>()
        array<int>   inKB = array.new<int>()
        array<bool>  inKT = array.new<bool>()
        array<int>   inKM = array.new<int>()
        array<float> hsKP = array.new<float>()
        array<int>   hsKB = array.new<int>()
        array<bool>  hsKT = array.new<bool>()
        array<int>   hsKM = array.new<int>()
        for i = 0 to nkp - 1
            int bk = array.get(kB, i)
            if bk >= histLeft
                array.push(inKP, array.get(kP, i))
                array.push(inKB, bk)
                array.push(inKT, array.get(kT, i))
                array.push(inKM, i)
            else
                array.push(hsKP, array.get(kP, i))
                array.push(hsKB, bk)
                array.push(hsKT, array.get(kT, i))
                array.push(hsKM, i)
        array<bool> kEff  = array.new<bool>(nkp, false)
        array<bool> kPend = array.new<bool>(nkp, false)   // [V3.7] معلّقة (مرآة dgPend): غير مغطّاة + بلا تطرّف تالٍ يؤكّدها
        int nin = array.size(inKM)
        if nin > 0
            for j = 0 to nin - 1
                int oi = array.get(inKM, j)
                bool covI = f_coveredIn(kP, kB, kT, oi)
                bool pndI = f_pending(inKP, inKT, inKB, array.get(kB, oi), array.get(kT, oi), largeDir)
                bool sqI  = f_seqEff(inKP, inKB, inKT, j, largeDir)      // [V3.48] ترتيب وسائط f_seqEff = (price, bar, top)
                bool acI  = f_activated(inKP, inKB, inKT, j, largeDir)
                array.set(kEff,  oi, (not covI) and (not pndI) and (not applySeqAct or (sqI and acI)))   // [V3.58] التتابُع/الفعالية يبوّبهما applySeqAct (الافتراضيّ مفعّل = الدرس 07؛ مطفأ = تغطية+موضعيّة فقط)
                array.set(kPend, oi, (not covI) and pndI)
        int nhs = array.size(hsKM)
        if nhs > 0
            int bigHistDir = -largeDir   // الموجة الكبيرة السابقة معاكسة (تتناوب)
            for j = 0 to nhs - 1
                int oh = array.get(hsKM, j)
                bool covH = f_coveredIn(kP, kB, kT, oh)
                bool pndH = f_pending(hsKP, hsKT, hsKB, array.get(kB, oh), array.get(kT, oh), bigHistDir)
                bool sqH  = f_seqEff(hsKP, hsKB, hsKT, j, bigHistDir)
                bool acH  = f_activated(hsKP, hsKB, hsKT, j, bigHistDir)
                bool outKH = array.get(kP, oh) > hwHiE or array.get(kP, oh) < hwLoE   // [V4.3] خارج نطاق الموجة ⇒ فعّال
                array.set(kEff,  oh, outKH or ((not pndH) and (not covH) and (not applySeqAct or (sqH and acH))))   // [V3.58] الخارج (موضعيّ) فعّال؛ الداخليّ يخضع للتتابُع/الفعالية حين applySeqAct
                array.set(kPend, oh, (not outKH) and (not covH) and pndH)
        for i = 0 to nkp - 1
            array.push(bigP,   array.get(kP, i))
            array.push(bigLvl, array.get(kLvl, i))
            array.push(bigBar, array.get(kB, i))
            array.push(bigTop, array.get(kT, i))
            array.push(bigEff, array.get(kEff, i))
            array.push(bigPend, array.get(kPend, i))
    // ارسم النقاط الزرقاء الفعّالة (بعد التنظيف) + روابطها
    int nb = array.size(kP)
    int prevBar = na
    float prevP = na
    if showBig and nb > 0   // [v3.88.10] رسم دوائر/خطوط الكبيرة فقط عند showBig (الاستخراج أعلاه يعمل للترقيم أيضًا)
        for i = 0 to nb - 1
            float p = array.get(kP, i)
            int   b = array.get(kB, i)
            bool  me = array.get(bigEff, i)   // محسوبة مرّة في طبقة الوصول
            bool  mp = array.size(bigPend) > i and array.get(bigPend, i)   // [V3.7] معلّقة؟
            // [V4.38] تصحيح **اللون فقط** (لا يمسّ bigEff/السيولة): النقطة الدافعة الزرقاء التي اخترقها السعر = مُختبَرة ⇒ ميّتة.
            //   هبوطاً: قاع أزرق و hwLoE < سعره (هبط تحته)؛ صعوداً: قمّة زرقاء و hwHiE > سعرها (صعد فوقها). النوع التصحيحيّ يبقى.
            bool  testedB = (medActiveDir == -1 and not array.get(kT, i) and hwLoE < p) or (medActiveDir == 1 and array.get(kT, i) and hwHiE > p)   // [V4.39] باتجاه الموجة العاملة لا largeDir
            bool  meC = me and not testedB
            // نمط الدائرة الموحّد (نفس المتوسطة): بوردر ثابت (محجوز) + تعبئة تُرمّز الفعالية (فعّال أزرق / معلّق رماديّ / غير فعّال أحمر)
            label lbO = label.new(b, p, "", xloc = xloc.bar_index, yloc = yloc.price,
                 style = label.style_circle, color = mp ? (showPending ? cPendBordBig : color.new(color.gray, 100)) : cBigBorder, size = f_lblSize(bigCircleSize))   // [V4.8] إخفاء المعلّق ⇒ شفاف
            array.push(bigLbls, lbO)
            label lb = label.new(b, p, "", xloc = xloc.bar_index, yloc = yloc.price,
                 style = label.style_circle, color = meC ? cBig : mp ? (showPending ? cPend : color.new(color.gray, 100)) : cBigDead, size = f_lblSizeIn(bigCircleSize))
            array.push(bigLbls, lb)
            if linkBig and not na(prevBar)
                line ln = line.new(prevBar, prevP, b, p, xloc = xloc.bar_index,
                     color = color.new(cBig, 0), width = 2)
                array.push(bigLines, ln)
            prevBar := b
            prevP := p
    // خط السيولة الأزرق + مستوى الاتجاه الأزرق من آخر قمتين/قاعين
    if not na(bigLiqLine)
        line.delete(bigLiqLine)
        bigLiqLine := na
    if not na(bigLvlLine)
        line.delete(bigLvlLine)
        bigLvlLine := na
    if showLiq or showLvl
        // [V4.18] سيولة/مستوى الكبيرة (الدرس 09/10): الأزرق يتبع اتجاه الموجة المتوسطة (medActiveDir).
        //   ننتظر **زوجًا أزرق صالحًا** (قاعين متصاعدين أسفل السعر صعوداً / قمّتين متنازلتين أعلاه هبوطاً)
        //   لرسم الخطّين **معًا**. إن لم نجد زوجًا جديدًا نُبقي الزوج المثبَّت (الخطّ القديم يثبت عبر انقلاب
        //   الأصفر حتى تظهر نقاط زرقاء جديدة) ⇒ أثناء الانتظار يخالف الأزرقُ الأصفرَ = «سيولة غير محدّدة» (الدرس 10، س13).
        //   نبحث qa1 (الأحدث) ثم qa2 (أقرب أقدم على الجهة الصحيحة). المستوى على qa1.
        int   qa1i = na
        int   qa1  = na
        float qv1  = na
        int   qa2  = na
        float qv2  = na
        int   bigWaveDir = largeDir       // [V4.65] الأزرق يتبع **اتجاه الدرجة الكبيرة** (largeDir البنيويّ الثابت) لا المتوسطة —
        //   المرجع: «الكبيرة ثابتة نسبيًّا»؛ يصلح اختفاء الخطوط الزرقاء عند تصحيح متوسط (لا يقلب إلّا بكسر قاع/قمّة الترند الكبير).
        bool  wantTop = bigWaveDir == -1   // هبوطاً نريد قممًا، صعوداً قيعانًا
        // [V4.19] آخر **قاعين/قمّتين فعّالين** على الجهة الصحيحة من السعر (مرآة المتوسطة) — بلا اشتراط تصاعد/تنازل
        //   صارم (كان يرفض القيعان المتنازلة بعد الهبوط ⇒ لا خطّ رغم وجود قاعين). الميل يأتي من النقطتين كما هما.
        if bigWaveDir != 0 and nb > 0
            for ii = nb - 1 to 0
                if array.get(bigEff, ii) and array.get(kT, ii) == wantTop and (wantTop ? array.get(kP, ii) > close : array.get(kP, ii) < close)
                    if na(qa1)
                        qa1i := ii
                        qa1  := array.get(kB, ii)
                        qv1  := array.get(kP, ii)
                    else if na(qa2)
                        qa2  := array.get(kB, ii)
                        qv2  := array.get(kP, ii)
        // [V4.73] مرساة **المستوى** الأزرق منفصلة عن السيولة: آخر تطرّف أزرق **غير مُغطّى** (يشمل المعلّق غير المُغطّى).
        //   الدرس 08: «المستوى على آخر قاع/قمّة» ⇒ يتحرّك مع التطرّف الجديد (كالأصفر تمامًا) ولا يبقى على قاع صار
        //   غير فعّال. (السيولة تبقى على الزوج الفعّال المثبَّت لاستقرار الخطّ ذي النقطتين.)
        int   bigLvlBar = na
        float bigLvlVv  = na
        // [V4.77] اتجاه **المستوى** = اتجاه المرساة (bigAncDir) لا largeDir — ليتطابق مع السيولة واللوحة.
        //   largeDir قد ينقلب بنيويًّا (قاع أدنى) بينما المرساة/اللوحة صاعدة (لا زوج قمم بعدُ) ⇒ كان المستوى يقفز
        //   لقمّة بينما السيولة على القيعان واللوحة «صاعد» = تناقض. الآن المستوى يتبع المرساة (متّسق مع السيولة).
        int   bigLvlDrawDir = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : largeDir
        bool  wantTopL  = bigLvlDrawDir == -1
        if bigLvlDrawDir != 0 and nb > 0
            for ii = nb - 1 to 0
                bool nonCovL = array.get(bigEff, ii)   // [V3.74] الفعّال فقط (أُزيل bigPend) ⇒ المستوى الأزرق يرسي على تطرّف له دائرة زرقاء **مصمتة** لا معلّقة رماديّة (الدرس 09: المستوى على تطرّف مؤكَّد)
                if na(bigLvlBar) and nonCovL and (na(bigLvlBrkBar) or array.get(kB, ii) > bigLvlBrkBar) and array.get(kT, ii) == wantTopL and (wantTopL ? array.get(kP, ii) > close : array.get(kP, ii) < close)
                    bigLvlBar := array.get(kB, ii)   // [V4.75] محور أزرق **بعد** إعادة البناء فقط (القاعدة 2)
                    bigLvlVv  := na(array.get(kLvl, ii)) ? array.get(kP, ii) : array.get(kLvl, ii)
        // [V4.18] تشخيص: عُدّ النقاط الزرقاء الفعّالة على كلّ جهة من السعر
        bigDbgBelow := 0
        bigDbgAbove := 0
        if nb > 0
            for ci = 0 to nb - 1
                if array.get(bigEff, ci)
                    if not array.get(kT, ci) and array.get(kP, ci) < close
                        bigDbgBelow += 1
                    if array.get(kT, ci) and array.get(kP, ci) > close
                        bigDbgAbove += 1
        bigDbgPair := not na(qa1) and not na(qa2)
        bigDbgNb := nb
        // [V4.66] الأزرق **شبه ثابت** (قرار المستخدم): يُعاد التثبيت فقط عند **محور أزرق جديد** (qa1 أحدث من المثبَّت =
        //   قاع/قمّة زرقاء جديدة، الحالة 2) أو **انقلاب اتجاه الكبيرة** (الحالة 1) — لا عند تذبذب فعاليّة النقاط القائمة
        //   (كان يقفز لقيعان التاريخ حين تُعلَّق قمّة الموجة المؤكِّدة بقاعدة الانتظار فيُعلَّق قاعها).
        bool reAnchorBig = na(bigAncQa1) or bigWaveDir != bigAncDir or qa1 > bigAncQa1
        if not na(qa1) and not na(qa2) and qa1 != qa2 and reAnchorBig
            bigAncQa1 := qa1
            bigAncQv1 := qv1
            bigAncQa2 := qa2
            bigAncQv2 := qv2
            bigAncLvl := na(array.get(kLvl, qa1i)) ? qv1 : array.get(kLvl, qa1i)
            bigAncDir := bigWaveDir
        // ارسم الخطّين معًا من الزوج المثبَّت (يمتدّان للحافة الحيّة كل بار) — النقل دائمًا للخطّين سويًّا
        if not na(bigAncQa1) and not na(bigAncQa2) and bigAncQa1 != bigAncQa2
            // [V4.72] بعد كسر السيولة الأزرق لا يُعاد رسمها إلّا بمحورين زرقاوين جديدين (الأقدم bigAncQa2 بعد بار الكسر).
            if showLiq and (na(bigLiqBrkBar) or bigAncQa2 > bigLiqBrkBar)
                float slB = (bigAncQv1 - bigAncQv2) / (bigAncQa1 - bigAncQa2)
                int   rbB = last_bar_index + liqExtBars
                // [V4.25] الأزرق (درجة أكبر) أعرض من الأصفر بمقدارين فيظهر كحاشية حوله حين تتطابق نقاطهما (الأزرق ضمنيًّا أصفر)
                float projB = bigAncQv1 + slB * (bar_index - bigAncQa1)
                if bigAncDir == 1 ? close >= projB : close <= projB   // [v3.87.14] الدرس 08 حرفيًّا: آخر زوج أزرق بلا شرط اتجاه؛ حارس «لا يُرسم مكسورًا» (close مقابل الإسقاط) يبقى
                    bigLiqLine := line.new(bigAncQa2, bigAncQv2, rbB, bigAncQv1 + slB * (rbB - bigAncQa1),
                         xloc = xloc.bar_index, color = cLiqB, width = wBig)
        // [V4.73] المستوى الأزرق **مستقلّ** عن الزوج: على آخر تطرّف أزرق غير مُغطّى (يتحرّك مع التطرّف الجديد، لا يبقى على غير الفعّال).
        if showLvl and not na(bigLvlBar) and not na(bigLvlVv)
            bigLvlLine := line.new(bigLvlBar, bigLvlVv, last_bar_index + lvlExtBars, bigLvlVv,
                 xloc = xloc.bar_index, color = cLvlB, width = wBig)
        // ===== مرحلة الكبيرة: تُحسب الآن لكل بار بآلة المراحل الخمس الكاملة (bigPh) =====
        //   (عبر phaseOnBar(bigPh) على bigLiqLvl المنطقي + phaseOnPivot عند كل نقطة زرقاء).
        //   نص المرحلة (bigPhase) صار يُضبط في الكتلة لكل بار — لا حساب مبسّط هنا.
        // ===== كسر مستوى الاتجاه الكبير (شمعتان) ⇒ إعادة تقييم سياق فقط =====
        //   لا يقلب الاتجاه، لا يمسح، لا ينهي الموجة (الدرس لم يحدّد له آلية كالمتوسطة).
        float bigTL = bigAncLvl   // [V4.18] مستوى الاتجاه الأزرق المثبَّت (نفس مرساة الخطّ المرسوم)
        bigCtxReview := false
        if not na(bigTL) and not na(bigAncQa1)
            int  ccB = 0
            int  lastBrkB = na
            int  lastRecB = na
            int  anchorB  = bigAncQa1
            int  sJB      = math.max(anchorB, bar_index - 4000)
            for j = sJB to bar_index
                int off = bar_index - j
                if off >= 0
                    float c = close[off]
                    float o = open[off]
                    if bigAncDir == 1
                        ccB := (c < o and c < bigTL) ? ccB + 1 : 0
                        if ccB >= 2
                            lastBrkB := j
                        if c > bigTL
                            lastRecB := j
                    if bigAncDir == -1
                        ccB := (c > o and c > bigTL) ? ccB + 1 : 0
                        if ccB >= 2
                            lastBrkB := j
                        if c < bigTL
                            lastRecB := j
            bigCtxReview := not na(lastBrkB) and (na(lastRecB) or lastBrkB > lastRecB)

// [V4.11] تشخيص حالة الموجة (مؤقّت، مع «تشخيص مؤقّت») — يكشف: اتجاه المتوسطة/الكبيرة، بداية الموجة (تحديث النطاق
//   بعد كسر الأصفر)، النطاق [أدنى,أعلى]، وعدد النقاط الكبيرة (كلّي/داخل الموجة+التاريخ) — لتشخيص قلّة الكبيرة والنطاق.


// [V3.7] المرشّح المعلّق الحيّ للمتوسطة (قاعدة الانتظار، الدرس 06): آخر تطرّف لم يُكسَر بعد لم يُنبَعث في mcP
//   ⇒ لا تظهر عليه دائرة افتراضاً. نرسمه دائرةً رماديّةً (cPend) عند islast فقط — يحلّ التباس
//   «قمّة أعلى من آخر زرقاء لم يتحدّث الرسم»: هي معلّقة حتى يُكسر قاع متوسط أدنى فتُؤكَّد وتُنبَعث.
var label medPendLblO = na
var label medPendLbl  = na
if showMed and barstate.islast
    label.delete(medPendLblO)
    label.delete(medPendLbl)
    medPendLblO := na
    medPendLbl  := na
    float pcP = na
    int   pcB = na
    if pmed.dir == 1 and not na(pmed.maxTopP)
        pcP := pmed.maxTopP
        pcB := pmed.maxTopBar
    else if pmed.dir == -1 and not na(pmed.minBotP)
        pcP := pmed.minBotP
        pcB := pmed.minBotBar
    if showPending and not na(pcP) and not na(pcB) and pcB >= drawLeft
        medPendLblO := label.new(pcB, pcP, "", xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_circle, color = cPendBordMed, size = f_lblSize(medCircleSize))   // [V3.8] بوردر أصفر = متوسطة معلّقة
        medPendLbl  := label.new(pcB, pcP, "", xloc = xloc.bar_index, yloc = yloc.price,
             style = label.style_circle, color = cPend, size = f_lblSizeIn(medCircleSize))


// ===== بناء قائمة المناطق (5-أ) — العملية الخماسية (الدرس 10) — بعد كتلة الكبيرة =====
//   لا تخصيص للزرقاء: القمة/القاع الأزرق يُعامَل كنقطة متوسطة («صفراء ضمنياً»). الترتيب:
//   (1) نحدّد القمم/القيعان الفعّالة (غير مُغطّاة = غير مُختبَرة + غير معلّقة) — zoneEff. (التتابُع/الفعالية للبنية فقط، v4.1)
//   (2) نرسم خطوط m.A على الفعّالة فقط.  (3) نزاوج بالجوار داخل الموجة (غير التصحيح).
//   (4) المنفردة بلا جار ⇒ نعود للتاريخ ونستعير أقرب قمة/قاع فعّال.  (5) نرسم المستطيلات.
// يُعاد الحساب عند انبعاث نقطة متوسطة (الحدث) أو على آخر شمعة — لا كل شمعة (الأداء).
//   النتيجة تُخزَّن في zTop/zBot وتُفحص العضوية per-bar. الرسم يبقى في islast (حدود الكائنات).
if barstate.islast or emittedMedBar
    int mmz = array.size(mcP)
    // [V4.5] نافذة تقييم الفعالية تغطّي نافذة الرسم (drawLeft) + نافذة الجدول (diagBigWaves) معاً —
    //   الأبعد للخلف منهما — كي تقرأ كل المستهلكين (الدوائر + m.A + الجداول) zoneEff صالحاً لكل نقطة مرسومة/معروضة.
    // [V4.35] نوسّعها لتشمل **كل نقاط mcP المتاحة** (≤80) كي تُقيَّم نقاط التاريخ القديمة وتصلح كشركاء للمنفردة
    //   (الدرس L2-02: أقرب شريك في كلّ التاريخ). لا يغيّر ألوان الدوائر (تستعمل mcEff قبل drawLeft).
    int effLeft = math.min(drawLeft, array.size(bigBar) > 0 ? array.get(bigBar, math.max(0, array.size(bigBar) - diagBigWaves * 2)) : drawLeft)
    effLeft := array.size(mcBar) > 0 ? math.min(effLeft, array.get(mcBar, 0)) : effLeft
    // [V3] الخطوة 1: فعالية المتوسطة طازجةً مُقيّدةً بالموجة (لا نثق بـ mcEff العالميّ عبر انقلاب الموجة).
    //   القوانين الثلاثة (الشرح + قائمة التحقق): (1) التتابُع f_seqEff للنقطة الدافعة (قمم تتصاعد صعوداً /
    //   قيعان تتناقص هبوطاً)؛ (2) الفعالية f_activated لغير الدافعة (قاع يُفعَّل بقمة أعلى / قمة بقاع أدنى)؛
    //   (3) التغطية f_coveredIn العامّة (مُغطّى بنقطة لاحقة تتجاوزه ⇒ غير فعّال). التتابُع/الفعالية مُقيّدان
    //   بالموجة باتجاهها (medActiveDir للحالية، المعاكس للتاريخ)؛ التغطية عالميّة للأمام. inMap/hsMap للفهرس.
    array.clear(zoneEff)
    array.clear(dgCov)
    array.clear(dgSeq)
    array.clear(dgAct)
    array.clear(dgPend)
    array.clear(dgReason)
    if mmz > 0
        array<float> inP   = array.new<float>()
        array<int>   inBar = array.new<int>()
        array<bool>  inTop = array.new<bool>()
        array<int>   inMap = array.new<int>()
        array<float> hsP   = array.new<float>()
        array<int>   hsBar = array.new<int>()
        array<bool>  hsTop = array.new<bool>()
        array<int>   hsMap = array.new<int>()
        for i = 0 to mmz - 1
            int bi = array.get(mcBar, i)
            array.push(zoneEff, false)                       // تهيئة 1:1 مع mcP
            array.push(dgCov, false)
            array.push(dgSeq, false)
            array.push(dgAct, false)
            array.push(dgPend, false)
            array.push(dgReason, "")
            if bi >= histLeft
                array.push(inP, array.get(mcP, i))
                array.push(inBar, bi)
                array.push(inTop, array.get(mcTop, i))
                array.push(inMap, i)
            else if bi >= effLeft
                array.push(hsP, array.get(mcP, i))
                array.push(hsBar, bi)
                array.push(hsTop, array.get(mcTop, i))
                array.push(hsMap, i)
        int niW = array.size(inMap)
        if niW > 0
            for j = 0 to niW - 1
                int oi = array.get(inMap, j)
                // القوانين الثلاثة (الشرح + قائمة التحقق): تتابُع (الدافعة) + فعالية (غير الدافعة) داخل الموجة
                //   باتجاه medActiveDir، + تغطية عالميّة (مُغطّى بنقطة لاحقة تتجاوزه ⇒ غير فعّال).
                bool covd = f_coveredIn(mcP, mcBar, mcTop, oi)
                bool sq   = f_seqEff(inP, inBar, inTop, j, medActiveDir)
                bool ac   = f_activated(inP, inBar, inTop, j, medActiveDir)
                bool pnd  = f_pending(inP, inTop, inBar, array.get(mcBar, oi), array.get(mcTop, oi), medActiveDir)
                array.set(zoneEff, oi, (not covd) and (not pnd) and (not applySeqAct or (sq and ac)))   // [V3.58] التتابُع (sq)/الفعالية (ac) يبوّبهما applySeqAct (الافتراضيّ مفعّل = الدرس 06؛ مطفأ = تغطية+موضعيّة)
                array.set(dgCov, oi, covd)
                array.set(dgSeq, oi, sq)
                array.set(dgAct, oi, ac)
                array.set(dgPend, oi, (not covd) and pnd)
                if (showEffTable or showDerivTable) and barstate.islast
                    array.set(dgReason, oi, f_effReason(oi, mmz, inP, inTop, inBar, medActiveDir, covd, sq, ac))
        int nhW = array.size(hsMap)
        if nhW > 0
            int histDirC = -medActiveDir   // نافذة التاريخ = الموجة السابقة (الاتجاه معاكس — الموجات تتناوب)
            for j = 0 to nhW - 1
                int oh = array.get(hsMap, j)
                // نفس القوانين الثلاثة داخل نافذة التاريخ باتجاه الموجة السابقة — شريك صالح للاستعارة
                bool covh = f_coveredIn(mcP, mcBar, mcTop, oh)
                bool sqh  = f_seqEff(hsP, hsBar, hsTop, j, histDirC)
                bool ach  = f_activated(hsP, hsBar, hsTop, j, histDirC)
                bool pndh = f_pending(hsP, hsTop, hsBar, array.get(mcBar, oh), array.get(mcTop, oh), histDirC)
                bool outH = array.get(mcP, oh) > hwHiE or array.get(mcP, oh) < hwLoE   // [V4.3] خارج نطاق الموجة [hwLoE,hwHiE] ⇒ منطقة تفاعل خارجيّة ⇒ فعّال (قاعدة المستخدم)
                array.set(zoneEff, oh, outH or ((not pndh) and (not covh) and (not applySeqAct or (sqh and ach))))   // [V3.58] الخارج (outH موضعيّ) فعّال دائماً؛ الداخليّ يخضع للتتابُع/الفعالية حين applySeqAct
                array.set(dgCov, oh, covh)
                array.set(dgSeq, oh, sqh)
                array.set(dgAct, oh, ach)
                array.set(dgPend, oh, (not outH) and (not covh) and pndh)
                if (showEffTable or showDerivTable) and barstate.islast
                    array.set(dgReason, oh, outH ? "فعّال (خارج نطاق الموجة) ✓" : f_effReason(oh, mmz, hsP, hsTop, hsBar, histDirC, covh, sqh, ach))
    // [V4.31] إعادة تلوين دوائر المتوسطة بـ zoneEff/dgPend **الطازجة** (كتلة التلوين س1865 تسبق هذه الكتلة ⇒ كانت قديمة
    //   بإطار ⇒ دائرة رماديّة قديمة مع خطّ m.A طازج). الآن الدوائر تطابق m.A تمامًا — لا خطّ على رماديّة/حمراء.
    if barstate.islast
        for i = 0 to mmz - 1
            if array.size(mcLbl) > i
                label li2  = array.get(mcLbl, i)
                label liO2 = array.size(mcLblO) > i ? array.get(mcLblO, i) : na
                float pci2 = array.get(mcP, i)
                bool outC2 = pci2 > hwHiE or pci2 < hwLoE
                bool inW2  = array.size(zoneEff) > i and array.get(mcBar, i) >= drawLeft
                bool effC2 = outC2 or (inW2 ? array.get(zoneEff, i) : array.get(mcEff, i))
                bool pnd2  = (not outC2) and inW2 and array.size(dgPend) > i ? array.get(dgPend, i) : false
                // [V3.52] ارسم النقطة المتأخّرة الناقصة: تأكّدت بعد ساق طويلة فسقط بارها من drawLeft لحظة الانبعاث ⇒ لم تُرسم دائرتها/خطّها رغم أنّها داخل النافذة الآن (يُرسَم مرّة ويُخزَّن فلا يتكرّر)
                if na(li2) and showMed   // [V3.53] أيّ نقطة متوسطة ناقصة (حتى الأقدم من drawLeft): جيرانها المرسومون عند الانبعاث يبقون، فيجب إكمال البنية (السقف 80 يحدّ العدد)
                    liO2 := label.new(array.get(mcBar, i), pci2, "", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_circle, color = cMedBorder, size = f_lblSize(medCircleSize))
                    li2  := label.new(array.get(mcBar, i), pci2, "", xloc = xloc.bar_index, yloc = yloc.price, style = label.style_circle, color = cMed, size = f_lblSizeIn(medCircleSize))
                    array.set(mcLblO, i, liO2)
                    array.set(mcLbl, i, li2)
                    if linkMed and i > 0
                        line.new(array.get(mcBar, i - 1), array.get(mcP, i - 1), array.get(mcBar, i), pci2, xloc = xloc.bar_index, color = cLineM, width = 2)
                if not na(li2)
                    label.set_color(li2, effC2 ? cMed : pnd2 ? (showPending ? cPend : color.new(color.gray, 100)) : cMedDead)
                if not na(liO2)
                    label.set_color(liO2, pnd2 ? (showPending ? cPendBordMed : color.new(color.gray, 100)) : cMedBorder)
    // [V4.34] (أُلغِيَ v4.33) لا نُجبر دائرة الكبيرة على حالة المتوسطة — لكلّ درجة حالتها المستقلّة (التداخل = النقطة
    //   موجودة في كلّ الدرجات لا أن حالتها واحدة). الزرقاء المعلّقة/الميّتة تبقى، والصفراء الفعّالة تحتها تظهر عند إخفاء المعلّق.
    // [V3.6] سيولة المتوسطة ومستوى اتجاهها من النقاط الفعّالة فقط (مرآة الكبيرة) — لا تُرسم على غير الفعّالة.
    if not na(memM.liq)
        line.delete(memM.liq)
        memM.liq := na
    if not na(memM.lvl)
        line.delete(memM.lvl)
        memM.lvl := na
    if (showLiq or showLvl) and mmz > 0
        int mb1 = na
        int mb2 = na
        int mt1 = na
        int mt2 = na
        for i = 0 to mmz - 1
            if array.size(zoneEff) > i and array.get(zoneEff, i) and array.get(mcBar, i) >= histLeft
                bool tp = array.get(mcTop, i)
                int  bb = array.get(mcBar, i)
                float pr = array.get(mcP, i)   // [V4.23] قيد جهة السعر (مرآة الكبيرة): قاع أسفل السعر صعوداً / قمّة أعلى السعر هبوطاً
                if tp and pr > close
                    if na(mt1) or bb > array.get(mcBar, mt1)
                        mt2 := mt1
                        mt1 := i
                    else if na(mt2) or bb > array.get(mcBar, mt2)
                        mt2 := i
                else if (not tp) and pr < close
                    if na(mb1) or bb > array.get(mcBar, mb1)
                        mb2 := mb1
                        mb1 := i
                    else if na(mb2) or bb > array.get(mcBar, mb2)
                        mb2 := i
        int rbM = last_bar_index + liqExtBars
        // [V4.64] بعد الكسر البنيويّ: لا يُعاد رسم السيولة إلّا بظهور **قاعين جديدين** (الدرس 09) ⇒ حتى الأقدم (mb2) بعد بار الكسر.
        if medActiveDir == 1 and showLiq and not na(mb1) and not na(mb2) and (na(medLiqBrkBar) or array.get(mcBar, mb2) > medLiqBrkBar)   // [v3.87.14] الدرس 08 حرفيًّا: آخر قاعين بلا شرط تصاعد (حارس «غير مكسور» close>=projNow أدناه يبقى)
            int   lb1 = array.get(mcBar, mb1)
            int   lb2 = array.get(mcBar, mb2)
            float lp1 = array.get(mcP, mb1)
            float lp2 = array.get(mcP, mb2)
            float slM = lb1 != lb2 ? (lp1 - lp2) / (lb1 - lb2) : 0.0
            // [V4.69] لا يُرسم خطّ السيولة **مكسورًا أصلًا**: صعودًا يجب أن يكون السعر **فوق** إسقاط الخطّ عند الحافّة الحيّة.
            float projNow = lp1 + slM * (bar_index - lb1)
            if close >= projNow
                memM.liq := line.new(lb2, lp2, rbM, lp1 + slM * (rbM - lb1), xloc = xloc.bar_index, color = cLiqM, width = wMed)
        // [V4.64] مكسور ⇒ لا يُعاد رسمه إلّا بـ**قمّتين جديدتين** (الأقدم mt2) بعد بار الكسر.
        if medActiveDir == -1 and showLiq and not na(mt1) and not na(mt2) and (na(medLiqBrkBar) or array.get(mcBar, mt2) > medLiqBrkBar)   // [v3.87.14] الدرس 08 حرفيًّا: آخر قمّتين بلا شرط تنازل (حارس «غير مكسور» close<=projNow أدناه يبقى)
            int   lt1 = array.get(mcBar, mt1)
            int   lt2 = array.get(mcBar, mt2)
            float ltp1 = array.get(mcP, mt1)
            float ltp2 = array.get(mcP, mt2)
            float slM = lt1 != lt2 ? (ltp1 - ltp2) / (lt1 - lt2) : 0.0
            // [V4.69] هبوطًا يجب أن يكون السعر **تحت** إسقاط الخطّ (لا يُرسم مكسورًا أصلًا).
            float projNow = ltp1 + slM * (bar_index - lt1)
            if close <= projNow
                memM.liq := line.new(lt2, ltp2, rbM, ltp1 + slM * (rbM - lt1), xloc = xloc.bar_index, color = cLiqM, width = wMed)
        // [V3.75 · v3.87.14] fallback السيولة: لا قمّتان/قاعان فعّالان في النافذة ⇒ آخر تطرّفين خام (memM)، بلا شرط تصاعد (الدرس 08 حرفيًّا) + حارس «غير مكسور». (أثر مقصود: الاستنتاجات تعرّف اتجاه السيولة حين يتوفّر زوج خام — اتجاه حقيقيّ لا تلفيق.)
        if showLiq and na(memM.liq) and medActiveDir == 1 and not na(memM.lbP) and not na(memM.pbP) and memM.lbBar != memM.pbBar and (na(medLiqBrkBar) or memM.pbBar > medLiqBrkBar)   // [v3.87.14] احتياطيّ: آخر قاعين خام بلا شرط تصاعد (الدرس 08)؛ التبويب ببار الكسر يبقى (الدرس 09)
            float slFbU = (memM.lbP - memM.pbP) / (memM.lbBar - memM.pbBar)
            if close >= memM.lbP + slFbU * (bar_index - memM.lbBar)
                memM.liq := line.new(memM.pbBar, memM.pbP, rbM, memM.lbP + slFbU * (rbM - memM.lbBar), xloc = xloc.bar_index, color = cLiqM, width = wMed)
        if showLiq and na(memM.liq) and medActiveDir == -1 and not na(memM.ltP) and not na(memM.ptP) and memM.ltBar != memM.ptBar and (na(medLiqBrkBar) or memM.ptBar > medLiqBrkBar)   // [v3.87.14] احتياطيّ: آخر قمّتين خام بلا شرط تنازل (الدرس 08)؛ التبويب ببار الكسر يبقى (الدرس 09)
            float slFbD = (memM.ltP - memM.ptP) / (memM.ltBar - memM.ptBar)
            if close <= memM.ltP + slFbD * (bar_index - memM.ltBar)
                memM.liq := line.new(memM.ptBar, memM.ptP, rbM, memM.ltP + slFbD * (rbM - memM.ltBar), xloc = xloc.bar_index, color = cLiqM, width = wMed)
        if medActiveDir == 1 and showLvl and not na(mb1)
            float lvlMU = array.get(mcLvl, mb1)
            memM.lvl := line.new(array.get(mcBar, mb1), lvlMU, last_bar_index + lvlExtBars, lvlMU, xloc = xloc.bar_index, color = cLvlM, width = wMed, style = line.style_solid)
        if medActiveDir == -1 and showLvl and not na(mt1)
            float lvlMD = array.get(mcLvl, mt1)
            memM.lvl := line.new(array.get(mcBar, mt1), lvlMD, last_bar_index + lvlExtBars, lvlMD, xloc = xloc.bar_index, color = cLvlM, width = wMed, style = line.style_solid)
        // [V3.75] fallback المستوى: لا تطرّف فعّال في النافذة (mt1/mb1=na، مثل قمّة الانقلاب الخام بعد التحوّل للهبوط) ⇒ آخر تطرّف خام (memM.body) ⇒ المستوى يُرسم دائمًا على المقاومة/الدعم (الدرس 09: المستوى على آخر تطرّف). بصريّ فقط (mEff من medActiveDir لا memM.lvl).
        if showLvl and na(memM.lvl) and medActiveDir == 1 and not na(memM.lbBody)
            memM.lvl := line.new(memM.lbBar, memM.lbBody, last_bar_index + lvlExtBars, memM.lbBody, xloc = xloc.bar_index, color = cLvlM, width = wMed, style = line.style_solid)
        if showLvl and na(memM.lvl) and medActiveDir == -1 and not na(memM.ltBody)
            memM.lvl := line.new(memM.ltBar, memM.ltBody, last_bar_index + lvlExtBars, memM.ltBody, xloc = xloc.bar_index, color = cLvlM, width = wMed, style = line.style_solid)
    array.clear(zTop)
    array.clear(zBot)
    array.clear(zAnchor)
    array.clear(zSrcA)
    array.clear(zSrcB)
    array.clear(zIsHist)
    array.clear(zLeftTm)
    array.clear(zHistP)
    array.clear(zHistTm)
    array.clear(zHistIdx)
    if mmz > 0
        array<int> effIdx = array.new<int>()
        for i = 0 to mmz - 1
            // [V4.37] (أُلغِيَ v4.36) الشريك يجب أن يكون **فعّالًا فعليًّا** (zoneEff) — لا نضمّ الأزرق «الفعّال»
            //   الذي يقع داخل النطاق وقد اخترقه السعر (مُختبَر) — راجع سيناريو 4098 المُختبَر.
            if f_effForZone(i, histLeft)
                array.push(effIdx, i)            // فعّالة للمناطق (داخل الموجة أو نافذة التاريخ)، بترتيب الزمن
        int en = array.size(effIdx)
        if en > 0
            array<bool> usedZ = array.new<bool>(en, false)
            // [V1] هامش «القرب» المشتقّ من الدرجة (لا رقم مخترع) لفحص العبور عبر تصحيح
            float zTol = (not na(memS.ltP) and not na(memS.lbP)) ? bufMult * math.abs(memS.ltP - memS.lbP) : 0.0
            // المرحلة 1: داخل الموجة الفعّالة — الأقرب سعرياً أولاً (عالمياً)، مع:
            //   استبعاد التصحيح المتجاور (قمة+قاعها المباشر)، ومنع الاحتواء (منطقة داخل منطقة).
            array<int>   pAi = array.new<int>()
            array<int>   pBi = array.new<int>()
            array<float> pD  = array.new<float>()
            for a = 0 to en - 1
                int iaa = array.get(effIdx, a)
                if array.get(mcBar, iaa) >= histLeft and a < en - 1
                    for b = a + 1 to en - 1
                        int jbb = array.get(effIdx, b)
                        if array.get(mcBar, jbb) >= histLeft
                            bool adjc = (b - a) == 1
                            bool oppc = array.get(mcTop, jbb) != array.get(mcTop, iaa)
                            if not (adjc and oppc)              // استبعاد التصحيح المتجاور فقط
                                array.push(pAi, a)
                                array.push(pBi, b)
                                array.push(pD, math.abs(array.get(mcLvl, iaa) - array.get(mcLvl, jbb)))
            int np = array.size(pD)
            if np > 0
                array<bool> pDone = array.new<bool>(np, false)
                for _it = 1 to np
                    int   best = -1
                    float bd   = 1e18
                    for x = 0 to np - 1
                        if not array.get(pDone, x)
                            if (not array.get(usedZ, array.get(pAi, x))) and (not array.get(usedZ, array.get(pBi, x)))
                                if array.get(pD, x) < bd
                                    bd   := array.get(pD, x)
                                    best := x
                    if best < 0
                        break
                    array.set(pDone, best, true)
                    int aa  = array.get(pAi, best)
                    int bb  = array.get(pBi, best)
                    int ica = array.get(effIdx, aa)
                    int icb = array.get(effIdx, bb)
                    float la = array.get(mcLvl, ica)
                    float lb = array.get(mcLvl, icb)
                    float cT = math.max(la, lb)
                    float cB = math.min(la, lb)
                    bool oppPair = array.get(mcTop, ica) != array.get(mcTop, icb)   // معاكسان (قمة+قاع)؟ — البوّابة عليهما فقط
                    if not f_zoneContain(cT, cB) and not (oppPair and f_crossesCorrection(ica, icb, cB, cT, zTol, histLeft)) and not f_levelBetween(cB, cT, ica, icb, histLeft)   // لا احتواء؛ لا عبور تصحيح للمعاكسين؛ لا مستوى ثالث بينهما (مجاورة)
                        array.set(usedZ, aa, true)
                        array.set(usedZ, bb, true)
                        array.push(zTop, cT)
                        array.push(zBot, cB)
                        array.push(zAnchor, math.max(array.get(mcBar, ica), array.get(mcBar, icb)))
                        array.push(zLeftTm, math.min(array.get(mcTm, ica), array.get(mcTm, icb)))
                        array.push(zSrcA, ica)
                        array.push(zSrcB, icb)
                        array.push(zIsHist, false)
            // المرحلة 2: استعارة عالمية بالأقرب سعرياً — أقرب زوج (منفردة حالية ↔ نقطة تاريخ التاريخ) أولاً.
            //   يمنع خطف منفردة بعيدة لشريك تحتاجه منفردة أقرب (2-3 فرق 82 قبل 1-3 فرق 980)، مع منع الاحتواء.
            array<int>   qAi = array.new<int>()
            array<int>   qBi = array.new<int>()
            array<float> qD  = array.new<float>()
            for a = 0 to en - 1
                int ia2 = array.get(effIdx, a)
                if not array.get(usedZ, a) and array.get(mcBar, ia2) >= histLeft
                    for b = 0 to en - 1
                        int jb2 = array.get(effIdx, b)
                        // [V4.35] الدرس L2-02: للمنفردة نبحث **أقرب شريك في كلّ التاريخ** (لا نقتصر على نافذة hohLeft)
                        //   — الأقرب سعريًّا يفوز، وقاعدتا f_levelBetween/f_zoneContain تمنعان المربّع العريض/المحتوي.
                        if array.get(mcBar, jb2) < histLeft
                            array.push(qAi, a)
                            array.push(qBi, b)
                            array.push(qD, math.abs(array.get(mcLvl, ia2) - array.get(mcLvl, jb2)))
            int nq = array.size(qD)
            if nq > 0
                array<bool> qDone = array.new<bool>(nq, false)
                for _it2 = 1 to nq
                    int   qbest = -1
                    float qbd   = 1e18
                    for x = 0 to nq - 1
                        if not array.get(qDone, x)
                            if (not array.get(usedZ, array.get(qAi, x))) and (not array.get(usedZ, array.get(qBi, x)))
                                if array.get(qD, x) < qbd
                                    qbd   := array.get(qD, x)
                                    qbest := x
                    if qbest < 0
                        break
                    array.set(qDone, qbest, true)
                    int qa  = array.get(qAi, qbest)
                    int qb  = array.get(qBi, qbest)
                    int iqa = array.get(effIdx, qa)
                    int iqb = array.get(effIdx, qb)
                    float la2 = array.get(mcLvl, iqa)
                    float lb2 = array.get(mcLvl, iqb)
                    float cT2 = math.max(la2, lb2)
                    float cB2 = math.min(la2, lb2)
                    if not f_zoneContain(cT2, cB2) and not f_levelBetween(cB2, cT2, iqa, iqb, histLeft)   // لا احتواء؛ لا مستوى ثالث بينهما (مجاورة) — يمنع الاستعارة العريضة
                        array.set(usedZ, qa, true)
                        array.set(usedZ, qb, true)
                        array.push(zTop, cT2)
                        array.push(zBot, cB2)
                        array.push(zAnchor, math.max(array.get(mcBar, iqa), array.get(mcBar, iqb)))
                        array.push(zLeftTm, math.min(array.get(mcTm, iqa), array.get(mcTm, iqb)))
                        array.push(zSrcA, iqa)
                        array.push(zSrcB, iqb)
                        array.push(zIsHist, true)
                        // iqb = نقطة التاريخ (الشريك) ⇒ سجّلها لرسم خط m.A عليها
                        array.push(zHistP,  array.get(mcLvl, iqb))
                        array.push(zHistTm, array.get(mcTm, iqb))
                        array.push(zHistIdx, iqb)
            // المرحلة 3: ما تبقّى من منفردات الموجة الحالية بلا شريك صالح ⇒ خط m.A فقط (طبيعي)
            for a = en - 1 to 0
                int ia3 = array.get(effIdx, a)
                if not array.get(usedZ, a) and array.get(mcBar, ia3) >= histLeft
                    array.set(usedZ, a, true)
                    array.push(zTop, array.get(mcLvl, ia3))
                    array.push(zBot, array.get(mcLvl, ia3))
                    array.push(zAnchor, array.get(mcBar, ia3))
                    array.push(zLeftTm, array.get(mcTm, ia3))
                    array.push(zSrcA, ia3)
                    array.push(zSrcB, ia3)
                    array.push(zIsHist, false)

// ===== [v3.88.0 · A1] ترقيم الموجات (إليوت/داو) — طبقة وصفيّة، شارت فقط، لا تمسّ أيّ منطق =====
//   قاعدة الاشتقاق: كلّ ساق دافعة فعّالة ⇒ الرقم التالي (1→2→3→4→5)؛ بعد 5: مشاركة مستمرّة (امتداد) ⇒ يبقى «5»،
//   تصحيح (ذعر/يأس، phCode≠0) ⇒ a·b·c. الوسم على منتصف كلّ ساق بلون الدرجة. الرسم islast (غير مُعيد للرسم).
//   معمّمة على الدرجة؛ A1 يصل المتوسطة فقط (الصغيرة/الكبيرة مطفأتان افتراضيًّا — تُوصَلان لاحقًا).
var array<label> wcLbls = array.new<label>()
// [v3.88.11 — منطق LuxAlgo المُكيَّف] نمرّر نافذة 6 نقاط على نقاط الدرجة الفعّالة، ونُرقّم الدفعة 1-5
//   **فقط إن حقّقت قواعد إليوت** (مدفوع بالقواعد، لا ترقيم أعمى). الشروط تنقلب حسب اتجاه الدفعة:
//   صاعدة (تنتهي بقمّة): ق1 _3>_1 · ق3 _5>_2 · ق2 _W3≠الأصغر · قمّة جديدة _6>_4. هابطة: المرآة.
//   _1 = أصل الموجة (بلا وسم)؛ الوسوم (1)(2)(3)(4)(5) على _2.._6. الدفعات غير متداخلة (lastEnd).
f_drawWaveCount(array<float> pP, array<int> pBar, array<bool> pTop, color col, string sz, float offUp, float offDn, int maxSets) =>
    int n = array.size(pP)
    if n >= 6
        // المرور 1: اعثر على نهايات الدفعات الخماسيّة الصحيحة (غير متداخلة، تحجز 3 خانات لـ abc)
        array<int> ends = array.new<int>()
        int lastEnd = -1
        for e = 5 to n - 1
            if e - 5 >= lastEnd
                bool t6 = array.get(pTop, e)   // قمّة ⇒ دفعة صاعدة، قاع ⇒ هابطة
                bool altOk = array.get(pTop, e-4) == t6 and array.get(pTop, e-2) == t6 and array.get(pTop, e-5) != t6 and array.get(pTop, e-3) != t6 and array.get(pTop, e-1) != t6
                if altOk
                    float p1 = array.get(pP, e-5)
                    float p2 = array.get(pP, e-4)
                    float p3 = array.get(pP, e-3)
                    float p4 = array.get(pP, e-2)
                    float p5 = array.get(pP, e-1)
                    float p6 = array.get(pP, e)
                    bool isWave = false
                    if t6   // صاعدة: ق1 p3>p1 · ق3 p5>p2 · ق2 W3≠الأصغر · قمّة جديدة p6>p4
                        float mn = math.min(p2 - p1, math.min(p4 - p3, p6 - p5))
                        isWave := (p4 - p3) != mn and p6 > p4 and p3 > p1 and p5 > p2
                    else    // هابطة: المرآة
                        float mn = math.min(p1 - p2, math.min(p3 - p4, p5 - p6))
                        isWave := (p3 - p4) != mn and p4 > p6 and p1 > p3 and p2 > p5
                    if isWave
                        array.push(ends, e)
                        lastEnd := e + 3   // احجز خانات a·b·c (الدفعة التالية بعدها)
        // المرور 2: ارسم آخر maxSets دفعات فقط (0 = الكلّ): (1)-(5) ثمّ a·b·c
        int total = array.size(ends)
        int fromI = (maxSets > 0 and total > maxSets) ? total - maxSets : 0
        if total > 0
            for s = fromI to total - 1
                int e = array.get(ends, s)
                for w = 0 to 7   // 0-4 ⇒ (1)-(5)، 5-7 ⇒ (a)(b)(c) [التصحيح بعد الموجة 5]
                    int idx = e - 4 + w
                    if idx < n
                        string lbl  = w <= 4 ? "(" + str.tostring(w + 1) + ")" : (w == 5 ? "(a)" : w == 6 ? "(b)" : "(c)")
                        bool   isTop = array.get(pTop, idx)
                        float  py    = array.get(pP, idx) + (isTop ? offUp : -offDn)
                        if bar_index - array.get(pBar, idx) < 4900
                            label lb = label.new(array.get(pBar, idx), py, lbl, xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = col, size = sz)
                            array.push(wcLbls, lb)
// ===== [v3.88.23 · B1/B2] فيبوناتشي — على آخر ساق دافعة فعّالة بالاتجاه (ارتداد=دخول · امتداد=هدف أماميّ) =====
var array<line>  fibLines   = array.new<line>()
var array<label> fibLbls    = array.new<label>()
var array<float> zonePrices = array.new<float>()   // [v3.88.25 · B3] أسعار مستويات المناطق الفعّالة — لفحص التقاطُع مع الفيبو
f_nearZone(float price, float tol) =>   // [B3] هل يتطابق سعر فيبو مع أيّ مستوى منطقة ضمن الهامش؟ (خروج مبكّر)
    bool hit = false
    int nz = array.size(zonePrices)
    if nz > 0
        for z = 0 to nz - 1
            if math.abs(array.get(zonePrices, z) - price) <= tol
                hit := true
                break
    hit
f_lastImpulse(array<float> pP, array<bool> pTop, int dir) =>   // [v3.88.22] فهرس آخر دفعة خماسيّة **تطابق اتجاه الدرجة** — مسح خلفيّ + خروج مبكّر
    int n = array.size(pP)
    int last = -1
    if n >= 6
        for e = n - 1 to 5
            if last == -1   // توقّف عند أوّل دفعة صحيحة من اليمين (الأحدث)
                bool t6 = array.get(pTop, e)
                // فلتر الاتجاه: صعودًا (dir=1) دفعة صاعدة تنتهي بقمّة (t6)، هبوطًا (dir=-1) دفعة هابطة تنتهي بقاع. dir=0 ⇒ أيّ اتجاه
                bool dirOk = dir == 0 or (dir == 1 and t6) or (dir == -1 and not t6)
                bool altOk = dirOk and array.get(pTop, e-4) == t6 and array.get(pTop, e-2) == t6 and array.get(pTop, e-5) != t6 and array.get(pTop, e-3) != t6 and array.get(pTop, e-1) != t6
                if altOk
                    float p1 = array.get(pP, e-5)
                    float p2 = array.get(pP, e-4)
                    float p3 = array.get(pP, e-3)
                    float p4 = array.get(pP, e-2)
                    float p5 = array.get(pP, e-1)
                    float p6 = array.get(pP, e)
                    bool isWave = t6 ? ((p4-p3) != math.min(p2-p1, math.min(p4-p3, p6-p5)) and p6 > p4 and p3 > p1 and p5 > p2) : ((p3-p4) != math.min(p1-p2, math.min(p3-p4, p5-p6)) and p4 > p6 and p1 > p3 and p2 > p5)
                    if isWave
                        last := e
    last
f_lastLeg(array<float> pP, array<bool> pTop, int dir) =>   // [v3.88.23] فهرس نهاية آخر ساق دافعة فعّالة بالاتجاه (قمّة صعودًا / قاع هبوطًا) — قرب السعر
    int n = array.size(pP)
    int idx = -1
    if n >= 2 and dir != 0
        bool wantTop = dir == 1   // صعودًا نهاية الساق قمّة، هبوطًا قاع
        for i = n - 1 to 1
            if idx == -1 and array.get(pTop, i) == wantTop and array.get(pTop, i - 1) != wantTop
                idx := i   // الساق = (i-1 المعاكسة → i)
    idx
f_drawFibRetrace(array<float> pP, array<int> pBar, array<bool> pTop, color col, int dir) =>
    int idx = f_lastLeg(pP, pTop, dir)
    if idx >= 1
        float legS = array.get(pP, idx - 1)   // بداية الساق (القاع صعودًا)
        float legE = array.get(pP, idx)       // نهاية الساق (القمّة صعودًا)
        int   xb   = array.get(pBar, idx - 1)
        if bar_index - xb < 4900
            int   rb  = last_bar_index + 10
            float rng = legE - legS   // طول الساق (موجَّب صعودًا / سالب هبوطًا)
            array<float> lvls = array.from(0.382, 0.5, 0.618, 0.786)
            for li = 0 to 3
                float lv = array.get(lvls, li)
                float yp = legE - lv * rng   // ارتداد من نهاية الساق نحو بدايتها = منطقة التصحيح/الدخول
                bool   cf = showFibConfluence and f_nearZone(yp, fibConflTol * atrv)   // [B3] تقاطُع مع منطقة فعّالة
                line ln = line.new(xb, yp, rb, yp, xloc = xloc.bar_index, color = color.new(col, cf ? 0 : 25), style = line.style_dotted, width = cf ? 2 : 1)
                array.push(fibLines, ln)
                label lb = label.new(rb, yp, str.tostring(lv, "0.000") + (cf ? " ☆" : ""), xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = col, size = size.small)
                array.push(fibLbls, lb)
f_drawFibExtension(array<float> pP, array<int> pBar, array<bool> pTop, color col, int dir) =>   // [v3.88.23 · B2] امتداد الساق = هدف أماميّ
    int idx = f_lastLeg(pP, pTop, dir)
    if idx >= 1
        float legS = array.get(pP, idx - 1)   // بداية الساق
        float legE = array.get(pP, idx)       // نهاية الساق
        int   xb   = array.get(pBar, idx - 1)
        if bar_index - xb < 4900
            int   rb  = last_bar_index + 10
            float rng = legE - legS   // طول الساق (موجَّب صعودًا / سالب هبوطًا)
            array<float> lvls = array.from(1.272, 1.618, 2.618)
            for li = 0 to 2
                float lv = array.get(lvls, li)
                float yp = legS + lv * rng   // إسقاط الساق من بدايتها = هدف أبعد من نهايتها (فوق صعودًا)
                bool   cf = showFibConfluence and f_nearZone(yp, fibConflTol * atrv)   // [B3] تقاطُع مع منطقة فعّالة
                line ln = line.new(xb, yp, rb, yp, xloc = xloc.bar_index, color = color.new(col, cf ? 0 : 25), style = line.style_dashed, width = cf ? 2 : 1)
                array.push(fibLines, ln)
                label lb = label.new(rb, yp, "ext " + str.tostring(lv, "0.000") + (cf ? " ☆" : ""), xloc = xloc.bar_index, yloc = yloc.price, style = label.style_none, textcolor = col, size = size.small)
                array.push(fibLbls, lb)
if barstate.islast
    if array.size(wcLbls) > 0
        for li = 0 to array.size(wcLbls) - 1
            label.delete(array.get(wcLbls, li))
    array.clear(wcLbls)
    // [v3.88.17 أداء] مسح الفيبو + بناء مصفوفات المتوسطة/الصغيرة **مرّة واحدة** (تُستعمل للترقيم وللفيبو معًا، بدل مرّتين)
    if array.size(fibLines) > 0
        for li = 0 to array.size(fibLines) - 1
            line.delete(array.get(fibLines, li))
    if array.size(fibLbls) > 0
        for li = 0 to array.size(fibLbls) - 1
            label.delete(array.get(fibLbls, li))
    array.clear(fibLines)
    array.clear(fibLbls)
    // [v3.88.25 · B3] أسعار مستويات المناطق الفعّالة لفحص التقاطُع (نفس شروط كتلة المناطق س3413 — مستوى m.A على نقطة متوسطة فعّالة غير معلّقة داخل الموجة + شركاء التاريخ zHistP)
    array.clear(zonePrices)
    if showFib and showFibConfluence
        int mz = array.size(mcP)
        if mz > 0
            for i = math.max(0, mz - wcMaxPivots) to mz - 1   // [v3.88.28 أداء] آخر N نقطة فقط (الفيبو قرب السعر)
                float pci = array.get(mcP, i)
                bool outsideZ = pci > hwHiE or pci < hwLoE
                bool inWinZ   = array.size(zoneEff) > i and array.get(mcBar, i) >= drawLeft
                bool effZ     = outsideZ or (inWinZ ? array.get(zoneEff, i) : array.get(mcEff, i))
                bool pndZ     = (not outsideZ) and inWinZ and array.size(dgPend) > i ? array.get(dgPend, i) : false
                if effZ and not pndZ and array.get(mcBar, i) >= histLeft
                    array.push(zonePrices, array.get(mcLvl, i))
        int nhz = array.size(zHistP)
        if nhz > 0
            for i = 0 to nhz - 1
                array.push(zonePrices, array.get(zHistP, i))
    // [v3.88.18 أداء] بناء آخر wcMaxPivots نقطة فقط لكلّ درجة (لا كلّ التاريخ) — يحلّ خطأ CPU
    bool needBig   = (showWaveCount and showWaveCountBig)   or (showFib and (fibRetrBig   or fibExtBig))
    bool needMed   = (showWaveCount and showWaveCountMed)   or (showFib and (fibRetrMed   or fibExtMed))
    bool needSmall = (showWaveCount and showWaveCountSmall) or (showFib and (fibRetrSmall or fibExtSmall))
    array<float> bpP   = array.new<float>()
    array<int>   bpBar = array.new<int>()
    array<bool>  bpTop = array.new<bool>()
    if needBig
        int nbg = array.size(bluePivotP)
        if nbg > 0
            for i = math.max(0, nbg - wcMaxPivots) to nbg - 1
                array.push(bpP, array.get(bluePivotP, i))
                array.push(bpBar, array.get(bluePivotBars, i))
                array.push(bpTop, array.get(bluePivotT, i))
    array<float> cpP   = array.new<float>()
    array<int>   cpBar = array.new<int>()
    array<bool>  cpTop = array.new<bool>()
    if needMed
        int mmw = array.size(mcP)
        if mmw > 0
            for i = math.max(0, mmw - wcMaxPivots) to mmw - 1
                bool pnd = array.size(dgPend) > i and array.get(dgPend, i)
                if not pnd   // كلّ القمم/القيعان المتوسطة المرسومة (تطابق الدوائر/خطّ الوصل)
                    array.push(cpP, array.get(mcP, i))
                    array.push(cpBar, array.get(mcBar, i))
                    array.push(cpTop, array.get(mcTop, i))
    array<float> spP   = array.new<float>()
    array<int>   spBar = array.new<int>()
    array<bool>  spTop = array.new<bool>()
    if needSmall
        int nds = array.size(dsP)
        if nds > 0
            for i = math.max(0, nds - wcMaxPivots) to nds - 1
                array.push(spP, array.get(dsP, i))
                array.push(spBar, array.get(dsBar, i))
                array.push(spTop, array.get(dsTop, i))
    if showWaveCount   // ===== الترقيم (الكبيرة أوّلًا، ثمّ المتوسطة، ثمّ الصغيرة) =====
        string wsz  = waveLblSize == "Tiny" ? size.tiny : waveLblSize == "Normal" ? size.normal : size.small
        if showWaveCountBig
            f_drawWaveCount(bpP, bpBar, bpTop, waveLblColBig, wsz, waveUpBig * atrv, waveDnBig * atrv, maxWaveSets)
        if showWaveCountMed
            f_drawWaveCount(cpP, cpBar, cpTop, waveLblColMed, wsz, waveUpMed * atrv, waveDnMed * atrv, maxWaveSets)
        if showWaveCountSmall
            f_drawWaveCount(spP, spBar, spTop, waveLblColSmall, wsz, waveUpSmall * atrv, waveDnSmall * atrv, maxWaveSets)
    if showFib   // ===== [B1 ارتداد منقّط · B2 امتداد متقطّع] — تحكّم مستقلّ لكلّ (درجة × نوع)، كلّ درجة باتجاهها =====
        if fibRetrBig
            f_drawFibRetrace(bpP, bpBar, bpTop, fibColBig, largeDir)
        if fibRetrMed
            f_drawFibRetrace(cpP, cpBar, cpTop, fibColMed, medActiveDir)
        if fibRetrSmall
            f_drawFibRetrace(spP, spBar, spTop, fibColSmall, smallActiveDir)
        if fibExtBig
            f_drawFibExtension(bpP, bpBar, bpTop, fibColBig, largeDir)
        if fibExtMed
            f_drawFibExtension(cpP, cpBar, cpTop, fibColMed, medActiveDir)
        if fibExtSmall
            f_drawFibExtension(spP, spBar, spTop, fibColSmall, smallActiveDir)

// ===================== المناطق (مستقلّة عن إظهار الكبيرة) =====================
// مطابق للدرس: ارسم مستوى أفقياً على جسم كل قمة/قاع متوسط فعّال (أصفر).
//   المحلّل يختار المنطقة بصرياً بين مستويين متقاربين (لا مسافة رقمية في الشرح).
// المستطيل التلقائي (zoneAutoBox) أداة عرض اختيارية فقط — ليست من الاستراتيجية.
if showZones and barstate.islast
    // امسح المستويات/الصناديق السابقة
    if array.size(zoneLvls) > 0
        for i = 0 to array.size(zoneLvls) - 1
            line.delete(array.get(zoneLvls, i))
        array.clear(zoneLvls)
    if array.size(dispBoxes) > 0
        for i = 0 to array.size(dispBoxes) - 1
            box.delete(array.get(dispBoxes, i))
        array.clear(dispBoxes)
    int   rEdge = time + zoneExt * (1000 * timeframe.in_seconds(timeframe.period))
    int   m     = array.size(mcP)
    // (1) مستويات M.A — خط أفقي على جسم كل نقطة متوسطة فعّالة داخل الموجة الحالية فقط
    //     (تاريخ التاريخ لا يُرسم مباشرةً — يُستعمل فقط كشريك fallback في المستطيلات أدناه)
    if showZoneLevels and m > 0
        for i = 0 to m - 1
            // [V4.30] m.A على النقاط الصفراء **الفعّالة فقط** (البرتقاليّة) — لا على المعلّقة (رماديّة) ولا غير الفعّالة (حمراء).
            //   نطابق تمامًا منطق تلوين الدائرة (effC/pndC) فلا يظهر خطّ على دائرة غير برتقاليّة.
            float pci = array.get(mcP, i)
            bool outsideC = pci > hwHiE or pci < hwLoE
            bool inWin = array.size(zoneEff) > i and array.get(mcBar, i) >= drawLeft
            bool effC = outsideC or (inWin ? array.get(zoneEff, i) : array.get(mcEff, i))
            bool pndC = (not outsideC) and inWin and array.size(dgPend) > i ? array.get(dgPend, i) : false
            if effC and not pndC and array.get(mcBar, i) >= histLeft
                line lv = line.new(array.get(mcTm, i), array.get(mcLvl, i), rEdge, array.get(mcLvl, i),
                     xloc = xloc.bar_time, color = zoneLvlCol, width = 1)
                array.push(zoneLvls, lv)
        // نقاط التاريخ التي دخلت أزواجاً (شركاء المنفردة) ⇒ ارسم خط m.A عليها أيضاً
        int nh = array.size(zHistP)
        if nh > 0
            for i = 0 to nh - 1
                line lvh = line.new(array.get(zHistTm, i), array.get(zHistP, i), rEdge, array.get(zHistP, i),
                     xloc = xloc.bar_time, color = zoneLvlCol, width = 1)
                array.push(zoneLvls, lvh)
    // (2) مستطيلات اقتراحية (اختياري): تُرسم من قائمة المناطق المبنيّة (5-أ) — التزاوج الصحيح
    //     (تتالٍ فعّال + زوج واحد + استعارة المنفردة). المنفردة (zt==zb) لا مستطيل لها (خط m.A فقط).
    if zoneAutoBox
        int znb = array.size(zTop)
        if znb > 0
            for k = 0 to znb - 1
                float zt = array.get(zTop, k)
                float zb = array.get(zBot, k)
                if zt > zb
                    int laT = array.get(mcTm, array.get(zSrcA, k))
                    int lbT = array.get(mcTm, array.get(zSrcB, k))
                    int lEdge = laT > lbT ? laT : lbT   // أحدث المصدرين ⇒ صندوق مدمج حديث (لا شريط يعبر الشارت تحت الصندوق الكبير)
                    box bx = box.new(lEdge, zt, rEdge, zb, xloc = xloc.bar_time,
                         border_color = zoneBorder, bgcolor = zoneFill, border_width = 1)
                    array.push(dispBoxes, bx)

// ===================== الاستنتاجات وحالة السوق (لوحة) =====================
// تُقرأ من اتجاهات الدرجات وذاكرة السيولة:
//   • اتجاه السيولة = توافق الكبيرة + المتوسطة (تعارض ⇒ Range).
//   • الدخول المتاح = صديق الترند (صاعد⇒شراء فقط / هابط⇒بيع فقط / تعارض⇒الاثنان).
//   • قوة السيولة (الحالة العامّة) = نقاطُها من الصغيرة لكن باتجاه الترند الأكبر (المتوسطة) ⇒ «عكس الصغيرة» وقت انقلابها (v3.87.10): تصحيح يخترق المرجع ⇒ ضعيفة؛ يلامسه/قبله ⇒ قويّة. [قوّة كلّ درجة منفصلة = للعرض الخام فقط، لا تمسّ الاستنتاج]
//   • الحالة لكل درجة = صاعدة (مشاركة عامة) / هابطة (تصريف/هبوط).
f_dir(int d) => d == 1 ? f_t("صاعد ▲","Up ▲") : d == -1 ? f_t("هابط ▼","Down ▼") : "—"
f_state(int d) => d == 1 ? f_t("مشاركة صاعدة","Markup") : d == -1 ? f_t("تصريف/هبوط","Markdown") : "—"
// [v3.87.6] قوّة السيولة لكلّ درجة منفصلة — **للعرض فقط** (لا تمسّ concStrong/الاستنتاج/الإشارات).
//   نفس قاعدة الدرس 10-2 معمّمة على الدرجة [[reusable-degree-functions]]: الموجة تتباعد عن التطرّف المعاكس السابق ⇒ قويّة؛ تتداخل ⇒ ضعيفة.
//   صعودًا: القاع الحاليّ (lbP) فوق القمّة السابقة (ptP) بهامش tolV ⇒ قويّة. هبوطًا: القمّة السابقة-المعاكسة (pbP) فوق القمّة الحاليّة (ltP) ⇒ قويّة. (مطابق صيغة concStrong س1869/1883)
//   يعيد "" إن لم تتوفّر التطرّفات (لا قيمة قديمة).
f_degStrTok(int dir, float ltP, float ptP, float lbP, float pbP, float tolV) =>
    string tok = ""
    if dir == 1 and not na(lbP) and not na(ptP)
        tok := (lbP - ptP) >= -tolV ? f_t(" · قويّة"," · Strong") : f_t(" · ضعيفة"," · Weak")   // [v3.87.9] ملامسة/قبل المرجع ⇒ قويّة؛ اختراق بأكثر من tolV ⇒ ضعيفة
    else if dir == -1 and not na(ltP) and not na(pbP)
        tok := (pbP - ltP) >= -tolV ? f_t(" · قويّة"," · Strong") : f_t(" · ضعيفة"," · Weak")   // [v3.87.9] ملامسة/قبل المرجع ⇒ قويّة؛ اختراق بأكثر من tolV ⇒ ضعيفة
    tok
// تحويل اختيار الموضع النصّي إلى ثابت position (لتغيير مكان اللوحات بحرية)
f_pos(string s) => s == "Top L" ? position.top_left : s == "Top C" ? position.top_center : s == "Top R" ? position.top_right : s == "Mid L" ? position.middle_left : s == "Center" ? position.middle_center : s == "Mid R" ? position.middle_right : s == "Bot L" ? position.bottom_left : s == "Bot C" ? position.bottom_center : position.bottom_right

// ===== اختبار الموجة (الدرس 03): وسيط زمن الموجة الدافعة المتوسطة ⇒ نوع العمل =====
// مضاربة/سوينغ/استثمار من وسيط زمن السيقان الدافعة (الأطول إجمالاً) بالأيام، ضمن نطاق الدرس (2–10، غير إلزاميّ).
//   + «درجات ظاهرة /3» (روح الخطوتين 1–2). الحدّان مدخلان قابلان للضبط لكل أداة.
var table fht = table.new(f_pos(fhPos), 2, 7, bgcolor = fhBg, border_width = 1,
     border_color = #2A2E39, frame_width = 1, frame_color = #2A2E39)
// [V3.76] لُفّت كتلة لوحة اختبار الموجة في دالّة لتقليص حجم الجسم الرئيسيّ (إصلاح CE10295). تقرأ globals وتكتب في fht بالمرجع ⇒ صفر تغيير سلوك.
f_drawFramePanel() =>
    table.set_position(fht, f_pos(fhPos))
    // الدرس 03 — اختبار الموجة: نقيس زمن السيقان الدافعة المتوسطة بالأيام.
    //   الدافعة = مجموعة السيقان الأطول إجمالاً (اتجاه الترند) — تُختار بالقياس لا بـ dirF (أمتن ضدّ قلب الاتجاه،
    //   كان سبب خطأ v1.93: قياس السيقان التصحيحية القصيرة ⇒ «مضاربة» خاطئة). كلا الطرفين داخل الموجة التاريخية.
    int   nmF = array.size(mcBar)
    array<float> upDur = array.new<float>()
    array<float> dnDur = array.new<float>()
    if nmF > 1
        for i = 0 to nmF - 2
            if array.get(mcBar, i) >= ctxLeft and array.get(mcBar, i + 1) >= ctxLeft
                float durDays = (array.get(mcTm, i + 1) - array.get(mcTm, i)) / 86400000.0   // ms ⇒ أيام
                bool ti  = array.get(mcTop, i)
                bool ti1 = array.get(mcTop, i + 1)
                if durDays > 0   // [V3.60] تجاهل سيقان بنفس الوقت (durDays<=0) لئلّا تشوّه وسيط/مجموع تصنيف الفريم
                    if (not ti) and ti1
                        array.push(upDur, durDays)        // ساق صاعدة (قاع⇒قمة)
                    else if ti and (not ti1)
                        array.push(dnDur, durDays)        // ساق هابطة (قمة⇒قاع)
    float upTot = array.size(upDur) > 0 ? array.sum(upDur) : 0.0
    float dnTot = array.size(dnDur) > 0 ? array.sum(dnDur) : 0.0
    array<float> impDur = upTot >= dnTot ? upDur : dnDur   // الدافعة = الأطول إجمالاً
    int   numImp  = array.size(impDur)
    // التصنيف بالوسيط (median) لا المتوسط: متين ضدّ شذوذ موجة (تساهل الدرس: موجة أو اثنتان خارج النطاق قليلاً مقبول).
    float medDays = numImp > 0 ? array.median(impDur) : na
    string timeTxt = na(medDays) ? "—" : medDays >= 1 ? str.tostring(medDays, "#.0") + f_t(" يوم"," d") : medDays >= 0.0417 ? str.tostring(medDays * 24, "#.0") + f_t(" ساعة"," h") : str.tostring(medDays * 1440, "#.0") + f_t(" دق"," m")
    // [V3.64] عدّ درجات **موجتنا العاملة فقط** (bigBar >= ctxLeft) — تصحيح: v3.62 حسب الكبيرة (nLh) والرابعة عبر **كلّ التاريخ** (موجات متعدّدة) ⇒ مبالغة. الآن داخل الموجة كالمتوسطة (numImp تستعمل ctxLeft أصلًا). bluePivotBars نفسها بلا تغيير (تستعملها المناطق).
    //   الكبيرة (nLh) + الرابعة الأخشن (deg4، الدرس 04 «4 ⇒ اصعد»: bigP يُغذّى محرّك كسر رابع، مرآة متوسطة→كبيرة س2188) في حلقة واحدة. عرض فقط — صفر مساس بالإشارات/المناطق/الاستخراج.
    int nLh = 0
    int deg4Emits = 0
    int nBlue4 = array.size(bigP)
    if nBlue4 > 0
        Proc p4 = Proc.new()
        for ib4 = 0 to nBlue4 - 1
            if array.get(bigBar, ib4) >= ctxLeft   // داخل موجتنا العاملة فقط (لا تاريخ التاريخ ولا أقدم)
                nLh := nLh + 1
                float kp4 = array.get(bigP, ib4)
                [em4, e4P, e4Hi, e4Lo, e4Tm, e4B, e4Top] = feed(p4, kp4, kp4, kp4, array.get(bigBar, ib4), array.get(bigBar, ib4), array.get(bigTop, ib4))
                if em4
                    deg4Emits := deg4Emits + 1
    bool deg4High = deg4Emits >= 1   // [V3.65] درجة رابعة أخشن موجودة في موجتنا إن انعكست الزرقاء بنيويًّا مرّة على الأقلّ (الزرقاء صارت موجاتٍ) ⇒ أكثر من 3 درجات ⇒ اصعد
    int degCount = (nLh >= 2 ? 1 : 0) + (numImp >= 1 ? 1 : 0) + (not na(memS.lbBar) ? 1 : 0)
    // الهدف: معرفة نوع التداول المناسب للفريم الحالي — بلا توجيه لأسلوب بعينه (أُزيل انحياز السوينغ).
    //   النوع من وسيط زمن الموجة الدافعة ضمن نطاق الدرس [swingMinDays, swingMaxDays] (2–10، غير إلزاميّ).
    //   (الدرس القادم سيضيف عدد درجات الموجة إلى معيار النوع — يُدمج لاحقاً.)
    string waveType = na(medDays) ? "—" : medDays < swingMinDays ? f_t("مضاربة","Scalp") : medDays <= swingMaxDays ? f_t("سوينغ","Swing") : f_t("استثمار","Invest")
    color  wtBg = na(medDays) ? color.new(#787B86, 0) : medDays < swingMinDays ? color.new(#FF9800, 0) : medDays <= swingMaxDays ? color.new(#089981, 0) : color.new(#2962FF, 0)
    // نمط الصفقة (محايد): يصف مدّة الصفقة لهذا النوع على الفريم الحالي، لا يوجّه لفريم بعينه.
    string tradeNature = na(medDays) ? f_t("بيانات غير كافية","Insufficient data") : medDays < swingMinDays ? f_t("صفقات دقائق–يوم","Minutes–day trades") : medDays <= swingMaxDays ? f_t("صفقات يومين–10 أيام","2–10 day trades") : f_t("صفقات أسابيع–شهور","Weeks–months trades")
    string typeTip = f_t("نوع التداول المناسب للفريم الحالي.\nالحدود (أيام/موجة دافعة):\n• مضاربة: < ","Trading type suited to the current timeframe.\nThresholds (days/impulse wave):\n• Scalp: < ") + str.tostring(swingMinDays, "#.#") + f_t("\n• سوينغ: ","\n• Swing: ") + str.tostring(swingMinDays, "#.#") + "–" + str.tostring(swingMaxDays, "#.#") + f_t("\n• استثمار: > ","\n• Invest: > ") + str.tostring(swingMaxDays, "#.#") + f_t("\nلتغيير النوع غيّر فريم الشارت (أصغر=مضاربة، أكبر=استثمار).\nاللوحة لا تُسحب بالماوس (قيد Pine) — استعمل «موضع لوحة اختبار الموجة».","\nTo change the type, change the chart timeframe (smaller=Scalp, larger=Invest).\nThe panel cannot be dragged by mouse (Pine limit) — use the wave-test panel position.")
    // ===== هويّة TradingView الداكنة (الخلفية وشفافيتها من الإعدادات) =====
    color tvBg   = fhBg     // خلفية النافذة (مع شفافيتها من منتقي اللون)
    color tvHdr  = color.new(color.rgb(color.r(fhBg) * 0.72, color.g(fhBg) * 0.72, color.b(fhBg) * 0.72), color.t(fhBg))   // رأس أغمق بنفس شفافية اللون
    color tvMain = #D1D4DC     // نصّ رئيسيّ فاتح
    color tvMute = #787B86     // تسمية مكتومة
    table.cell(fht, 0, 0, f_t("لوحة اختبار الموجة","Wave Test"), text_color = tvMain, bgcolor = tvHdr, text_size = size.normal, text_halign = text.align_right)
    table.cell(fht, 1, 0, "", text_color = tvMute, bgcolor = tvHdr, text_size = size.small)
    table.cell(fht, 0, 1, f_t("درجات ظاهرة","Visible degrees"), text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 1, str.tostring(deg4High ? 4 : degCount) + " / 3", text_color = (degCount == 3 and not deg4High) ? #089981 : #FF9800, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 2, f_t("موجات دافعة","Impulse waves"), text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 2, str.tostring(numImp), text_color = tvMain, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 3, f_t("وسيط زمن الموجة","Median wave time"), text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 3, timeTxt, text_color = tvMain, bgcolor = tvBg, text_size = size.small)
    table.cell(fht, 0, 4, f_t("نوع التداول","Trading type"), text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right, tooltip = typeTip)
    table.cell(fht, 1, 4, waveType, text_color = color.white, bgcolor = wtBg, text_size = size.small, tooltip = typeTip)
    table.cell(fht, 0, 5, f_t("نمط الصفقة","Trade nature"), text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right)
    table.cell(fht, 1, 5, tradeNature, text_color = tvMain, bgcolor = tvBg, text_size = size.small)
    // الفريم مناسب؟ — توجيه اتجاهيّ (الدرس 08 التحقّق التمهيدي + الدرس 04):
    //   لا درجة متوسطة (numImp==0، كلها صغيرة بلا كسر) ⇒ فريم كبير ⇒ انزل لأصغر.
    //   [V3.65] القاعدة البسيطة (الدرس 04): 3 درجات ⇒ مناسب · أكثر (رابعة أخشن) ⇒ اصعد · أقلّ (درجة ناقصة) ⇒ انزل.
    bool frameOK3 = degCount == 3
    string frameTxt = deg4High ? f_t("اصعد فريمًا (أكثر من 3 درجات)","Move up a TF (>3 degrees)") : frameOK3 ? f_t("مناسب ✓ (3 درجات)","Suitable ✓ (3 degrees)") : f_t("انزل فريمًا (أقلّ من 3 درجات)","Move down a TF (<3 degrees)")
    color  frameBg = frameOK3 and not deg4High ? color.new(#089981, 0) : color.new(#FF9800, 0)
    string frameTip = f_t("عدّ درجات موجتك (صغيرة→متوسطة→كبيرة→رابعة أخشن، داخل الموجة العاملة فقط):\n• 3 درجات ⇒ مناسب ✓.\n• أكثر من 3 (الزرقاء كوّنت موجاتٍ = رابعة أخشن) ⇒ اصعد فريماً.\n• أقلّ من 3 (درجة ناقصة) ⇒ انزل فريماً.","Counts your wave's degrees (small→medium→big→coarser 4th, within the active wave only):\n• 3 degrees ⇒ suitable ✓.\n• More than 3 (blue formed waves = a coarser 4th) ⇒ move up a TF.\n• Fewer than 3 (a degree missing) ⇒ move down a TF.")
    table.cell(fht, 0, 6, f_t("الفريم مناسب؟","TF suitable?"), text_color = tvMute, bgcolor = tvBg, text_size = size.small, text_halign = text.align_right, tooltip = frameTip)
    table.cell(fht, 1, 6, frameTxt, text_color = color.white, bgcolor = frameBg, text_size = size.small, tooltip = frameTip)

if showFrameHelper and barstate.islast
    f_drawFramePanel()

var table tbl = table.new(f_pos(panelPos), 2, 12, bgcolor = panelBg, border_width = 1,
     border_color = #2A2E39, frame_width = 1, frame_color = #2A2E39)

// [V3.76] لُفّت كتلة لوحة الاستنتاجات في دالّة (إصلاح CE10295). العوامّ الـ6 (concDefined/...) صارت محلّيّة (تُقرأ داخل اللوحة فقط — الـgrep يؤكّد) ⇒ صفر impact.
f_drawConclusionsPanel() =>
    table.set_position(tbl, f_pos(panelPos))
    // [V4.21] صفّ «الكبيرة» يتبع **خطّ السيولة الأزرق المرسوم** (bigAncDir) ليتطابق مع «اتجاه السيولة» (الأزرق ضمنيًّا أصفر)؛
    //   احتياطيّ largeDir البنيويّ عند غياب الخطّ (انتظار) حتى لا يفرغ الصفّ.
    int  pBigDir = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : largeDir   // [V4.86] أُعيدت التسمية (كان bigEff يُظلّل المصفوفة العالميّة)
    int  medEff = medActiveDir
    int  smlEff = smallActiveDir
    // [V4.14] «الموجة التاريخية» = الموجة المتوسطة العاملة (الدرس 09) ⇒ عنوانها يتبع medActiveDir (لا largeDir).
    //   الكبيرة درجة منفصلة (صفّها يبقى largeDir). احتياطيّ للكبيرة إن لم تتحدّد المتوسطة بعد.
    int  histWaveDir = medActiveDir != 0 ? medActiveDir : largeDir
    bool reliable = pBigDir != 0 and medEff != 0   // الكبيرة والمتوسطة مؤسَّستان ⇒ الاستنتاجات موثوقة
    // ===== هويّة TradingView الداكنة =====
    color pBg   = panelBg
    color pHdr  = color.new(color.rgb(color.r(panelBg) * 0.72, color.g(panelBg) * 0.72, color.b(panelBg) * 0.72), color.t(panelBg))
    color pMain = #D1D4DC
    color pMute = #787B86
    color cUp   = #089981
    color cDn   = #F23645
    color cRng  = #FF9800
    // [V4.20] إعادة حساب الاستنتاجات **هنا بعد كتل الرسم** لتعكس الخطوط المرسومة فعلاً لا حالة ما قبل الرسم.
    //   (الحساب في الحلقة الرئيسية س1541 يسبق رسم سيولة المتوسطة س2420 والأزرق س2230 ⇒ تأخّر إصدار دائم على آخر بار.)
    int  pMedLiqDir = (not na(memM.liq)) ? medActiveDir : 0
    int  pBigLiqDir = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : 0
    bool cDefL = pMedLiqDir != 0 and pBigLiqDir != 0          // [V3.76] محلّيّة (كانت concDefined العامّة؛ تُقرأ داخل اللوحة فقط ⇒ صفر impact)
    bool cRngL = cDefL and pMedLiqDir != pBigLiqDir
    int  cLiqL = (cDefL and not cRngL) ? pMedLiqDir : 0
    int  pBigLvlDir = (not na(bigAncQa1) and bigAncDir != 0) ? bigAncDir : (largeDir != 0 ? largeDir : bigDir)   // [V3.57] نفس احتياطيّ الإشارة (bEff) ⇒ توحيد اللوحة↔الإشارة (largeDir اتجاه بنيويّ حقيقيّ عند غياب المرساة، لا «بيانات غير كافية» بينما الإشارة تُطلَق)
    int  pMedLvlDir = medActiveDir != 0 ? medActiveDir : pBigLvlDir   // [V3.57] = mEff: يحفظ القلب الفوريّ v3.54 + احتياطيّ bEff
    bool eDefL = pMedLvlDir != 0 and pBigLvlDir != 0
    bool eRngL = eDefL and pMedLvlDir != pBigLvlDir
    int  cEntL = (not eDefL) ? 0 : eRngL ? 0 : pMedLvlDir
    // ===== الاستنتاجات الثلاثة (تُقرأ من الحالة global — أُعيد حسابها أعلاه بعد الرسم) =====
    string histDir = histWaveDir == 1 ? f_t("صاعدة ▲","Up ▲") : histWaveDir == -1 ? f_t("هابطة ▼","Down ▼") : "—"
    color  histCol = histWaveDir == 1 ? cUp : histWaveDir == -1 ? cDn : pMute
    // الحالات الأربع: غير محدَّد (بيانات غير كافية) · عرضيّ/Range · صاعدة · هابطة.
    bool   concDir = cDefL and not cRngL
    string liqTxt  = not cDefL ? f_t("غير محدّد (بيانات غير كافية)","Undefined (insufficient data)") : cRngL ? f_t("عرضيّ (Range)","Range") : cLiqL == 1 ? f_t("صاعدة","Up") : f_t("هابطة","Down")
    color  liqCol  = not cDefL ? pMute : cRngL ? cRng : cLiqL == 1 ? cUp : cDn
    string entryTxt = not eDefL ? f_t("بيانات غير كافية","Insufficient data") : eRngL ? f_t("شراء وبيع","Buy & Sell") : cEntL == 1 ? f_t("شراء فقط","Buy only") : f_t("بيع فقط","Sell only")
    color  entryCol = not eDefL ? pMute : eRngL ? cRng : cEntL == 1 ? cUp : cDn
    string strTxt  = not concStrongDef ? "—" : concStrong ? f_t("قويّة","Strong") : f_t("ضعيفة","Weak")   // [v3.87.7] قوّة السيولة مقياس مستقلّ من الصغيرة (الدرس 10-2) — لا يلزمه اتجاه سيولة مُعرَّف (أُزيل قيد concDir)؛ يبقى «—» فقط إن لم تُحسب القوّة للاتجاه الحاليّ (concStrongDef=false، لا قيمة قديمة V3.59)
    color  strCol  = not concStrongDef ? pMute : concStrong ? cUp : cDn
    table.cell(tbl, 0, 0, f_t("لوحة الاستنتاجات","Conclusions"), text_color = pMain, bgcolor = pHdr, text_size = size.normal, text_halign = text.align_right)
    table.cell(tbl, 1, 0, "", text_color = pMute, bgcolor = pHdr, text_size = size.small)
    table.cell(tbl, 0, 1, f_t("اتجاه الموجة التاريخية","Historical wave"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 1, histDir, text_color = color.white, bgcolor = histCol, text_size = size.small)
    table.cell(tbl, 0, 2, f_t("اتجاه السيولة","Liquidity direction"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 2, liqTxt, text_color = color.white, bgcolor = liqCol, text_size = size.small)
    table.cell(tbl, 0, 3, f_t("قوة السيولة","Liquidity strength"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 3, strTxt, text_color = color.white, bgcolor = strCol, text_size = size.small)
    table.cell(tbl, 0, 4, f_t("الدخول المتاح","Available entry"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 4, entryTxt, text_color = color.white, bgcolor = entryCol, text_size = size.small)
    color smCol = smlEff == 1 ? cUp : smlEff == -1 ? cDn : pHdr
    color mdCol = medEff == 1 ? cUp : medEff == -1 ? cDn : pHdr
    color bgCol = pBigDir == 1 ? cUp : pBigDir == -1 ? cDn : pHdr
    float tolVd = liqTol * atrv   // [v3.87.6] هامش قوّة السيولة لكلّ درجة (نفس liqTolV العامّ)
    table.cell(tbl, 0, 5, f_t("الصغيرة","Small"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 5, f_dir(smlEff) + " | " + smallPhase + f_degStrTok(smlEff, memS.ltP, memS.ptP, memS.lbP, memS.pbP, tolVd), text_color = color.white, bgcolor = smCol, text_size = size.small)
    table.cell(tbl, 0, 6, f_t("المتوسطة","Medium"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 6, f_dir(medEff) + " | " + medPhase + f_degStrTok(medEff, memM.ltP, memM.ptP, memM.lbP, memM.pbP, tolVd), text_color = color.white, bgcolor = mdCol, text_size = size.small)
    table.cell(tbl, 0, 7, f_t("الكبيرة","Big"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    // [v3.83] نصّ مرحلة الكبيرة يُعاد حسابه هنا بـ pBigDir (اتجاه السهم الطازج، بعد كتلة islast) لا bigPhase
    //   المحسوب بـ bDirPh المقروء **قبل** كتلة الاتجاه (س1720) ⇒ كان يتأخّر دورة فيُظهر «صاعد ▲ | مشاركة عامة هابطة».
    //   عرضيّ بحت: الكود bigPh.code كما هو، يتغيّر **لاحقة الاتجاه** لمرحلة المشاركة(0) فقط لتطابق السهم. (الملاحظة 2)
    table.cell(tbl, 1, 7, f_dir(pBigDir) + " | " + phaseText(bigPh, pBigDir) + f_degStrTok(pBigDir, memBph.ltP, memBph.ptP, memBph.lbP, memBph.pbP, tolVd) + (bigCtxReview ? " ⚠" : ""), text_color = color.white, bgcolor = bgCol, text_size = size.small)
    // لون الفرصة يتدرّج حسب القرب والقوّة: دخول مؤكّد ⇒ أخضر صريح؛ أساسية مُسلّحة قريبة ⇒ أخضر أفتح؛
    //   عالية مخاطر/غير أساسية متوقّعة ⇒ تحذير (كهرماني)؛ داخل منطقة بلا مرحلة ⇒ محايد باهت؛ وإلا الخلفية.
    bool oppConfirmed = entryBuy or entrySell
    bool oppBasic     = oppBasicBuy or oppBasicSell
    bool oppHR        = oppHRBuy or oppHRSell
    color oppBg = oppConfirmed ? #089981 : oppBasic ? #26A69A : oppHR ? #FF9800 : diagInZone ? color.new(#5C6BC0, 25) : pBg
    color oppTx = (oppConfirmed or oppBasic or oppHR or diagInZone) ? color.white : pMain
    table.cell(tbl, 0, 8, f_t("الفرصة","Opportunity"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 8, oppText, text_color = oppTx, bgcolor = oppBg, text_size = size.small)
    // ملخّص الحالة (الاستنتاج الرابع/الربط): تصحيح متوقّع عند 3 درجات مشاركة + ضعف + ذروة سعر.
    string noteTxt = concCorrectionLikely ? f_t("تصحيح متوسط متوقّع ⚠","Medium correction likely ⚠") : "—"
    color  noteBg  = concCorrectionLikely ? #FF9800 : pBg
    color  noteTx  = concCorrectionLikely ? color.white : pMute
    table.cell(tbl, 0, 9, f_t("ملخّص الحالة","Status"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
    table.cell(tbl, 1, 9, noteTxt, text_color = noteTx, bgcolor = noteBg, text_size = size.small)
    // [V4.46] صفّ الصفقة المفتوحة: الاتجاه + الدخول + الوقف المتحرّك (التأمين) + الهدف القادم
    if enableManage
        float trRR = f_rr(tradeEntry, tradeStop, tradeTgt)
        bool tSecured = tradeDir != 0 and not na(tradeStop) and not na(tradeEntry) and ((tradeDir == 1 and tradeStop >= tradeEntry) or (tradeDir == -1 and tradeStop <= tradeEntry))   // [V4.87] الوقف مؤمَّن (≥ تعادُل)؟
        string trTxt = tradeDir == 0 ? "—" : (tradeDir == 1 ? f_t("شراء ▲","Buy ▲") : f_t("بيع ▼","Sell ▼")) + f_t("  دخول ","  Entry ") + (na(tradeEntry) ? "—" : str.tostring(tradeEntry, format.mintick)) + f_t("  وقف ","  Stop ") + (na(tradeStop) ? "—" : str.tostring(tradeStop, format.mintick)) + f_t("  هدف ","  Target ") + (na(tradeTgt) ? "—" : str.tostring(tradeTgt, format.mintick)) + "  RR " + (na(trRR) ? "—" : str.tostring(trRR, "#.##")) + (tSecured ? f_t("  · 🔒 مؤمَّن","  · 🔒 Secured") : "")
        color  trBg  = tradeDir == 1 ? cUp : tradeDir == -1 ? cDn : pBg
        table.cell(tbl, 0, 10, f_t("الصفقة + التأمين","Trade + Stop"), text_color = pMute, bgcolor = pBg, text_size = size.small, text_halign = text.align_right)
        table.cell(tbl, 1, 10, trTxt, text_color = tradeDir == 0 ? pMute : color.white, bgcolor = trBg, text_size = size.small)

if showPanel and barstate.islast
    f_drawConclusionsPanel()

// ============================================================================
//  القسم الأخير القادم:
//
//  (هـ) إشارات الصفقات: عند تطابق منطقة + مرحلة (تجميع/تصريف) + تأكيد كسر آخر قمة/قاع
//                      بدرجة أصغر ⇒ إشارة دخول + وقف خلف القاع/القمة + هدف عند المنطقة
//                      التالية + تنبيه alert().
// ============================================================================

// ===================== تنبيهات طبقة الفرص (المرحلة 2) =====================
// حالة/تنبيه فقط — ليست دخولاً. الدخول والتأكيد والوقف والهدف في المرحلة 3 لاحقاً.
alertcondition(oppBasicBuy,  title = "فرصة شراء أساسية (انتظار تأكيد تجميع)", message = "M-Waves: فرصة شراء أساسية داخل منطقة دعم — انتظار تأكيد التجميع")
alertcondition(oppBasicSell, title = "فرصة بيع أساسية (انتظار تأكيد تصريف)", message = "M-Waves: فرصة بيع أساسية داخل منطقة مقاومة — انتظار تأكيد التصريف")
alertcondition(oppHRBuy,     title = "فرصة شراء عالية المخاطر",  message = "M-Waves: فرصة شراء عالية المخاطر داخل منطقة (تصحيح بعد الذعر)")
alertcondition(oppHRSell,    title = "فرصة بيع عالية المخاطر",   message = "M-Waves: فرصة بيع عالية المخاطر داخل منطقة (تصحيح بعد الذعر)")

// ===================== تنبيهات الدخول المؤكّد (المرحلة 3) =====================
// تأكيد التجميع/التصريف (كسر بنية اليأس) داخل منطقة ⇒ دخول مع وقف وهدف.
alertcondition(entryBuy,  title = "دخول شراء مؤكّد",  message = "M-Waves: دخول شراء مؤكّد — تأكيد تجميع داخل منطقة دعم")
alertcondition(entrySell, title = "دخول بيع مؤكّد",   message = "M-Waves: دخول بيع مؤكّد — تأكيد تصريف داخل منطقة مقاومة")

// [V3.9] نافذة الجداول التشخيصيّة = آخر diagBigWaves موجات كبيرة (موجة كبيرة ≈ نقطتان زرقاوان: قمة+قاع).
//   diagBigWaves=1 ⇒ النطاق التاريخيّ [hohLeft]؛ >1 ⇒ نعود لبار النقطة الزرقاء (diagBigWaves*2) من النهاية.
int diagLeft = (diagBigWaves <= 1 or array.size(bigBar) == 0) ? hohLeft : array.get(bigBar, math.max(0, array.size(bigBar) - diagBigWaves * 2))
// جدول تشخيص الفعالية: لكل نقطة متوسطة داخل النطاق [diagLeft,now] — لماذا فعّالة/غير فعّالة + لون الدائرة + م.A + السبب.
//   اللون = لون الدائرة الفعليّ (برتقالي فعّال / أحمر غير فعّال — نفس zoneEff). السبب = القانون الذي أسقطها + المرجع.
//   فعّال = (غير مُغطّى) و(تتابُع) و(فعالية). الأحدث أعلى الجدول. يطابق تماماً تلوين الدائرة + رسم م.A.
f_drawEffTable(int dgLeft, int hgLeft) =>   // [V4.79] نُقلت لدالّة (حدّ Pine CE10295) — المصفوفات عالميّة؛ diagLeft/histLeft وسيطان (لا تظليل)
    int mmE = array.size(mcP)
    color gC = color.new(#2E7D32, 0)
    color rC = color.new(#C00000, 0)
    color oC = color.new(#C55A11, 0)
    var table et = table.new(position.bottom_right, 8, 61, bgcolor = color.new(color.black, 10), border_width = 1)
    table.cell(et, 0, 0, "نوع",    text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    table.cell(et, 1, 0, "السعر",  text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    table.cell(et, 2, 0, "غُطّي؟",  text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    table.cell(et, 3, 0, "تتابُع",  text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    table.cell(et, 4, 0, "فعالية", text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    table.cell(et, 5, 0, "اللون",  text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    table.cell(et, 6, 0, "م.A",    text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    table.cell(et, 7, 0, "السبب",  text_color = color.white, text_size = size.tiny, bgcolor = color.new(#1F3A5F, 0))
    int rowsE = 0
    if mmE > 0 and array.size(zoneEff) >= mmE and array.size(dgReason) >= mmE
        for i = mmE - 1 to 0
            if rowsE < 60 and array.get(mcBar, i) >= dgLeft
                bool tp = array.get(mcTop, i)
                bool cv = array.get(dgCov, i)
                bool sq = array.get(dgSeq, i)
                bool ac = array.get(dgAct, i)
                bool ze = array.get(zoneEff, i)
                bool pe = array.size(dgPend) > i ? array.get(dgPend, i) : false
                bool inW = array.get(mcBar, i) >= hgLeft
                table.cell(et, 0, rowsE + 1, tp ? "قمة" : "قاع", text_color = color.white, text_size = size.tiny)
                table.cell(et, 1, rowsE + 1, str.tostring(array.get(mcP, i), format.mintick), text_color = color.white, text_size = size.tiny)
                table.cell(et, 2, rowsE + 1, cv ? "نعم" : "لا", text_color = color.white, text_size = size.tiny, bgcolor = cv ? rC : gC)
                table.cell(et, 3, rowsE + 1, sq ? "✓" : "✗", text_color = color.white, text_size = size.tiny, bgcolor = sq ? gC : rC)
                table.cell(et, 4, rowsE + 1, ac ? "✓" : "✗", text_color = color.white, text_size = size.tiny, bgcolor = ac ? gC : rC)
                table.cell(et, 5, rowsE + 1, ze ? "برتقالي" : pe ? "معلّق" : "أحمر", text_color = color.white, text_size = size.tiny, bgcolor = ze ? oC : pe ? color.new(#787B86, 0) : rC)
                table.cell(et, 6, rowsE + 1, (ze and inW) ? "✓" : (ze and not inW) ? "تاريخ" : "—", text_color = color.white, text_size = size.tiny, bgcolor = (ze and inW) ? gC : color.new(color.gray, 50))
                table.cell(et, 7, rowsE + 1, array.get(dgReason, i), text_color = color.white, text_size = size.tiny, bgcolor = ze ? color.new(color.gray, 60) : color.new(#7A2E00, 0))
                rowsE += 1

// جدول الاشتقاق: كل نقطة صغيرة بالترتيب الزمنيّ (الأحدث أعلى ← الأقدم أسفل) داخل [hohLeft,now] + هل صارت متوسطة/كبيرة ولماذا + فعاليتها.
//   الدرجة = أعلى درجة بلغها بارها. الاشتقاق = الكسر الذي أنشأها (الصغيرة→متوسطة→كبيرة). اللون/السبب = الفعالية.
f_drawDerivTable(int dgLeft) =>   // [V4.79] نُقلت لدالّة (حدّ Pine CE10295) — المصفوفات عالميّة؛ diagLeft وسيط (لا تظليل)
    int nds = array.size(dsP)
    color hC  = color.new(#1F3A5F, 0)
    color oC2 = color.new(#C55A11, 0)
    color bC2 = color.new(#1F3A5F, 0)
    color rC2 = color.new(#C00000, 0)
    var table dvt = table.new(position.middle_right, 6, 81, bgcolor = color.new(color.black, 10), border_width = 1)
    table.cell(dvt, 0, 0, "السعر",   text_color = color.white, text_size = size.tiny, bgcolor = hC)
    table.cell(dvt, 1, 0, "نوع",     text_color = color.white, text_size = size.tiny, bgcolor = hC)
    table.cell(dvt, 2, 0, "درجة",    text_color = color.white, text_size = size.tiny, bgcolor = hC)
    table.cell(dvt, 3, 0, "الاشتقاق", text_color = color.white, text_size = size.tiny, bgcolor = hC)
    table.cell(dvt, 4, 0, "اللون",   text_color = color.white, text_size = size.tiny, bgcolor = hC)
    table.cell(dvt, 5, 0, "السبب",   text_color = color.white, text_size = size.tiny, bgcolor = hC)
    int rd = 0
    if nds > 0
        for i = nds - 1 to 0   // [V3.51] ترتيب زمنيّ: الأحدث أعلى ← الأقدم أسفل (متّسق مع جدول الفعالية)
            int  bi = array.get(dsBar, i)
            int  mIdx = f_idxByBar(mcBar, bi)
            int  bIdx = f_idxByBar(bigBar, bi)
            bool skipSmall = diagBigWaves > 1 and mIdx < 0 and bIdx < 0   // [V3.9] متعدّد الموجات ⇒ ركّز على المتوسطة/الكبيرة
            if rd < 80 and bi >= dgLeft and not skipSmall
                bool tp = array.get(dsTop, i)
                string deg = bIdx >= 0 ? "كبيرة" : mIdx >= 0 ? "متوسطة" : "صغيرة"
                color degC = bIdx >= 0 ? bC2 : mIdx >= 0 ? oC2 : color.new(color.gray, 40)
                string drv = bIdx >= 0 ? (tp ? "أعلى قبل كسر قاع متوسط ⬇" : "أدنى قبل كسر قمة متوسطة ⬆") : mIdx >= 0 ? (tp ? "أعلى قبل كسر قاع صغير ⬇" : "أدنى قبل كسر قمة صغيرة ⬆") : "شمعتان صحيحتان"
                bool effM = (mIdx >= 0 and array.size(zoneEff) > mIdx) ? array.get(zoneEff, mIdx) : false
                bool effB = (bIdx >= 0 and array.size(bigEff) > bIdx) ? array.get(bigEff, bIdx) : false
                bool pndM = (mIdx >= 0 and array.size(dgPend) > mIdx) ? array.get(dgPend, mIdx) : false
                bool pndB = (bIdx >= 0 and array.size(bigPend) > bIdx) ? array.get(bigPend, bIdx) : false   // [V4.1] من مصفوفة bigPend (مُقيَّدة بالموجة)
                string lon = bIdx >= 0 ? (effB ? "أزرق" : pndB ? "معلّق" : "أحمر") : mIdx >= 0 ? (effM ? "برتقالي" : pndM ? "معلّق" : "أحمر") : "—"
                color  lonC = bIdx >= 0 ? (effB ? bC2 : pndB ? color.new(#787B86, 0) : rC2) : mIdx >= 0 ? (effM ? oC2 : pndM ? color.new(#787B86, 0) : rC2) : color.new(color.gray, 50)
                string rsn = bIdx >= 0 ? (effB ? "زرقاء فعّالة ✓" : pndB ? "زرقاء: معلّقة (انتظار)" : "زرقاء: مُغطّاة داخل النطاق (مُختبَرة)") : (mIdx >= 0 and array.size(dgReason) > mIdx) ? array.get(dgReason, mIdx) : "—"
                table.cell(dvt, 0, rd + 1, str.tostring(array.get(dsP, i), format.mintick), text_color = color.white, text_size = size.tiny)
                table.cell(dvt, 1, rd + 1, tp ? "قمة" : "قاع", text_color = color.white, text_size = size.tiny)
                table.cell(dvt, 2, rd + 1, deg, text_color = color.white, text_size = size.tiny, bgcolor = degC)
                table.cell(dvt, 3, rd + 1, drv, text_color = color.white, text_size = size.tiny)
                table.cell(dvt, 4, rd + 1, lon, text_color = color.white, text_size = size.tiny, bgcolor = lonC)
                table.cell(dvt, 5, rd + 1, rsn, text_color = color.white, text_size = size.tiny)
                rd += 1

// [V4.79] استدعاء جداول التشخيص (نُقلت أجسامها لدوالّ أعلاه لتقليص الجسم الرئيسيّ — حدّ Pine CE10295)
if showEffTable and barstate.islast
    f_drawEffTable(diagLeft, histLeft)
if showDerivTable and barstate.islast
    f_drawDerivTable(diagLeft)
// ============================================================================
