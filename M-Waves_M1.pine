//@version=6
// ============================================================================
//  استراتيجية M-Waves — نواة المحرّك (المرحلة أ — الإصدار 0.1)
//  Engine nucleus: القمم والقيعان للدرجات الثلاث + قاعدة الشمعتين + الكسر
// ----------------------------------------------------------------------------
//  المنهج:
//   • الدرجة الصغيرة (أحمر/أخضر): تُكتشف بقاعدة «الشمعتين الصحيحتين» في التصحيح،
//     مع قانونَي التتابُع والفعالية (لا تُرسم النقطة إلا بعد تأكّدها).
//   • الدرجة المتوسطة (برتقالي): تُشتق من الصغيرة «بالكسر» (قاعدة الاستراتيجية).
//   • الدرجة الكبيرة (أزرق): اتجاهها فقط = اتجاه ترند الموجة التاريخية (bigDir)؛
//     أُزيل اشتقاقها بالكسر. بناء قمم/قيعان الكبيرة (آخر 7 موجات، §07) لاحقاً.
//
//  هذا إصدار أوّلي للتحقّق مقابل تحليلك اليدوي. الأجزاء التقديرية المتبقّية (اختيار
//  الموجة التاريخية، والفريم) تُقارَب بمعاملات قابلة للضبط — لا تُطابَق 100%.
//
//  خريطة التوسعة:
//   [✓] خطوط السيولة            [✓] مستويات تحديد الاتجاه
//   [✓] الاستنتاجات وحالة السوق  [✓] المناطق (المستوى الثاني)
//   [ ] إشارات الصفقات (دخول/وقف/هدف)
// ============================================================================
indicator("M-Waves Engine v1.13", overlay = true, max_labels_count = 500, max_lines_count = 500, max_polylines_count = 100, max_boxes_count = 300, max_bars_back = 5000)

// ============================ الإعدادات ====================================
grpEng  = "محرّك الدرجات"
minCorr = input.int(2, "عدد شموع التصحيح لتأكيد القمة/القاع", minval = 1, maxval = 5, group = grpEng,
     tooltip = "قاعدة الاستراتيجية = شمعتان صحيحتان في اتجاه التصحيح")
useValid = input.bool(true, "اشتراط الشمعة الصحيحة (جسم ≥ كل ذيل)", group = grpEng,
     tooltip = "استبعاد النويز كاندل: أي ذيل أطول من الجسم")

grpShow   = "الإظهار"
showSmall = input.bool(true,  "الدرجة الصغيرة (أحمر/أخضر)", group = grpShow)
showMed   = input.bool(true,  "الدرجة المتوسطة (برتقالي)",  group = grpShow)
showBig   = input.bool(true,  "الدرجة الكبيرة (أزرق)",      group = grpShow)
linkSmall = input.bool(true,  "وصل قمم/قيعان الصغيرة بخطوط", group = grpShow)
linkMed   = input.bool(true,  "وصل قمم/قيعان المتوسطة بخطوط", group = grpShow)
linkBig   = input.bool(true,  "وصل قمم/قيعان الكبيرة بخطوط",  group = grpShow)
drawWaves = input.int(3, "عدد الموجات المرسومة (أداء)", minval = 1, maxval = 20, group = grpShow,
     tooltip = "القمم/القيعان الصغيرة والمتوسطة والإشارات تُرسم على آخر هذا العدد من الموجات فقط. الأقدم يُحسب للحالة دون رسم. (الكبيرة الزرقاء تبقى 7).")

// ===== الدرجة الكبيرة (Layer 3): تجميع legs من المتوسطة الفعّالة =====
grpBig    = "الدرجة الكبيرة"
bigMinSwings = input.int(2, "أدنى نقاط متوسطة في الموجة الكبيرة", minval = 1, maxval = 10, group = grpBig,
     tooltip = "فلتر مساعد (تلقائي): أقل عدد نقاط متوسطة لاعتبار الحركة موجة كبيرة")
bigMinATR    = input.float(3.0, "أدنى حجم للموجة الكبيرة (× ATR)", minval = 0.0, step = 0.5, group = grpBig,
     tooltip = "فلتر مساعد: 0 = تعطيل")
bigMinBars   = input.int(30, "أدنى زمن للموجة الكبيرة (شموع)", minval = 0, group = grpBig,
     tooltip = "فلتر مساعد: 0 = تعطيل")
bigLegs      = input.int(7, "عدد الموجات الكبيرة المرشّحة", minval = 2, maxval = 15, group = grpBig)
// ===== شكل السهم (مصمت يشبه shape.arrowup مع تحكّم بالطول والعرض) =====
