cBigDead = input.color(color.new(#C00000, 45), "تعبئة الكبيرة غير الفعّالة (داخل أحمر)", group = grpCol)
// حدّ أغمق تلقائياً من لون الدرجة (للدوائر الفعّالة) — صلب بلا شفافية
f_dark(color c) => color.rgb(color.r(c) * 0.5, color.g(c) * 0.5, color.b(c) * 0.5)
// مُعيِّن حجم الدائرة (سلسلة ⇒ ثابت size) + درجة أصغر للحلقة الداخلية — معمّم لكل الدرجات (إعادة استخدام)
f_lblSize(string s)   => s == "دقيق" ? size.tiny : s == "صغير" ? size.small : s == "كبير" ? size.large : s == "ضخم" ? size.huge : size.normal
f_lblSizeIn(string s) => s == "ضخم" ? size.large : s == "كبير" ? size.normal : s == "عادي" ? size.small : size.tiny

